msgctxt "192_Employee"
msgid "Hello, sir. Thank you for playing Boxcelios 2."
msgstr "Hola, señor. Gracias por jugar a Boxcelios 2."

msgctxt "204_Employee"
msgid "Due to popular demand, the previous version of Boxcelios is now available for your enjoyment. You can play it at our Theater Square location, too."
msgstr "Por una demanda popular, la versión anterior de Boxcelios está disponible para su disfrute. También se puede jugar en nuestro local en la Plaza del Teatro."

msgctxt "216_Employee"
msgid "We hope you continue to enjoy your time at Club SEGA."
msgstr "Esperamos que siga disfrutando de su tiempo en el Club SEGA."

msgctxt "240_Employee"
msgid "Welcome to Club SEGA! What can I do for you today, sir?"
msgstr "Bienvenido al Club Sega. ¿En qué puedo ayudarle, señor?"

msgctxt "252_Player"
msgid "(Hmm...)"
msgstr "(Mmm...)"

msgctxt "264_Player"
msgid "(Hmm...)"
msgstr "(Mmm...)"

msgctxt "276_Player"
msgid "Think you could change out the prizes in the UFO Catcher?"
msgstr "¿Podría cambiar los premios del UFO Catcher?"

msgctxt "288_Employee"
msgid "Of course! Give me one moment."
msgstr "Claro, dame un momento."

msgctxt "336_Employee"
msgid "There you go, sir. Have fun!"
msgstr "Aquí tiene, señor. ¡Diviértase!"

msgctxt "348_Player"
msgid "Think you could change out the prizes in the UFO Catcher?"
msgstr "¿Podría cambiar los premios del UFO Catcher?"

msgctxt "360_Employee"
msgid "Of course! Give me one moment."
msgstr "Claro, dame un momento."

msgctxt "408_Employee"
msgid "There you go, sir. Have fun!"
msgstr "Aquí tiene, señor. ¡Diviértase!"

msgctxt "420_Player"
msgid "Nothing right now, actually."
msgstr "Nada en este momento, en realidad."

msgctxt "432_Employee"
msgid "If you need any assistance, we're here to help. Have fun!"
msgstr "Si necesita ayuda, estamos aquí para ayudarle. ¡Diviértase!"

msgctxt "444_Employee"
msgid "Replace the prizes in the right UFO Catcher."
msgstr "Reemplazar los premios en el UFO Catcher de la derecha."

msgctxt "456_Employee"
msgid "Replace the prizes in the left UFO Catcher."
msgstr "Reemplazar los premios en el UFO Catcher de la izquierda."

msgctxt "468_Employee"
msgid "Never mind."
msgstr "No importa."

