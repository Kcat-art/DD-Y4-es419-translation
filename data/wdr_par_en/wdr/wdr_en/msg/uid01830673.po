msgid "Camera Angle:\\r\n"
"While deciding your shot angle, you can use <Action:Button_RS_Up@Billard><Action:Button_RS_Down@Billard><Action:Button_RS_Left@Billard><Action:Button_RS_Right@Billard> to change the camera angle."
msgstr "Ángulo de Cámara:\\r\n"
"Mientras decides tu ángulo de tiro, usa\n"
"<Action:Button_RS_Up@Billard><Action:Button_RS_Down@Billard><Action:Button_RS_Left@Billard><Action:Button_RS_Right@Billard> para cambiar la perspectiva."

