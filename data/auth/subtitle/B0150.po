msgctxt "1883	1943"
msgid "Why?"
msgstr "¿Tú?"

msgctxt "2497	2597"
msgid "Why're you... still here?"
msgstr "¿Tú, por qué?"

msgctxt "2737	2876"
msgid "Eh. Thought it'd leave\\na bad taste in my mouth."
msgstr "Pensé que hacer eso me\\ndejaría un mal sabor de boca."

msgctxt "2904	2970"
msgid "Ditching you and all."
msgstr "Déjandote atrás."

msgctxt "3065	3125"
msgid "Besides..."
msgstr "Después de todo..."

msgctxt "3159	3250"
msgid "You're only the second one."
msgstr "Tú eres el segundo."

msgctxt "3393	3534"
msgid "The second guy who's ever trusted me."
msgstr "El segundo tipo que alguna vez ha confiado en mí."

msgctxt "4171	4238"
msgid "It's all you this time."
msgstr "Ahora es tu turno."

msgctxt "4326	4403"
msgid "We made it up here safe."
msgstr "Logramos llegar tan lejos."

msgctxt "4406	4550"
msgid "Only one thing left now.\\nIt's us against the sea."
msgstr "Ahora solo se trata de llegar\\na tierra antes de ahogarnos."

msgctxt "4572	4637"
msgid "Your clock's ticking."
msgstr "No queda mucho tiempo."

msgctxt "4643	4681"
msgid "Get down there."
msgstr "Así que baja."

msgctxt "4697	4761"
msgid "I get ya, but I..."
msgstr "Entiendo, pero yo..."

msgctxt "4763	4823"
msgid "You're on death row!"
msgstr "¡Estás en el corredor de la muerte!"

msgctxt "4842	4946"
msgid "The quicker you can\\nget outta here, the better."
msgstr "Cuanto más rápido\\nsalgas de aquí, mejor."

msgctxt "4970	5030"
msgid "But..."
msgstr "Pero..."

msgctxt "5052	5189"
msgid "Don't worry.\\nI got everything I need right here."
msgstr "No te preocupes por mí.\\nTengo una carta de triunfo."

msgctxt "5217	5318"
msgid "The thing you took from\\nthe warden's office?"
msgstr "¿Es lo que tomaste de la\\noficina del director de la prisión?"

msgctxt "5334	5486"
msgid "Yup. This here's my ticket back into business."
msgstr "Sí. Gracias a esto aún puedo continuar con mi vida."

msgctxt "5533	5593"
msgid "Now move!"
msgstr "¡Vamos!"

msgctxt "5836	5896"
msgid "Catch ya later..."
msgstr "Nos vemos..."

msgctxt "5894	5935"
msgid "Brother."
msgstr "Kyoudai."

msgctxt "5969	6029"
msgid "Brother?"
msgstr "¿Kyoudai?"

msgctxt "6040	6100"
msgid "Ya heard me."
msgstr "Sí."

msgctxt "6100	6280"
msgid "Hasn't been long,\\nbut we're partners in crime now."
msgstr "Como puedes notar,\\nahora somos compañeros de crimen."

msgctxt "6301	6361"
msgid "Brothers."
msgstr "Kyoudais."

msgctxt "6406	6466"
msgid "Saejima..."
msgstr "Saejima..."

msgctxt "6900	6960"
msgid "Saejima!"
msgstr "¡Saejima!"

msgctxt "6994	7102"
msgid "If we both somehow make it outta this alive..."
msgstr "Cuando hayamos escapado y hayas arreglado tus problemas...."

msgctxt "7103	7173"
msgid "How 'bout we team up?"
msgstr "¡Formemos un equipo e intentemos de nuevo!"

msgctxt "7208	7287"
msgid "You and me'd be unstoppable!"
msgstr "¡Tú y yo seríamos imparables!"

msgctxt "7278	7403"
msgid "The Tojo... Hell, the whole country could be ours!"
msgstr "¡El Clan Tojo, no, todo el país podría ser nuestro!"

msgctxt "7413	7520"
msgid "So, whaddya say?\\nPretty convincing, huh?"
msgstr "¿Y? ¿Qué te parece?\\nBastante convincente, ¿no?"

msgctxt "7543	7595"
msgid "Hamazaki..."
msgstr "Hamazaki..."

msgctxt "7596	7635"
msgid "All you've gotta do is make it to shore."
msgstr "Así que lo único que debes hacer es..."

msgctxt "7704	7764"
msgid "Hamazaki!"
msgstr "¡Hamazaki!"

msgctxt "7831	7899"
msgid "Not on my watch."
msgstr "No dejaré que te escapes."

msgctxt "7933	8003"
msgid "Criminal scum."
msgstr "Pedazo de mierda."

msgctxt "8018	8085"
msgid "Hamazaki!"
msgstr "¡Hamazaki!"

msgctxt "8248	8308"
msgid "Saejima..."
msgstr "Saejima..."

msgctxt "8403	8463"
msgid "Kiryu."
msgstr "Kiryu."

msgctxt "8466	8613"
msgid "Once you hit shore,\\nsearch out a man named Kiryu."
msgstr "Una vez que llegues a la orilla,\\nbusca a un hombre llamado Kiryu."

msgctxt "8646	8739"
msgid "Whaddya mean?\\nWe're goin' together, brother!"
msgstr "¿Qué?\\n¡¿Qué crees que haces?!"

msgctxt "8762	8865"
msgid "He's here, in Okinawa."
msgstr "Está aquí, en Okinawa."

msgctxt "8871	8942"
msgid "Dependable guy."
msgstr "Un hombre confiable."

msgctxt "8946	9041"
msgid "It's Kiryu, got it?"
msgstr "¡Es Kiryu! Recuérdalo."

msgctxt "9060	9104"
msgid "Hamazaki?"
msgstr "¿Hamazaki?"

msgctxt "9105	9201"
msgid "Hamazaki! C'mon!"
msgstr "¡Hamazaki! ¡Oye!"

msgctxt "9326	9386"
msgid "What are you doing!?\\nLet go!"
msgstr "¿Qué estás haciendo?\\n¡Suéltame!"

msgctxt "9464	9563"
msgid "No! Stop!"
msgstr "¡Detente! ¡No!"

msgctxt "9564	9610"
msgid "Don't do it!"
msgstr "¡No lo hagas!"

msgctxt "9747	9791"
msgid "Hamazaki?"
msgstr "¿Hamazaki?"

msgctxt "9797	9857"
msgid "Hamazaki!"
msgstr "¡Hamazaki!"

msgctxt "9906	9966"
msgid "Shit!"
msgstr "¡Mierda!"

