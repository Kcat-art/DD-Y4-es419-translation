msgctxt "2904_Attendant"
msgid "Yeah, I remember those days."
msgstr "Yo también he tenido esa experiencia..."

msgctxt "2916_Attendant"
msgid "That's understandable."
msgstr "Bueno, es entendible."

msgctxt "2928_Attendant"
msgid "Well, I'm always pretty calm."
msgstr "¿Y si yo fuera así siempre?"

msgctxt "2940_Attendant"
msgid "Don't worry about it."
msgstr "No hay de que."

msgctxt "2952_Attendant"
msgid "Hey, I like you."
msgstr "Oye, me agradas."

msgctxt "2964_Attendant"
