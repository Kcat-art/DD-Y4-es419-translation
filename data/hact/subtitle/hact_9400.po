msgctxt "45	90"
msgid "[You're lookin' fine as ever, babe!]"
msgstr "[¡Sigues tan guapa como siempre, nena!]"

msgctxt "95	140"
msgid "[Really? It's all for you, darling.]"
msgstr "[¿De veras? Pues es todo para ti, cariño.]"

msgctxt "162	202"
msgid "[Oh, you!]"
msgstr "[¡Qué pícara!]"

msgctxt "220	250"
msgid "[Hold it!]"
msgstr "[¡Alto ahí!]"

msgctxt "300	360"
msgid "[I turn my back for one second,\\nand this happens!?]"
msgstr "[Te dejo solo por un segundo,\\n¡¿y pasa esto?!]"

msgctxt "400	470"
msgid "[Well, darling...\\nGet ready to die!]"
msgstr "[Muy bien, cariño...\\n¡Este es tu final!]"

msgctxt "730	770"
msgid "[You no-good son of a bitch!]"
msgstr "[¡Maldito desgraciado!]"

