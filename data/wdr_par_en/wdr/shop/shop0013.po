msgctxt "308"
msgid "Quit"
msgstr "Salir"

msgctxt "313"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "331"
msgid "Order"
msgstr "Pagar"

msgctxt "337"
msgid "Order the currently selected item.  "
msgstr "Pedir el objeto actualmente seleccionado.  "

msgctxt "374"
msgid "(I haven't picked anything.)  "
msgstr "(No he escogido nada)"

msgctxt "405"
msgid "(I'm short on cash.)  "
msgstr "(Me hace falta dinero)"

msgctxt "428"
msgid "Will that be all for you?"
msgstr "¿Eso será todo?"

msgctxt "454"
msgid "(I can't carry any more stuff.)"
msgstr "(No puedo llevar más cosas)."

msgctxt "486"
msgid "(They're sold out.)"
msgstr "(Están agotados)."

msgctxt "506"
msgid "This gorgeous platter is overflowing with fresh fruits."
msgstr "Esta hermosa bandeja rebosa de frutas frescas."

msgctxt "562"
msgid "A basket of deep-fried chicken thigh meat."
msgstr "Una cesta de muslos de pollo fritos."

msgctxt "605"
msgid "These vegetable sticks are made only from the \n"
"freshest organic vegetables."
msgstr "Estas brochetas de verduras están hechas\n"
"únicamente con las verduras orgánicas más frescas."

msgctxt "681"
msgid "We lightly grill this fresh ray fin over coals to give it \n"
"that sweet, roasted flavor."
msgstr "Asamos ligeramente esta aleta de raya fresca sobre\n"
"brasas para darle ese dulce sabor tostado."

msgctxt "768"
msgid "This high-grade chocolate was made by a renowned\n"
"European patissier."
msgstr "Este chocolate de alta calidad fue elaborado por un\n"
"reconocido pastelero europeo."

msgctxt "837"
msgid "These fresh vegetables have been marinated in salt \n"
"and flavored with seaweed broth."
msgstr "Estas verduras frescas han sido marinadas en sal \n"
"y aderezadas con caldo de algas marinas."

