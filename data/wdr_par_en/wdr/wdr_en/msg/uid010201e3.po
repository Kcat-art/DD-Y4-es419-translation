msgctxt "2408"
msgid "Akiyama"
msgstr "Akiyama"

msgctxt "2412"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "2416"
msgid "Lily"
msgstr "Lily"

msgctxt "2420"
msgid "Talk_Quest"
msgstr "Talk_Quest"

msgctxt "2424"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "80_Akiyama"
msgid "Phew... We should be safe here."
msgstr "Uf... Deberíamos estar a salvo aquí."

msgctxt "92_Akiyama"
msgid "Sorry you got dragged into that. It's been an interesting couple of days."
msgstr "Lamento haberte metido en esto. Han sido días algo inusuales."

msgctxt "104_Lily"
msgid "It's okay..."
msgstr "No pasa nada..."

msgctxt "116_Akiyama"
msgid "Hey, are you all right? You're not hurt, are you?"
msgstr "Oye, ¿estás bien? No estás herida, ¿verdad?"

msgctxt "128_Lily"
msgid "No, I'm fine."
msgstr "No, estoy bien."

msgctxt "140_Akiyama"
msgid "Much as I hate to say it, we should probably call it a night. I'd hate to run into more of them."
msgstr "Odio decirlo, pero, será mejor que dejemos la cita hasta aquí. No me gustaría encontrarnos con más de ellos."

msgctxt "152_Lily"
msgid "You're probably right."
msgstr "Quizás tengas razón."

msgctxt "164_Akiyama"
msgid "Well, do your best tomorrow, all right? I'll swing by and check in on you if I can."
msgstr "Bueno, mucha suerte mañana, me pasaré para ver como te va cuando pueda."

msgctxt "176_Lily"
msgid "Okay. Good night, Akiyama-san."
msgstr "Está bien. Buenas noches, Akiyama-san."

