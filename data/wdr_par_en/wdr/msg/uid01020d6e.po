msgctxt "756"
msgid "Saejima"
msgstr "Saejima"

msgctxt "84_Saejima"
msgid "(Kido-chan said to head north of the theater before going topside. It's swarmin' with cops up there, so I'd best play it safe for now.)"
msgstr "(Kido-chan dijo que antes de subir fuera al lado norte del teatro. Está lleno de policías ahí arriba, así que será mejor que me ponga a salvo ahora)."

msgctxt "120_Saejima"
msgid "(Shit. This ain't the way to the hideout.)"
msgstr "(Mierda. Este no es el camino al escondite)."

