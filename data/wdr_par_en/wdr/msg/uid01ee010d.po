msgctxt "1988"
msgid "Akiyama"
msgstr "Akiyama"

msgctxt "268_Akiyama"
msgid "(I don't have any more business here.)"
msgstr "(I don't have any more business here.)"

msgctxt "280_Akiyama"
msgid "(Gotta scout some girls for the club...)"
msgstr "(Tengo que ir a buscar candidatas para el club...)."

msgctxt "292_Akiyama"
msgid "(Or should I stop recruiting for the moment?)"
msgstr "(¿O debería detener el reclutamiento por ahora?)."

msgctxt "304_Akiyama"
msgid "(I'll stop for now.)"
msgstr "(Por ahora, voy a parar el reclutamiento)."

msgctxt "328_Akiyama"
msgid "(No, I should keep looking.)"
msgstr "(No, voy a seguir buscando)."

msgctxt "340_Akiyama"
msgid "(Now's not the time for this.)"
msgstr "(Ahora no es momento para distracciones...)."

msgctxt "352_Akiyama"
msgid "(Now's not the time for this.)"
msgstr "(Ahora no es momento para distracciones...)."

msgctxt "388_Akiyama"
msgid "(Come to think of it, I was recruiting hostesses earlier. Maybe I should try again.)"
msgstr "(Ahora que lo pienso, dejé el reclutamiento a medias. ¿Debería volver a buscar chicas para el club?)."

msgctxt "400_Akiyama"
msgid "(Okay, I'll give it another try.)"
msgstr "(Bien, retomemos el reclutamiento)."

msgctxt "424_Akiyama"
msgid "(No, I have other things to do. I'll get back to recruiting later.)"
msgstr "(No, todavía tengo cosas que hacer. Retomaré el reclutamiento más tarde)."

msgctxt "436_Akiyama"
msgid "Stop Recruiting"
msgstr "Dejar de Reclutar"

msgctxt "448_Akiyama"
msgid "Continue Recruiting"
msgstr "Continuar Reclutando"

msgctxt "460_Akiyama"
msgid "Start Recruiting Again"
msgstr "Empezar a Reclutar de Nuevo"

msgctxt "472_Akiyama"
msgid "Not Now"
msgstr "Ahora no"

