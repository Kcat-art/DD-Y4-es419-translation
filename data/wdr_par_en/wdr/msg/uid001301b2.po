msgctxt "84_Tanimura"
msgid "What's the situation?"
msgstr "¿Cuál es la situación?"

msgctxt "96_Officer"
msgid "Oh, Tanimura-san."
msgstr "Oh, Tanimura-san."

msgctxt "108_Officer"
msgid "The perp ran off down this alley."
msgstr "El perpetrador escapó por este callejón."

msgctxt "120_Panicked Old Woman"
msgid "He took the purse my granddaughter gave me!"
msgstr "¡Se llevó el bolso que mi nieta me dio!"

msgctxt "132_Tanimura"
msgid "Okay, I'll go after him."
msgstr "Bien, iré a por él."

msgctxt "144_Officer"
msgid "Thanks for your help."
msgstr "Gracias por tu ayuda."

msgctxt "192_Tanimura"
msgid "Hmm... Can't seem to spot him."
msgstr "Mmm... No puedo encontrarlo."

msgctxt "204_Tanimura"
msgid "Ah, what about... That's got to be him!"
msgstr "Ah, qué tal si... ¡Ese debe de ser él!"

msgctxt "216_Tanimura"
msgid "I got you now! Don't move an inch!"
msgstr "¡Te tengo! ¡No te muevas ni un centímetro!"

msgctxt "228_Thief"
msgid "Damn! A cop! You'll never take me in!"
msgstr "¡Maldición! ¡Un policía! ¡Nunca me atraparás!"

