msgctxt "140_Akiyama"
msgid "(So this is where she went... Now, let's see what she does.)"
msgstr "(Así que aquí es donde ha venido... Veamos que es lo que hace.)"

msgctxt "212_Akiyama"
msgid "(She went inside... Better keep a low profile.)"
msgstr "(Ha entrado... será mejor que mantenga un perfil bajo.)"

msgctxt "236_Akiyama"
msgid "(Crap! Here she comes.)"
msgstr "(¡Diablos! Ahí viene.)"

msgctxt "332_Akiyama"
msgid "(Doesn't look like she bought anything...)"
msgstr "(No parece que se haya comprado nada...)"

msgctxt "356_Akiyama"
msgid "(Now, then, where's she off to next?)"
msgstr "(¿Dónde irá ahora?)"

msgctxt "416_Akiyama"
msgid "(All right, Shoko-san should be heading back to the office by now. I ought to head over that way myself.)"
msgstr "(Pues bien, Shoko-san debería volver a la oficina a estas alturas. Debería ir también)"

