msgctxt "172\t232"
msgid "Hey, Uncle Kaz!"
msgstr "Oye, Tío Kaz."

msgctxt "237\t297"
msgid "Who's he?"
msgstr "¿Quién es él?"

msgctxt "318\t378"
msgid "That's Hamazaki-san."
msgstr "Él es Hamazaki-san."

msgctxt "385\t436"
msgid "He's an old friend of－"
msgstr "Es un viejo conocido de－"

msgctxt "441\t495"
msgid "No!"
msgstr "¡No!"

msgctxt "501\t554"
msgid "Don't go near him!"
msgstr "¡Aléjense de él!"

msgctxt "714\t802"
msgid "Haruka...chan?"
msgstr "¿Haruka...chan?"

msgctxt "924\t979"
msgid "You're not coming any closer!"
msgstr "¡Aléjate de estos niños!"

msgctxt "983\t1018"
msgid "Haruka, please..."
msgstr "Haruka, por favor..."

msgctxt "1019\t1077"
msgid "Don't \"Haruka\" me!"
msgstr "¡No digas más, Tío Kaz!"

msgctxt "1080\t1200"
msgid "I still haven't forgiven him for what he did to you!"
msgstr "¡Todavía no lo he perdonado por lo que te hizo!"

msgctxt "1269\t1325"
msgid "Don't you remember, Uncle Kaz!?"
msgstr "¡¿Acaso lo olvidaste, Tío Kaz?!"

msgctxt "1328\t1450"
msgid "This is the same guy who\\nstabbed you last year, remember!?"
msgstr "¡¿Acaso no es el mismo Hamazaki\\nque te apuñaló hace un año?!"

msgctxt "1453\t1552"
msgid "And I had to watch while he did it!"
msgstr "¡Lo vi hacerlo justo al frente de mí!"

msgctxt "1668\t1723"
msgid "She's right."
msgstr "Es verdad."

msgctxt "1727\t1808"
msgid "I'm one of the bad guys."
msgstr "Soy uno de los malos."

msgctxt "1852\t1896"
msgid "Hamazaki."
msgstr "Hamazaki..."

msgctxt "1929\t1999"
msgid "Sorry 'bout this, Haruka-chan."
msgstr "Perdón por eso, Haruka-chan."

msgctxt "2003\t2082"
msgid "I'll keep whatever distance you need."
msgstr "Trataré de no acercarme a los niños."

msgctxt "2238\t2295"
msgid "Haruka, that's enough."
msgstr "Haruka, todo está bien ahora."

msgctxt "2297\t2332"
msgid "It's not enough!"
msgstr "¡¿Todo está bien?!"

msgctxt "2333\t2378"
msgid "And it never will be!"
msgstr "¡Nunca estará bien!"

msgctxt "2399\t2521"
msgid "Uncle Kaz, you don't really trust Hamazaki, do you!?"
msgstr "Tío Kaz, ¡¿realmente confías en Hamazaki?!"

msgctxt "2538\t2584"
msgid "Yeah."
msgstr "Sí."

msgctxt "2585\t2626"
msgid "Actually, I do."
msgstr "Lo hago."

msgctxt "2638\t2791"
msgid "Fine! But don't blame me when he betrays you again!"
msgstr "¡Bien! ¡Entonces ya no me importa lo que pase contigo!"

