msgctxt "1948"
msgid "Employee"
msgstr "Empleado"

msgctxt "1952"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "1956"
msgid "Player"
msgstr "Akiyama"

msgctxt "1960"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "116_Employee"
msgid "Hello! Let's see... I'd recommend these items for you, sir."
msgstr "¡Hola! Veamos... Le recomendaría estos artículos, señor."

msgctxt "128_Player"
msgid "Show me what you've got for sale."
msgstr "Enséñame lo que tienes a la venta."

msgctxt "140_Employee"
msgid "Equipment and weapons all have their strengths and weaknesses! That's why I've picked out a few that I think would interest you."
msgstr "¡Tanto equipamiento como armas tienen sus pros y sus contras! Es por eso que he elegido algunos que creo te interesarán."

msgctxt "164_Employee"
msgid "Thank you, and come again."
msgstr "Gracias, y vuelva otra vez."

msgctxt "176_Player"
msgid "I've got some things to sell."
msgstr "Tengo algunas cosas que vender."

msgctxt "188_Employee"
msgid "Sure thing. Let's see what you got there. But don't forget, used weapons are worth less than new weapons."
msgstr "Seguro. Veamos qué tienes ahí. Pero no olvides que las armas usadas valen menos que las nuevas."

msgctxt "212_Employee"
msgid "Thank you, and come again."
msgstr "Gracias, y vuelva otra vez."

msgctxt "224_Player"
msgid "Not right now."
msgstr "Ahora no."

msgctxt "236_Employee"
msgid "Is that so? Well, please come again."
msgstr "Bueno, por favor, vuelve otra vez."

msgctxt "248_Employee"
msgid "I'm here to buy."
msgstr "Estoy aquí para comprar."

msgctxt "260_Employee"
msgid "I'm here to sell."
msgstr "Estoy aquí para vender."

msgctxt "272_Employee"
msgid "Never mind."
msgstr "No importa."

