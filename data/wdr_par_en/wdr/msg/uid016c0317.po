msgctxt "816_Player"
msgid "\"Thanks for everything, teacher.\""
msgstr "\"Thanks for everything, teacher.\""

msgctxt "828_Player"
msgid "\"Give me the second button of your uniform.\""
msgstr "\"Give me the second button of your uniform.\""

msgctxt "840_Player"
msgid "\"I'm the only one getting held back a year.\""
msgstr "\"I'm the only one getting held back a year.\""

msgctxt "852_Player"
msgid "\"So you're blaming me?\""
msgstr "\"So you're blaming me?\""

msgctxt "864_Player"
msgid "\"I think you need a change of pace.\""
msgstr "\"I think you need a change of pace.\""

msgctxt "876_Player"
msgid "\"Sleeping is best at times like that.\""
msgstr "\"Sleeping is best at times like that.\""

msgctxt "888_Player"
msgid "\"Wouldn't it be cheaper to take a taxi?\""
msgstr "\"Wouldn't it be cheaper to take a taxi?\""

msgctxt "900_Player"
msgid "\"The train should be good enough.\""
msgstr "\"The train should be good enough.\""

msgctxt "912_Player"
msgid "\"How about using a pull-cart?\""
msgstr "\"How about using a pull-cart?\""

msgctxt "924_Player"
msgid "\"I don't ride motorcycles.\""
msgstr "\"I don't ride motorcycles.\""

msgctxt "936_Player"
msgid "\"Let me ride behind you.\""
msgstr "\"Let me ride behind you.\""

msgctxt "948_Player"
msgid "\"You shouldn't mess with your vehicles.\""
msgstr "\"You shouldn't mess with your vehicles.\""

msgctxt "960_Player"
msgid "\"I'll go see you at the club again.\""
msgstr "\"Iré al verte en el club otra vez.\""

msgctxt "972_Player"
msgid "\"Good luck with your band.\""
msgstr "\"Buena suerte con tu banda.\""

msgctxt "984_Player"
msgid "\"When's your next show?\""
msgstr "\"¿Cuándo es tu próximo concierto?\""

