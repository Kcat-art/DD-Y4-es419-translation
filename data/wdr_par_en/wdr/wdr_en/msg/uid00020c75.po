msgctxt "56_Prison Guard"
msgid "What do you want, inmate?"
msgstr "¿Qué es lo que quieres, condenado?"

msgctxt "68_Saejima"
msgid "Just a drink o' water. Mind lettin' me through?"
msgstr "Solo un sorbo de agua. ¿Te importa dejarme pasar?"

msgctxt "80_Prison Guard"
msgid "Fine, but make it quick."
msgstr "Vale. Pero que sea rápido."

