msgctxt "224"
msgid "Quit"
msgstr "Salir"

msgctxt "229"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "247"
msgid "Order"
msgstr "Pagar"

msgctxt "253"
msgid "Order the currently selected item.  "
msgstr "Pedir el objeto actualmente seleccionado.  "

msgctxt "290"
msgid "(I haven't picked anything.)  "
msgstr "(No he escogido nada)"

msgctxt "321"
msgid "(I'm short on cash.)  "
msgstr "(Me hace falta dinero)"

msgctxt "344"
msgid "That comes to %s."
msgstr "Sería un total de %s."

msgctxt "362"
msgid "(I can't carry any more stuff.)"
msgstr "(No puedo llevar más cosas)."

msgctxt "394"
msgid "(They're sold out.)"
msgstr "(Están agotados)."

msgctxt "414"
msgid "This is Temp 1. Its unique sweet flavor sets it apart\n"
"from Temp 2."
msgstr "Esto es Temp 1. Su sabor dulce único lo diferencia de \n"
"Temp 2."

msgctxt "481"
msgid "Temp 2 is a popular product of Settsu province, made\n"
"traditionally with their famous water."
msgstr "Temp 2 es un producto popular de la provincia de Settsu, \n"
"elaborado tradicionalmente con su famosa agua."

msgctxt "573"
msgid "This strong Temp 3 was made from Satsuma's famous\n"
"sweet potatoes."
msgstr "Este Temp 3 fuerte fue hecho con las famosas batatas de \n"
"Satsuma."

