msgctxt "88_Man"
msgid "Hey you! Aren't you forgetting something? We play by our own set of rules around here."
msgstr "¡Oye tú! ¿No estás olvidando algo? Aquí tenemos nuestras propias reglas."

msgctxt "100_Man"
msgid "You wanna get past me, you're gonna have to pay!"
msgstr "¡Si quieres pasar por aquí, vas a tener que pagar!"

msgctxt "124_Man"
msgid "Yikes! I'm sorry. I don't need your money!"
msgstr "¡Ay! Lo siento. ¡No necesito tu dinero!"

msgctxt "136_Man"
msgid "That was a real loser move. Please forgive me."
msgstr "Fue un movimiento muy patético. Por favor, perdóname."

msgctxt "148_Man"
msgid "You got a loser's %s."
msgstr "Obtuviste un %s."

msgctxt "184_Man"
msgid "Poverty can drive you to do some really shameful things. *sniffle*"
msgstr "La pobreza puede llevarte a hacer cosas realmente vergonzosas. *solloza”"

