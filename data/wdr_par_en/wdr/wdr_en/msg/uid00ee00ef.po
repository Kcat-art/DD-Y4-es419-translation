msgctxt "220_Staff"
msgid "Sir, it seems you don't have enough wooden tags to play cee-lo."
msgstr "Señor, parece que no tiene suficientes fichas de madera para jugar cee-lo."

msgctxt "232_Staff"
msgid "The minimum bet is 10 tags. You can play after you buy some more wooden tags."
msgstr "La apuesta mínima es de 10 fichas. Puedes jugar después de comprar más fichas de madera."

msgctxt "244_Staff"
msgid "Excuse me, sir. Would you like to play cee-lo?"
msgstr "Disculpe, señor. ¿Le gustaría jugar cee-lo?"

msgctxt "268_Haruka"
msgid "Uncle Kaz! I bet you can get 500 points in cee-lo!"
msgstr "¡Tío Kaz! ¡Apuesto a que puedes sacar 500 puntos en el cee-lo!"

msgctxt "280_Kiryu"
msgid "(500 points in cee-lo... Should I give it a try?)"
msgstr "(500 puntos en cee-lo... ¿Debería intentarlo?)."

msgctxt "292_Staff"
msgid "Sure, I'll play."
msgstr "Claro, jugaré."

msgctxt "304_Staff"
msgid "All right. Right this way."
msgstr "Perfecto. Por aquí."

msgctxt "316_Haruka"
msgid "Good luck, Uncle Kaz!"
msgstr "¡Buena suerte, Tío Kaz!"

msgctxt "340_Staff"
msgid "Not right now."
msgstr "Ahora no."

msgctxt "352_Staff"
msgid "Very well. Please come again."
msgstr "Está bien. Por favor, vuelva pronto."

msgctxt "364_Haruka"
msgid "Aww, I wanted to watch you play cee-lo, though..."
msgstr "Ayyy... pero yo quería verte jugar al cee-lo..."

