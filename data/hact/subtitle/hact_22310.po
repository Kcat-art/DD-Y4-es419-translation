msgctxt "40	100"
msgid "Welcome!"
msgstr "¡Bienvenido!"

msgctxt "210	300"
msgid "Okay, just relax\\nand lay on your side."
msgstr "Está bien, solo relájate\\ny acuéstate de lado."

msgctxt "360	485"
msgid "You're so cool!\\nYou make me blush."
msgstr "¡Eres genial!\\nMe haces sonrojar."

msgctxt "588	670"
msgid "I'll give you the best\\nmassage ever!"
msgstr "¡Te daré el mejor masaje\\nde todos los tiempos!"

msgctxt "805	860"
msgid "Let me know if it hurts."
msgstr "Avísame si duele."

msgctxt "1055	1095"
msgid "Does that hurt?"
msgstr "¿Eso dolió?"

msgctxt "1175	1245"
msgid "How is it?\\nI'm pretty good, right?"
msgstr "¿Cómo así?\\nSoy bastante bueno, ¿no?"

msgctxt "1325	1370"
msgid "Does that feel good?"
msgstr "¿Se siente bien?"

msgctxt "1415	1490"
msgid "Let me know if you can't take\\nit any more."
msgstr "Hazme saber si no puedes soportarlo más."

msgctxt "1590	1645"
msgid "...How's this?  ...How's that?"
msgstr "...¿Qué es esto? ... ¿Qué es eso?"

msgctxt "1685	1750"
msgid "Hm?\\nWhat is it?"
msgstr "¿hm?\\n¿Qué es?"

msgctxt "1800	1850"
msgid "What do you want me\\nto do for you?"
msgstr "¿Qué quieres que haga por ti?\\n"

msgctxt "1890	1990"
msgid "I'll do anything for you!"
msgstr "¡Haré cualquier cosa por ti!"

