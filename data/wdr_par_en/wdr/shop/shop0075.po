msgctxt "392"
msgid "Quit"
msgstr "Salir"

msgctxt "397"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "415"
msgid "Order"
msgstr "Pagar"

msgctxt "421"
msgid "Order the currently selected item.  "
msgstr "Pedir el objeto actualmente seleccionado.  "

msgctxt "458"
msgid "(I haven't picked anything.)  "
msgstr "(No he escogido nada)"

msgctxt "489"
msgid "(I'm short on cash.)  "
msgstr "(Me hace falta dinero)"

msgctxt "512"
msgid "Yes, yes, that'll be %s."
msgstr "Sí, sí, eso serían %s."

msgctxt "537"
msgid "(I can't carry any more stuff.)"
msgstr "(No puedo llevar más cosas)."

msgctxt "569"
msgid "(They're sold out.)"
msgstr "(Están agotados)."

msgctxt "589"
msgid "Filleted horse mackerel is great for bait."
msgstr "El jurel fileteado es ideal para como carnada."

msgctxt "632"
msgid "Filleted squid makes good bait."
msgstr "El calamar fileteado es una buena carnada."

msgctxt "664"
msgid "This shrimp makes fine bait."
msgstr "Este camarón es una buena carnada."

msgctxt "693"
msgid "This pickled squid makes good fishing bait."
msgstr "Este calamar encurtido es una buena carnada de pesca."

msgctxt "737"
msgid "A plain old earthworm. Classic bait."
msgstr "El típico gusano. Clásica carnada."

msgctxt "774"
msgid "This common shellfish can be used for bait."
msgstr "Este molusco común puede utilizarse como cebo."

msgctxt "818"
msgid "This clam is small but makes good bait."
msgstr "Esta almeja es pequeña pero sirve como buena carnada."

msgctxt "858"
msgid "These large prawns are tasty, but they can be used as\n"
"bait as well."
msgstr "Estos grandes langostinos son sabrosos, pero también pueden utilizarse como cebo."

msgctxt "926"
msgid "Lobster is a delicious treat, but it can be used as bait,\n"
"too."
msgstr "La langosta es un manjar delicioso, pero también puede usarse como cebo."

