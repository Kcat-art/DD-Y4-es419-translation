msgctxt "116_峰村七海：源氏名"
msgid "I'm a pretty tough player, by the way."
msgstr "Por cierto, soy muy difícil de vencer."

msgctxt "128_Tanimura"
msgid "Well, let's see just how tough you are then."
msgstr "Bueno, veamos que tan difícil es."

msgctxt "140_峰村七海：源氏名"
msgid "Let's go in."
msgstr "Entremos."

msgctxt "164_峰村七海：源氏名"
msgid "I'm a pretty tough player, by the way. You'll see!"
msgstr "Por cierto, soy difícil de vencer. ¡Ya lo verá!"

msgctxt "176_峰村七海：源氏名"
msgid "Let's head in."
msgstr "Entremos."

msgctxt "188_Tanimura"
msgid "Hold on... Seems I didn't bring enough money."
msgstr "Espera... Parece que no traje suficiente dinero."

msgctxt "200_峰村七海：源氏名"
msgid "I'm sorry, I must have misheard you. What did you say?"
msgstr "Disculpe, creo que no lo escuche bien. ¿Qué dijo?"

msgctxt "212_Tanimura"
msgid "Um... I mean... Sorry."
msgstr "Eh... Quiero decir... Perdón."

msgctxt "224_峰村七海：源氏名"
msgid "I don't believe it! You can't manage your own finances? How do you even survive as an adult?"
msgstr "¡No me lo puedo creer! ¿Acaso no puede manejar su propio dinero? ¿Cómo es que logra sobrevivir siendo un adulto?"

msgctxt "236_峰村七海：源氏名"
msgid "I'm going home. Goodbye."
msgstr "Me voy a casa. Adiós."

msgctxt "248_Tanimura"
msgid "(I should've checked my money earlier...)"
msgstr "(Debí haber revisado mi dinero antes...)"

msgctxt "356_峰村七海：源氏名"
msgid "Aw, I lost... Hadn't guessed you'd be good at bowling."
msgstr "Ay, perdí... No sabía que usted sería tan bueno en los bolos."

msgctxt "368_Tanimura"
msgid "Well, I'm okay..."
msgstr "Bueno, se me da bien..."

msgctxt "380_峰村七海：源氏名"
msgid "I had a really good time. We should go out again. <Color:7>♥<Color:Default>"
msgstr "La pasé muy bien. Deberíamos volver a salir. <Color:7>♥<Color:Default>"

msgctxt "392_峰村七海：源氏名"
msgid "Well, I better get going. Bye for now."
msgstr "Bueno, será mejor que me vaya. Nos vemos."

msgctxt "416_峰村七海：源氏名"
msgid "Haha. We tied."
msgstr "Ja, ja. Empatamos."

msgctxt "428_Tanimura"
msgid "I thought I had you there."
msgstr "Pensaba que la tenía ganada."

msgctxt "440_峰村七海：源氏名"
msgid "I had fun today. I'll see you at the club soon."
msgstr "I had fun today. I'll see you at the club soon."

msgctxt "464_峰村七海：源氏名"
msgid "Too bad, I win this time!"
msgstr "Too bad, I win this time!"

msgctxt "476_Tanimura"
msgid "Indeed."
msgstr "Indeed."

