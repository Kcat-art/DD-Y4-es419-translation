msgctxt "116_Chihiro"
msgid "I'm gonna sing till I drop!"
msgstr "¡Voy a cantar hasta desmayarme!"

msgctxt "128_Player"
msgid "Let's go in."
msgstr "Entremos."

msgctxt "152_Chihiro"
msgid "I'm gonna sing till I drop!"
msgstr "¡Voy a cantar hasta desmayarme!"

msgctxt "164_Player"
msgid "Hold on a sec... Um, looks like I'm low on cash."
msgstr "Un segundo... Mmm, parece que no tengo dinero."

msgctxt "176_Chihiro"
msgid "What? You are!?"
msgstr "¿Qué? ¡¿En serio?!"

msgctxt "188_Player"
msgid "Yeah. Sorry."
msgstr "Sí. Lo siento."

msgctxt "200_Chihiro"
msgid "That's a shame. I guess that's it today.\\r\n"\n"\\r\n"\n"Goodbye for now."
msgstr "Es una pena. Supongo que esto será todo por hoy.\\r\n"\n"\\r\n"\n"Nos vemos."

msgctxt "212_Player"
msgid "(I better find some money...)"
msgstr "(Será mejor que encuentre algo de dinero...)."

msgctxt "320_Chihiro"
msgid "That felt incredible! I love karaoke!"
msgstr "¡Eso fue increíble! ¡Me encanta el karaoke!"

msgctxt "332_Player"
msgid "And you've got a great voice."
msgstr "Tienes una gran voz."

msgctxt "344_Chihiro"
msgid "Thanks! You're not bad yourself!"
msgstr "¡Gracias! ¡Usted tampoco lo hace nada mal!"

msgctxt "380_Chihiro"
msgid "I haven't sung like that in a while."
msgstr "Hace tanto que no cantaba así."

msgctxt "392_Player"
msgid "You were great in there."
msgstr "Estuviste genial ahí."

msgctxt "404_Chihiro"
msgid "You certainly keep things lively. I'm pleasantly surprised."
msgstr "Sabes mantener las cosas animadas. Estoy sorprendida."

msgctxt "440_Chihiro"
msgid "I didn't sing all that well..."
msgstr "No canté muy bien..."

msgctxt "452_Player"
msgid "Oh. I thought you were all right."
msgstr "Uh. Yo creo que lo hacías bien."

msgctxt "464_Chihiro"
msgid "I'll head home for the day. See you at the club."
msgstr "Ya me voy a casa. Nos vemos en el club."

