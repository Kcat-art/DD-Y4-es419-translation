msgctxt "196"
msgid "Quit"
msgstr "Salir"

msgctxt "201"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "219"
msgid "Order"
msgstr "Pagar"

msgctxt "225"
msgid "Order the currently selected item.  "
msgstr "Pedir el objeto actualmente seleccionado.  "

msgctxt "262"
msgid "(I haven't picked anything.)  "
msgstr "(No he escogido nada)"

msgctxt "293"
msgid "(I'm short on cash.)  "
msgstr "(Me hace falta dinero)"

msgctxt "316"
msgid "Thank you. That'll be %s."
msgstr "Gracias. Eso sería %s."

msgctxt "342"
msgid "(I can't carry any more stuff.)"
msgstr "(No puedo llevar más cosas)."

msgctxt "374"
msgid "(They're sold out.)"
msgstr "(Están agotados)."

msgctxt "394"
msgid "A body-hugging, halter-neck dress that amplifies its\n"
"wearer's sexiness."
msgstr "Un vestido ajustado al cuerpo y con cuello de tipo\n"
"halter que realza la sensualidad de su portadora."

msgctxt "466"
msgid "The elegant body line and sophisticated color of this\n"
"dress are sure to turn heads."
msgstr "La elegante silueta del cuerpo y el sofisticado color\n"
"de este vestido seguro que atraerán todas las miradas."

