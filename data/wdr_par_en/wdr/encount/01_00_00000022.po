msgctxt "116_Man"
msgid "Boy, you sure are lucky! After all, you met me, didn't you? So how about a little drinking money for your pal here, hmm?"
msgstr "¡Oye, qué suerte tienes! Después de todo, me conoces, ¿no? ¿Qué tal un poco de dinero para las copas de tu compa, Mmm?"

msgctxt "128_Man"
msgid "Now hand over the money!"
msgstr "¡Ahora dame el dinero!"

msgctxt "152_Man"
msgid "I give up. I shouldn't have picked that fight."
msgstr "Me rindo. No debí haber empezado esta pelea."

msgctxt "164_Man"
msgid "Here, take this－and please cut me some slack."
msgstr "Toma esto, y por favor, no seas tan duro conmigo."

msgctxt "176_Man"
msgid "You got a pretty cool %s."
msgstr "Obtuviste un %s."

msgctxt "212_Man"
msgid "I'll be good from now on, I swear."
msgstr "Me portaré bien a partir de ahora, lo juro."

