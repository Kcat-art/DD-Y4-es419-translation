msgctxt "80_Saejima"
msgid "......"
msgstr "......"

msgctxt "104_Saejima"
msgid "They ain't wastin' any time. You stay put, hear me?"
msgstr "No malgastan ni un segundo. No te muevas, ¿sí?"

msgctxt "116_Client"
msgid "Kill him, quick! Crud, I just wet myself..."
msgstr "¡Mátalo, rápido! Diablos, me acabo de orinar..."

msgctxt "128_Saejima"
msgid "Shit. A job's a job, but I'm losin' motivation real quick."
msgstr "Mierda. El trabajo es trabajo, pero estoy perdiendo la motivación muy rápido."

msgctxt "140_Saejima"
msgid "Ah, screw it. Let's get this over with."
msgstr "¿Sabes qué?, al diablo. Terminemos con esto."

