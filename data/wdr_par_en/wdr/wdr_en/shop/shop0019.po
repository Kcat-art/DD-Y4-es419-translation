msgctxt "252"
msgid "Quit"
msgstr "Salir"

msgctxt "257"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "275"
msgid "Order"
msgstr "Pagar"

msgctxt "281"
msgid "Order the currently selected item.  "
msgstr "Pedir el objeto actualmente seleccionado.  "

msgctxt "318"
msgid "(I haven't picked anything.)  "
msgstr "(No he escogido nada)"

msgctxt "349"
msgid "(I'm short on cash.)  "
msgstr "(Me hace falta dinero)"

msgctxt "372"
msgid "Hey, thanks! That'll be %s."
msgstr "Gracias. Eso será %s."

msgctxt "400"
msgid "(I can't carry any more stuff.)"
msgstr "(No puedo llevar más cosas)."

msgctxt "432"
msgid "(They're sold out.)"
msgstr "(Están agotados)."

msgctxt "452"
msgid "A popular after work drink. It charges up your health\n"
"and Heat a little."
msgstr "Una bebida popular para después del trabajo. \n"
"Recarga un poco tu Heat y salud."

msgctxt "525"
msgid "One of our most popular products. It'll charge up your\n"
"Heat a bit."
msgstr "Uno de nuestros productos más populares. Cargará tu\n"
"Heat un poco."

msgctxt "592"
msgid "You like that black umbrella? You could probably use\n"
"it for a weapon. Hell, my pops was a beast with one."
msgstr "¿Te gusta ese paraguas negro? Probablemente podrías usarlo\n"
"como arma. Demonios, mi padre era una bestia con uno."

msgctxt "698"
msgid "This smells so bad, it might save your ass in a fight. \n"
"Just leave it behind when you go to the club!"
msgstr "Esto huele tan mal que podría salvarte el culo en una pelea. \n"
"¡Solo olvídalo cuando vayas al club!"

