msgctxt "620"
msgid "Quit"
msgstr "Salir"

msgctxt "625"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "643"
msgid "Order"
msgstr "Pagar"

msgctxt "649"
msgid "Order the currently selected item."
msgstr "Pagar el objeto seleccionado actualmente."

msgctxt "684"
msgid "(I haven't picked anything.)"
msgstr "(No he escogido nada)"

msgctxt "713"
msgid "(I'm short on cash.)"
msgstr "(Me hace falta dinero)"

msgctxt "734"
msgid "Thank you. Your total comes to %s."
msgstr "Gracias. El precio total es de %s."

msgctxt "769"
msgid "(I can't eat anymore...)"
msgstr "(No puedo comer más...)"

msgctxt "812"
msgid "Thick-cut chuck meat. Some of the best beef on offer."
msgstr "Carne de ternera de corte grueso. Una de las mejores carnes disponibles."

msgctxt "866"
msgid "This tongue meat is popular for its unique flavor."
msgstr "Esta carne de lengua es popular por su sabor único."

msgctxt "917"
msgid "This tongue meat from carefully selected beef is soft\n"
"and rich. Enjoy! "
msgstr "Esta carne de lengua de res cuidadosamente seleccionada \n"
"es suave y deliciosa. ¡Disfrútala! "

msgctxt "989"
msgid "Meat from the belly of the cow. Popular for its \n"
"incredibly rich flavor."
msgstr "Carne del vientre de la vaca. Popular por su sabor \n"
"increíblemente delicioso."

msgctxt "1062"
msgid "Top-grade kalbi beef taken from the choicest parts of\n"
"a single cow."
msgstr "Carne de kalbi de primera calidad tomada de las partes \n"
"más selectas de una sola vaca."

msgctxt "1130"
msgid "Beef back strap with a mild flavor and relatively low\n"
"in fat."
msgstr "Carne de lomo con un sabor suave y relativamente \n"
"baja en grasa."

msgctxt "1192"
msgid "Choice sirloin taken from top-grade Japanese beef.\n"
"The taste is incredible."
msgstr "Un solomillo selecto extraído de carne de res japonesa \n"
"de primera calidad. El sabor es increíble."

msgctxt "1268"
msgid "This beef skirt steak is actually considered to be \n"
"entrails, but it's very popular nonetheless."
msgstr "Este bistec de falda de res se considera en realidad\n"
"como vísceras, pero sigue siendo muy popular."

msgctxt "1365"
msgid "Harami taken from top-grade Japanese beef. An \n"
"incredible treat for your tastebuds."
msgstr "Harami extraído de carne de res japonesa de primera\n"
"calidad. Un placer increíble para el paladar."

msgctxt "1449"
msgid "Fresh liver cut up into raw strips with a delicious \n"
"sesame-based sauce."
msgstr "Hígado fresco cortado en tiras crudas con una\n"
"deliciosa salsa a base de sésamo."

msgctxt "1522"
msgid "Some say this choice beef intestine only finds \n"
"its true worth in being burnt black."
msgstr "Algunos dicen que este selecto intestino de res \n"
"sólo encuentra su verdadero valor cuando se \n"
"quema hasta quedar negro."

msgctxt "1607"
msgid "A serving of succulent seafood, such as shrimp, \n"
"scallops, and squid."
msgstr "Una porción de mariscos suculentos, como\n"
"camarones, vieiras y calamares."

msgctxt "1677"
msgid "Kimchi made from Chinese cabbage, cucumbers, \n"
"daikon, and more in this tantalizing combo dish."
msgstr "Kimchi hecho con col china, pepinos, daikon y más \n"
"en este plato tentador."

msgctxt "1772"
msgid "Eat it up with our salty sweet gochujang sauce. \n"
"Delicious when roasted to a golden brown."
msgstr "Cómelo con nuestra salsa gochujang salada y dulce.\n"
"Delicioso cuando se asa hasta dorarlo."

msgctxt "1863"
msgid "Spicy beef soup and rice is one of our house \n"
"specialties."
msgstr "La sopa de carne de res picante y el arroz es\n"
"una de nuestras especialidades de la casa."

