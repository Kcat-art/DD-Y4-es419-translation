msgctxt "585	645"
msgid "<Italic>Sky Finance</Italic>"
msgstr "<Italic>Sky Finance</Italic>"

msgctxt "1434	1524"
msgid "A serial killer, now?"
msgstr "¿Un asesino en serie?"

msgctxt "1613	1674"
msgid "Scary shit..."
msgstr "Qué miedo..."

msgctxt "1725	1890"
msgid "<Italic>Murder Spree Rocks Kamurocho!\\nSerial Killer on the Loose!</Italic>"
msgstr "<Italic>¡Una ola de asesinatos sacude Kamurocho!\\n¡Un asesino en serie anda suelto!</Italic>"

msgctxt "3262	3336"
msgid "All right, all right!"
msgstr "¡Ah, está bien!"

msgctxt "3395	3463"
msgid "Hm? Hana-chan?"
msgstr "¿Eh? ¿Hana-chan?"

msgctxt "3492	3534"
msgid "Hey, how's it hanging?"
msgstr "Hey, ¿cómo te va?"

msgctxt "3535	3592"
msgid "Oh, finally."
msgstr "Ah, por fin."

msgctxt "3596	3717"
msgid "Where the <Italic>heck</Italic> have you been!?"
msgstr "Oiga, ¡¿dónde rayos está?!"

msgctxt "3731	3832"
msgid "What, me? I'm, uh, at a client's?"
msgstr "¿Quién, yo? Esto, eh, justo acabo de salir."

msgctxt "3811	3873"
msgid "And I'm the Queen of France."
msgstr "Suena a mentira."

msgctxt "3874	3968"
msgid "You're still at the office, aren't you?"
msgstr "¿Será que aún está en la oficina?"

msgctxt "3964	4074"
msgid "Why didn't you answer any of my calls!?"
msgstr "¡Uah! ¡¿Entonces por qué no contestaba mis llamadas?!"

msgctxt "4132	4215"
msgid "Hey! Are you even listening!?"
msgstr "¡Oiga! ¡¿Me está escuchando?!"

msgctxt "4235	4319"
msgid "Ugh, this stupid phone..."
msgstr "¿Eh? ¿Será que se fue la señal?"

msgctxt "4309	4348"
msgid "Akiyama-san?"
msgstr "¿Akiyama-san?"

msgctxt "4349	4449"
msgid "Akiyama-san!\\nEarth to Akiyama-san!"
msgstr "¡Akiyama-saan!\\n¿Puede escucharmeee?"

msgctxt "4450	4587"
msgid "Yeah, yeah. I can hear you.\\nLook, I'm sorry!"
msgstr "Sí, sí. Puedo escucharte.\\n¡Lo siento, de verdad!"

msgctxt "4593	4674"
msgid "So what's the word?\\nYou need something?"
msgstr "Entonces, dime.\\n¿Necesitas algo?"

msgctxt "4660	4710"
msgid "What?"
msgstr "¿Qué?"

msgctxt "4711	4861"
msgid "Of course I need something!\\nWhy else would I have called!?"
msgstr "¡¿Qué estás diciendo?!\\n¡Si te llamo es porque hay algo que hacer!"

msgctxt "4864	4959"
msgid "Right, sorry, okay!\\nMy bad."
msgstr "¡Oh, tienes razón, lo siento!\\nMi error."

msgctxt "4960	5004"
msgid "What can I do you for?"
msgstr "Entonces, ¿en qué te puedo ayudar?"

msgctxt "5005	5115"
msgid "Do you have any idea what day it is today?"
msgstr "¿Tiene alguna idea de qué día es hoy?"

msgctxt "5143	5178"
msgid "Today?"
msgstr "¿Hoy?"

msgctxt "5179	5260"
msgid "Well, er..."
msgstr "Bueno, hoy..."

msgctxt "5269	5310"
msgid "Is it..."
msgstr "Es tu..."

msgctxt "5311	5358"
msgid "Your birthday?"
msgstr "¿cumpleaños?"

msgctxt "5359	5403"
msgid "No!"
msgstr "¡No!"

msgctxt "5404	5492"
msgid "Can you just look at the calendar!?"
msgstr "¡Por favor, apúrese y dele un vistazo al calendario!"

msgctxt "5666	5771"
msgid "Ohhh, right. Collection day!"
msgstr "Oh, cierto. ¡Día de recolección!"

msgctxt "5754	5824"
msgid "You forgot again, didn't you!?"
msgstr "¡Lo habías olvidado por completo!"

msgctxt "5825	5916"
msgid "Hey, come on now, I didn't forget."
msgstr "Qué va, no es como si lo hubiese olvidado."

msgctxt "5922	6032"
msgid "I was just giving it some time,\\nwaiting for the, uh..."
msgstr "Pensaba salir en un rato,\\nsolo estaba algo indeciso..."

msgctxt "6033	6071"
msgid "You know..."
msgstr "Ya sabes por qué..."

msgctxt "6072	6167"
msgid "I don't know.\\nFor what!?"
msgstr "No sé.\\n¡¿Por qué?!"

msgctxt "6179	6252"
msgid "Isn't it obvious?"
msgstr "Bueno, es que hoy..."

msgctxt "6284	6357"
msgid "For the rain to stop."
msgstr "... está lloviendo mucho."

msgctxt "6495	6600"
msgid "It's been dry out there for hours, Chief."
msgstr "Si tu excusa era la lluvia, lamento decirte que paró hace horas."

msgctxt "6652	6725"
msgid "Now would you <Italic>please</Italic> get moving?"
msgstr "Ahora, ¡<Italic>por favor</Italic>, salga a trabajar!"

msgctxt "6725	6834"
msgid "I'll be back just after I swing by\\nKanrai for a kalbi bento."
msgstr "Iré para allá luego de pasar por\\nKanrai a por un kalbi bento especial."

msgctxt "6834	6894"
msgid "See you soon."
msgstr "Nos vemos."

