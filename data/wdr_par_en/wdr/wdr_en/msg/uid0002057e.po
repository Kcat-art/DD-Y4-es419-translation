msgctxt "3296"
msgid "Hamazaki"
msgstr "Hamazaki"

msgctxt "3300"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "3304"
msgid "Kiryu"
msgstr "Kiryu"

msgctxt "3308"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "116_Hamazaki"
msgid "It's go time, Kiryu-san. You ready?"
msgstr "Es hora de irse, Kiryu-san. ¿Estás listo?"

msgctxt "128_Kiryu"
msgid "Not quite yet. Just need to do a few things first."
msgstr "Aún no. Necesito hacer un par de cosas primero."

msgctxt "140_Hamazaki"
msgid "All right, but make it snappy."
msgstr "Está bien, pero que sea rápido."

msgctxt "152_Kiryu"
msgid "Yeah, let's do it."
msgstr "Sí, hagámoslo."

msgctxt "212_Hamazaki"
msgid "Guess I'm gonna head down to the station now. Turn myself in."
msgstr "Supongo que ahora iré a la comisaría. Me entregaré."

msgctxt "224_Kiryu"
msgid "Already?"
msgstr "¿Ya?"

msgctxt "236_Hamazaki"
msgid "Sooner the better, I figure. Anyway... I'll be seeing you,\\r\n"
"Kiryu-san."
msgstr "Sooner the better, I figure. Anyway... I'll be seeing you,\\r\n"
"Kiryu-san."

msgctxt "248_Kiryu"
msgid "Hold on. Do you even know where the police station is?"
msgstr "Espera. ¿Sabes dónde queda la comisaría?"

msgctxt "260_Hamazaki"
msgid "I'm an adult, I got eyes. I'll find it."
msgstr "Soy un adulto, y tengo ojos. Lo encontraré."

msgctxt "272_Kiryu"
msgid "I'm coming with you, Hamazaki. We might have had our\\r\n"
"differences, but you at least deserve a proper send-off after all we've been through together."
msgstr "I'm coming with you, Hamazaki. We might have had our\\r\n"
"differences, but you at least deserve a proper send-off after all we've been through together."

msgctxt "284_Hamazaki"
msgid "Heh. Suit yourself."
msgstr "Heh. Como quieras."

msgctxt "308_Hamazaki"
msgid "Not quite yet."
msgstr "Todavía no."

msgctxt "320_Hamazaki"
msgid "Yeah, let's do it."
msgstr "Sí, hagámoslo."

