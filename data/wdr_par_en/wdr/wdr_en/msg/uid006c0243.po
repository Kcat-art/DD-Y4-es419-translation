msgctxt "116_Chihiro"
msgid "Okay, this match is for keeps."
msgstr "Esta bien, este partido es para siempre."

msgctxt "128_Player"
msgid "Heh. You take this seriously, don't you?"
msgstr "Je. Eres del tipo competitivo, ¿no?"

msgctxt "140_Chihiro"
msgid "Let's go in."
msgstr "Entremos."

msgctxt "164_Chihiro"
msgid "Okay, this match is for keeps."
msgstr "Esta bien, este partido es para siempre."

msgctxt "176_Player"
msgid "Hold on a sec... Um, looks like I'm low on cash."
msgstr "Un segundo... Mmm, parece que no tengo dinero."

msgctxt "188_Chihiro"
msgid "What? You are!?"
msgstr "¿Qué? ¡¿En serio?!"

msgctxt "200_Player"
msgid "Yeah. Sorry."
msgstr "Sí. Lo siento."

msgctxt "212_Chihiro"
msgid "That's a shame. I guess that's it today.\\r\n"\n"\\r\n"\n"Goodbye for now."
msgstr "Es una pena. Supongo que será todo por hoy.\\r\n"\n"\\r\n"\n"Nos vemos."

msgctxt "224_Player"
msgid "(I better find some money...)"
msgstr "(Será mejor que encuentre algo de dinero...)."

msgctxt "332_Chihiro"
msgid "Oh, I lost. You could've gone a bit easier on me!"
msgstr "Ah, perdí. ¡Podrías haberte contenido un poco!"

msgctxt "344_Player"
msgid "Hey, you said this was for keeps."
msgstr "Hey, you said this was for keeps."

msgctxt "356_Chihiro"
msgid "Yeah, I did. And I had fun, too. I'll just have to practice! <Color:7>♥<Color:Default>"
msgstr "Sí, lo hice. Y me divertí. ¡Tendré que mejorar con la práctica! <Color:7>♥<Color:Default>"

msgctxt "368_Chihiro"
msgid "I'll be waiting for you at the club."
msgstr "Te estaré esperando en el club."

msgctxt "392_Chihiro"
msgid "Looks like a draw."
msgstr "Parece que terminamos empatando."

msgctxt "404_Player"
msgid "Yeah. You're pretty good."
msgstr "Sí. Eres muy buena."

msgctxt "416_Chihiro"
msgid "Thank you! That was intense, wasn't it?"
msgstr "¡Gracias! Eso estuvo muy peleado, ¿no?"

msgctxt "428_Talk_Ojigi"
msgid "Well, I'll see you at the club."
msgstr "Genial. Entonces, te veré en el club."

msgctxt "452_Chihiro"
msgid "I did it! I beat you!"
msgstr "¡Lo hice! ¡Le gané!"

msgctxt "464_Player"
