msgctxt "72_Food Distributor"
msgid "Hey, man, lookin' for something to eat?"
msgstr "Ey, amigo, ¿buscas algo pa' comer?"

msgctxt "84_Food Distributor"
msgid "Wait, you don't have any points."
msgstr "Espera, No tienes puntos."

msgctxt "96_Player"
msgid "Points? Don't you guys take money?"
msgstr "¿Puntos? ¿No aceptan dinero normal?"

msgctxt "108_Food Distributor"
msgid "Nope. We only take special points you use down here in the underground."
msgstr "Nop. Solo aceptamos puntos especiales que se usan aquí abajo, en el subterráneo."

msgctxt "120_Food Distributor"
msgid "If you wanna learn more about 'em, go ask the guy at the top of the stairs over there."
msgstr "Si te interesa saber más, ve a preguntarle al tipo que está subiendo las escaleras."

msgctxt "132_Food Distributor"
msgid "Hey, man, lookin' for something to eat? It's not as nice as the stuff you might get up above, but it's better than nothing."
msgstr "¿Ey, amigo, buscas algo pa' comer? No es tan bueno como lo de arriba, pero peor es nada."

msgctxt "156_Food Distributor"
msgid "Thanks for coming! Stop by any time."
msgstr "¡Gracias por venir! Pasa cuando quieras."

msgctxt "168_Food Distributor"
msgid "(No point eating now. I'm not even hungry.)"
msgstr "(No tiene sentido comer ahora. Ni siquiera tengo hambre)."

msgctxt "180_Player"
msgid "Sorry, I'm not hungry."
msgstr "No tengo hambre, gracias."

msgctxt "192_Food Distributor"
msgid "No worries. Come by when you are."
msgstr "No pasa nada. Pásate por aquí cuando quieras."

msgctxt "204_Player"
msgid "Sorry, something just came up."
msgstr "Discúlpe, me surgió un imprevisto."

msgctxt "216_Food Distributor"
msgid "No worries. Come by anytime."
msgstr "No te preocupes. Pásate cuando quieras."

