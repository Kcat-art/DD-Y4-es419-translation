msgctxt "266\t359"
msgid "Those are my terms."
msgstr "Esos son los términos del lugar."

msgctxt "369\t494"
msgid "If you don't pass the test,\\nI'm afraid I can't offer you the loan."
msgstr "Si no pasas la prueba,\\nme temo que no podremos darte el préstamo."

msgctxt "562\t652"
msgid "And about the ten days you mentioned."
msgstr "Y sobre los diez días que mencionaste."

msgctxt "654\t789"
msgid "You really need the money that soon?"
msgstr "¿Realmente necesitas el dinero con tanta ungencia?"

msgctxt "811\t852"
msgid "I do."
msgstr "Sí."

msgctxt "853\t913"
msgid "Pretty big hurry, huh?"
msgstr "Tienes prisa, ¿no?"

msgctxt "946\t1031"
msgid "Yes. That's right."
msgstr "Sí. Así es."

msgctxt "1058\t1234"
msgid "But if you don't pass my test,\\nyou'll have wasted some of that precious time."
msgstr "Pero si no pasas la prueba,\\ntodo habrá sido una pérdida de tiempo."

msgctxt "1255\t1374"
msgid "What do you think?\\nStill want to give it a shot?"
msgstr "¿Qué te parece?\\n¿Aún quieres hacer la prueba?"

msgctxt "1862\t1914"
msgid "Yes."
msgstr "Sí."

msgctxt "1915\t1972"
msgid "I have to try."
msgstr "Déjeme intentarlo."

msgctxt "2008\t2096"
msgid "And you're really sure?"
msgstr "¿Estás realmente segura?"

msgctxt "2201\t2298"
msgid "This is the only option I have left."
msgstr "Esta es la única opción que me queda."

msgctxt "2374\t2429"
msgid "So please."
msgstr "Así que, por favor."

msgctxt "2440\t2566"
msgid "Let me take your test."
msgstr "Déjeme tomar esa prueba."

