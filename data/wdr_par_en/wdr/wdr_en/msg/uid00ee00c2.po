msgid "Welcome. Have you decided what you would like?"
msgstr "Bienvenido. ¿Ha decidido ya lo que quiere?"

msgctxt "96_Haruka"
msgid "Uncle Kaz! Will you get me a <Color:8>Burdock Stick<Color:Default>? I'm kinda hungry..."
msgstr "¡Tío Kaz! ¿Me compras un <Color:8>Palito de Bardana<Color:Default>? Tengo un poco de hambre..."

