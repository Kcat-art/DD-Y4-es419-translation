msgctxt "816_Player"
msgid "\"You really like cake, don't you?\""
msgstr "\"You really like cake, don't you?\""

msgctxt "828_Player"
msgid "\"I'd like to try some of that myself.\""
msgstr "\"I'd like to try some of that myself.\""

msgctxt "840_Player"
msgid "\"You're not cutting back at all, are you?\""
msgstr "\"You're not cutting back at all, are you?\""

msgctxt "852_Player"
msgid "\"It's not healthy to deny yourself too much.\""
msgstr "\"It's not healthy to deny yourself too much.\""

msgctxt "864_Player"
msgid "\"I don't worry about what I eat.\""
msgstr "\"I don't worry about what I eat.\""

msgctxt "876_Player"
msgid "\"I'd love to see a fat ballerina.\""
msgstr "\"I'd love to see a fat ballerina.\""

msgctxt "888_Player"
msgid "\"I could drive you, but I'd go slow.\""
msgstr "\"I could drive you, but I'd go slow.\""

msgctxt "900_Player"
msgid "\"Why don't you go to the racetrack?\""
msgstr "\"Why don't you go to the racetrack?\""

msgctxt "912_Player"
msgid "\"Aren't all cars basically the same?\""
msgstr "\"Aren't all cars basically the same?\""

msgctxt "924_Player"
msgid "\"Why don't you go ahead and buy it?\""
msgstr "\"¿Por qué no lo compras? Date el gusto\"."

msgctxt "936_Player"
msgid "\"If you're not sure, you shouldn't buy it.\""
msgstr "\"Si no estás segura, no deberías comprarlo\"."

msgctxt "948_Player"
msgid "\"Are you asking me to buy it for you?\""
msgstr "\"¿Me estás pidiendo que te lo compre?\""

msgctxt "960_Player"
msgid "\"Are you a lightweight?\""
msgstr "\"¿Eres delgaducha?\""

msgctxt "972_Player"
msgid "\"I had fun, too.\""
msgstr "\"Yo también me divertí.\""

msgctxt "984_Player"
msgid "\"Can I call you?\""
msgstr "\"¿Puedo llamarte?\""

