msgctxt "100_Saejima"
msgid "(Gotta stay outta the cops' sight till I make it to the hideout...)"
msgstr "(Tengo que mantenerme alejado de los policías hasta llegar al escondite...)"

msgctxt "124_Stranger"
msgid "Hey! Wait, Saejima-san!"
msgstr "¡Oye! ¡Espera, Saejima-san!"

msgctxt "148_Stranger"
msgid "I just watched you fight! It was impressive how you withstood all that pain! I was moved!"
msgstr "¡Te vi pelear! ¡Es impresionante como aguantaste todo ese dolor! ¡Fue conmovedor!"

msgctxt "160_Saejima"
msgid "Who the hell are ya?"
msgstr "¿Y quién se supone que eres?"

msgctxt "172_Stranger"
msgid "Oh, sorry! My name is Sodachi. I run a dojo in the neighborhood."
msgstr "¡Ah, disculpa! Me llamo Sodachi. Dirijo un dojo de por aquí."

msgctxt "184_Saejima"
msgid "Well whaddya want with me?"
msgstr "¿Y qué quieres de mí?"

msgctxt "196_Sodachi"
msgid "To tell you the truth, I was hoping you could help me with something."
msgstr "Para serte sincero, esperaba que me pudieras ayudar con algo."

msgctxt "208_Saejima"
msgid "Help ya...?"
msgstr "¿Ayudar con algo...?"

msgctxt "220_Sodachi"
msgid "Yes... But let's talk at my dojo. That way you can see it for yourself. It's really close by. Do you have a little time to spare?"
msgstr "Sí... ¿qué tal si hablamos en el dojo? Así podrás verlo tú mismo. Es por acá cerca. ¿Tienes tiempo?"

msgctxt "232_Saejima"
msgid "Fine. But make it quick."
msgstr "Vale. Pero que sea rápido."

msgctxt "244_Sodachi"
msgid "Great! Woohoo! Just follow me and we'll be there in a jiffy!"
msgstr "¡Qué bien! ¡Yujuu! ¡Sígueme, estaremos allí en un santiamén!"

msgctxt "268_Saejima"
msgid "Sorry. Ain't got the time."
msgstr "Disculpa. No tengo tiempo."

msgctxt "280_Sodachi"
msgid "I see... I bet you're a pretty busy guy! No worries! Heheh... Heh..."
msgstr "Entiendo... ¡apuesto a que eres alguien bastante ocupado!, ¡no te preocupes! Je, je, je... je..."

msgctxt "292_Sodachi"
msgid "Rats... There's no hope left... My dojo is finished!"
msgstr "Caray... Ya no hay esperanza... ¡Mi dojo está acabado!"

msgctxt "304_Sodachi"
msgid "So, this is what utter despair feels like... My chest, oh, it hurts!"
msgstr "¿Así se siente la desesperación? El pecho, ¡me duele!"

msgctxt "316_Saejima"
msgid "Enough already. I'll go with ya. Just keep it short."
msgstr "Ya es suficiente. Te acompañaré. Pero que sea rápido."

msgctxt "328_Sodachi"
msgid "Great! Woohoo! Follow me! Right this way! Let's go!"
msgstr "¡Qué bien! ¡Yujuuu! ¡Sígueme! ¡Por aquí! ¡Vamos!"

msgctxt "352_Saejima"
msgid "Follow to the Dojo"
msgstr "Ir al dojo"

msgctxt "364_Saejima"
msgid "Decline"
msgstr "No ir"

