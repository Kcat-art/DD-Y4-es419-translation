msgctxt "129	190"
msgid "Munakata?"
msgstr "¿Munakata?"

msgctxt "224	355"
msgid "As in... Deputy Commissioner of the Tokyo PD!?"
msgstr "¡¿Te refieres al subdirector general del DPM de Tokyo?!"

msgctxt "376	436"
msgid "That's the one."
msgstr "Así es."

msgctxt "442	502"
msgid "Guy's backed us for years."
msgstr "Siempre tuvimos su apoyo."

msgctxt "524	599"
msgid "Ever since I turned that report in."
msgstr "El subdirector siempre estuvo atrás de nosotros."

msgctxt "648	711"
msgid "You see what you're up against?"
msgstr "Ahora ya sabes a lo que te enfrentas."

msgctxt "734	856"
msgid "You're in way over your head, kid."
msgstr "Este enemigo es demasiado poderoso."

msgctxt "1094	1154"
msgid "Man, that feels good."
msgstr "Ah, que alivio."

msgctxt "1231	1291"
msgid "Been 30 years."
msgstr "30 años."

msgctxt "1331	1424"
msgid "30 years I've lived this lie."
msgstr "He estado viviendo esta mentira durante 30 años."

msgctxt "1463	1523"
msgid "No one to confide in."
msgstr "Si poder hablar de ello..."

msgctxt "1533	1597"
msgid "No one who'd understand me."
msgstr "Sin nadie que me comprenda."

msgctxt "1707	1829"
msgid "You have any clue how tough that is?"
msgstr "¿Puedes entender todo este sufrimiento?"

msgctxt "1907	1967"
msgid "Sugiuchi..."
msgstr "Tú..."

msgctxt "2042	2117"
msgid "The hell have I been doing with my life?"
msgstr "¿Qué diablos he estado haciendo con mi vida?"

msgctxt "2150	2213"
msgid "For decades now..."
msgstr "Ese momento hace 25 años..."

msgctxt "2227	2317"
msgid "Ever since the day I introduced\\nMunakata to Katsuragi..."
msgstr "Desde el día en el que presenté\\nMunakata a Katsuragi..."

msgctxt "2342	2483"
msgid "I've been a goddamn lapdog.\\nFor cops and yakuza alike."
msgstr "No he sido más que un perro faldero.\\nPara la policía y para la yakuza."

msgctxt "2536	2611"
msgid "And my own dream?"
msgstr "Y mis propios sueños..."

msgctxt "2638	2703"
msgid "It fizzled out years ago."
msgstr "Los terminé olvidando por completo."

msgctxt "2865	2925"
msgid "You're one of the good ones."
msgstr "Tú eres increíble."

msgctxt "2939	3000"
msgid "A real, honest cop."
msgstr "Viviendo mejor que un criminal."

msgctxt "3060	3201"
msgid "Lie or not, with 30 years on the force..."
msgstr "Mentira o no, con 30 años en la policía..."

msgctxt "3219	3400"
msgid "I've gotten my fair share of praise.\\nBeen thanked countless times for my service."
msgstr "Hubo momentos en los que\\nfui apreciado y querido por las personas."

msgctxt "3425	3525"
msgid "Every word of it tore my heart out."
msgstr "Cada palabra me atormentaba."

msgctxt "3546	3651"
msgid "Made me wonder what I was even doing."
msgstr "Me hizo preguntarme qué estaba haciendo."

msgctxt "3698	3837"
msgid "I'd close a case.\\nGet my pat on the back."
msgstr "Cerraría un caso.\\nRecibiría el agradecimiento de la gente."

msgctxt "3864	3987"
msgid "And you know? Even though\\nI knew it shouldn't have..."
msgstr "Incluso si sé que es una mentira\\ncreada por mi mente..."

msgctxt "3996	4119"
msgid "It felt good.\\nSomewhere deep in my heart."
msgstr "En lo profundo de mi corazón\\neso me hacía sentir feliz."

msgctxt "4227	4287"
msgid "Truth is..."
msgstr "Pero sabes..."

msgctxt "4320	4488"
msgid "Seeing you struggle, suffer, succeed..."
msgstr "Verte luchar, sufrir, triunfar..."

msgctxt "4521	4601"
msgid "Made me wish I'd gone straight ages ago."
msgstr "Me hizo desear, con todas mis fuerzas,\\nquerer ser un detective de verdad."

msgctxt "4672	4732"
msgid "Sugiuchi-san..."
msgstr "Sugiuchi-san..."

msgctxt "4854	4914"
msgid "Take me in."
msgstr "Arréstame."

msgctxt "4959	5148"
msgid "You did this all on your own.\\nAvenged your old man. Brought me down."
msgstr "Hiciste todo esto por tu cuenta.\\nVengaste a tu padre. Me atrapaste."

msgctxt "5249	5309"
msgid "What's wrong?"
msgstr "¿Qué pasa?"

msgctxt "5319	5437"
msgid "I need to know something."
msgstr "Necesito saber algo."

msgctxt "5503	5587"
msgid "What's Munakata trying to do?"
msgstr "¿Qué está tratando de hacer Munakata?"

msgctxt "5619	5790"
msgid "Why use you and Katsuragi like this?\\nWhat's the point?"
msgstr "¿Por qué usarte a ti y a Katsuragi de esta manera?\\n¿Cuál es el punto?"

msgctxt "5796	5906"
msgid "You've already accomplished your goal."
msgstr "Tu objetivo era atraparme, ¿verdad?"

msgctxt "5917	5978"
msgid "I'm done."
msgstr "Entonces, ya lo lograste."

msgctxt "5996	6079"
msgid "Best leave that stone unturned."
msgstr "Lo mejor es ignorar lo demás."

msgctxt "6084	6195"
msgid "I can't do that!\\nNot a chance."
msgstr "¡No puedo hacer eso!\\nNo es una posibilidad."

msgctxt "6207	6336"
msgid "My father's out there somewhere,\\ntelling me to see this thing through."
msgstr "Mi padre está ahí afuera en alguna parte,\\ndiciéndome que eso está mal."

msgctxt "6389	6460"
msgid "It's not over yet."
msgstr "Esto aún no ha terminado."

msgctxt "6507	6595"
msgid "Not until I drag Munakata to his knees."
msgstr "No hasta que capture a Munakata."

msgctxt "6625	6676"
msgid "If you try..."
msgstr "Sabes que eso significaría..."

msgctxt "6691	6782"
msgid "He'll get every last cop\\nin Japan on your ass."
msgstr "Tener a toda la policía\\nde Japón en tu contra."

msgctxt "6783	6834"
msgid "You sure you want that?"
msgstr "¿Seguro que quieres eso?"

msgctxt "6871	7029"
msgid "This is why I took up the badge.\\nTo find the truth about my father."
msgstr "Esa es la razón por la que entré al cuerpo policial.\\nPara encontrar la verdad detrás de la muerte de mi padre."

msgctxt "7030	7090"
msgid "I'll do whatever it takes."
msgstr "Estoy preparado para lo que sea."

msgctxt "7159	7219"
msgid "That so?"
msgstr "Ya veo."

msgctxt "8438	8487"
msgid "Sugiuchi-san!"
msgstr "¡Sugiuchi-san!"

msgctxt "8707	8756"
msgid "Sugiuchi-san!"
msgstr "¡Sugiuchi-san!"

msgctxt "8757	8817"
msgid "Stay with me!"
msgstr "¡Resiste!"

msgctxt "8861	8921"
msgid "Tanimura..."
msgstr "Tanimura..."

msgctxt "8933	8993"
msgid "What is it?"
msgstr "¡¿Qué ocurre?!"

msgctxt "9016	9077"
msgid "It wasn't just me."
msgstr "No soy solo yo."

msgctxt "9094	9154"
msgid "There's another traitor."
msgstr "Hay otro traidor..."

msgctxt "9222	9282"
msgid "Who is it?"
msgstr "¡¿Otro traidor?!"

msgctxt "9329	9375"
msgid "Sugiuchi-san!"
msgstr "¡Sugiuchi-san!"

msgctxt "9376	9436"
msgid "Sugiuchi-san!?"
msgstr "¡¿Sugiuchi-san?!"

msgctxt "9448	9508"
msgid "After all these years..."
msgstr "Después de todos estos años..."

msgctxt "9537	9597"
msgid "Finally..."
msgstr "Finalmente..."

msgctxt "9693	9753"
msgid "Some peace."
msgstr "Puedo estar en paz..."

msgctxt "9884	10032"
msgid "Thank... you."
msgstr "Gracias..."

msgctxt "10126	10186"
msgid "Sugiuchi-san!"
msgstr "¡Sugiuchi-san!"

msgctxt "10205	10265"
msgid "Don't die on me!"
msgstr "¡Abre tus ojos!"

msgctxt "10266	10316"
msgid "Sugiuchi!"
msgstr "¡Sugiuchi!"

msgctxt "10317	10382"
msgid "Sugiuchi!"
msgstr "¡Sugiuchi!"

