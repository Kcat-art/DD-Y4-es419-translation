msgctxt "581	MSG_LV1"
msgid "Training to acquire faster and stronger punches.\n"
"Well-balanced training focused on <Color:7>Power<Color:Default>."
msgstr "Entrenamiento para adquirir golpes más rápidos y más fuertes.\n"
"Entrenamiento bien balanceado enfocado en <Color:7>Poder<Color:Default>."

msgctxt "695	MSG_LV1"
msgid "Training to acquire stronger and more precise kicks.\n"
"Well-balanced training focused on <Color:7>Speed<Color:Default>."
msgstr "Entrenamiento para adquirir patadas más fuertes y precisas.\n"
"Entrenamiento equilibrado centrado en <Color:7>Velocidad<Color:Default>."

msgctxt "813	MSG_LV1"
msgid "Training to refine ground offensive and defensive skills.\n"
"Well-balanced training focused on <Color:7>Technique<Color:Default>."
msgstr "Entrenamiento para perfeccionar las habilidades ofensivas y defensivas terrestres.\n"
"Entrenamiento equilibrado centrado en <Color:7>Técnica<Color:Default>."

msgctxt "940	MSG_LV1"
msgid "Bulk up and create a powerful, athletic body.\n"
"Focuses on <Color:20>Power<Color:Default> alone, so <Color:22>other abilities<Color:Default> may decline."
msgstr "Se acumula y crea un cuerpo potente y atlético.\n"
"se concentra solo en <Color:20>Power<Color:Default>, por lo que <Color:22>otras habilidades<Color:Default> pueden disminuir."

msgctxt "1092	MSG_LV1"
msgid "Run to acquire the basic health needed to sustain training.\n"
"Increases <Color:20>Max Stamina<Color:Default>."
msgstr "Corre para adquirir la salud básica necesaria para mantener el entrenamiento.\n"
"Aumenta <Color:20>Resistencia máxima<Color:Default>."

msgctxt "1200	MSG_LV1"
msgid "Repeated short-distance sprints to train your legs.\n"
"Focuses on <Color:20>Speed<Color:Default> alone, so <Color:22>other abilities<Color:Default> may decline."
msgstr "Sprints repetidos de corta distancia para entrenar las piernas.\n"
"Se centra en <Color:20>Velocidad<Color:Default> solo, así que <Color:22>Otras habilidades<Color:Default> puede disminuir."

msgctxt "1358	MSG_LV1"
msgid "Learn about fighting theory and techniques to win. Focuses\n"
"on <Color:20>Technique<Color:Default> alone, so <Color:22>other abilities<Color:Default> may decline."
msgstr "Aprenda sobre la teoría de la lucha y las técnicas para ganar. Enfoca\n"
"en <Color:20>Técnica<Color:Default> solo, por lo que <Color:22>otras habilidades<Color:Default> pueden disminuir."

msgctxt "1519	MSG_LV1"
msgid "Tune your <Color:20>Mood<Color:Default> after repeated hard workouts.\n"
"Also restores some <Color:7>Stamina<Color:Default>."
msgstr "Mejore su <Color:20>Estado de ánimo<Color:Default> después de hacer ejercicio repetido.\n"
"También restaura algo de <Color:7>Resistencia<Color:Default>."

msgctxt "1641	MSG_LV1"
msgid "Take a rest to rid your body of accumulated fatigue.\n"
"Greatly restores <Color:20>Stamina<Color:Default>."
msgstr "Tome un descanso para librar su cuerpo de fatiga acumulada.\n"
"restaura en gran medida <Color:20>Stamina<Color:Default>."

msgctxt "1745	MSG_LV1"
msgid "Not set."
msgstr "No establecido."

