msgctxt "1120	1240"
msgid "The flower growing in my lonely heart"
msgstr "La flor que crece en mi corazón solitario"

msgctxt "1250	1340"
msgid "blossoms in your light."
msgstr "florece en tu luz."

msgctxt "1350	1420"
msgid "This neon city shines,"
msgstr "Esta ciudad de neón brilla,"

msgctxt "1425	1515"
msgid "bright as our love."
msgstr "brillante como nuestro amor."

msgctxt "1520	1630"
msgid "Now together let's write Kamurocho's purest love song."
msgstr "Ahora juntos escribamos la canción de amor más pura de Kamurocho."

