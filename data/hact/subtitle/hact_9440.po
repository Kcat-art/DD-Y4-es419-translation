msgctxt "1	25"
msgid "Nooo!"
msgstr "¡Nooo!"

msgctxt "32	70"
msgid "I don't wanna die!"
msgstr "¡No quiero morir!"

msgctxt "85	129"
msgid "You did this to yourself, pal."
msgstr "Tú te hiciste eso, amigo."

msgctxt "130	200"
msgid "It's your own damn fault."
msgstr "Todo esto es culpa tuya."

msgctxt "220	255"
msgid "Help!"
msgstr "¡Ayuda!"

msgctxt "280	336"
msgid "Please, somebody help!"
msgstr "¡Por favor, que alguien me ayude!"

msgctxt "336	380"
msgid "One, two...!"
msgstr "¡Uno, dos...!"

msgctxt "405	475"
msgid "Shit, this thing weighs a fuckin' ton!"
msgstr "Mierda, ¡esto pesa una jodida tonelada!"

msgctxt "475	530"
msgid "Keep lifting!"
msgstr "¡Sigue levantándolo!"

msgctxt "575	624"
msgid "No, please!"
msgstr "¡No, por favor!"

msgctxt "675	730"
msgid "C'mon, lift your side!"
msgstr "¡Vamos, ponle ganas!"

msgctxt "735	790"
msgid "You hear me?\\nYou're not even lifting!"
msgstr "¿Me estás oyendo?\\n¡Parece que ni lo estás intentando!"

msgctxt "797	840"
msgid "I'm trying!\\nI'm trying, man!"
msgstr "¡Que sí!\\n¡Que lo estoy intentando, tío!"

msgctxt "875	932"
msgid "Wait, hold it!\\nQuit moving!"
msgstr "Espera, ¡aguanta!\\n¡Deja de moverte!"

msgctxt "933	993"
msgid "Stay still, you idiot!\\nStay still!"
msgstr "¡Quieto, idiota!\\n¡Quédate quieto!"

msgctxt "1233	1321"
msgid "I'm alive!"
msgstr "¡Estoy vivo!"

msgctxt "1505	1555"
msgid "I'm gonna die!"
msgstr "¡Voy a morir!"

msgctxt "1556	1619"
msgid "Noooooo!"
msgstr "¡Nooooo!"

