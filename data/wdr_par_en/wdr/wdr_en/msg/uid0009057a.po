msgctxt "1140"
msgid "Middle-aged Man"
msgstr "Hombre de mediana edad"

msgctxt "1144"
msgid "Tanimura"
msgstr "Tanimura"

msgctxt "1148"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "1152"
msgid "Talk_Info_F"
msgstr "Talk_Info_F"

msgctxt "84_Middle-aged Man"
msgid "[Ah, that you, Ma-chan? You lost or something?]"
msgstr "[Oh, ¿eres tú, Ma-chan? ¿Acaso te perdiste?]"

msgctxt "96_Tanimura"
msgid "[Yeah, I think I am. For some reason, I can never get my bearings around here.]"
msgstr "[Sí, puede que me haya perdido. Nunca logro orientarme en este lugar.]"

msgctxt "108_Middle-aged Man"
msgid "[I know the feeling. I still get lost even though I've lived here dozens of years.]"
msgstr "[Me pasa lo mismo. Yo he vivido aquí durante décadas y todavía me pierdo.]"

msgctxt "120_Middle-aged Man"
msgid "[Anyway, if you're trying to get out of Little Asia, just keep going straight.]"
msgstr "[Sea como sea, si lo que quieres es salir de Pequeña Asia, sigue de frente.]"

msgctxt "132_Tanimura"
msgid "[Got it. Thanks a million.]"
msgstr "[Ah, ya veo. Gracias, me has salvado.]"

msgctxt "144_Middle-aged Man"
msgid "[Don't mention it. We're all family here. Got to help each other out, hm?]"
msgstr "[No hay de qué. Aquí somos una gran familia. Tenemos que ayudarnos entre nosotros, ¿no?]"

