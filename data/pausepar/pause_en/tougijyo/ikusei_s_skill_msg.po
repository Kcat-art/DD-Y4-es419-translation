msgctxt "335	MSG"
msgid "A simple yet powerful body slam.\n"
"Power: Low"
msgstr "Un golpe al cuerpo simple pero poderoso.\n"
"Potencia: Baja"

msgctxt "379	MSG"
msgid "Move quickly to the rear of the opponent to perform a suplex move.\n"
"Power: Low"
msgstr "Muévete rápidamente hacia la parte trasera del oponente para realizar un movimiento suplex.\n"
"Potencia: baja"

msgctxt "457	MSG"
msgid "Uses brute strength to toss the opponent far away.\n"
"Power: Medium"
msgstr "Usa la fuerza bruta para lanzar al oponente lejos.\n"
"Potencia: Media"

msgctxt "522	MSG"
msgid "A powerful standing attack using knee and leg kick combos.\n"
"Power: Medium"
msgstr "Un poderoso ataque de pie con combos de patadas de rodilla y pierna.\n"
"Potencia: Media"

msgctxt "595	MSG"
msgid "Stomp an enemy with brute leg strength.\n"
"Power: High"
msgstr "Pisotea a un enemigo con fuerza bruta en las piernas.\n"
"Potencia: Alta"

msgctxt "647	MSG"
msgid "Punch the face of a downed enemy without mercy.\n"
"Power: High ~Can only be used when opponent is down."
msgstr "Golpea la cara de un enemigo abatido sin piedad.\n"
"Potencia: Alta ~Solo se puede usar cuando el oponente está caído."

msgctxt "748	MSG"
msgid "Launch a downed enemy into the air for a clothesline.\n"
"Power: Super ~Can only be used when opponent is down."
msgstr "Lanza a un enemigo caído al aire para lanzarle un tendedero.\n"
"Poder: Súper ~Solo se puede usar cuando el oponente está caído."

msgctxt "856	MSG"
msgid "A merciless attack that slams an enemy's face into a fence.\n"
"Power: Medium ~Can only be used when grabbing an opponent."
msgstr "Un ataque despiadado que golpea la cara de un enemigo contra una valla.\n"
"Poder: Medio ~ Solo se puede usar cuando se agarra a un oponente."

msgctxt "975	MSG"
msgid "Grab and power slam an enemy into the ground.\n"
"Power: Super ~Can only be used while grabbing an opponent."
msgstr "Agarra y golpea con fuerza a un enemigo contra el suelo.\n"
"Poder: Super ~ Solo se puede usar mientras agarra a un oponente."

msgctxt "1080	MSG"
msgid "An extremely powerful move that knocks the enemy face down by leveraging your entire body strength.\n"
"Power: High"
msgstr "Un movimiento extremadamente poderoso que derriba al enemigo boca abajo aprovechando la fuerza de todo tu cuerpo.\n"
"Potencia: Alta"

