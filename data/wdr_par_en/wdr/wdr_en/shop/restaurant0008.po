msgctxt "300"
msgid "Quit"
msgstr "Salir"

msgctxt "305"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "323"
msgid "Order"
msgstr "Pagar"

msgctxt "329"
msgid "Order the currently selected item."
msgstr "Pagar el objeto seleccionado actualmente."

msgctxt "364"
msgid "(I haven't picked anything.)"
msgstr "(No he escogido nada)"

msgctxt "393"
msgid "(I'm short on cash.)"
msgstr "(Me hace falta dinero)"

msgctxt "414"
msgid "Very well, sir."
msgstr "Muy bien, señor."

msgctxt "430"
msgid "(I can't eat anymore...)"
msgstr "(No puedo comer más...)"

msgctxt "474"
msgid "Spaghetti made with eggplant, tomato sauce, and \n"
"savory bacon imported from Denmark."
msgstr "Espaguetis elaborados con berenjena, salsa de tomate y\n"
"sabroso tocino importado de Dinamarca."

msgctxt "559"
msgid "Made with succulent mini shrimp and rich tomato \n"
"cream sauce. A delightful and savory delicacy."
msgstr "Elaborado con suculentos mini camarones y una rica salsa\n"
"de crema de tomate. Un manjar delicioso y sabroso."

msgctxt "655"
msgid "Carefully simmered, rich meat sauce on our specially \n"
"prepared spaghetti noodles."
msgstr "Rica salsa de carne cuidadosamente condimentada\n"
"sobre nuestros espaguetis especialmente preparados."

msgctxt "737"
msgid "This delicious spaghetti dish is made with authentic \n"
"spicy cod roe from Hakata."
msgstr "Este delicioso plato de espaguetis se elabora con\n"
"auténticas huevas de pescado picantes de Hakata."

msgctxt "818"
msgid "This is our Rich Egg Carbonara, with a tasty soft-boiled\n"
"egg on top and creamy sauce."
msgstr "Este es nuestro Huevo a la Carbonara, con un sabroso\n"
"huevo pasado por agua por encima y salsa cremosa."

