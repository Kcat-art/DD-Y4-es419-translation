msgctxt "600"
msgid "Welcome to the baccarat table."
msgstr "Bienvenido a la mesa de baccarat."

msgctxt "612"
msgid "Let's begin."
msgstr "Comencemos."

msgctxt "624"
msgid "We look forward to seeing you again soon."
msgstr "Esperamos volver a verte pronto."

msgctxt "636"
msgid "You seem to be short on chips. Please come visit us again soon."
msgstr "Parece que te faltan fichas. Vuelva a visitarnos pronto."

msgctxt "648"
msgid "Please select what you will bet on:\\r\n"
"the Player, the Banker, or a tie."
msgstr "Por favor, elige en qué quieres apostar:\\r\n"
"al Jugador, al Banquero o al empate."

msgctxt "660"
msgid "Select a wager between the minimum and maximum betting limit."
msgstr "Elige una apuesta que esté entre el mínimo y el máximo establecido."

msgctxt "672"
msgid "I will now deal the cards."
msgstr "Ahora repartiré las cartas."

msgctxt "684"
msgid "I'll reveal the Player's first card."
msgstr "Voy a revelar la primera carta del Jugador."

msgctxt "696"
msgid "I'll reveal the Player's second card."
msgstr "Voy a revelar la segunda carta del Jugador."

msgctxt "708"
msgid "The Player stands with 6."
msgstr "El Jugador se planta con 6."

msgctxt "720"
msgid "The Player stands with 7."
msgstr "El Jugador se planta con 7."

msgctxt "732"
msgid "The Player has a natural 8."
msgstr "El Jugador tiene un 8 natural."

msgctxt "744"
msgid "The Player has a natural 9."
msgstr "El Jugador tiene un 9 natural."

msgctxt "756"
msgid "A third card will be dealt if the Banker does\\r\n"
"not have an 8 or a 9."
msgstr "Se repartirá una tercera carta si el Banquero\\r\n"
"no tiene un 8 o un 9."

msgctxt "768"
msgid "I'll reveal the Banker's first card."
msgstr "Voy a revelar la primera carta del Banco."

msgctxt "780"
msgid "I'll reveal the Banker's second card."
msgstr "Voy a revelar la segunda carta del Banquero."

msgctxt "792"
msgid "The Banker stands with 6."
msgstr "El Banquero se planta con 6."

msgctxt "804"
msgid "The Banker stands with 6.\\r\n"
"I'll deal a third card to the Player."
msgstr "El Banquero se planta con 6.\\r\n"
"Repartiré una tercera carta al Jugador."

msgctxt "816"
msgid "The Banker stands with 7."
msgstr "El Banquero se planta con 7."

msgctxt "828"
msgid "The Banker stands with 7.\\r\n"
"I'll deal a third card to the Player."
msgstr "El Banquero se planta con 7.\\r\n"
"Repartiré una tercera carta al Jugador."

msgctxt "840"
msgid "The Banker has a natural 8."
msgstr "El Banquero tiene un 8 natural."

msgctxt "852"
msgid "The Banker has a natural 9."
msgstr "El Banquero tiene un 9 natural."

msgctxt "864"
msgid "A third card will be dealt to the Banker, depending on the Player's third card."
msgstr "Se repartirá una tercera carta al Banquero, dependiendo de la tercera carta del Jugador."

msgctxt "876"
msgid "The Player stands.\\r\n"
"I'll deal a third card to the Banker."
msgstr "El Jugador se planta.\\r\n"
"Repartiré una tercera carta al Banquero."

msgctxt "888"
msgid "I'll reveal the Player's third card."
msgstr ""

msgctxt "900"
msgid "Due to the outcome, the Banker will not be dealt a third card."
msgstr "Debido al resultado, al Banquero no se le repartirá una tercera carta."

msgctxt "912"
msgid "Due to the outcome, the Banker will be dealt a third card."
msgstr "Debido al resultado, se repartirá una tercera carta al Banquero."

msgctxt "924"
msgid "I'll reveal the Banker's third card."
msgstr "Voy a revelar la tercera carta del Banquero."

msgctxt "936"
msgid "The Player wins."
msgstr ""

msgctxt "948"
msgid "The Banker wins."
msgstr "El Banquero gana."

msgctxt "960"
msgid "It's a tie."
msgstr ""

msgctxt "972"
msgid "Congratulations."
msgstr ""

msgctxt "984"
msgid "That's too bad."
msgstr "Eso es... una pena."

msgctxt "996"
msgid "Would you like to continue?"
msgstr ""

msgctxt "1008"
msgid "Here you are."
msgstr "Permítame."

msgctxt "1020"
msgid "The deck is running low, so I'll shuffle."
msgstr ""

