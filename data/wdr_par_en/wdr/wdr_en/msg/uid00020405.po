msgctxt "116_The Florist"
msgid "I take it you're ready to enter the coliseum?"
msgstr "Veo que estás listo para entrar al Coliseo, ¿no?"

msgctxt "128_Saejima"
msgid "Not yet. I'll get back to ya."
msgstr "Todavía no. Ya te avisaré."

msgctxt "140_The Florist"
msgid "All right. Let me know when you're prepared."
msgstr "Bueno. Avísame cuando estés listo."

msgctxt "152_Saejima"
msgid "Yeah, I'm ready."
msgstr "Sí, estoy listo."

msgctxt "164_The Florist"
msgid "All right, then. Let's go."
msgstr "Genial. Vamos."

msgctxt "188_Saejima"
msgid "To tell ya the truth... I'm broke. No money to prep with."
msgstr "Si te digo la verdad... estoy arruinado. No tengo un duro para prepararme."

msgctxt "200_The Florist"
msgid "......"
msgstr "......"

msgctxt "212_The Florist"
msgid "......"
msgstr "......"

msgctxt "224_The Florist"
msgid "I probably should've seen this coming."
msgstr "Debí habérmelo imaginado."

msgctxt "236_The Florist"
msgid "Since you're so strapped for cash, take this.\\r\n"\n"Consider it an advance on your prize money."
msgstr "Ya que estás tan corto de dinero, toma esto.\\r\n"\n"Considéralo un adelanto a lo que te vas a llevar de premio."

msgctxt "272_The Florist"
msgid "Now, hurry up and get ready to earn that back."
msgstr "Ahora date prisa y prepárate para ganarte ese dinero de vuelta."

msgctxt "284_The Florist"
msgid "Not yet."
msgstr "Todavía no."

msgctxt "296_The Florist"
msgid "I'm ready."
msgstr "Estoy listo."

msgctxt "308_The Florist"
msgid "I'm broke."
msgstr "Estoy sin un duro."

