msgctxt "1168"
msgid "Tanimura"
msgstr "Tanimura"

msgctxt "1172"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "1176"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "128_Tanimura"
msgid "(Here it is... Purple Moon. Am I ready to do this?)"
msgstr "(Aqui está... Purple Moon. ¿Estoy listo?)"

msgctxt "140_Tanimura"
msgid "(Maybe I should wait and see what happens. Give myself a little mental prep.)"
msgstr "(Tal vez debería esperar y ver qué pasa. Y darme un poco de \\r tiempo para prepararme.)"

msgctxt "152_Tanimura"
msgid "(But I can't just hang around forever. If I don't get in there, Fay might lose her life.)"
msgstr "(Pero no me puedo quedar de brazos cruzados para siempre. \\r Si no entro ahí, Fay puede perder la vida.)"

msgctxt "164_Tanimura"
msgid "(All right, I'm going in. Isawa's strapped, so I need to be careful how I approach him.)"
msgstr "(Muy bien, allá voy. Isawa está armado, así que debo tener \\r cuidado al acercarme.)"

msgctxt "188_Tanimura"
msgid "Hang Back"
msgstr "Esperar"

msgctxt "200_Tanimura"
msgid "Hurry Inside"
msgstr "Correr Adentro"

