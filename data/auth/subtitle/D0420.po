msgctxt "190	274"
msgid "Are you going now, Uncle Kaz?"
msgstr "¿Te vas ahora, Tío Kaz?"

msgctxt "309	369"
msgid "Yeah."
msgstr "Sí."

msgctxt "371	493"
msgid "I might be a while.\\nThink you'll be okay?"
msgstr "Es posible que tome un poco tiempo.\\n¿Estarás bien?"

msgctxt "506	579"
msgid "Mhm. Take your time."
msgstr "Sí, te estaré esperando."

msgctxt "597	662"
msgid "All right. I'll be back."
msgstr "Bien. Volveré pronto."

msgctxt "2823	2887"
msgid "Welcome back, sir!"
msgstr "¡Sea bienvenido, señor!"

msgctxt "3714	3898"
msgid "This clan is the only proof\\nwe ever walked this earth."
msgstr "El Clan Tojo\\nes la prueba de que estamos vivos."

msgctxt "3864	3916"
msgid "Yup."
msgstr "Sí."

msgctxt "3917	3992"
msgid "Serve it well."
msgstr "Cuento con tu ayuda."

msgctxt "4017	4102"
msgid "You and the whole Saejima Family."
msgstr "De ti y de toda la Familia Saejima."

msgctxt "4209	4272"
msgid "Ya can count on it."
msgstr "Puedes contar con ello."

msgctxt "4335	4748"
msgid "<Italic>Tojo Clan, Saejima Family\\nPatriarchal Inauguration</Italic>"
msgstr "<Italic>Clan Tojo, Familia Saejima\\nInauguración Patriarcal</Italic>"

msgctxt "5164	5297"
msgid "Come on.\\nWe have work to do."
msgstr "Bien.\\nVamos."

