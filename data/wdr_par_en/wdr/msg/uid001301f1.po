msgid "Officer"
msgstr "Oficial"

msgctxt "992"
msgid "Suspicious Man"
msgstr "Hombre sospechoso"

msgctxt "84_Tanimura"
msgid "Is there a problem here?"
msgstr "¿Hay algún problema aquí?"

msgctxt "96_Officer"
msgid "Yes, there is. For some reason, he won't let me see what's in his bag."
msgstr "Sí, lo hay. Por algún motivo, no me deja ver qué hay en su bolsa."

msgctxt "108_Suspicious Man"
msgid "I told you, there's nothing inside!"
msgstr "¡Ya te lo dije, no hay nada dentro!"

msgctxt "120_Tanimura"
msgid "Hey! Now hold up!"
msgstr "¡Hey! ¡Espera!"

