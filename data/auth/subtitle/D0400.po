msgctxt "495	655"
msgid "Hm? Ah, my bad, ma'am!\\nCome in, come in."
msgstr "Oh, lo siento.\\nEras un cliente."

msgctxt "669	727"
msgid "Please, take a seat."
msgstr "Por favor, tome asiento."

msgctxt "741	800"
msgid "Sorry it's not the cleanest."
msgstr "¡Oh, lo siento!"

msgctxt "811	888"
msgid "My secretary left a while back, so..."
msgstr "Hace mucho que no tengo secretaria."

msgctxt "898	1032"
msgid "Sad, isn't it? I'm practically\\nuseless on my own."
msgstr "Esto es horrible.\\nSin ella realmente parece que soy un inútil."

msgctxt "1048	1214"
msgid "I'm surprised you've even remembered\\nto breathe while I'm gone, Chief."
msgstr "Realmente me sorprende que no\\npuedas hacer nada sin mí, Jefe."

msgctxt "1219	1419"
msgid "You're..."
msgstr "Tú eres..."

msgctxt "1437	1528"
msgid "I'm back, Akiyama-san."
msgstr "He vuelto, Akiyama-san."

msgctxt "1542	1605"
msgid "Hana-chan?"
msgstr "¿Hana-chan?"

msgctxt "1719	1853"
msgid "What the heck happened to you?\\nYou're skinny as a rail..."
msgstr "¿Qué te pasó Hana-chan?\\nHas perdido mucho peso..."

msgctxt "1898	1994"
msgid "I guess you're not the only one\\nwho's useless on their own."
msgstr "Parece que también soy inútil\\nsi el Jefe no está a mi lado."

msgctxt "2006	2092"
msgid "I've barely eaten a thing since I left."
msgstr "Apenas he comido desde que me fui."

msgctxt "2211	2407"
msgid "So Chief... What would you say to\\ngiving me my old job back?"
msgstr "Entonces, Jefe, ¿puedo ser contratada\\npor esta oficina una vez más?"

msgctxt "2469	2510"
msgid "Hana-chan."
msgstr "Hana-chan."

msgctxt "3052	3087"
msgid "Oh, hold on a sec."
msgstr "Oh, cierto."

msgctxt "3103	3129"
msgid "Huh?"
msgstr "Uh, ¿y eso?"

msgctxt "3144	3226"
msgid "I've got some spare yakiniku bentos\\nfrom over at Kanrai. You want one?"
msgstr "Tengo algunos bentos yakiniku guardados\\nde Kanrai. ¿Quieres comer uno?"

msgctxt "3235	3254"
msgid "What!?"
msgstr "¡¿Qué?!"

msgctxt "3262	3379"
msgid "I thought you'd be back any time\\nso I kept stocking up on them."
msgstr "¡Pensé que volverías pronto,\\nasí que los compré para ti!"

msgctxt "3383	3476"
msgid "You're so skinny, you must be\\nhungry enough to eat a horse!"
msgstr "Estás muy delgada, de seguro\\ntienes mucha hambre, ¿verdad?"

msgctxt "3481	3674"
msgid "Chief! Would it kill you to stop for\\njust one second and tell me how pretty I am!?"
msgstr "¡Jefe! ¡Oh, vamos! Estaría bien que dijeras\\ncosas como, te has vuelto más hermosa..."

msgctxt "3675	3719"
msgid "Oh, yeah you look great."
msgstr "Ah, sí. Luces hermosa."

msgctxt "3721	3848"
msgid "Ugh! Say it like you mean it!"
msgstr "¡Así no! ¡Suena como si te forzaras a ello!"

msgctxt "3857	4001"
msgid "What happened to my poor client registry!?\\nIt looks like a tornado struck down in here!"
msgstr "¡¿Qué le pasó a mi registro de clientes?!\\n¡¿Por qué está tan desordenado?!"

msgctxt "4004	4060"
msgid "Huh, maybe it did."
msgstr "Oh, me pregunto por qué."

