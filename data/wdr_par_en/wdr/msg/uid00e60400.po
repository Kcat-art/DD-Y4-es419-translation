msgctxt "2552"
msgid "Tanimura"
msgstr "Tanimura"

msgctxt "2556"
msgid "Tsugawa"
msgstr "Tsugawa"

msgctxt "2560"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "2564"
msgid "Talk_Quest"
msgstr "Talk_Quest"

msgctxt "2568"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "2572"
msgid "Talk_Away"
msgstr "Talk_Away"

msgctxt "56_Tanimura"
msgid "You know the guy they call Bridge, right?"
msgstr "Conoces al tipo al que llaman Bridge, ¿verdad?"

msgctxt "68_Tsugawa"
msgid "...You're shit outta luck. I don't know a damn thing."
msgstr "...Estás jodido. No sé un carajo."

msgctxt "80_Tanimura"
msgid "Okay, let's make a deal."
msgstr "Está bien, hagamos un trato."

msgctxt "92_Tsugawa"
msgid "Huh?"
msgstr "Uh, ¿y eso?"

msgctxt "104_Tanimura"
msgid "Give up Bridge's identity and promise to never get involved with crime again, and I'll forget about everything you've done."
msgstr "Dame la identidad de Bridge y jura no volver a involucrarte en el crimen, y me olvidaré de todo lo que has hecho."

msgctxt "116_Tsugawa"
msgid "......"
msgstr "......"

msgctxt "128_Tanimura"
msgid "Or you can rot in a jail cell. Your choice."
msgstr "O puedes pudrirte en una celda. Tú eliges."

msgctxt "140_Tsugawa"
msgid "...Will you promise you'll never tell anybody I talked?"
msgstr "... ¿Prometes no decirle nunca a nadie que hablé?"

msgctxt "152_Tanimura"
msgid "Sure."
msgstr "Claro."

msgctxt "164_Tsugawa"
msgid "The real name of the man they call Bridge is Yuji Katsuura."
msgstr "Su verdadero nombre es Yuji Katsuura."

msgctxt "176_Tanimura"
msgid "Yuji Katsuura..."
msgstr "Yuji Katsuura..."

msgctxt "188_Tsugawa"
msgid "He's the chairman of the Asian Women's Friendship Association."
msgstr "Es el presidente de la Asociación de Amistad de las Mujeres Asiáticas."

msgctxt "200_Tanimura"
msgid "\"Friendship,\" huh? So they use that as a front to hide the terrible things they really do..."
msgstr "\"Amistad\", ¿eh? Así que usan eso como una fachada para ocultar las cosas terribles que realmente hacen..."

msgctxt "212_Tanimura"
msgid "If you value your life, you should run."
msgstr "Si valoras tu vida, más te vale que salgas corriendo."

