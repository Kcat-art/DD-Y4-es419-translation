msgctxt "401	511"
msgid "Not such a big man now, are you?"
msgstr "No te ves tan intimidante ahora, ¿eh?"

msgctxt "633	708"
msgid "Don't give me that look."
msgstr "Vamos, no me gusta nada esa mirada."

msgctxt "709	787"
msgid "You want more!?"
msgstr "¡¿Es que acaso buscas más?!"

msgctxt "961	1024"
msgid "Hey, Saito."
msgstr "Ey, Saito."

msgctxt "1043	1112"
msgid "Listen to me, Saito."
msgstr "Oye, Saito, escúchame."

msgctxt "1114	1174"
msgid "Saito!"
msgstr "¡Saito, basta!"

msgctxt "1195	1255"
msgid "That's enough."
msgstr "Ya fue suficiente."

msgctxt "1369	1443"
msgid "Goddamn. He's a freak of nature!"
msgstr "¡Mierda! ¿De qué diablos está hecho este tipo?"

msgctxt "1446	1521"
msgid "Not one who's scheduled for execution today."
msgstr "Su ejecución no está programada para hoy."

msgctxt "1530	1580"
msgid "Lay off him."
msgstr "No lo mates."

msgctxt "1675	1774"
msgid "What for? Who cares if he lives or dies?"
msgstr "¿Y por qué? ¿A alguien le importa su vida siquiera?"

msgctxt "1775	1840"
msgid "Nobody's gonna miss this human trash."
msgstr "No. Nadie va a lamentarse por esta escoria."

msgctxt "1841	1946"
msgid "That would make three prisoners\\nwho have died under your watch."
msgstr "Así como con los tres que llevas\\nen el mes,¿Verdad?"

msgctxt "1939	1999"
msgid "You can't keep doing this."
msgstr "Debes controlarte."

msgctxt "2022	2082"
msgid "Fuck off!"
msgstr "¡Joder!"

msgctxt "2090	2162"
msgid "It's your lucky day, freak."
msgstr "Parece que la suerte te acompaña."

msgctxt "2656	2755"
msgid "You've got a visitor."
msgstr "Hay alguien que vino a verte."

msgctxt "3169	3259"
msgid "This little favor'll cost you."
msgstr "El favor no te saldrá barato."

msgctxt "3285	3467"
msgid "I got friends on the outside.\\nSure they'd be glad to slip a cool mil into your account."
msgstr "Mis amigos de fuera no tendrán\\nproblemas en transferir un par de miles a tu cuenta."

msgctxt "3468	3528"
msgid "That enough for you?"
msgstr "¿Te parece suficiente?"

msgctxt "3551	3616"
msgid "I'll take it."
msgstr "Más que suficiente, de hecho."

msgctxt "3610	3765"
msgid "I was just thinking of getting\\na nice new car, too. Thanks for the help."
msgstr "Justamente pensaba en comprarme\\nun nuevo carro. Agradezco la ayuda."

msgctxt "3815	3887"
msgid "Now, clock's ticking."
msgstr "Pero no te quedes por mucho tiempo."

msgctxt "3892	3952"
msgid "Tick, tock."
msgstr "Tick, tock."

