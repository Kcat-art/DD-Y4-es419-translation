msgctxt "493\t546"
msgid "Florist!"
msgstr "¡Florista!"

msgctxt "634\t715"
msgid "Kinda late, aren't you?"
msgstr "Llegas tarde."

msgctxt "748\t808"
msgid "Kiryu."
msgstr "Kiryu."

msgctxt "1035\t1118"
msgid "What in the world...?"
msgstr "¿Qué fue lo que pasó aquí?"

msgctxt "1296\t1350"
msgid "Where's Yasuko-san?"
msgstr "¿Dónde está Yasuko-san?"

msgctxt "1360\t1419"
msgid "They nabbed her."
msgstr "Ellos se la llevaron."

msgctxt "1428\t1474"
msgid "Who's \"they\"?"
msgstr "¿Quiénes son \"ellos\"?"

msgctxt "1495\t1656"
msgid "Katsuragi. Him...\\nand some punk named Kido."
msgstr "Katsuragi. Él...\\ny un tal chico llamado Kido."

msgctxt "1791\t1828"
msgid "Dammit."
msgstr "¡Maldita sea!"

msgctxt "1844\t1909"
msgid "The hell's going on here?"
msgstr "¿Qué está pasando aquí?"

