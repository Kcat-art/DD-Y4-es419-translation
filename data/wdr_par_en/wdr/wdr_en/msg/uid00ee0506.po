msgctxt "2920"
msgid "Akiyama"
msgstr "Akiyama"

msgctxt "2924"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "2928"
msgid "Lily"
msgstr "Lily"

msgctxt "2932"
msgid "Talk_Ojigi"
msgstr "Talk_Ojigi"

msgctxt "2936"
msgid "Putting Together a Stylish Outfit"
msgstr "Combinar un atuendo elegante"

msgctxt "104_Akiyama"
msgid "Okay. Let's get started."
msgstr "Bien. Empecemos."

msgctxt "116_Lily"
msgid "Yes, let's."
msgstr "Sí, vamos."

msgctxt "128_Akiyama"
msgid "First, let's get you changed into an outfit that brings out the best of your natural beauty. Don't worry, I guarantee you'll look great."
msgstr "Primero, vamos a cambiarte a un atuendo que resalte lo mejor de tu belleza natural. No te preocupes, te garantizo que te verás genial."

msgctxt "152_Akiyama"
msgid "Looking good."
msgstr "Te ves bien."

msgctxt "164_Lily"
msgid "You think so?"
msgstr "¿De verdad?"

msgctxt "176_Akiyama"
msgid "Of course. Now go get 'em."
msgstr "Claro. Ahora sal ahí a dar lo mejor de ti."

msgctxt "188_Lily"
msgid "Okay... I'll do my best."
msgstr "Sí, haré mi mejor esfuerzo."

msgctxt "248_Akiyama"
msgid "Get a feel for your customers' preferences by walking around the club, then return to the break room and coordinate your hostess to fit their ideal image."
msgstr "Familiarízate con las preferencias de los clientes caminando por el club, luego regresa a la sala de descanso y coordina a tu hostess para que se ajuste a su imagen ideal."

msgctxt "260_Akiyama"
msgid "(Guess I should take a stroll around the club.)"
msgstr "(Creo que debería revisar un poco el club)."

msgctxt "284_Akiyama"
msgid "I've taught you everything I know. It's all up to you now."
msgstr "Te enseñé todo lo que sé. Ahora todo depende de ti."

msgctxt "296_Lily"
msgid "Okay..."
msgstr "Bueno..."

msgctxt "308_Akiyama"
msgid "There's still some time until the club closes. Good luck."
msgstr "Todavía queda algo de tiempo hasta que el club cierre. Buena suerte."

msgctxt "320_Lily"
msgid "Thank you."
msgstr "Gracias."

msgctxt "332_Akiyama"
msgid "The manager will contact me once he's calculated your sales. We just need to wait until then."
msgstr "El gerente se pondrá en contacto conmigo una vez que haya calculado tus ventas. Solo tenemos que esperar hasta entonces."

msgctxt "344_Lily"
msgid "Okay."
msgstr "Está bien."

