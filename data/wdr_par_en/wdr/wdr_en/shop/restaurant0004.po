msgctxt "268"
msgid "Quit"
msgstr "Salir"

msgctxt "273"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "291"
msgid "Order"
msgstr "Pagar"

msgctxt "297"
msgid "Order the currently selected item."
msgstr "Pagar el objeto seleccionado actualmente."

msgctxt "332"
msgid "(I haven't picked anything.)"
msgstr "(No he escogido nada)"

msgctxt "361"
msgid "(I'm short on cash.)"
msgstr "(Me hace falta dinero)"

msgctxt "382"
msgid "Have you decided what you want?"
msgstr "¿Ya decidió que va a querer?"

msgctxt "414"
msgid "(I can't eat anymore...)"
msgstr "(No puedo comer más...)"

msgctxt "439"
msgid "Tofu handmade from the finest organic soybeans.\n"
"Savor that rich, natural flavor."
msgstr "Tofu hecho a mano con la mejor soja orgánica.\n"
"Saborea ese rico, sabor natural."

msgctxt "520"
msgid "One of our most popular items. The contrast of crispy\n"
"skin and juicy meat is just to die for."
msgstr "Uno de nuestros artículos más populares. El contraste de la piel crujiente\n"
"con la carne jugosa está para morirse."

msgctxt "614"
msgid "This fluffy omelet has the rich flavor of grated yam\n"
"and fermented soybeans, finished with a fresh sauce."
msgstr "Este omelet esponjoso tiene el rico sabor de ñame rallado\n"
"y soja fermentada, acabado con una salsa fresca."

msgctxt "720"
msgid "Fresh Hokkaido mackerel slow-grilled to preserve its\n"
"true flavor."
msgstr "Mackerel fresco de Hokkaido asado lentamente para\n"
"preservar su verdadero sabor."

