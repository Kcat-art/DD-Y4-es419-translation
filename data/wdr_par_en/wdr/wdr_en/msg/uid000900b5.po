msgctxt "68_Tanimura"
msgid "Is that you, Nui?"
msgstr "¿Eres tú, Nui?"

msgctxt "80_Nui"
msgid "Uh-oh!"
msgstr "¡Oh-oh!"

msgctxt "104_Tanimura"
msgid "Wait!"
msgstr "¡Espera!"

msgctxt "116_Tanimura"
msgid "(Man, that kid's fast! I doubt he'll leave Little Asia, but there are so many places he could hide around here...)"
msgstr "(¡Demonios, ese niño es rápido! Dudo que se vaya de Pequeña Asia, pero hay tantos lugares donde podría esconderse por aquí...)"

msgctxt "128_Find Nui"
msgid "When you find out where Nui is hiding, press <Action:Button_R3@Adventure> to switch to a first-person perspective. Just looking at him will make him come out of hiding."
msgstr "Cuando encuentres dónde se esconde Nui, presiona <Action:Button_R3@Adventure> para cambiar a una perspectiva en primera persona. Solo con mirarlo lo hará salir de su escondite."

