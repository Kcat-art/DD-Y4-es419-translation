msgctxt "116_Man"
msgid "Care to contribute to my fundraising efforts? All for the benefit of my empty wallet."
msgstr "¿Te gustaría contribuir a mi campaña de recaudación de fondos? Todo es para el beneficio de mi billetera vacía."

msgctxt "128_Man"
msgid "Did I mention it's not exactly voluntary? Pay up or I'll kick your ass!"
msgstr "¿Mencioné que no es exactamente opcional? ¡Paga o te voy a partir la cara!"

msgctxt "152_Man"
msgid "Ow, that hurt. Sorry I got carried away."
msgstr "¡Ay, eso dolió! Perdón por descontrolarme."

msgctxt "164_Man"
msgid "This is for you."
msgstr "Esto es para ti."

msgctxt "176_Man"
msgid "You got an extreme %s."
msgstr "Obtuviste un %s."

msgctxt "212_Man"
msgid "I won't do it again..."
msgstr "No lo volveré a hacer..."

