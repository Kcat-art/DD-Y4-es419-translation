msgctxt "180	309"
msgid "What's wrong, bro?\\nNo gas left in the tank?"
msgstr "¿Qué pasa, kyoudai?\\n¿Ya te rindes?"

msgctxt "365	459"
msgid "You goin' down that easy!?"
msgstr "¡¿Vas a caer así de fácil?!"

msgctxt "1041	1138"
msgid "Hey, bro..."
msgstr "Hey, kyoudai..."

msgctxt "1143	1203"
msgid "Yeah?"
msgstr "¿Sí?"

msgctxt "1212	1339"
msgid "You n' me...\\nWe've changed."
msgstr "Tú y yo...\\nHemos cambiado."

msgctxt "1423	1483"
msgid "Ya don't say."
msgstr "¿De verdad?"

msgctxt "1624	1716"
msgid "We used to burn so damn bright."
msgstr "Solíamos brillar muchísimo en el pasado."

msgctxt "1757	1901"
msgid "But now, all these years..."
msgstr "Pero antes de darme cuenta, tú yo..."

msgctxt "1910	1992"
msgid "It's turned us into a pair o' farts."
msgstr "Nos convertimos en un par de viejos."

msgctxt "2116	2243"
msgid "Least now ya can keep up the Kansai act."
msgstr "Al menos ahora puedes mantener tu dialecto Kansai."

msgctxt "2328	2426"
msgid "What, you startin' shit again?"
msgstr "¿Qué? ¿Vas a empezar a joder con eso de nuevo?"

msgctxt "2456	2516"
msgid "Relax."
msgstr "No, tranquilo."

msgctxt "2526	2709"
msgid "Gotta say, though.\\nThis ain't how I remember ya."
msgstr "Sin embargo, tengo que decir que...\\nNo es así como te recuerdo."

msgctxt "2710	2818"
msgid "You used to be a hundred times stronger than that."
msgstr "Solías ser cien veces más fuerte que eso."

msgctxt "2878	2960"
msgid "'Sup with that shit on your eye, anyway?"
msgstr "¿Por qué llevas ese raro parche en el ojo?"

msgctxt "2965	3031"
msgid "That's what's holdin' ya back?"
msgstr "¿Acaso eso no te deja pelear bien?"

msgctxt "3041	3109"
msgid "Ain't got nothin' to do with it."
msgstr "No tiene nada que ver con eso."

msgctxt "3143	3297"
msgid "Been carryin' this burden 25 years now."
msgstr "He estado llevando esta carga 25 años."

msgctxt "3300	3350"
msgid "Since '85?"
msgstr "¿25 años?"

msgctxt "3351	3415"
msgid "Damn straight."
msgstr "Así es."

msgctxt "3420	3541"
msgid "The same day old man Sasai n' I lost you..."
msgstr "El mismo día que el viejo Sasai y yo te perdimos..."

msgctxt "3560	3649"
msgid "That's when my peeper went, too."
msgstr "Fue también el día que perdí mi ojo izquierdo."

msgctxt "3663	3723"
msgid "What?"
msgstr "¿Qué quieres decir?"

msgctxt "4083	4195"
msgid "So, yeah.\\nThat's the thick of it."
msgstr "Bueno.\\nAsí es como son las cosas."

msgctxt "4222	4457"
msgid "Dunno, seein' 20/20 prolly <Italic>did</Italic> help.\\nDon't feel half as tough just seein' 20, y'know?"
msgstr "Tal vez me he vuelto más débil,\\npero no creo que haya sido por culpa de un ojo."

msgctxt "4467	4624"
msgid "But hey, wouldn't be fair if\\nI didn't have a teensy handicap!"
msgstr "Pero imagina que no tuviera algún\\ntipo de debilidad, no sería justo."

msgctxt "4679	4739"
msgid "Brother."
msgstr "Kyoudai."

msgctxt "4775	4835"
msgid "That eye o' yours."
msgstr "Ese ojo tuyo."

msgctxt "4860	4938"
msgid "Ya lose it on my account?"
msgstr "¿Tiene que ver con el incidente?"

msgctxt "5023	5172"
msgid "You get mixed up in somethin'?\\nIs that why ya didn't show?"
msgstr "¡¿Tu ojo tiene que ver con la razón\\nde que no aparecieras ese día?!"

msgctxt "5232	5299"
msgid "Tell me the truth, bro."
msgstr "Dime la verdad, kyoudai."

msgctxt "5321	5418"
msgid "That day, back in '85..."
msgstr "Ese día, en ese momento."

msgctxt "5435	5525"
msgid "What kept ya from comin' to help?"
msgstr "¿Qué fue lo que te impidió venir?"

msgctxt "5872	5973"
msgid "That whole Ueno Seiwa hit..."
msgstr "Todo ese plan contra Ueno Seiwa..."

msgctxt "6029	6163"
msgid "Far as I can tell,\\nit was all just a setup."
msgstr "Por lo que yo puedo decir,\\nfue todo un montaje."

msgctxt "6171	6218"
msgid "Ya ain't sure?"
msgstr "¿Seguro?"

msgctxt "6219	6279"
msgid "Not 100 percent."
msgstr "No estoy completamente seguro."

msgctxt "6280	6384"
msgid "No way of findin' out now, though."
msgstr "Y no hay manera de descubrirlo."

msgctxt "6388	6431"
msgid "Why's that?"
msgstr "¿Por qué?"

msgctxt "6469	6554"
msgid "The guy I'm bettin' was behind it..."
msgstr "El tipo que pudo habernos contado todo..."

msgctxt "6593	6671"
msgid "He ain't ever gonna talk again."
msgstr "Fue asesinado recientemente."

msgctxt "6677	6764"
msgid "Huh? Who?"
msgstr "¿A quién te refieres?"

msgctxt "6806	6866"
msgid "Shibata."
msgstr "Shibata."

msgctxt "6912	6976"
msgid "Kazuo Shibata."
msgstr "Shibata Kazuo."

msgctxt "6993	7137"
msgid "If I'm right...\\nme, you, old man Sasai..."
msgstr "Si no me equivoco, él es culpable de que\\nel viejo Sasai, tú y yo termináramos así."

msgctxt "7138	7270"
msgid "He's the one who left us all to hang."
msgstr "Él fue la persona que nos jodió la vida."

