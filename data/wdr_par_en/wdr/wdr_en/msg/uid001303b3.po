msgctxt "56_ニセ桐生"
msgid "ふ、ふぐっ……\\r\n"
"テメェ、こんな事したら\\r\n"
"東城会が黙ってねえぞ～？"
msgstr "ふ、ふぐっ……\\r\n"
"テメェ、こんな事したら\\r\n"
"東城会が黙ってねえぞ～？"

msgctxt "68_桐生"
msgid "……お前、昔もこんなことやってなかったか？"
msgstr "……お前、昔もこんなことやってなかったか？"

msgctxt "80_ニセ桐生"
msgid "……え？"
msgstr "……え？"

msgctxt "92_ニセ桐生"
msgid "あ！　も、もしかして、アナタ……\\r\n"
"本物の、桐生、一馬さんですか？"
msgstr "あ！　も、もしかして、アナタ……\\r\n"
"本物の、桐生、一馬さんですか？"

msgctxt "104_桐生"
msgid "真似るんなら本人の顔くらい、すぐ気付くんだな。"
msgstr "真似るんなら本人の顔くらい、すぐ気付くんだな。"

msgctxt "116_ニセ桐生"
msgid "す、すいませんでした！\\r\n"
"最近桐生さんのお噂を聞かなかったので、\\r\n"
"つい出来心で……"
msgstr "す、すいませんでした！\\r\n"
"最近桐生さんのお噂を聞かなかったので、\\r\n"
"つい出来心で……"

msgctxt "128_桐生"
msgid "出来心で、暴れまわって\\r\n"
"くだらねぇ日記を垂れ流されちゃたまらねえな。"
msgstr "出来心で、暴れまわって\\r\n"
"くだらねぇ日記を垂れ流されちゃたまらねえな。"

msgctxt "140_ニセ桐生"
msgid "う、そこまでご存知とは……\\r\n"
"スグにブログにお詫びを書きます！"
msgstr "う、そこまでご存知とは……\\r\n"
"スグにブログにお詫びを書きます！"

msgctxt "152_ニセ桐生"
msgid "こ、これも差し上げますから、許してください!!"
msgstr "こ、これも差し上げますから、許してください!!"

msgctxt "176_ニセ桐生"
msgid "ほ、ほんと、スミマセンでしたぁ～っ!!"
msgstr "ほ、ほんと、スミマセンでしたぁ～っ!!"

msgctxt "188_桐生"
msgid "おい、話はまだ……逃げ足の速ぇ奴だな。"
msgstr "おい、話はまだ……逃げ足の速ぇ奴だな。"

msgctxt "200_桐生"
msgid "（ブログで詫びるとか言ってたが……\\r\n"
"　本当に懲りてんのか？）"
msgstr "（ブログで詫びるとか言ってたが……\\r\n"
"　本当に懲りてんのか？）"

msgctxt "212_桐生"
msgid "（お、もうブログが更新されてるな……）"
msgstr "（お、もうブログが更新されてるな……）"

msgctxt "272_桐生"
msgid "（ふっ、ブログの更新だけは早ぇんだな。）"
msgstr "（ふっ、ブログの更新だけは早ぇんだな。）"

