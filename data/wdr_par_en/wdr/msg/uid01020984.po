msgctxt "1664"
msgid "0"
msgstr "0"

msgctxt "100_Haruka"
msgid "Are you... going in there, Uncle Kaz?"
msgstr "¿Vas a entrar... ahí, tío Kaz?"

msgctxt "112_Kiryu"
msgid "(Shoot, I forgot Haruka was with me! What now!?)"
msgstr "(¡Diablos, olvidé que Haruka estaba conmigo! ¿Y ahora qué hago!?)"

msgctxt "124_Haruka"
msgid "Yeah, sorry. Think you can be a big girl and wait here while I'm gone?"
msgstr "Sí, lo siento. ¿Podrías ser una niña grande y esperarme aquí mientras?"

msgctxt "136_Haruka"
msgid "...Okay. Have fun, Uncle Kaz."
msgstr "... Bueno, diviértete, tío Kaz."

msgctxt "148_Haruka"
msgid "No, I changed my mind."
msgstr "No, cambié de opinión."

msgctxt "160_Haruka"
msgid "Really? I don't mind."
msgstr "¿En serio? No me importa."

msgctxt "232_Haruka"
msgid "Go In Anyway"
msgstr "Entrar"

msgctxt "244_Haruka"
msgid "Forget It"
msgstr "Olvidarlo"

