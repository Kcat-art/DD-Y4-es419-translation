msgctxt "1026	1086"
msgid "Arai-san?"
msgstr "¿Arai-san?"

msgctxt "1403	1463"
msgid "Akiyama-san."
msgstr "Akiyama-san."

msgctxt "1541	1624"
msgid "You said I had a chance\\nto make it big..."
msgstr "Sobre esa oportunidad que\\nestabas tratando de darme..."

msgctxt "1659	1777"
msgid "But I guess it just\\nwasn't meant to be."
msgstr "Creo que la dejé escapar."

msgctxt "1856	1916"
msgid "I'll be seeing you."
msgstr "Adiós."

msgctxt "1967	2027"
msgid "Arai-san!"
msgstr "¡Arai-san!"

msgctxt "2704	2858"
msgid "One bullet, straight to the head.\\nClean and simple."
msgstr "Una bala directamente a la cabeza.\\nSin disparos adicionales."

msgctxt "2853	2953"
msgid "No quicker way to bump a guy off."
msgstr "Un disparo con única intención de matar."

msgctxt "2996	3091"
msgid "Shouldn't you be running?"
msgstr "¿No deberías estar huyendo?"

msgctxt "3126	3221"
msgid "The perp's the guy who just ran off, yeah?"
msgstr "El culpable es aquel tipo que escapó antes, ¿verdad?"

msgctxt "3236	3346"
msgid "Do you really want to try\\nexplaining that to the cops?"
msgstr "Si sigues aquí la policía te arrestará\\na ti y tendrás que explicar el asunto."

msgctxt "3362	3422"
msgid "Who are you?"
msgstr "¿Quién eres?"

msgctxt "3535	3637"
msgid "I'm guessing you're not yakuza."
msgstr "No eres más que un civil, ¿verdad?"

msgctxt "3650	3710"
msgid "Well no, but..."
msgstr "Eh. Sí, pero..."

msgctxt "3722	3834"
msgid "The force is full of nasty characters."
msgstr "La policía está llena de tipos desagradables."

msgctxt "3850	3967"
msgid "Some will beat a confession out of you\\njust for shits and giggles."
msgstr "Si te atrapan, de seguro\\nte obligarán a confesar otra verdad."

msgctxt "3989	4049"
msgid "Chief!"
msgstr "¡Jefe!"

msgctxt "4062	4122"
msgid "Hana-chan!"
msgstr "¡Hana-chan!"

msgctxt "4196	4256"
msgid "Looks like you're out of time."
msgstr "Parece que se te acabó el tiempo."

msgctxt "4300	4330"
msgid "Not another step!"
msgstr "¡Quieto!"

msgctxt "4341	4401"
msgid "Wait, me?"
msgstr "¿Eh? ¿Yo?"

msgctxt "4405	4440"
msgid "I said don't move!"
msgstr "¡Te dije que no te movieras!"

msgctxt "4443	4540"
msgid "Hey, you've got the wrong guy!\\nIt wasn't me!"
msgstr "¡Oi! ¡Tienen al tipo equivocado!\\n¡No fui yo!"

msgctxt "4545	4585"
msgid "Stop struggling!"
msgstr "¡Deja de poner resistencia!"

msgctxt "4595	4753"
msgid "Sugiuchi-san sure loves his interrogations.\\nTry not to sweat too much."
msgstr "De seguro el interrogatorio de Sugiuchi-san será implacable.\\nBuena suerte con ello."

msgctxt "4754	4814"
msgid "Have fun."
msgstr "Nos vemos."

msgctxt "4813	4892"
msgid "Sugiuchi? You mean－"
msgstr "¿Sugiuchi? Qué－"

msgctxt "4899	4981"
msgid "Hey, hold on a sec!"
msgstr "¡Oi, espera un segundo!"

msgctxt "4993	5166"
msgid "I'm telling you, it wasn't me!\\nAsk the guy who just ran off! C'mon!"
msgstr "¡Les estoy diciento que no fui yo!\\n¡Pregúntenle al tipo de antes! ¡Vamos!"

msgctxt "5152	5183"
msgid "Chief!"
msgstr "¡Jefe!"

msgctxt "5184	5272"
msgid "Hana-chan!"
msgstr "¡Hana-chan!"

msgctxt "5246	5325"
msgid "<Italic>Chief!</Italic>"
msgstr "<Italic>¡Jefeeeeeeee!</Italic>"

