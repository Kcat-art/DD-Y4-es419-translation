msgctxt "80"
msgid "You \"borrowed\" a <Color:8>Hoe<Color:Default>."
msgstr "Obtienes una <Color:8>Azada<Color:Default> \"prestada\"."

msgctxt "1336"
msgid "Kawana"
msgstr "Kawana"

msgctxt "1340"
msgid "Saejima"
msgstr "Saejima"

msgctxt "1344"
msgid "Sync_Send"
msgstr "Sync_Send"

msgctxt "56_Kawana"
msgid "I give, I give! Just take the damn hoe and go."
msgstr "¡Te la daré, te la daré! Sólo toma esta maldita azada y vete."

msgctxt "68_Saejima"
msgid "Appreciate it. Could've saved yourself a world o' trouble if you just gave it to me in the first place."
msgstr "Te doy las gracias. Pero podría haber evitado todos este problema si me la hubieras dado desde un principio."

msgctxt "128_Saejima"
msgid "(Perfect, now Kamiyama can make me that grapplin' hook.)"
msgstr "(Perfecto, ahora Kamiyama puede darme ese gancho)."

