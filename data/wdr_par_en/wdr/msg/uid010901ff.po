msgctxt "2436"
msgid "Tanimura"
msgstr "Tanimura"

msgctxt "2440"
msgid "Mi-Youn"
msgstr "Mi-Youn"

msgctxt "2444"
msgid "Talk_NoBig"
msgstr "Talk_NoBig"

msgctxt "2448"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "2452"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "56_Tanimura"
msgid "All right, Mi-Youn. Come on over here."
msgstr "Muy bien, Mi-Youn. Baja ahora aquí."

msgctxt "68_Mi-Youn"
msgid "Nooooo! How'd you spot me!?"
msgstr "¡No! ¡¿Cómo me viste?!"

msgctxt "140_Tanimura"
msgid "You wanna tell me what's going on?"
msgstr "¿Quieres decirme qué está pasando?"

msgctxt "152_Mi-Youn"
msgid "No, and don't try and boss me around! You're not my dad!"
msgstr "¡No, y no trates de regañarme! ¡Tú no eres mi papá!"

msgctxt "164_Tanimura"
msgid "Look, I feel for you, but you need to think about what you're doing."
msgstr "Mira, te entiendo, pero tienes que pensar en lo que estás haciendo."

msgctxt "176_Mi-Youn"
msgid "Oh yeah? How would you know how I feel!?"
msgstr "¿Ah, sí? ¡¿Qué sabrás tú cómo me siento?!"

msgctxt "188_Tanimura"
msgid "Believe me. You and I aren't all that different."
msgstr "Créeme. Tú y yo no somos tan diferentes."

msgctxt "200_Mi-Youn"
msgid "...Really?"
msgstr "...¿E-En serio?"

msgctxt "212_Tanimura"
msgid "Yeah. Now, Nui and Tao are waiting in West Park. I want to hear the story from all three of you."
msgstr "Sí. Ahora, Nui y Tao están esperando en el Parque Oeste. Quiero escuchar la historia de ustedes tres."

msgctxt "224_Tanimura"
msgid "Come on. Let's get going."
msgstr "Vamos. Pongámonos en marcha."

msgctxt "236_Mi-Youn"
msgid "Okay..."
msgstr "Bueno..."

