msgctxt "407	470"
msgid "We got a situation here."
msgstr "¿Qué está sucediendo afuera?"

msgctxt "481	541"
msgid "What's wrong?"
msgstr "¿Qué ocurre?"

msgctxt "547	635"
msgid "Looks like we're about to have some company."
msgstr "Muchas personas están entrando en el edificio."

msgctxt "637	688"
msgid "Prolly the cops."
msgstr "Debe ser la policía."

msgctxt "700	760"
msgid "What's our move, Kiryu?"
msgstr "¿Qué hacemos, Kiryu?"

msgctxt "767	884"
msgid "We can't waste time here\\nexplaining everything to the police."
msgstr "No podemos perder el tiempo\\nexplicándolo todo a la policía."

msgctxt "900	960"
msgid "Let's get moving. Now."
msgstr "Por ahora, salgamos de aquí."

msgctxt "973	1033"
msgid "Right."
msgstr "Entendido."

