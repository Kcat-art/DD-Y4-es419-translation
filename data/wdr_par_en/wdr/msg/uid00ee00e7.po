msgctxt "144_Dealer"
msgid "Welcome. Here, you can play Texas hold 'em poker. Would you like to play?"
msgstr "Bienvenido. Aquí puedes jugar al póker Texas hold 'em. ¿Quieres jugar?"

msgctxt "156_Player"
msgid "Sure, I'll play."
msgstr "Claro, jugaré."

msgctxt "168_Dealer"
msgid "An excellent choice. What stakes would you like to play for?"
msgstr "Una elección excelente. ¿Con qué apuestas le gustaría jugar?"

msgctxt "180_Player"
msgid "I'll go with the low stakes."
msgstr "Iré con las apuestas bajas."

msgctxt "204_Dealer"
msgid "The starting bets are as follows: 5 chips for rounds one and two, then 10 chips on rounds three and four."
msgstr "Las apuestas iniciales son las que sigue: 5 fichas para las rondas uno y dos, luego, 10 fichas en las rondas tres y cuatro."

msgctxt "216_Dealer"
msgid "Please take a seat, sir."
msgstr "Por favor, tome asiento señor."

msgctxt "240_Dealer"
msgid "You'll need a minimum of 100 chips to play low-stakes poker, sir."
msgstr "Necesitarás un mínimo de 100 fichas para jugar al póker de bajo riesgo, señor."

msgctxt "252_Player"
msgid "I'll go with the high stakes."
msgstr "Voy a ir con las apuestas altas."

msgctxt "276_Dealer"
msgid "The starting bets are as follows: 50 chips for rounds one and two, then 100 chips on rounds three and four."
msgstr "Las apuestas iniciales son las que sigue: 50 fichas para las rondas uno y dos, luego, 100 fichas en las rondas tres y cuatro."

msgctxt "288_Dealer"
msgid "Please take a seat, sir."
msgstr "Por favor, tome asiento señor."

msgctxt "312_Dealer"
msgid "You'll need a minimum of 1,000 chips to play high-stakes poker, sir."
msgstr "Necesitarás un mínimo de 1000 fichas para jugar al póker de alto riesgo, señor."

msgctxt "324_Player"
msgid "Not right now."
msgstr "Ahora no."

msgctxt "336_Dealer"
msgid "Very well. We hope you'll play with us next time."
msgstr "Muy bien. Esperamos que vuelvas a jugar con nosotros."

msgctxt "348_Dealer"
msgid "Play"
msgstr "Jugar"

msgctxt "360_Dealer"
msgid "Not Now"
msgstr "Ahora no"

msgctxt "372_Dealer"
msgid "Low Stakes (5 chips/10 chips)"
msgstr "Apuestas Bajas (5 fichas/10 fichas)"

msgctxt "384_Dealer"
msgid "High Stakes (50 chips/100 chips)"
msgstr "Apuestas Altas (50 fichas/100 fichas)"

