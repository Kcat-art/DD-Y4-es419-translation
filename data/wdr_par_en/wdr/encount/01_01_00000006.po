msgstr "Talk_Yes"

msgctxt "1480"
msgid "Sync_Send"
msgstr "Sync_Send"

msgctxt "116_Man"
msgid "It's you! You're the guy who attacked the boss's beloved Mimi-san three days ago!"
msgstr "¡Eres tú! ¡Eres el tipo que atacó a la querida Mimi-san del jefe hace tres días!"

msgctxt "128_Man"
msgid "You got a lotta nerve to still be out here wandering the streets of Kamurocho. I'm gonna tear your head off!"
msgstr "¡Tienes mucho valor para seguir rondando por las calles de Kamurocho! ¡Voy a arrancarte la cabeza!"

msgctxt "152_Man"
msgid "Who's Mimi? She's the boss's pet kitty..."
msgstr "¿Quién es Mimi? Es la gatita del jefe..."

msgctxt "164_Man"
msgid "I apologize. It looks like I got the wrong guy."
msgstr "Pido disculpas. Parece que me equivoqué de persona."

msgctxt "176_Man"
msgid "You got an underwhelming %s."
msgstr "Obtuviste un %s."

msgctxt "212_Man"
msgid "I guess I'm not cut out to be a yakuza. I should just go home to the sticks and take over my momma's restaurant business."
msgstr "Supongo que no estoy hecho para ser un yakuza. Debería regresar al campo y hacerme cargo del restaurante de mi mamá."

