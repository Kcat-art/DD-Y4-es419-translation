msgctxt "428"
msgid "Quit"
msgstr "Salir"

msgctxt "433"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "451"
msgid "Order"
msgstr "Pagar"

msgctxt "457"
msgid "Order the currently selected item."
msgstr "Pagar el objeto seleccionado actualmente."

msgctxt "492"
msgid "(I haven't picked anything.)"
msgstr "(No he escogido nada)"

msgctxt "521"
msgid "(I'm short on cash.)"
msgstr "(Me hace falta dinero)"

msgctxt "542"
msgid "Very well, sir."
msgstr "Muy bien, señor."

msgctxt "558"
msgid "(I can't eat anymore...)"
msgstr "(No puedo comer más...)"

msgctxt "602"
msgid "Prepared from fresh tomatoes and mozzarella with a\n"
"light olive oil drizzle."
msgstr "Preparado a partir de tomates frescos y mozzarella con un liviano aceite de oliva."

msgctxt "678"
msgid "Soft Hokkaido octopus and zesty ponzu sauce make this\n"
"carpaccio really stand out."
msgstr "El suave pulpo de Hokkaido y la vibrante salsa ponzu hacen\n"
"que este carpaccio realmente destaque."

msgctxt "760"
msgid "A salad of avocado and shrimp topped with a light\n"
"Japanese-style dressing."
msgstr "Una ensalada de aguacate y camarones cubierta con\n"
"un aderezo ligero al estilo japonés."

msgctxt "835"
msgid "Spicy, bite-sized, Hawaiian-style Portuguese sausages.\n"
"Goes great with beer."
msgstr "Salchichas portuguesas al estilo hawaiano, picantes y en porciones pequeñas.\n"
"Combina muy bien con cerveza."

msgctxt "912"
msgid "Fries made from fresh strips of burdock. Enjoy their\n"
"crunchy goodness!"
msgstr "Papas fritas hechas de tiras frescas de bardana.\n"
"¡Disfruta de su crujiente sabor!"

msgctxt "983"
msgid "Spicy fries made by seasoning Hokkaido Matilda\n"
"potatoes with chipotle salt."
msgstr "Papas fritas picantes sazonadas con sal de chipotle\n"
"hechas con papas Matilda de Hokkaido."

msgctxt "1059"
msgid "Oven-roasted, fragrant, spicy chorizo sausage seasoned\n"
"with chipotle salt."
msgstr "Chorizo aromático y picante, asado al horno y sazonado\n"
"con sal de chipotle."

msgctxt "1134"
msgid "Fresh, tender sea snails from Akkeshi, roasted in garlic\n"
"butter."
msgstr "Caracoles marinos frescos y tiernos de Akkeshi, asados\n"
"en mantequilla de ajo."

msgctxt "1199"
msgid "This Roman pizza is basic Margherita-style, made with\n"
"fresh tomato sauce and basil."
msgstr "Esta pizza romana es el básico estilo Margherita, hecha con salsa de tomate fresco y albahaca."

