msgctxt "128"
msgid "The Assault on Yoshiharu Ueno"
msgstr "The Assault on Yoshiharu Ueno"

msgctxt "140"
msgid "1. Case Overview"
msgstr "1. Case Overview"

msgctxt "152"
msgid "The attempt on Yoshiharu Ueno's life was carried out\\r\n"\n"on April 21, 1985."
msgstr "The attempt on Yoshiharu Ueno's life was carried out\\r\n"\n"on April 21, 1985."

msgctxt "164"
msgid "Shortly after 12:00 noon that day, a lone gunman\\r\n"\n"armed with six revolvers burst into a ramen shop\\r\n"\n"located in Tokyo's Suginami Ward."
msgstr "Shortly after 12:00 noon that day, a lone gunman\\r\n"\n"armed with six revolvers burst into a ramen shop\\r\n"\n"located in Tokyo's Suginami Ward."

msgctxt "176"
msgid "Yoshiharu Ueno, chairman of the Ueno Seiwa Clan, was one of\\r\n"\n"the 20 men shot inside, and one of the two who survived."
msgstr "Yoshiharu Ueno, chairman of the Ueno Seiwa Clan, was one of\\r\n"\n"the 20 men shot inside, and one of the two who survived."

msgctxt "188"
msgid "The gunman was one Taiga Saejima, a 20-year-old\\r\n"\n"member of the Tojo Clan."
msgstr "The gunman was one Taiga Saejima, a 20-year-old\\r\n"\n"member of the Tojo Clan."

msgctxt "200"
msgid "On the day of the incident, Ueno had just been\\r\n"\n"released after serving a two-year prison term.\\r\n"\n"With him were several top members of his clan."
msgstr "On the day of the incident, Ueno had just been\\r\n"\n"released after serving a two-year prison term.\\r\n"\n"With him were several top members of his clan."

msgctxt "224"
msgid "2. Investigation"
msgstr "2. Investigation"

msgctxt "236"
msgid "The Tokyo Metropolitan Police Department formed\\r\n"\n"a special investigation team led by detectives\\r\n"\n"<Color:7>Taigi Tanimura<Color:Default> and <Color:7>Junji Sugiuchi<Color:Default>."
msgstr "The Tokyo Metropolitan Police Department formed\\r\n"\n"a special investigation team led by detectives\\r\n"\n"<Color:7>Taigi Tanimura<Color:Default> and <Color:7>Junji Sugiuchi<Color:Default>."

