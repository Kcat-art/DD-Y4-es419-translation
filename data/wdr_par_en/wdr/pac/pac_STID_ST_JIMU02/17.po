msgctxt "68"
msgid "おい、お前！　いったいなにをしている!?"
msgstr "おい、お前！　いったいなにをしている!?"

msgctxt "80"
msgid "谷村さん！"
msgstr "谷村さん！"

msgctxt "92"
msgid "なんだあんたは？"
msgstr "なんだあんたは？"

msgctxt "104"
msgid "警察だ！　すぐに彼女から離れろ！\\r\n"
"暴行の容疑で逮捕するぞ！"
msgstr "警察だ！　すぐに彼女から離れろ！\\r\n"
"暴行の容疑で逮捕するぞ！"

msgctxt "116"
msgid "ちょ、ちょっと待ってくださいよ。\\r\n"
"あんた、なにか誤解してないか？"
msgstr "ちょ、ちょっと待ってくださいよ。\\r\n"
"あんた、なにか誤解してないか？"

msgctxt "128"
msgid "誤解だって？"
msgstr "誤解だって？"

msgctxt "140"
msgid "これはね、お互い合意の上でやってることなんだ。\\r\n"
"芸能界にはよくあることですよ。　彼女が女優として\\r\n"
"デビューするために、必要なことなんだ。"
msgstr "これはね、お互い合意の上でやってることなんだ。\\r\n"
"芸能界にはよくあることですよ。　彼女が女優として\\r\n"
"デビューするために、必要なことなんだ。"

msgctxt "152"
msgid "ふざけるな！"
msgstr "ふざけるな！"

msgctxt "164"
msgid "まぁまぁ。\\r\n"
"彼女の意思を聞いてみようじゃないですか。\\r\n"
"どうだい千洋ちゃん？"
msgstr "まぁまぁ。\\r\n"
"彼女の意思を聞いてみようじゃないですか。\\r\n"
"どうだい千洋ちゃん？"

msgctxt "176"
msgid "…………"
msgstr "…………"

msgctxt "188"
msgid "僕ならキミをデビューさせてあげられるんだよ？"
msgstr "僕ならキミをデビューさせてあげられるんだよ？"

msgctxt "200"
msgid "…………お断りします！\\r\n"
"私は本物の女優になるために、毎日トレーニングを\\r\n"
"頑張ってるんです！"
msgstr "…………お断りします！\\r\n"
"私は本物の女優になるために、毎日トレーニングを\\r\n"
"頑張ってるんです！"

msgctxt "212"
msgid "デビューするんなら、\\r\n"
"ちゃんと実力を認められてデビューしたいんです！"
msgstr "デビューするんなら、\\r\n"
"ちゃんと実力を認められてデビューしたいんです！"

msgctxt "224"
msgid "……だとさ。"
msgstr "……だとさ。"

msgctxt "236"
msgid "くそ……\\r\n"
"せっかくいいカモを捕まえたと思ったのに、\\r\n"
"邪魔しやがって……！"
msgstr "くそ……\\r\n"
"せっかくいいカモを捕まえたと思ったのに、\\r\n"
"邪魔しやがって……！"

msgctxt "248"
msgid "オイ、お前ら！"
msgstr "オイ、お前ら！"

msgctxt "260"
msgid "化けの皮が剥がれたな。　おおかた、\\r\n"
"デビューを口実にアイドルを目指す女の子を\\r\n"
"騙すつもりだったんだろう。"
msgstr "化けの皮が剥がれたな。　おおかた、\\r\n"
"デビューを口実にアイドルを目指す女の子を\\r\n"
"騙すつもりだったんだろう。"

msgctxt "272"
msgid "芸能プロダクションが聞いて呆れる。"
msgstr "芸能プロダクションが聞いて呆れる。"

msgctxt "284"
msgid "うるせぇ！　おまわりだとしても関係ねぇ！\\r\n"
"こっから生きて返すな！"
msgstr "うるせぇ！　おまわりだとしても関係ねぇ！\\r\n"
"こっから生きて返すな！"

