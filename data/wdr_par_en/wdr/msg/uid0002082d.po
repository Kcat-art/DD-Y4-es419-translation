msgctxt "972"
msgid "Saejima"
msgstr "Saejima"

msgctxt "976"
msgid "Police Officer"
msgstr "Policía"

msgctxt "88_Saejima"
msgid "(A cop on patrol. If he sees me, he's sure to come runnin'. Better move carefully.)"
msgstr "(Un policía patrullando. Si me ve, seguro vendrá corriendo. Mejor me muevo con cuidado)."

msgctxt "124_Police Officer"
msgid "Huh? You there! Halt!"
msgstr "¿Eh? ¡Tú ahí! ¡Detente!"

msgctxt "136_Saejima"
msgid "(Damn, I was spotted!)"
msgstr "(Maldición, ¡me han descubierto!)."

msgctxt "148_Police Officer"
msgid "We're currently on high alert for suspicious persons. Sorry, but we need you to come with us to the station."
msgstr "Actualmente estamos en alerta máxima por personas sospechosas. Lo siento, pero necesitamos que nos acompañe a la comisaría."

