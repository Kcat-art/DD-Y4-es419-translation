msgctxt "532"
msgid "Quit"
msgstr "Salir"

msgctxt "537"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "555"
msgid "Order"
msgstr "Pagar"

msgctxt "561"
msgid "Order the currently selected item.  "
msgstr "Pedir el objeto actualmente seleccionado.  "

msgctxt "598"
msgid "(I haven't picked anything.)  "
msgstr "(No he escogido nada)"

msgctxt "629"
msgid "(I'm short on cash.)  "
msgstr "(Me hace falta dinero)"

msgctxt "652"
msgid "All right. That comes to %s."
msgstr "Muy bien. Eso da %s."

msgctxt "681"
msgid "(I can't carry any more stuff.)"
msgstr "(No puedo llevar más cosas)."

msgctxt "713"
msgid "(They're sold out.)"
msgstr "(Están agotados)."

msgctxt "733"
msgid "This is a blunt weapon designed for self-defense, but\n"
"I wouldn't try using it in a brawl."
msgstr "Este es un arma contundente diseñada para autodefensa,\n"
"pero no intentaría usarla en una pelea."

msgctxt "823"
msgid "Not a very powerful weapon, but it's compact and\n"
"easy to hide."
msgstr "No es un arma muy poderosa, pero es compacta y\n"
"fácil de ocultar."

msgctxt "886"
msgid "I don't need to explain how this works, do I? It's\n"
"designed for self-defense."
msgstr "No necesito explicar cómo funciona esto, ¿verdad?\n"
"Está diseñado para la autodefensa."

msgctxt "964"
msgid "Basically a mini flamethrower. So, what do you think?"
msgstr "Básicamente un mini lanzallamas. Entonces, ¿qué opinas?"

msgctxt "1018"
msgid "The next generation in self-defense technology."
msgstr "La próxima generación en tecnología de autodefensa."

msgctxt "1066"
msgid "This is your run-of-the-mill wooden driver."
msgstr "Este es su controlador de madera común y corriente."

msgctxt "1110"
msgid "Perfect for kali stick beginners."
msgstr "Perfecto para principiantes en el palo de kali."

msgctxt "1144"
msgid "A good nunchaku set for beginners to start out with."
msgstr "Un buen set de nunchaku para principiantes."

msgctxt "1197"
msgid "The street brawler's weapons of choice. Put them on\n"
"your fists to increase the power of your punches."
msgstr "Las armas preferidas del luchador callejero. Ponlos en\n"
"tus puños para aumentar el poder de tus golpes."

msgctxt "1299"
msgid "I thought it might be a good idea to send away for a\n"
"few of these."
msgstr "Pensé que podría ser una buena idea mandar a buscar un\n"
"pocos de estos."

msgctxt "1366"
msgid "You're gonna need a lot of upper body strength to\n"
"swing this thing around."
msgstr "Vas a necesitar mucha fuerza en la parte superior del cuerpo para balancear esta cosa."

msgctxt "1441"
msgid "Collapsible and easy to store in a purse or jacket\n"
"pocket. It's good for blocking low attacks, too."
msgstr "Plegable y fácil de almacenar en una bolsa o chaqueta\n"
"de bolsillo. También es bueno para bloquear ataques bajos."

msgctxt "1541"
msgid "A standard tonfa made of iron."
msgstr "Una tonfa estándar hecha de hierro."

msgctxt "1572"
msgid "That's a double action revolver. That means pulling \n"
"the trigger both cocks the hammer and fires the gun.\n"
"Well worth the price."
msgstr "Ese es un revólver de doble acción. Eso significa que\n"
"al apretar del gatillo, tanto se arma el martillo como se\n"
"dispara el arma. Merece totalmente el precio."

