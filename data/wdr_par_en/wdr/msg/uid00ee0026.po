msgctxt "2352"
msgid "Tanimura"
msgstr "Tanimura"

msgctxt "2356"
msgid "Man"
msgstr "Hombre"

msgctxt "2360"
msgid "Kiryu"
msgstr "Kiryu"

msgctxt "2364"
msgid "Akiyama"
msgstr "Akiyama"

msgctxt "2368"
msgid "Saejima"
msgstr "Saejima"

msgctxt "2372"
msgid "Foreign Man"
msgstr "Hombre Extranjero"

msgctxt "128_Tanimura"
msgid "Excuse me, I'd like to pass through here."
msgstr "Disculpe, quiero pasar por aquí."

msgctxt "140_Man"
msgid "這里是進入禁止。"
msgstr "這里是進入禁止。"

msgctxt "152_Tanimura"
msgid "(Doesn't look like he understands Japanese.)"
msgstr "(Creo que no entiende japonés)."

msgctxt "164_Tanimura"
msgid "\"Excuse me, are you Chinese? I'm a policeman. Could you let me through?\""
msgstr "\"Disculpe, ¿es chino? Soy policía, ¿me podría dejar pasar?\""

msgctxt "176_Man"
msgid "\"Go right ahead.\""
msgstr "\"Adelante\"."

msgctxt "236_Kiryu"
msgid "Hey, could you move?"
msgstr "Oiga, ¿podría moverse?"

msgctxt "248_Akiyama"
msgid "Hey there, pal. Think you could move out of my way?"
msgstr "Hey, amigo. ¿Podrías moverte?"

msgctxt "260_Saejima"
msgid "Hey, you're in my way."
msgstr "Oye, estás en mi camino."

msgctxt "272_Tanimura"
msgid "This place definitely wouldn't have been chosen."
msgstr "Este lugar definitivamente no habría sido elegido."

msgctxt "284_Foreign Man"
msgid "這里是進入禁止。"
msgstr "這里是進入禁止。"

msgctxt "308_Kiryu"
msgid "(A foreigner... Doesn't look like he understands Japanese. I guess I'll avoid Little Asia for now.)"
msgstr "(A foreigner... Doesn't look like he understands Japanese. I guess I'll avoid Little Asia for now.)"

msgctxt "320_Akiyama"
msgid "(Doesn't look like he has any interest in letting me through.)"
msgstr "(Parece que no tiene ningún interés en dejarme pasar.)"

msgctxt "332_Saejima"
msgid "(Doesn't look like he's gonna let me through. Best to avoid causin' trouble.)"
msgstr "(No parece que me vaya a dejar pasar. Mejor me evito problemas)."

msgctxt "344_Tanimura"
msgid "This place definitely wouldn't have been chosen."
msgstr "Este lugar definitivamente no habría sido elegido."

