msgstr "Claro."

msgctxt "18756_Kiryu"
msgid "I should get going."
msgstr "Bueno, bueno, es momento de ir a casa."

msgctxt "18768_F_cab_sitsofa_tlk_noA"
msgid "You're leaving already?"
msgstr "¿Ya se va?"

msgctxt "18780_Shizuka"
msgid "I guess it's about that time."
msgstr "Supongo que ya es hora."

msgctxt "18792_P_sitsofaR_tlk_yes"
