msgctxt "116_Man"
msgid "Kamurocho belongs to me! Don't be swaggering around like you own the place!"
msgstr "¡Kamurocho me pertenece! ¡No andes paseándote por aquí como si fuera tuyo!"

msgctxt "128_Man"
msgid "Now lemme give you a great going-away present!"
msgstr "¡Déjame darte un gran regalo de despedida!"

msgctxt "152_Man"
msgid "Argh! That really hurt! You're way too strong for me."
msgstr "¡Argh! ¡Eso dolió mucho! Eres demasiado fuerte para mí."

msgctxt "164_Man"
msgid "I'm sorry. I should never have tangled with you in the first place. Please take this."
msgstr "Lo siento. Nunca debí haberme metido contigo en primer lugar. Por favor, acepta esto."

msgctxt "176_Man"
msgid "You got a hairy %s."
msgstr "Obtuviste un %s."

msgctxt "212_Man"
msgid "Kamurocho is all yours now..."
msgstr "Kamurocho es todo tuyo ahora..."

