msgctxt "4684"
msgid "Hana"
msgstr "Hana"

msgctxt "4688"
msgid "Akiyama"
msgstr "Akiyama"

msgctxt "256_Hana"
msgid "I can't believe I'm going to karaoke with you, Chief...\\r\n"\n"I'm so excited. Now, what should I sing?"
msgstr "No puedo creer que vaya al karaoke contigo, Jefe...\\r\n"\n"Estoy tan emocionada. Ahora, ¿qué debería cantar?"

msgctxt "268_Hana"
msgid "I think I'll try \"Raindrops.\" The lyrics are heartrending, but it's one of my favorite songs."
msgstr "Creo que intentaré \"Raindrops.\" La letra es desgarradora, pero es una de mis canciones favoritas."

msgctxt "280_Hana"
msgid "Not bad, Chief! I never knew you were so good at cheering people on."
msgstr "¡Nada mal, Jefe! No sabía que eras tan bueno animando."

msgctxt "292_Hana"
msgid "Aren't you going to sing? Oh, I know! Why don't we sing a duet!?"
msgstr "¿No va a cantar, jefe? ¡Ah, cierto!\n"\n"¡¿Qué tal si hacemos un dúo?!"

msgctxt "304_Akiyama"
msgid "A duet, huh? Sure, why not? How about \"Pure Love in Kamurocho\"?"
msgstr "¿Un dúo? Interesante.\n"\n"¿Qué tal \"Pure Love in Kamurocho\"?"

msgctxt "316_Hana"
msgid "Perfect! I can't wait!"
msgstr "¡Perfecto! ¡No puedo esperar!"

msgctxt "328_Akiyama"
msgid "Sorry, not today."
msgstr "No, lo siento."

msgctxt "340_Hana"
msgid "Really? Oh, all right. Too bad..."
msgstr "Eh... Entiendo, es una pena."

msgctxt "352_Hana"
msgid "Chief... You're breaking my rhythm."
msgstr "Jefe... Arruina mi ritmo."

msgctxt "364_Akiyama"
msgid "Sorry..."
msgstr "Lo siento..."

msgctxt "376_Hana"
msgid "That felt out of this world! I never knew you were so good at cheering people on, Chief!"
msgstr "¡Eso se sintió de otro mundo! ¡No sabía que fueras tan bueno animando a la gente, Jefe!"

msgctxt "388_Hana"
msgid "Aren't you going to sing? Oh, I know! Why don't we sing a duet!?"
msgstr "¿No va a cantar, jefe? ¡Ah, cierto!\n"\n"¡¿Qué tal si hacemos un dúo?!"

msgctxt "400_Akiyama"
msgid "A duet, huh? Sure, why not? How about \"Pure Love in Kamurocho\"?"
msgstr "¿Un dúo? Interesante.\n"\n"¿Qué tal \"Pure Love in Kamurocho\"?"

msgctxt "412_Hana"
msgid "Perfect! I can't wait!"
msgstr "¡Perfecto! ¡No puedo esperar!"

msgctxt "424_Akiyama"
msgid "Sorry, not today."
msgstr "No, lo siento."

msgctxt "436_Hana"
msgid "Really? Oh, all right. Too bad..."
msgstr "Eh... Entiendo, es una pena."

msgctxt "448_Hana"
msgid "Hehe... Don't you think we were completely in sync? We were flowing like pros."
msgstr "Jeje... ¿No crees que estábamos completamente sincronizados? Fluíamos como profesionales."

msgctxt "460_Akiyama"
msgid "Heheh, I guess so."
msgstr "Heheh, supongo que sí."

msgctxt "472_Hana"
msgid "Chief... Stop getting in my way."
msgstr "Jefe... Deje de meterse en mi camino."

msgctxt "484_Akiyama"
msgid "Sorry..."
msgstr "Lo siento..."

msgctxt "496_Hana"
msgid "That was perfect! I think we could release a CD. <Color:7>♥<Color:Default>"
msgstr "¡Eso fue perfecto! Creo que podríamos lanzar un CD. <Color:7>♥<Color:Default>"

msgctxt "508_Akiyama"
msgid "Heheh, sure."
msgstr "Jejeje, claro."

msgctxt "520_Hana"
msgid "Sure."
msgstr "Claro."

msgctxt "532_Hana"
msgid "I'd rather not."
msgstr "Preferiría no hacerlo."

msgctxt "544_Hana"
msgid "Sure."
msgstr "Claro."

msgctxt "556_Hana"
msgid "I'd rather not."
msgstr "Preferiría no hacerlo."

