msgctxt "1532"
msgid "Akiyama"
msgstr "Akiyama"

msgctxt "1536"
msgid "Player"
msgstr "Player"

msgctxt "164_Akiyama"
msgid "(I can't be going back to the office right now. I need to find Midorikawa, and get back Kido-chan and the client list...)"
msgstr ""

msgctxt "176_Akiyama"
msgid "(The girl we were training at Elise just disappeared.)"
msgstr ""

msgctxt "188_Akiyama"
msgid "(I need to find her quickly. Where would she be... Maybe where we recruited her?)"
msgstr ""

msgctxt "200_Akiyama"
msgid "(The manager's asked me to go scout for him. I've got to find some potential hostesses.)"
msgstr ""

msgctxt "212_Akiyama"
msgid "(Or should I stop recruiting for the moment?)"
msgstr "(¿O debería detener el reclutamiento por ahora?)."

msgctxt "224_Akiyama"
msgid "(I'll stop for now.)"
msgstr "(Por ahora, voy a parar el reclutamiento)."

msgctxt "248_Akiyama"
msgid "(No, I should keep looking.)"
msgstr "(No, voy a seguir buscando)."

msgctxt "272_Player"
msgid "(Looks like it's locked.)"
msgstr ""

msgctxt "284_Akiyama"
msgid "Stop Recruiting"
msgstr "Dejar de Reclutar"

msgctxt "296_Akiyama"
msgid "Continue Recruiting"
msgstr "Continuar Reclutando"

