msgctxt "1512"
msgid "Lucky Harris"
msgstr "Lucky Harris"

msgctxt "232_Lucky Harris"
msgid "Let's pick the banker."
msgstr "Elijamos al banquero."

msgctxt "244_Lucky Harris"
msgid "Cool, I'm the banker."
msgstr "Genial, soy el banquero."

msgctxt "256_Lucky Harris"
msgid "So how much are you gonna bet?"
msgstr "So how much are you gonna bet?"

msgctxt "268_Lucky Harris"
msgid "Let's get down to business!"
msgstr "Let's get down to business!"

msgctxt "280_Lucky Harris"
msgid "My turn!"
msgstr "My turn!"

msgctxt "292_Lucky Harris"
msgid "(This line signifies failure.)"
msgstr "(This line signifies failure.)"

msgctxt "304_Lucky Harris"
msgid "Let's settle."
msgstr "Let's settle."

msgctxt "316_Lucky Harris"
msgid "You're banker, bro."
msgstr "Tú serás el banquero."

msgctxt "328_Lucky Harris"
msgid "So we change bankers now."
msgstr "Le toca a otro ser el banquero."

msgctxt "340_Lucky Harris"
msgid "Wanna try that again?"
msgstr "Wanna try that again?"

msgctxt "352_Lucky Harris"
msgid "Shit! I'm broke! I'm outta here!"
msgstr "Shit! I'm broke! I'm outta here!"

msgctxt "364_Lucky Harris"
msgid "Looks like you're broke. Better luck next time!"
msgstr "Looks like you're broke. Better luck next time!"

