msgctxt "82286	EXPLANATION"
msgid "Money (1,000 Yen)"
msgstr "Dinero (1,000 Yenes)"

msgctxt "82304	EXPLANATION"
msgid "Restores health and charges Heat slightly."
msgstr "Restaura salud y carga ligeramente el Heat."

msgctxt "82347	EXPLANATION"
msgid "Restores health and charges Heat significantly."
msgstr "Restaura salud y carga significativamente el Heat."

msgctxt "82395	EXPLANATION"
msgid "Restores health and charges Heat dramatically. "
msgstr "Restaura la salud y carga el Heat dramáticamente. "

msgctxt "82443	EXPLANATION"
msgid "Restores health and charges Heat completely. "
msgstr "Restaura completamente la salud y el Heat. "

msgctxt "82489	EXPLANATION"
msgid "Charges up your Heat a little."
msgstr "Recarga un poco el Heat."

msgctxt "82520	EXPLANATION"
msgid "Moderately charges up Heat."
msgstr "Carga moderadamente el Heat."

msgctxt "82548	EXPLANATION"
msgid "Charges up your Heat dramatically."
msgstr "Recarga tu Heat dramáticamente."

msgctxt "82583	EXPLANATION"
msgid "Charges up your Heat to its maximum level."
msgstr "Recarga el Heat al máximo."

msgctxt "82626	EXPLANATION"
msgid "Useful when you need a little health boost."
msgstr "Es útil para cuando necesitas restaurar un poco de salud."

msgctxt "82670	EXPLANATION"
msgid "Restores your health quite a bit."
msgstr "Restaura bastante la salud."

msgctxt "82704	EXPLANATION"
msgid "Restores your health dramatically."
msgstr "Recupera tu salud drásticamente."

msgctxt "82739	EXPLANATION"
msgid "Restores your health to its maximum."
msgstr "Recupera tu salud al máximo."

msgctxt "82776	EXPLANATION"
msgid "Made of some of the rarest metal in the world. Could fetch a small fortune at a pawn shop."
msgstr "Fabricado con uno de los metales más raros del mundo. Podrías ganar una pequeña fortuna en una casa de empeños."

msgctxt "82867	EXPLANATION"
msgid "The gold standard in plates. Could go for quite a lot at a pawn shop."
msgstr "Un plato de oro puro. Podría valer bastante en una casa de empeños."

msgctxt "82937	EXPLANATION"
msgid "This well-crafted plate could net a hefty sum over at a pawn shop."
msgstr "Un plato cuidadosamente elaborado. Podría valer una cantidad importante de dinero en una casa de empeños."

msgctxt "83004	EXPLANATION"
msgid "A plate made of bronze. Nothing special, but it could probably fetch some decent cash."
msgstr "Un plato hecho de bronce. Nada especial, pero se puede vender por un poco de dinero."

msgctxt "83091	EXPLANATION"
msgid "A plate made of iron. Nothing special, but it could probably fetch a little cash.  "
msgstr "Un plato hecho de hierro. Nada especial, pero podría valer algo.  "

msgctxt "83175	EXPLANATION"
msgid "Oden Soup is perfect for cold winter days. There's actually quite a lot in here.  "
msgstr "El Oden es perfecto para los dias fríos de invierno. De hecho, hay bastante aquí.  "

msgctxt "83258	EXPLANATION"
msgid "A rice ball with boiled seaweed at its center."
msgstr "Onigiri relleno con alga cocida."

msgctxt "83305	EXPLANATION"
msgid "This rice ball has tuna dressed with mayonnaise in the middle."
msgstr "Exquisito onigiri que lleva atún mezclado con mayonesa en el centro."

msgctxt "83368	EXPLANATION"
msgid "A standard rice ball with salmon flake filling."
msgstr "Bola de arroz común con relleno de salmón escamado."

msgctxt "83416	EXPLANATION"
msgid "Your average bento lunch. This is enough to fill you up.  "
msgstr "Tu bento habitual, es suficiente para satisfacerte.  "

msgctxt "83475	EXPLANATION"
msgid "A tonkatsu lunch set made with rich Satsuma pork."
msgstr "Un menú de almuerzo de tonkatsu con rico cerdo Satsuma."

msgctxt "83525	EXPLANATION"
msgid "A standard clubhouse sandwich with tomatoes, lettuce, and cheese."
msgstr "Un sandwich 'club' común con tomate, lechuga y queso."

msgctxt "83591	EXPLANATION"
msgid "Tuna, egg, and mayo on white bread."
msgstr "Atún, huevo y mayonesa sobre pan blanco."

msgctxt "83627	EXPLANATION"
msgid "Yakisoba with cabbage and pork. The smell of the sauce is simply irresistible."
msgstr "Yakisoba con col y cerdo. El olor de la salsa es simplemente irresistible."

msgctxt "83706	EXPLANATION"
msgid "A regular item at convenience stores. Popular for its superb flavor."
msgstr "Un artículo común en tiendas de conveniencia. Popular por su magnífico sabor."

msgctxt "83775	EXPLANATION"
msgid "A regular item at convenience stores. Popular for its sesame-flavored strained bean paste."
msgstr "Un artículo común en tiendas de conveniencia. Popular por su pasta de judías procesada con sabor a sésamo."

msgctxt "83866	EXPLANATION"
msgid "A Chinese-style steamed bun with yakisoba noodles in the middle. The sauce smells great."
msgstr "Un bollo chino al vapor con fideos Yakisoba en el medio. La salsa huele genial."

msgctxt "83955	EXPLANATION"
msgid "This large bottle of rice wine can be enjoyed heated or chilled."
msgstr "Esta botella grande de vino de arroz puede disfrutarse tanto caliente como fría."

msgctxt "84020	EXPLANATION"
msgid "Dry dog food. Contains a well-balanced mix of nutrients."
msgstr "Comida seca para perros. Contiene una mezcla de nutrientes bien balanceada."

msgctxt "84077	EXPLANATION"
msgid "Carefully selected nigiri-style sushi in a box. Includes only high-quality fish. Expensive."
msgstr "Sushi estilo nigiri, cuidadosamente seleccionado y presentado en una caja. Solo con pescado de alta calidad. Caro."

msgctxt "84169	EXPLANATION"
msgid "A blend of Mandheling and Brazilian beans with a Colombian base."
msgstr "Una mezcla de granos mandheling y brasileños con una base colombiana."

msgctxt "84234	EXPLANATION"
msgid "This is the ultimate cup of coffee, made with rich, top-grade coffee beans."
msgstr "Esta es la taza de café definitiva, elaborada con granos de café de primera calidad."

msgctxt "84310	EXPLANATION"
msgid "Countless coffee drinkers love mocha-style coffee for its rich, bitter flavor."
msgstr "Incontables amantes del café adoran el café estilo moka por su sabor intenso y amargo."

msgctxt "84389	EXPLANATION"
msgid "Enjoy the citrus bergamot fragrance of this tea grown in Sri Lanka under an exclusive contract."
msgstr "Disfruta del aroma a bergamota cítrica de este té cultivado en Sri Lanka bajo un contrato exclusivo."

msgctxt "84485	EXPLANATION"
msgid "Assam tea leaves from a tea farm under our exclusive contract that have been carefully brewed with creamy pasteurized milk from Hokkaido."
msgstr "Hojas de té Assam de una plantación con la que tenemos un contrato exclusivo, cuidadosamente infusionadas con leche cremosa pasteurizada de Hokkaido."

msgctxt "84623	EXPLANATION"
msgid "Made with healthy, organic tomatoes."
msgstr "Hecho con tomates saludables y orgánicos."

msgctxt "84660	EXPLANATION"
msgid "Richly scented tea from the hills of Nuwara Eliya in Sri Lanka, combined with organic lemon."
msgstr "Té con un aroma intenso, proveniente de las colinas de Nuwara Eliya en Sri Lanka. Combinado con limón orgánico."

msgctxt "84753	EXPLANATION"
msgid "A creamy parfait loaded with fresh strawberries."
msgstr "Un parfait cremoso cargado de fresas frescas."

msgctxt "84802	EXPLANATION"
msgid "A sizable parfait loaded with rich, delicious chocolate."
msgstr "Un parfait grande cargado de chocolate rico y delicioso."

msgctxt "84859	EXPLANATION"
