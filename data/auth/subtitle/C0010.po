msgctxt "271	314"
msgid "Answer me!"
msgstr "¡Responde!"

msgctxt "315	450"
msgid "The day of that murder...\\nWhat were you doing at Sky Finance!?"
msgstr "El día del asesinato...\\n¿Qué estabas haciendo en Sky Finance?"

msgctxt "529	639"
msgid "Your goddamn prints were\\nall over the stiff's chin!"
msgstr "¡Tu huellas dactilares estaban\\npor todo el mentón del cadáver!"

msgctxt "640	739"
msgid "You ever hear of putting on gloves!?"
msgstr "¡¿Acaso no usaste guantes?!"

msgctxt "765	886"
msgid "Hey, jackoff.\\nYou listening to a word I'm saying?"
msgstr "Oye, idiota.\\n¿Estás escuchando lo que te estoy diciendo?"

msgctxt "948	1016"
msgid "I asked you a question, dammit!"
msgstr "¡Te hice una pregunta, maldita sea!"

msgctxt "1040	1111"
msgid "Yes... Come on!"
msgstr "Sí... ¡Vamos!"

msgctxt "1145	1205"
msgid "You got a screw loose, kid?"
msgstr "¿Qué demonios?"

msgctxt "1275	1302"
msgid "You little..."
msgstr "Hijo de..."

msgctxt "1310	1340"
msgid "Oh."
msgstr "Oh."

msgctxt "1347	1411"
msgid "What do you got piping in there!?"
msgstr "¡¿Qué rayos estás escuchando?!"

msgctxt "1464	1581"
msgid "Seriously? This look like time for horse racing?"
msgstr "¿En serio?\\n¿Una carrera de caballos en un momento como este?"

msgctxt "1593	1700"
msgid "They don't let you pull this\\nshit over in Community Safety, do they?"
msgstr "¡¿Qué mierda le pasa a la\\nDivisión de Seguridad Comunitaria?!"

msgctxt "1701	1795"
msgid "Hey, let's not blow up over nothing."
msgstr "Hey, no hay que exaltarnos por nada."

msgctxt "1857	1969"
msgid "Now we done here?\\nI have places to be."
msgstr "¿Hemos terminado?\\nNo tengo tiempo para esto."

msgctxt "1968	2028"
msgid "Oh, you're busy, huh?"
msgstr "¿No tienes tiempo?"

msgctxt "2084	2144"
msgid "Listen up, Tanimura."
msgstr "Oye, Tanimura."

msgctxt "2213	2258"
msgid "What now?"
msgstr "¿Ahora qué?"

msgctxt "2286	2363"
msgid "I've got a little tip for you."
msgstr "Tengo un pequeño consejo para ti."

msgctxt "2372	2466"
msgid "Don't stick your nose where it doesn't belong."
msgstr "No metas la nariz en lugares que no conoces."

msgctxt "2467	2536"
msgid "All you'll find is an early grave."
msgstr "Todo lo que encontrarás será tu muerte."

msgctxt "2542	2609"
msgid "Just like your old man."
msgstr "Justo igual que tu padre."

msgctxt "2753	2854"
msgid "What?\\nLooking at something?"
msgstr "¿Qué?\\n¿Qué estás mirando?"

msgctxt "2855	2979"
msgid "Nah, not really."
msgstr "No, nada."

msgctxt "3007	3071"
msgid "Thanks for the pointer."
msgstr "Gracias por el consejo."

msgctxt "3074	3129"
msgid "Where are you going?"
msgstr "¿A dónde vas?"

msgctxt "3130	3198"
msgid "On patrol, duh."
msgstr "A patrullar, obviamente."

msgctxt "3205	3307"
msgid "That's what Community Safety's all about, remember?"
msgstr "Eso es lo que hace la División de Seguridad Comunitaria."

msgctxt "3311	3372"
msgid "Not sure where the safety comes in."
msgstr "No sé a qué te refieres con patrullar."

msgctxt "3385	3546"
msgid "Last I heard your patrols \"are nothing more\\nthan shaking down illegal business for hush money.\""
msgstr "Escuché que tus patrullas no son más\"\\nque extorsión de negocios ilegales a cambio de tu silencio."

msgctxt "3549	3667"
msgid "Huh. My reputation precedes me."
msgstr "Bueno, lo dejo a tu imaginación."

msgctxt "3667	3728"
msgid "I'm out."
msgstr "Nos vemos."

msgctxt "3879	3939"
msgid "Parasite."
msgstr "¡Parásito!"

