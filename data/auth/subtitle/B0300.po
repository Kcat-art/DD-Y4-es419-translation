msgctxt "671	749"
msgid "Do it!"
msgstr "¡Date prisa y mátalo!"

msgctxt "764	864"
msgid "We wanna see him bleed!"
msgstr "¡Ya queremos verlo muerto!"

msgctxt "869	954"
msgid "Yeah, end that fool!"
msgstr "¡Así es, acábalo de una vez!"

msgctxt "959	1039"
msgid "I thought this was a deathmatch!"
msgstr "¡Pensé que esto era un combate a muerte!"

msgctxt "1044	1148"
msgid "The hell, man? Quit stalling!"
msgstr "¿Qué estás haciendo? ¡Ya mátalo!"

msgctxt "1153	1207"
msgid "Kill him!"
msgstr "¡Mátalo!"

msgctxt "1207	1259"
msgid "Kill him! Kill him!"
msgstr "¡Mátalo! ¡Mátalo!"

msgctxt "1259	1313"
msgid "Kill him! Kill him! Kill him!"
msgstr "¡Mátalo! ¡Mátalo! ¡Mátalo!"

msgctxt "1313	1385"
msgid "Kill him! Kill him! Kill him! Kill him!"
msgstr "¡Mátalo! ¡Mátalo! ¡Mátalo! ¡Mátalo!"

msgctxt "1447	1551"
msgid "You already buried 18 other poor saps!"
msgstr "¡Oye tonto, ya mataste a 18 personas!"

msgctxt "1552	1657"
msgid "What's the big deal adding one more!?"
msgstr "¡¿Cuál es el problema con matar a alguien más?!"

msgctxt "1662	1781"
msgid "What're you waiting for?\\nFinish him off!"
msgstr "¡¿Qué estás esperando?!\\n¡Mátalo de una vez!"

msgctxt "2841	2927"
msgid "Attaboy! It's time for some action!"
msgstr "¡Muy bien! ¡Termina con él!"

msgctxt "3751	3838"
msgid "Shut your fuckin' holes!"
msgstr "¡Cierren sus malditas bocas!"

msgctxt "3958	4109"
msgid "Which one of you lunatics said\\nkilling a guy's no big deal!?"
msgstr "¡¿Quién de ustedes dijo que no había\\nproblema con matar a alguien más?!"

msgctxt "4134	4194"
msgid "Was it you!?"
msgstr "¡¿Fuiste tú?!"

msgctxt "4276	4336"
msgid "Or you!?"
msgstr "¡¿O tú?!"

msgctxt "4414	4569"
msgid "Ya sit up there chantin' \"kill, kill, kill.\""
msgstr "Están ahí sentandos gritando \"mátalo, mátalo, mátalo\"."

msgctxt "4587	4757"
msgid "But how many of ya have\\ntaken a life with your own two hands!?"
msgstr "Pero, ¡¿cuántos de ustedes\\nrealmente a matado a alguien?!"

msgctxt "4883	5002"
msgid "Fuckin' hyenas.\\nLemme fill ya in on somethin'."
msgstr "¿Nadie?\\nEntonces les contaré como se siente."

msgctxt "5037	5112"
msgid "Killin' another man..."
msgstr "Matar a otra persona..."

msgctxt "5182	5269"
msgid "Watchin' them breathe their last breath..."
msgstr "Verlos morir..."

msgctxt "5322	5424"
msgid "It's a fuckin' nightmare!"
msgstr "¡Es una maldita pesadilla!"

msgctxt "5520	5700"
msgid "Been 25 years since that day...\\nbut I still remember it crystal clear."
msgstr "Han pasado 25 años desde ese día...\\npero todavía lo recuerdo muy claro."

msgctxt "5745	5833"
msgid "Every night I dream of those 18 guys."
msgstr "Todas las noches sueño con esas 18 personas."

msgctxt "5849	5937"
msgid "My fists bashin' their heads in."
msgstr "Mis puños golpeando sus rostros."

msgctxt "5958	6018"
msgid "The sound of bones crackin'."
msgstr "El sonido de sus huesos quebrándose."

msgctxt "6023	6083"
msgid "The screams."
msgstr "Sus gritos."

msgctxt "6103	6177"
msgid "The fear on their dyin' faces."
msgstr "El miedo en sus rostros moribundos."

msgctxt "6239	6334"
msgid "I've been relivin' it every single day."
msgstr "Sueño con ello todos los días."

msgctxt "6377	6525"
msgid "N' think about how their families felt.\\nIt must've been mortifyin'."
msgstr "Pienso en cómo se sintieron sus familias.\\nDebió haber sido muy doloroso."

msgctxt "6559	6668"
msgid "But that... That remorse..."
msgstr "Pero ese... Ese remordimiento..."

msgctxt "6673	6742"
msgid "It's nothin' next to the real horror!"
msgstr "¡No es nada comparado al verdadero horror!"

msgctxt "6861	6924"
msgid "Once ya snuff out a life..."
msgstr "Una vez que apagas una vida..."

msgctxt "6948	7088"
msgid "There's no escapin' the dread of what ya did!"
msgstr "¡No hay escapatoria al horror de tus acciones!"

msgctxt "7144	7277"
msgid "Day in, day out, I gotta relive that bloodbath!"
msgstr "¡Día tras día, tengo que revivir esa horrible matanza!"

msgctxt "7306	7451"
msgid "Any of you got a fuckin' idea what that's like!?"
msgstr "¡¿Alguno de ustedes sabe lo doloroso que es eso?!"

msgctxt "7534	7629"
msgid "This tournament's a crock o' shit."
msgstr "Este torneo es una tontería."

msgctxt "7694	7750"
msgid "I'm out."
msgstr "Estoy fuera."

