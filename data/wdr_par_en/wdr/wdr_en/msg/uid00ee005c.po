msgctxt "136_Owner of Kyushu No. 1 Star"
msgid "Welcome! What'll it be?"
msgstr "¡Bienvenido! ¿Qué va a pedir?"

msgctxt "160_Haruka"
msgid "Uncle Kaz! I'm really craving some ramen... Can I get some <Color:8>Kyushu Tonkotsu Ramen<Color:Default>?"
msgstr "Uncle Kaz! I'm really craving some ramen... Can I get some <Color:8>Kyushu Tonkotsu Ramen<Color:Default>?"

msgctxt "172_Kiryu"
msgid "(Haruka wants me to get her some <Color:8>Kyushu Tonkotsu Ramen<Color:Default>...)"
msgstr "(Haruka wants me to get her some <Color:8>Kyushu Tonkotsu Ramen<Color:Default>...)"

msgctxt "196_Haruka"
msgid "But I wanted that <Color:8>Kyushu Tonkotsu Ramen<Color:Default>..."
msgstr "But I wanted that <Color:8>Kyushu Tonkotsu Ramen<Color:Default>..."

msgctxt "208_Owner of Kyushu No. 1 Star"
msgid "Is that so? Well, I hope you actually order something next time!"
msgstr "Is that so? Well, I hope you actually order something next time!"

msgctxt "232_Haruka"
msgid "Thanks, Uncle Kaz! I can't wait to dig in!"
msgstr "Thanks, Uncle Kaz! I can't wait to dig in!"

msgctxt "400_Haruka"
