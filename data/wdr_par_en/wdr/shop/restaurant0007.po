msgctxt "428"
msgid "Quit"
msgstr "Salir"

msgctxt "433"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "451"
msgid "Order"
msgstr "Pagar"

msgctxt "457"
msgid "Order the currently selected item."
msgstr "Pagar el objeto seleccionado actualmente."

msgctxt "492"
msgid "(I haven't picked anything.)"
msgstr "(No he escogido nada)"

msgctxt "521"
msgid "(I'm short on cash.)"
msgstr "(Me hace falta dinero)"

msgctxt "542"
msgid "Thank you. Your total comes to %s."
msgstr "Gracias. El precio total es de %s."

msgctxt "577"
msgid "(I can't eat anymore...)"
msgstr "(No puedo comer más...)"

msgctxt "625"
msgid "The limited-edition Kamuro Burger: an enticing\n"
"combination of avocado, tomato, and cheese."
msgstr "La hamburguesa Kamuro de edición limitada: una tentadora\n"
"combinación de aguacate, tomate, y queso."

msgctxt "716"
msgid "Our classic burger set, with a Smile Burger, fries, and\n"
"a drink."
msgstr "Nuestro clásico combo, con una Hamburguesa Smile,\n"
"papas fritas y una bebida."

msgctxt "781"
msgid "This set includes a Smile Cheeseburger, fries, and a\n"
"drink."
msgstr "Este combo incluye una hamburguesa de queso Smile,\n"
"papas fritas y una bebida."

msgctxt "841"
msgid "This set includes a Teriyaki Smile Burger with special\n"
"sauce, fries, and a drink."
msgstr "Este combo incluye una hamburguesa Teriyaki Smile\n"
"con salsa especial, papas fritas y una bebida."

msgctxt "923"
msgid "As advertised, this set comes with a King Smile \n"
"Burger, fries, and a drink."
msgstr "Como se anuncia, este combo viene con una\n"
"Hamburguesa King Smile, papas fritas y una bebida."

msgctxt "1000"
msgid "A tasty Tuna Burger with a unique texture. Fries and \n"
"a drink come with this set."
msgstr "Una sabrosa hamburguesa de atún con una textura\n"
"única. Este combo incluye papas fritas y una bebida."

msgctxt "1082"
msgid "A tender, stewed pork burger with fries and a drink."
msgstr "Una tierna hamburguesa de cerdo estofado con papas fritas y una bebida."

msgctxt "1135"
msgid "A Smile Shake made with fresh milk. Sure to put a \n"
"smile on anyone's face."
msgstr "Un batido Smile hecho con leche fresca. Seguro que \n"
"hará sonreír a cualquiera."

msgctxt "1210"
msgid "The golden-fried standard of french fries. Served \n"
"with a smile."
msgstr "Las clásicas y doradas papas fritas. Servidas con una sonrisa."

