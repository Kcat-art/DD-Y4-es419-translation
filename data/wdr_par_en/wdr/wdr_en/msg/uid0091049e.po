msgctxt "72_Serene Man"
msgid "[What the...]"
msgstr "[Pero qué...]"

msgctxt "84_Tanimura"
msgid "[That was a professional assassin. GG definitely isn't fooling around.]"
msgstr "[Este es un asesino profesional. GG definitivamente va\n"\n"en serio.]"

msgctxt "96_Nair"
msgid "[So where is GG? Hm?]"
msgstr "[¿Entonces donde está GG?... ¿Mm?]"

msgctxt "108_Tanimura"
msgid "[What is it?]"
msgstr "[¿Qué es?]"

msgctxt "120_Nair"
msgid "[There's a note here on the phone...]"
msgstr "[Hay una nota en el teléfono...]"

msgctxt "132_Tanimura"
msgid "[Tower... Helipad... A time's written here too. I bet the \"tower\" refers to the Millennium Tower.]"
msgstr "[Helipuerto... Torre... Hay un horario escrito también. Apuesto\n"\n"a que por \"torre\" se refiere a la Torre Millennium.]"

msgctxt "144_Nair"
msgid "[The tallest building in Kamurocho, right? Let's get going then!]"
msgstr "[Ese es el edificio más alto de Kamurocho, ¿cierto? ¡Vamos!]"

msgctxt "156_Tanimura"
msgid "[Wait! We still have a few hours until the time written on the note.]"
msgstr "[¡Espera! Todavía faltan un par de horas antes de la que esta\n"\n"escrita en la nota.]"

msgctxt "168_Tanimura"
msgid "[If we get there first they might see us and run away, and then we're back to square one.]"
msgstr "[Si vamos ahora mismo y llegamos primeros, podrían vernos\n"\n"y huir. Terminaríamos volviendo donde empezamos.]"

msgctxt "180_Tanimura"
msgid "[We should wait here first and make our move right before things go down.]"
msgstr "[Debemos esperar aquí y actuar justo antes que las cosas se\n"\n"pongan feas.]"

msgctxt "192_Nair"
msgid "[...Okay.]"
msgstr "[... Está bien.]"

msgctxt "252_Tanimura"
msgid "[It's about time. Are you ready?]"
msgstr "[Ya va siendo hora. ¿Estás lista?]"

msgctxt "264_Nair"
msgid "[As ever. Let's go.]"
msgstr "[Siempre lo estoy. Vamos.]"

msgctxt "312_Serene Man"
msgid "[...So you came.]"
msgstr "[... Así que viniste.]"

msgctxt "324_Nair"
msgid "[You must be GG.]"
msgstr "[Tú debes ser GG.]"

msgctxt "336_Serene Man"
msgid "[No, the boss is already gone.]"
msgstr "[No, el jefe ya se ha ido.]"

msgctxt "348_Tanimura"
msgid "[What!?]"
msgstr "[¡¿Qué?!]"

msgctxt "360_Serene Man"
msgid "[He warned you, didn't he? He told you not to interfere any further.]"
msgstr "[Él te lo advirtió, ¿no? Dijo que ya no interfirieras más.]"

msgctxt "372_Serene Man"
msgid "[I'm going to take care of you now. You can die together, regretting your stupid mistakes as one.]"
msgstr "[Ahora yo me encargaré de ustedes. Podrán compartir la muerte\n"\n"lamentando el estúpido error que cometieron.]"

