msgctxt "1248"
msgid "Tadokoro's Subordinate"
msgstr "Subordinado de Tadokoro"

msgctxt "1252"
msgid "Saejima"
msgstr "Saejima"

msgctxt "1256"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "1260"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "128_Tadokoro's Subordinate"
msgid "Are you ready to take part in the special match tournament,\\r\n"\n"Suzuki-san?"
msgstr "¿Estás listo para participar en el torneo especial, Suzuki-san?"

msgctxt "140_Saejima"
msgid "Can ya hang on a sec? I mighta forgotten somethin'."
msgstr "¿Puedes esperar un segundo? Me olvidé de algo."

msgctxt "152_Tadokoro's Subordinate"
msgid "Yes, of course. Come see me when you've prepared."
msgstr "Sí, claro. Ven a verme cuando estés preparado."

msgctxt "164_Saejima"
msgid "Yeah, I'm good to go anytime."
msgstr "Sí, ya estoy listo."

msgctxt "176_Tadokoro's Subordinate"
msgid "Please proceed inside. The tourney is about to begin."
msgstr "Por favor, entre al coliseo. El torneo está a punto de empezar."

msgctxt "200_Tadokoro's Subordinate"
msgid "I'm good to go."
msgstr "Estoy listo."

msgctxt "212_Tadokoro's Subordinate"
msgid "Hang on a sec."
msgstr "Espera un segundo."

