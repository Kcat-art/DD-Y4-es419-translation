msgctxt "357	484"
msgid "Down, Mame!\\nBe a good boy and stop pulling."
msgstr "¡Quieto, Mame!\\nSé un buen chico y deja de tirar."

msgctxt "497	623"
msgid "Hey, Mame! What's wrong?\\nYou're usually so good."
msgstr "¡Hey, Mame! ¿Qué pasa?\\nUsualmente eres más obediente."

msgctxt "662	722"
msgid "Mame!"
msgstr "¡Mame!"

msgctxt "900	995"
msgid "What's gotten into you?"
msgstr "Mame qué tienes..."

