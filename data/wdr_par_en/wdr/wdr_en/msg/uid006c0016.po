msgstr "¡Uy, a mí me encanta eso! ♪"

msgctxt "18204_Shizuka"
msgid "Would you mind if I ate with you?"
msgstr "¿Le importa si como con usted?"

msgctxt "18216_Shizuka"
msgid "I like that quite a bit myself."
msgstr "I like that quite a bit myself."

msgctxt "18228_Shizuka"
