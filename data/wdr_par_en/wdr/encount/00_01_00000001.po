msgctxt "3680"
msgid "Man"
msgstr "Hombre"

msgctxt "3684"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "3688"
msgid "Sync_Send"
msgstr "Sync_Send"

msgctxt "3692"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "128_Man"
msgid "Hey... I need to borrow you for a sec..."
msgstr "Oye... Necesito que me ayudes un segundo..."

msgctxt "140_Man"
msgid "I'm all powered up from the gym, so I need you to be my test subject for my punches! Here comes the first swing!"
msgstr "¡Estoy lleno de energía por el gimnasio, así que necesito que seas mi sujeto de prueba para mis golpes! ¡Aquí viene el primer golpe!"

msgctxt "152_Man"
msgid "The hell you think you're doing, being all shiny and shit! You're a freaking eyesore! Hope you're ready to die!"
msgstr "¡¿Quien demonios te crees con todas esas cosas brillantes?! ¡Eres una molestia visual! ¡Espero que estés listo para morir!"

msgctxt "164_Man"
msgid "Looks like you're really asking for it!"
msgstr "¡Parece que te lo has buscado!"

msgctxt "176_Man"
msgid "Looks like ya took real good care of one of my men the other day."
msgstr "Parece que el otro día trataste muy bien a uno de mis hombres."

msgctxt "188_Man"
msgid "Ya wrinkly shit! I'm gonna shove my hand up yer ass and use ya like a puppet!"
msgstr "¡Viejo arrugado! ¡Te meteré la mano por el culo y te usaré como un títere!"

msgctxt "224_Man"
msgid "Aiee! No more!"
msgstr "¡Aaah! ¡No más!"

msgctxt "236_Man"
msgid "I'm sorry! Here's something for bothering you! Please take it!"
msgstr "¡Lo siento! ¡Aquí tienes algo por la molestia! ¡Por favor, tómalo!"

msgctxt "248_Man"
msgid "You got a beaten-up %s."
msgstr "Obtuviste un %s."

msgctxt "272_Man"
msgid "P-Please, no more kicks!"
msgstr "¡Po-Porfavor, no más patadas!"

msgctxt "284_Man"
msgid "Here..."
msgstr "Toma..."

msgctxt "296_Man"
msgid "You got a kick-weary %s."
msgstr "Obtuviste un %s."

msgctxt "320_Man"
msgid "Huh... Wha?"
msgstr "Eh... ¿Qué?"

msgctxt "332_Man"
msgid "Oh. Looks like I already lost... I didn't stand a chance."
msgstr "Oh. Parece que ya perdí... No tuve ninguna oportunidad."

msgctxt "344_Man"
msgid "You got a tasty %s."
msgstr "Obtuviste un %s."

msgctxt "392_Man"
msgid "Urgh... I didn't even stand a chance..."
msgstr "Urgh... ni siquiera tuve oportunidad..."

msgctxt "404_Man"
msgid "*pant* *pant*"
msgstr "*jadeo* *jadeo*"

msgctxt "416_Man"
msgid "It won't go like this next time, old man."
msgstr "No será así la próxima vez, viejo."

