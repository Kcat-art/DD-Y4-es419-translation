msgctxt "350\t410"
msgid "To be frank..."
msgstr "Para ser sincera..."

msgctxt "419\t547"
msgid "I don't really care whether or not\\nhe killed those eighteen men."
msgstr "Realmente no me importa si mató\\no no a esos dieciocho hombres."

msgctxt "548\t620"
msgid "Even if the real killer is still at large."
msgstr "No me importa..."

msgctxt "624\t692"
msgid "None of that matters."
msgstr "si el verdadero culpable está en otra parte."

msgctxt "712\t865"
msgid "Whatever happened...\\nTaiga is still my brother."
msgstr "Porque sin importar lo que haya pasado,\\nmi hermano seguirá siendo mi hermano."

msgctxt "980\t1064"
msgid "I need you to stay here for now."
msgstr "Necesito que te quedes aquí por ahora."

msgctxt "1070\t1176"
msgid "Try to relax, calm down a bit."
msgstr "Será mejor que te relajes en este lugar."

msgctxt "1226\t1278"
msgid "That's cold, Kiryu."
msgstr "¿Qué estás diciendo, Kiryu?"

msgctxt "1280\t1366"
msgid "Can't you see how bad she needs this?"
msgstr "Puedes notar lo desesperada que está por verlo..."

msgctxt "1371\t1523"
msgid "Yasuko-san. Imagine you found out\\nSaejima was already dead."
msgstr "Yasuko-san. Imagina descubrir\\nque Saejima ya está muerto."

msgctxt "1524\t1616"
msgid "What would you do then?"
msgstr "¿Qué es lo que harías?"

msgctxt "1703\t1812"
msgid "Take your own life?"
msgstr "¿Te quitarías tu propia vida?"

