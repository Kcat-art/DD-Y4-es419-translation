msgctxt "3716"
msgid "Morimoto"
msgstr "Morimoto"

msgctxt "3720"
msgid "Yamashita"
msgstr "Yamashita"

msgctxt "3724"
msgid "Saejima"
msgstr "Saejima"

msgctxt "3728"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "3732"
msgid "Talk_Chohatu"
msgstr "Talk_Chohatu"

msgctxt "56_Morimoto"
msgid "I'm gonna need stitches..."
msgstr "Voy a necesitar que me pongan puntos..."

msgctxt "68_Yamashita"
msgid "Saejima-san!"
msgstr "¡Saejima-san!"

msgctxt "92_Saejima"
msgid "Hey again. What's up?"
msgstr "Hola de nuevo. ¿Qué pasa?"

msgctxt "104_Yamashita"
msgid "I heard a commotion... Oh, it's them."
msgstr "Escuché un escandalo... Ah, son ellos."

msgctxt "116_Saejima"
msgid "Yeah, the guys from before."
msgstr "Sí, los de antes."

msgctxt "128_Morimoto"
msgid "Urk... It's that homeless worm!"
msgstr "Uff... ¡Es ese gusano sintecho!"

msgctxt "140_Yamashita"
msgid "Excuse me, do you mind if I have a word with them?"
msgstr "Disculpa, ¿te importa si tengo una charla con ellos?"

msgctxt "164_Saejima"
msgid "Don't get too close."
msgstr "No te acerques mucho."

msgctxt "176_Morimoto"
msgid "Ugh. What the crap are you lookin' at?"
msgstr "Ugh. ¿Qué mierda miras?"

msgctxt "188_Yamashita"
msgid "Won't you tell me why? Are you really doing this just for the hell of it?"
msgstr "¿Me dirías la razón? ¿Solo hacen esto por puro gusto?"

msgctxt "200_Yamashita"
msgid "The way you lashed out got me, well, I got to thinking there must be more to it. What's this really about?"
msgstr "La manera en la que me gritabas me dejó pensando que, bueno, tiene que haber algo más. ¿De qué se trata realmente?"

msgctxt "212_Morimoto"
msgid "Hmph. We're the real victims here, just like Iguchi-san."
msgstr "Hm. Nosotros somos las verdaderas victimas en todo esto, al igual que Iguchi-san."

msgctxt "224_Yamashita"
msgid "Did this Iguchi put you up to all this? What happened to him?"
msgstr "¿Este tal Iguchi les hizo hacer todo esto? ¿Qué le pasó?"

msgctxt "236_Morimoto"
msgid "......"
msgstr "......"

msgctxt "248_Saejima"
msgid "This is goin' nowhere fast. Just take me to this Iguchi guy."
msgstr "Esto no lleva a ninguna parte. Llévame a ver a ese tal Iguchi."

msgctxt "260_Morimoto"
msgid "And why should we do a thing you say?"
msgstr "¿Y por qué haríamos algo así?"

msgctxt "272_Saejima"
msgid "'Cause you can take me to him like a good boy, or you can get another ass-whuppin'. Your choice."
msgstr "Porque o me llevas a las buenas, o yo te llevo al hospital. Tu decides."

msgctxt "284_Morimoto"
msgid "Damn it... Fine! Follow me."
msgstr "Maldición... ¡Está bien! Sígueme."

msgctxt "296_Saejima"
msgid "C'mon, let's go."
msgstr "Bien, vamos."

