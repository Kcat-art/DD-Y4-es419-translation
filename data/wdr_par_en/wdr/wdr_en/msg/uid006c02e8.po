msgctxt "116_Chihiro"
msgid "Well, here we are! I wonder what I should order."
msgstr "¡Bueno, ya llegamos! Me pregunto que debería pedir."

msgctxt "128_Player"
msgid "Let's go in."
msgstr "Entremos."

