msgctxt "88_Saejima"
msgid "Whew..."
msgstr "Uf..."

msgctxt "100_Saejima"
msgid "Sorry, but I ain't gettin' caught. Not today."
msgstr "Lo siento, pero no me atraparás. Al menos no por Hoy."

msgctxt "112_Hamazaki"
msgid "You all right?"
msgstr "¿Estás bien?"

msgctxt "124_Saejima"
msgid "No problems here. How 'bout you?"
msgstr "Estoy más que bien. ¿Y tú?"

msgctxt "136_Hamazaki"
msgid "I've got everything I need. Let's roll."
msgstr "Tengo todo lo que necesito. Vamos al ruedo."

msgctxt "148_Saejima"
msgid "'Bout time."
msgstr "Ya era hora."

msgctxt "196_Saejima"
msgid "Finally here..."
msgstr "Por fin..."

msgctxt "256_Saejima"
msgid "You're not done yet? What gives?"
msgstr "¿Aún no has terminado? ¿Qué ocurre?"

msgctxt "268_Hamazaki"
msgid "None of this proves a damn thing! I need hard evidence!"
msgstr "¡Esto no prueba nada! ¡Necesito evidencias mas contundentes!"

msgctxt "304_Saejima"
msgid "Dammit!"
msgstr "¡Maldita sea!"

msgctxt "340_Prison Guards"
msgid "Stop right there! This is as far as you go!"
msgstr "¡Alto ahí! ¡Hasta aquí has llegado!"

