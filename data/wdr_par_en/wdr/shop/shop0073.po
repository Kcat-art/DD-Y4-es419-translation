msgctxt "224"
msgid "Quit"
msgstr "Salir"

msgctxt "229"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "247"
msgid "Order"
msgstr "Pagar"

msgctxt "253"
msgid "Order the currently selected item.  "
msgstr "Pedir el objeto actualmente seleccionado.  "

msgctxt "290"
msgid "(I haven't picked anything.)  "
msgstr "(No he escogido nada)"

msgctxt "321"
msgid "(I'm short on cash.)  "
msgstr "(Me hace falta dinero)"

msgctxt "344"
msgid "Thank you for business. %s, please."
msgstr "Gracias por hacer negocios. %s, por favor."

msgctxt "380"
msgid "(I can't carry any more stuff.)"
msgstr "(No puedo llevar más cosas)."

msgctxt "412"
msgid "(They're sold out.)"
msgstr "(Están agotados)."

msgctxt "432"
msgid "This should help increase your Heat when you're\n"
"feeling down."
msgstr "Esto debería aumentar tu Heat cuando estés desanimado."

msgctxt "494"
msgid "This will give you a bigger Heat boost than the regular\n"
"Tauriner."
msgstr "Esto te dará un aumento de Heat mayor que el Tauriner \n"
"habitual."

msgctxt "560"
msgid "Heat up this sake to really bring out its flavor.  That's\n"
"the only way to drink it if you ask me."
msgstr "Calienta este sake para sacar realmente su sabor. Es\n"
"la única manera de beberlo si me preguntas."

