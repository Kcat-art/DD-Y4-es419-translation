msgctxt "200"
msgid "You're amazing, Uncle Kaz!"
msgstr "¡Eres asombroso, tío Kaz!"

msgctxt "212"
msgid "You're like a real baseball player!"
msgstr "¡Eres como un jugador de béisbol de verdad!"

msgctxt "248"
msgid "Oh, you were so close!"
msgstr "Oh, estuviste tan cerca!"

msgctxt "260"
msgid "Let's try again!"
msgstr "¡Volvamos a intentarlo!"

msgctxt "272"
msgid "I wanted to see you get a home run..."
msgstr "Quería verte conseguir un home run..."

msgctxt "320"
msgid "Uncle Kaz!"
msgstr "¡Tío Kaz!"

msgctxt "332"
msgid "The Normal Game is open."
msgstr "La partida normal empezó."

