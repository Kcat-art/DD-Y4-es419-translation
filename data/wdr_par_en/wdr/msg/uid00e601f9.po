msgctxt "92_Saejima"
msgid "This young man is named Tadashi. He'd like a word with you, so please give him a second of your time."
msgstr "Este muchacho se llama Tadashi. Por favor, concédale\n"
"un minuto de su tiempo, quiere hablarle sobre algo."

msgctxt "104_Tadashi"
msgid "My sister... Akiko is here somewhere! Let her go!"
msgstr "Mi hermana... ¡Akiko está aquí en alguna parte! ¡Déjala ir!"

msgctxt "116_Takasu"
msgid "So you... You're Akiko's..."
msgstr "Así que tú... Eres él..."

msgctxt "140_?"
msgid "Stop!"
msgstr "¡Espera!"

msgctxt "152_Tadashi"
msgid "Akiko?"
msgstr "¿Akiko?"

msgctxt "164_Akiko"
msgid "Don't do anything bad to Uncle Tatsuya!"
msgstr "¡No hagan daño al tío Tatsuya!"

msgctxt "176_Tadashi"
msgid "Akiko!"
msgstr "¡Akiko!"

msgctxt "188_Akiko"
msgid "Tadashi? Tadashi, is that you?"
msgstr "¿Tadashi? Tadashi, ¿eres tú?"

