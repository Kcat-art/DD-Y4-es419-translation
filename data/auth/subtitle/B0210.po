msgctxt "120\t166"
msgid "Before I forget, Haruka."
msgstr "Por cierto, Haruka."

msgctxt "203\t328"
msgid "There's a bag over by the door.\\nI think it must be his."
msgstr "Hay una bolsa junto a la puerta.\\nCreo que le pertenece a este hombre."

msgctxt "362\t409"
msgid "I didn't see any bags."
msgstr "¿Había una bolsa?"

msgctxt "410\t485"
msgid "I found it on the beach."
msgstr "La encontré en la playa."

msgctxt "486\t590"
msgid "Once he's awake again,\\nI want you to give it to him."
msgstr "Una vez que se despierte,\\nquiero que se la entregues."

msgctxt "678\t738"
msgid "Okay... I will."
msgstr "Bien... Lo haré."

msgctxt "746\t806"
msgid "Thanks, Haruka."
msgstr "Bien, nos vemos luego."

