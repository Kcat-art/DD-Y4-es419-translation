msgctxt "49	109"
msgid "You know what?"
msgstr "Después de todo..."

msgctxt "113	181"
msgid "I'm not gonna arrest you."
msgstr "No serás arrestado."

msgctxt "308	442"
msgid "I'm turning in my badge, Deputy Commissioner."
msgstr "Esto es mi renuncia, Subcomisionado."

msgctxt "461	513"
msgid "What are you getting at?"
msgstr "¿Qué quieres decir?"

msgctxt "525	671"
msgid "What I'm about to do goes against\\npretty much every rule in the police handbook."
msgstr "Significa que mis acciones pueden ser\\nlas de un criminal, ya no soy de la policía."

msgctxt "710	773"
msgid "Spare me."
msgstr "Que tontería."

msgctxt "969	1060"
msgid "What can you do against all of these men?"
msgstr "¿Qué puedes hacer contra todos estos hombres?"

msgctxt "1061	1184"
msgid "You'll die like a dog.\\nJust as your father did."
msgstr "Morirás como un perro,\\nal igual que tu padre."

msgctxt "1198	1337"
msgid "Munakata-san. You just don't get it, do you?"
msgstr "Munakata-san. Realmente no entiendes nada."

msgctxt "1365	1614"
msgid "In this town, there are men who'll take down\\na hundred guys by themselves if they have to."
msgstr "En esta ciudad, hay personas que luchan solas.\\nAunque eso signifique enfrentarse con 100 o 200 enemigos."

msgctxt "1631	1690"
msgid "Like them."
msgstr "Personas como ellos."

