msgctxt "2200"
msgid "Player"
msgstr "Player"

msgctxt "2204"
msgid "Boxcelios"
msgstr "Boxcelios"

msgctxt "2208"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "128_Player"
msgid "(Boxcelios? Looks like an arcade shooter...)"
msgstr "(¿Boxcelios? Parece ser un shooter arcade...)"

msgctxt "140_Boxcelios"
msgid "Boxcelios puts you in the seat of an invincible fighter and challenges you to destroy as many enemies as possible before time runs out. Move your ship with <Action:Button_LS_Up@Shooting><Action:Button_LS_Down@Shooting><Action:Button_LS_Left@Shooting><Action:Button_LS_Right@Shooting>, and fire your laser cannons with <Action:Button_Cross@Shooting>."
msgstr "Boxcelios te pone al comando de un caza invencible y te desafía a derrotar tantos enemigos como sea posible antes que acabe el tiempo. Mueve tu nave con <Action:Button_LS_Up@Shooting><Action:Button_LS_Down@Shooting><Action:Button_LS_Left@Shooting><Action:Button_LS_Right@Shooting>, y dispara tus cañones láser con <Action:Button_Cross@Shooting>."

msgctxt "152_Boxcelios"
msgid "Shoot and destroy either the glowing core or the majority of enemy ships to take them down."
msgstr "Dispara y destruye el núcleo brillante o la mayoría de las naves enemigas para acabar con ellas."

msgctxt "164_Boxcelios"
msgid "Time stands still for two seconds after an enemy appears. Use this time to aim for the enemy's core for maximum efficiency."
msgstr "Time stands still for two seconds after an enemy appears. Use this time to aim for the enemy's core for maximum efficiency."

msgctxt "176_Player"
msgid "(Only 100 yen for one game of Boxcelios. Do I feel like blasting aliens?)"
msgstr "(Solo 100 yenes por una partida de Boxcelios. ¿Estoy listo para acabar con naves alienígenas?)"

msgctxt "200_Player"
msgid "(All right, let's do this.)"
msgstr "(Muy bien, empecemos.)"

msgctxt "224_Player"
msgid "(I don't have enough money...)"
msgstr "(No tengo suficiente dinero...)."

msgctxt "236_Player"
msgid "(Maybe later.)"
msgstr "(Tal vez más tarde)."

msgctxt "248_Player"
msgid "Play"
msgstr "Jugar"

msgctxt "260_Player"
msgid "Read the Instructions"
msgstr "Leer las instrucciones"

msgctxt "272_Player"
msgid "Don't Play"
msgstr "No jugar"

