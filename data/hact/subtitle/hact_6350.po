msgctxt "20	159"
msgid "Sorry, but you're out of touch\\nwith how this city works."
msgstr "Bueno, llegó el momento de\\nhacer una investigación de campo."

msgctxt "160	259"
msgid "How about I refresh your memory?"
msgstr "Espero que estés preparado,\\nserá tu primera vez en décadas."

msgctxt "271	364"
msgid "Don't just stand there!\\nCrush this rat!"
msgstr "¡Vayan!\\n¡Maten a ese tipo, rápido!"

msgctxt "420	480"
msgid "Deputy Commissioner... No."
msgstr "Subcomisionado... No."

msgctxt "490	556"
msgid "Seishiro Munakata!"
msgstr "¡Munakata Seishiro!"

msgctxt "557	640"
msgid "Your ambitions end here."
msgstr "Tus ambiciones terminan aquí."

msgctxt "645	705"
msgid "You're mine!"
msgstr "¡Prepárate!"

