msgctxt "1062	1194"
msgid "You... just don't know when to quit, huh?"
msgstr "Nunca pensé que llegarías tan lejos..."

msgctxt "1290	1340"
msgid "Have it your way."
msgstr "Está bien, te lo diré."

msgctxt "1357	1412"
msgid "Your old man?"
msgstr "El asesino de tu padre..."

msgctxt "1455	1511"
msgid "That was me."
msgstr "Fui yo."

msgctxt "1554	1602"
msgid "What?"
msgstr "¿Qué?"

msgctxt "1621	1700"
msgid "I'm the one who killed your dad."
msgstr "Yo fui el maldito que asesinó a tu padre..."

msgctxt "1730	1808"
msgid "And now you're next, kid!"
msgstr "¡Y también te voy a asesinar a ti!"

msgctxt "2136	2240"
msgid "No more running!"
msgstr "¡Ya no te dejaré escapar...!"

msgctxt "2324	2547"
msgid "You think some goddamn handcuffs...\\nis all it's gonna take!? Tanimura!"
msgstr "¡No creas que unas esposas son suficiente para atraparme!\\n¡Tanimura!"

