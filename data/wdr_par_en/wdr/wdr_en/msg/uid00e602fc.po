msgctxt "84_Street Punk"
msgid "Yo! Whaddya want, shit-for-brains?"
msgstr "¡Oye! ¿Qué quieres, imbécil de mierda?"

msgctxt "96_Saejima"
msgid "I'm here to take out the trash. Now get outta here.\\r\n"\n"On the double."
msgstr "Vine a sacar la basura. Ahora se me van yendo y rápido."

msgctxt "108_Street Punk"
msgid "Want us to leave? We're gonna need a going-away present."
msgstr "¿Quieres que nos vayamos? Nos vendría bien un regalo de despedida."

msgctxt "120_Saejima"
msgid "Shut the fuck up! My fist in your face is all\\r\n"\n"you freeloaders deserve!"
msgstr "¡Cierra la puta boca! ¡Hacerte comer mis puños es lo\n"\n"único que unos parásitos como ustedes merecen!"

