msgctxt "156_Tanimura"
msgid "Excuse me, I'd like to pass through here."
msgstr "Disculpe, quiero pasar por aquí."

msgctxt "168_Man"
msgid "這里是進入禁止。"
msgstr "這里是進入禁止。"

msgctxt "180_Tanimura"
msgid "(Doesn't look like he understands Japanese.)"
msgstr "(Creo que no entiende japonés)."

msgctxt "192_Tanimura"
msgid "\"Excuse me, are you Chinese?\"\\r\n"\n"　\"I'm a policeman. Could you let me through?\""
msgstr "\"Excuse me, are you Chinese?\"\\r\n"\n"　\"I'm a policeman. Could you let me through?\""

msgctxt "204_Man"
msgid "\"Oh, shoot, really? Sure, you can go right ahead.\""
msgstr "\"Oh, shoot, really? Sure, you can go right ahead.\""

msgctxt "276_Kiryu"
msgid "Wait... I thought this was a passageway."
msgstr "Wait... I thought this was a passageway."

msgctxt "288_Akiyama"
msgid "Hey there. Think you could move out of my way?"
msgstr "Disculpe. ¿Podría dejarme pasar?"

msgctxt "300_Saejima"
msgid "Hey, think you could let me through?"
msgstr "Hey, think you could let me through?"

msgctxt "312_Tanimura"
msgid "This place definitely wouldn't have been chosen."
msgstr "Este lugar definitivamente no habría sido elegido."

msgctxt "324_Man"
msgid "這里是進入禁止。"
msgstr "這里是進入禁止。"

msgctxt "348_Kiryu"
msgid "(A foreigner... Doesn't look like he understands Japanese, or wants to let me through.)"
msgstr "(Un extranjero... No parece que entienda japonés o que me vaya a dejar pasar)."

msgctxt "360_Akiyama"
msgid "(Doesn't look like he speaks Japanese, or wants to let me through.)"
msgstr "(No parece que entienda japonés o que me vaya a dejar pasar)."

msgctxt "372_Saejima"
msgid "(Doesn't speak Japanese, huh? Looks like the inside's just a kitchen, so no reason for me to go forcin' my way in there.)"
msgstr "(Doesn't speak Japanese, huh? Looks like the inside's just a kitchen, so no reason for me to go forcin' my way in there.)"

msgctxt "384_Tanimura"
msgid "This place definitely wouldn't have been chosen."
msgstr "Este lugar definitivamente no habría sido elegido."

