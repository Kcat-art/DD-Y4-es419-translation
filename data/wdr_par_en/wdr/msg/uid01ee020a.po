msgctxt "188"
msgid "Go to the rooftop?"
msgstr "¿Ir a la azotea?"

msgctxt "1408"
msgid "Akiyama"
msgstr "Akiyama"

msgctxt "1412"
msgid "Player"
msgstr "Player"

msgctxt "176_Akiyama"
msgid "(This is where I'm supposed to meet up with Kido-chan. Guess I should start climbing.)"
msgstr "(Aquí es donde se supone que me iba a reunir con Kido-chan. Debería empezar a subir)."

msgctxt "200_Akiyama"
msgid "(Maybe later.)"
msgstr "(Tal vez más tarde)."

msgctxt "212_Akiyama"
msgid "(Okay, I better go see what Kido-chan wants.)"
msgstr "(Muy bien, hora de ver lo que Kido-chan quiere)."

msgctxt "236_Player"
msgid "(I'm not alone right now... Would be dangerous to take them to the rooftop with me.)"
msgstr "(No estoy solo ahora... Sería peligroso que me acompañe a la azotea)."

msgctxt "248_Player"
msgid "(It's dangerous to go to the rooftops in the rain. I shouldn't do that right now.)"
msgstr "(Es peligroso ir a los tejados cuando llueve. Mejor no)."

msgctxt "272_Akiyama"
msgid "Yes"
msgstr "Sí"

msgctxt "284_Akiyama"
msgid "No"
msgstr "No"

