msgctxt "1388"
msgid "Tsugawa"
msgstr "Tsugawa"

msgctxt "1392"
msgid "Tanimura"
msgstr "Tanimura"

msgctxt "1396"
msgid "Talk_Away"
msgstr "Talk_Away"

msgctxt "56_Tsugawa"
msgid "...Tanimura!?"
msgstr "... ¿¡Tanimura!?"

msgctxt "68_Tanimura"
msgid "So you're Tsugawa?"
msgstr "¿Así que tú eres Tsugawa?"

msgctxt "80_Tsugawa"
msgid "Hmph. So you came all this way, just to run into a literal dead end."
msgstr "Tsk. Así que viniste hasta aquí solo para llegar a un callejón sin salida."

msgctxt "92_Tsugawa"
msgid "Look, pal. You're in deep shit. And I mean the deep end of deep shit. You're in over your head in shit. In fact, you're about to be buried in it, just like that corpse of a writer."
msgstr "Mira, amigo. Estás en un buen lío. Y hablo de un lío de los grandes. Estás completamente metido en un problema que no sabes ni cómo manejar. De hecho, estás a punto de ser enterrado en él, como ese cadáver del escritor."

