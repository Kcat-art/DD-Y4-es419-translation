msgctxt "262\t324"
msgid "Take a look at this."
msgstr "Echa un vistazo a esto."

msgctxt "475\t650"
msgid "\"Tojo Clan: Destroyed\"\\n\"Kamurocho Hills → Ueno Seiwa Clan → Tokyo PD\""
msgstr "\"Clan Tojo: Destruído\"\\n\"Kamurocho Hills → Clan Ueno Seiwa → DP de Tokyo\""

msgctxt "725\t810"
msgid "With guys like us out in the cold..."
msgstr "Ahora que nosotros no estamos presentes..."

msgctxt "813\t898"
msgid "There's nowhere for the Tojo to go but down."
msgstr "Algo loco va a suceder con el Tojo Clan."

msgctxt "956\t1016"
msgid "Listen to me, Kiryu."
msgstr "Escúchame, Kiryu."

msgctxt "1037\t1167"
msgid "You gotta take the reins of that Kamurocho bull."
msgstr "Te pido que te pares una vez más en la cima de la ciudad."

msgctxt "1263\t1323"
msgid "Because if you don't..."
msgstr "De lo contrario..."

msgctxt "1330\t1547"
msgid "The clan we've spent our lives propping up...\\nis gonna get trampled to death."
msgstr "El clan por el que arriesgamos nuestras vidas...\\nDesaparecerá."

