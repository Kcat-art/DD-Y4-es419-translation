msgctxt "232"
msgid "I'll draw a card."
msgstr "Sacaré una carta."

msgctxt "244"
msgid "I'll stay with this hand."
msgstr "Me quedaré con esta mano."

msgctxt "256"
msgid "You can double your bet, but you must draw one more card."
msgstr "Puedes doblar tu apuesta, pero debes pedir una carta más."

msgctxt "268"
msgid "Split your hand in two. The second hand will mirror your current bet."
msgstr "Divida la mano en dos. La segunda mano reflejará su apuesta actual."

msgctxt "280"
msgid "Folding at this point will return half of your current bet."
msgstr "Retirarse en este momento le devolverá la mitad de su apuesta actual."

msgctxt "292"
msgid "Set half the bet amount as insurance against the dealer getting a blackjack."
msgstr "Establezca la mitad de la cantidad de apuesta como seguro contra el crupier si obtiene un blackjack."

msgctxt "304"
msgid "Refer to the bet limit to see how many chips you can bet."
msgstr "Consulte el límite de apuesta para ver cuántas fichas puede apostar."

msgctxt "316"
msgid "Play by betting the same amount as in the last game."
msgstr "Juega apostando la misma cantidad que en la última partida."

msgctxt "328"
msgid "Standard Blackjack\\r\n"\n"Reward: 2,000 chips"
msgstr "Blackjack estándar\\r\n"\n"Recompensa: 2.000 fichas"

msgctxt "340"
msgid "Blackjack using a deck with no 2, 3, or 4 cards.\\r\n"\n"Reward: 2,500 chips"
msgstr "Blackjack usando una baraja sin cartas 2, 3 o 4.\\r\n"\n"Bonificación: 2.500 fichas"

msgctxt "352"
msgid "Blackjack using a deck with no 7, 8, or 9 cards.\\r\n"\n"Reward: 2,000 chips"
msgstr "Blackjack usando una baraja sin cartas 7, 8 o 9.\\r\n"\n"Bonificación: 2.000 fichas"

msgctxt "364"
msgid "Blackjack using a deck with no J, Q, or K cards.\\r\n"\n"Reward: 4,000 chips"
msgstr "Blackjack usando una baraja sin cartas J, Q o K.\\r\n"\n"Bonificación: 4.000 fichas"

