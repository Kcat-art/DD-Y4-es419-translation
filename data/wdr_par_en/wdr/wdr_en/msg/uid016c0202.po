msgstr "Solo quería verte..., ahora estoy emocionada."

msgctxt "2748_Chihiro"
msgid "I'll wait for you in Theater Square."
msgstr "Lo esperaré en la Plaza del Teatro."

msgctxt "2760_Player"
msgid "Theater Square. Got it."
msgstr "¿Plaza del Teatro? Está bien."

msgctxt "2772_Chihiro"
msgid "Great! Don't be late, promise?"
msgstr "¡Genial! No tarde, ¿sí?"

