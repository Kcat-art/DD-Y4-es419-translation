msgctxt "100	159"
msgid "End of the line!"
msgstr "¡No tienes escapatoria!"

msgctxt "180	288"
msgid "Bullshit it is!\\nYou want the kid to get it!?"
msgstr "¡Es una mierda!\\n¡¿Quieres que el niño lo entienda?!"

msgctxt "293	326"
msgid "Answer me."
msgstr "Respóndeme."

msgctxt "325	465"
msgid "Which wire should I cut?\\nThe blue one or the red one!?"
msgstr "¿Qué cable debo cortar?\\n¡¿El azul o el rojo?!"

msgctxt "493	533"
msgid "Just drop the piece, lady!"
msgstr "¡Suelte la pistola, señorita!"

msgctxt "536	589"
msgid "You want a dead kid on your hands?"
msgstr "¿Acaso quieres un niño muerto sobre tu conciencia?"

msgctxt "1210	1240"
msgid "Take this!"
msgstr "Toma esto!"

msgctxt "1320	1350"
msgid "You... pervert!"
msgstr "¡Serás pervertido!"

