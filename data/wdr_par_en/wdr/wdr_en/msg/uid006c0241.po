msgctxt "116_Chihiro"
msgid "I can't wait to eat! What should I get first? Maybe tuna? Octopus? Or salmon roe!"
msgstr "¡No puedo esperar para comer! ¿Qué debería pedir primero? ¿Atún? ¿Quizá pulpo? ¡¿O mejor salmón?!"

msgctxt "128_Talk_Yes"
msgid "Come on, let's go inside!"
msgstr "¡Vamos, entremos!"

msgctxt "152_Chihiro"
msgid "I can't wait to eat! What should I get first? Maybe tuna? Octopus? Or salmon roe!"
msgstr "¡No puedo esperar para comer! ¿Qué debería pedir primero? ¿Atún? ¿Quizá pulpo? ¡¿O mejor salmón?!"

msgctxt "164_Player"
msgid "Hold on a sec... Um, looks like I'm low on cash."
msgstr "Un segundo... Mmm, parece que no tengo dinero."

msgctxt "176_Chihiro"
msgid "What? You are!?"
msgstr "¿Qué? ¡¿En serio?!"

msgctxt "188_Player"
msgid "Yeah. Sorry."
msgstr "Sí. Lo siento."

msgctxt "200_Chihiro"
msgid "That's a shame. I guess that's it today.\\r\n"\n"\\r\n"\n"Goodbye for now."
msgstr "Es una pena. Supongo que esto será todo por hoy.\\r\n"\n"\\r\n"\n"Nos vemos."

msgctxt "212_Player"
msgid "(I better find some money...)"
msgstr "(Será mejor que encuentre algo de dinero...)."

msgctxt "320_Chihiro"
msgid "That was so yummy! I think I ate too much, though."
msgstr "¡Estuvo delicioso! Aunque, creo que comí de más."

msgctxt "332_Player"
msgid "Heh, I'm glad you liked it."
msgstr "Je, me alegra que te haya gustado."

msgctxt "344_Chihiro"
msgid "Thank you."
msgstr "Gracias."

msgctxt "368_Talk_Ojigi"
msgid "See you at the club! <Color:7>♥<Color:Default>"
msgstr "¡Nos vemos en el club! <Color:7>♥<Color:Default>"

msgctxt "392_Chihiro"
msgid "That was great kappamaki. I haven't eaten like that in a while."
msgstr "Ese kappamaki estaba muy bueno. Hace mucho que no como de esa manera."

msgctxt "404_Player"
msgid "Heh, that's good."
msgstr "Je, me alegro."

msgctxt "416_Chihiro"
msgid "I'll see you at the club!"
msgstr "¡Nos vemos en el club!"

msgctxt "440_Chihiro"
msgid "......"
msgstr "......"

msgctxt "452_Player"
msgid "What's wrong?"
msgstr "¿Qué ocurre?"

msgctxt "464_Chihiro"
msgid "I didn't really care for the food..."
msgstr "No me gusto la comida..."

msgctxt "476_Player"
msgid "You didn't? Oh..."
msgstr "Ah, ¿no?..."

msgctxt "488_Chihiro"
msgid "Well, I should be going. I'll see you at the club."
msgstr "Bueno, ya debería irme. Nos vemos en el club."

