msgctxt "3329\t3409"
msgid "So, who do you think's gonna show?"
msgstr "Entonces, ¿quién crees que vendrá?"

msgctxt "3418\t3470"
msgid "Don't matter to me."
msgstr "No importa quién."

msgctxt "3475\t3535"
msgid "Might be Munakata.\\nMight be Arai."
msgstr "Podría ser Munakata.\\nPodría ser Arai."

msgctxt "3561\t3656"
msgid "I'm not lettin' anyone\\nfuck with the Tojo Clan."
msgstr "No dejaré que nadie\\ndestruya o se meta con el Clan Tojo."

msgctxt "3740\t3811"
msgid "Well, let's get moving."
msgstr "Bueno, vamos."

