msgctxt "7208"
msgid "Hana"
msgstr "Hana"

msgctxt "280_Akiyama"
msgid "(That settles that... Now I just have to do what I have to.)"
msgstr "(Eso ya está... Ahora solo tengo que hacer lo que tengo que hacer)."

msgctxt "364_Akiyama"
msgid "(Thanks, Hana-chan. It was fun.)"
msgstr "(...Gracias, Hana-chan. Fue divertido)."

msgctxt "436_Akiyama"
msgid "(All right... Let's go do this!)"
msgstr "(Bueno... ¡Me voy a hacer mis cosas!)."

msgctxt "460_Akiyama"
msgid "(I think that settles that.)"
msgstr "(Creo que eso ya está resuelto)."

msgctxt "472_Akiyama"
msgid "(It's a little lonely without Hana-chan in the office. Maybe I'll reminisce about the good old days...)"
msgstr "(Está un poco solitaria la oficina sin Hana-chan. Tal vez me ponga a recordar los buenos tiempos...)."

msgctxt "484_Akiyama"
msgid "(Now, what to do...)"
msgstr "(Ahora, ¿Qué hago...)."

msgctxt "496_Akiyama"
msgid "(Maybe later.)"
msgstr "(Tal vez más tarde)."

msgctxt "508_Akiyama"
msgid "(That settles that... Now I just have to do what I have to.)"
msgstr "(Eso ya está... Ahora solo tengo que hacer lo que tengo que hacer)."

msgctxt "676_Akiyama"
msgid "(I'll think about the good old days, just for a little bit...)"
msgstr "(...Tal vez me ponga a pensar un poco en los viejos tiempos...)."

msgctxt "832_Hana"
msgid "What is it, boss? Hold on, are you off to play pachinko again!?"
msgstr "¿Qué pasa, jefe? ¡Espera, ¿vas a ir a jugar pachinko otra vez?!"

msgctxt "844_Akiyama"
msgid "...Yeah, you got me. Anyway, I'm off."
msgstr "...Sí, sera un ratito. Voy y vengo."

msgctxt "880_Akiyama"
msgid "(Should I rest until dusk...?)"
msgstr "(¿Debería descansar hasta el atardecer...?)."

msgctxt "892_Akiyama"
msgid "(Should I rest until evening...?)"
msgstr "(¿Debería descansar hasta la noche...?)."

msgctxt "904_Akiyama"
msgid "(Maybe I should rest until tomorrow morning.)"
msgstr "(Quizá debería descansar hasta mañana por la mañana)."

msgctxt "916_Akiyama"
msgid "(Not right now...)"
msgstr "(Ahora no...)"

msgctxt "976_Akiyama"
msgid "Reminisce about Hana-chan"
msgstr "Recordar a Hana-chan"

msgctxt "988_Akiyama"
msgid "I've settled things."
msgstr "Ya dejé todo en orden."

msgctxt "1000_Akiyama"
msgid "Rest for a While"
msgstr "Descansar un Rato"

msgctxt "1012_Akiyama"
