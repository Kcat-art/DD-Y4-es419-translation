msgctxt "428"
msgid "Quit"
msgstr "Salir"

msgctxt "433"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "451"
msgid "Order"
msgstr "Pagar"

msgctxt "457"
msgid "Order the currently selected item."
msgstr "Pagar el objeto seleccionado actualmente."

msgctxt "492"
msgid "(I haven't picked anything.)"
msgstr "(No he escogido nada)"

msgctxt "521"
msgid "(I'm short on cash.)"
msgstr "(Me hace falta dinero)"

msgctxt "542"
msgid "Thank you. Your total comes to %s."
msgstr "Gracias. El precio total es de %s."

msgctxt "577"
msgid "(I can't eat anymore...)"
msgstr "(No puedo comer más...)"

msgctxt "625"
msgid "Our limited-edition black gelato. Looks can be\n"
"deceiving: it's actually chock-full of fruity flavor."
msgstr "Nuestro helato negro de edición limitada. Las apariencias pueden\n"
"engañar: en realidad tiene un fuerte sabor frutal."

msgctxt "726"
msgid "A single scoop of our popular vanilla gelato made \n"
"with real vanilla beans."
msgstr "Una cucharada de nuestro popular helado de vainilla elaborado\n"
"con auténticas vainas de vainilla."

msgctxt "802"
msgid "Strawberry gelato is especially popular with girls for \n"
"its uniquely sweet and tangy flavor."
msgstr "El helado de fresa es especialmente popular entre las\n"
"chicas por su inigualable sabor dulce y ácido."

msgctxt "895"
msgid "A single scoop of chocolate gelato. Its slightly bitter \n"
"taste is popular with adults."
msgstr "Una bola de helado de chocolate. Su sabor ligeramente amargo es popular entre los adultos."

msgctxt "982"
msgid "Popular gelato made with sweet azuki beans. Loved \n"
"by all ages."
msgstr "Helado popular elaborado con judías azuki dulces.\n"
"Popular entre todas las edades."

msgctxt "1046"
msgid "Who doesn't enjoy the sweet, sugary taste of caramel\n"
"gelato?"
msgstr "¿A quién no le gusta el sabor dulce y azucarado del\n"
"helado de caramelo?"

msgctxt "1107"
msgid "A single scoop of coffee gelato made with \n"
"high-quality mocha bean extract."
msgstr "Una cucharada de helado de café elaborado con \n"
"extracto de granos de moca de alta calidad."

msgctxt "1183"
msgid "Can't decide on one flavor? Get two with a double \n"
"scoop!"
msgstr "¿No puedes decidirte por un solo sabor? Pues\n"
"¡Obtén dos con una doble bola!"

msgctxt "1241"
msgid "Three flavors at once? Someone's feeling \n"
"adventurous."
msgstr "¿Tres sabores a la vez? Alguien se siente \n"
"aventurero."

