msgctxt "285\t347"
msgid "Kiryu-san..."
msgstr "Kiryu-san..."

msgctxt "365\t547"
msgid "This town looks the same as always...\\nbut I can tell something's not right here."
msgstr "A simple vista todo parece normal...\\n, pero hay algo diferente en Kamurocho."

msgctxt "715\t805"
msgid "There's no time to waste."
msgstr "No hay tiempo que perder."

msgctxt "810\t879"
msgid "Let's go find your brother."
msgstr "Hay que encontrar a tu hermano, pronto."

msgctxt "899\t940"
msgid "Right."
msgstr "Entendido."

msgctxt "943\t1013"
msgid "But before we do..."
msgstr "Pero antes de eso..."

msgctxt "1017\t1094"
msgid "There's something I need to ask you."
msgstr "Hay algo que tengo que decirte."

msgctxt "1111\t1190"
msgid "Follow me."
msgstr "Ven conmigo un momento."

