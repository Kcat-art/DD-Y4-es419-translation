msgid "Akiyama"
msgstr "Akiyama"

msgctxt "1076"
msgid "Saejima"
msgstr "Saejima"

msgctxt "116_Akiyama"
msgid "(Need to focus on the barkers right now. No time for detours.)"
msgstr "(...Ahora debo concentrarme en atraer clientes. No es momento para andar perdiendo el tiempo)."

msgctxt "152_Saejima"
msgid "(Ain't got no time for this... I should probably follow Kido.)"
msgstr "(Ahora no es momento para desviarme... Mejor sigo a Kido)."

msgctxt "176_Saejima"
msgid "(Looks like a burger joint. Ain't sure if it was the same place, but I think there was one here around 25 years ago, too.)"
msgstr "(¿Esto es una hamburguesería?, No sé si será el mismo, pero recuerdo que había uno aquí hace 25 años)."

