msgctxt "2160"
msgid "Kiryu"
msgstr "Kiryu"

msgctxt "2164"
msgid "Player"
msgstr "Player"

msgctxt "2168"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "2172"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "100_Kiryu"
msgid "You should rest up, %s. I'd be glad to take over for you if you need it."
msgstr "Deberías descansar, %s. Estaré encantado de hacerme cargo de todo."

msgctxt "124_Player"
msgid "I'll be okay on my own for now."
msgstr "Estaré bien por ahora."

msgctxt "136_Player"
msgid "Sorry, gonna have to pass."
msgstr "Lo siento, voy a tener que pasar."

msgctxt "148_Player"
msgid "I'm good."
msgstr "Estoy bien."

msgctxt "160_Player"
msgid "Nah, I'm fine."
msgstr "No, estoy bien."

msgctxt "172_Kiryu"
msgid "Right. Try not to overdo it."
msgstr "Bien, intenta no exagerar."

msgctxt "196_Player"
msgid "That's a good idea. Go ahead."
msgstr "Buena idea. Adelante."

msgctxt "208_Player"
msgid "Sure, why not. I'm always down to chill for a bit."
msgstr "Claro, por qué no. Siempre estoy dispuesto a relajarme un poco."

msgctxt "220_Player"
msgid "Guess I don't mind catchin' my breath."
msgstr "Supongo que no me importa recuperar el aliento."

msgctxt "232_Player"
msgid "All right, I'll let you take things from here."
msgstr "Muy bien, dejaré que tomes las riendas a partir de aquí."

msgctxt "244_Kiryu"
msgid "Okay, take it easy for a while. I'll be back soon."
msgstr "Está bien, tómalo con calma un rato. Volveré pronto."

msgctxt "268_Kiryu"
msgid "Cancel"
msgstr "Cancelar"

msgctxt "280_Kiryu"
msgid "Switch to Kiryu"
msgstr "Cambiar a Kiryu"

