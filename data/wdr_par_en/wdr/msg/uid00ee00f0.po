msgctxt "216_Gambler"
msgid "Ya need at least 200 tags to play koi-koi. You can buy 'em at the front."
msgstr "Necesitas al menos 200 etiquetas para jugar al koi-koi. Puedes comprarlas en la entrada."

msgctxt "228_Gambler"
msgid "Hey, buddy! Wanna play koi-koi?"
msgstr "¡Oye, colega! ¿Quieres jugar al koi-koi?"

msgctxt "252_Haruka"
msgid "Hey, Uncle Kaz, can we play some koi-koi? You should try to get 500 points in a game!"
msgstr "Hey, Tío Kaz, ¿podemos jugar al koi-koi? ¡Deberías intentar conseguir 500 puntos en una partida!"

msgctxt "264_Kiryu"
msgid "(500 points in koi-koi... Should I give it a go?)"
msgstr "(500 puntos en koi-koi... ¿Debería intentarlo?)"

msgctxt "276_Gambler"
msgid "Sure, I'll play."
msgstr "Claro, jugaré."

msgctxt "288_Gambler"
msgid "You got it! Let's do this!"
msgstr "¡Muy bien! ¡Hagámoslo!"

msgctxt "300_Haruka"
msgid "Good luck, Uncle Kaz!"
msgstr "¡Buena suerte, Tío Kaz!"

msgctxt "324_Gambler"
msgid "Not right now."
msgstr "Ahora no."

msgctxt "336_Gambler"
msgid "I gotcha. Maybe next time."
msgstr "Entendido. Tal vez la próxima vez."

msgctxt "348_Haruka"
msgid "Aw, man! I wanted to watch you play koi-koi..."
msgstr "¡Awwww! Quería verte jugar koi-koi..."

msgctxt "360_Haruka"
msgid "Hey, Uncle Kaz! I bet you could get 1,000 points in koi-koi! C'mon, let's do it!"
msgstr "¡Hey, Tío Kaz! Apuesto a que podrías conseguir 1.000 puntos en koi-koi! ¡Vamos, hagámoslo!"

