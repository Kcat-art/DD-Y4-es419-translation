msgctxt "132_Bookie"
msgid "We'll need you to buy wooden tags if you want to play here. How many would you like? One tag is 100 yen."
msgstr "Necesitaremos que compres etiquetas de madera si quieres jugar aquí. ¿Cuántas quieres? Una etiqueta cuesta 100 yenes."

msgctxt "144_Bookie"
msgid "I'll take 50 tags."
msgstr "Tomaré 50 etiquetas."

msgctxt "168_Bookie"
msgid "Okay, here you go. Have fun!"
msgstr "Bien, aquí tienes. ¡Que te diviertas!"

msgctxt "192_Bookie"
msgid "I'll take 100 tags."
msgstr "Tomaré 100 etiquetas."

msgctxt "216_Bookie"
msgid "Okay, here you go. Have fun!"
msgstr "Bien, aquí tienes. ¡Que te diviertas!"

msgctxt "240_Bookie"
msgid "I'll take 1,000 tags."
msgstr "Tomaré 1.000 etiquetas."

msgctxt "264_Bookie"
msgid "Okay, here you go. Have fun!"
msgstr "Bien, aquí tienes. ¡Que te diviertas!"

msgctxt "288_Bookie"
msgid "I'm fine for now."
msgstr "Por ahora estoy bien."

msgctxt "300_Bookie"
msgid "Well, all right. But I hope you'll buy some next time."
msgstr "Bueno, está bien. Pero espero que compres un poco la próxima vez."

msgctxt "312_Bookie"
msgid "Hey, you don't have enough to pay for that! Come back when you got money."
msgstr "¡Oye, no tienes suficiente para pagar eso! Vuelve cuando tengas dinero."

msgctxt "324_Bookie"
msgid "Buy 50 Tags for 5,000 Yen"
msgstr "Comprar 50 Etiquetas por 5.000 Yenes"

msgctxt "336_Bookie"
msgid "Buy 100 Tags for 10,000 Yen"
msgstr "Comprar 100 Etiquetas por 10.000 Yenes"

msgctxt "348_Bookie"
msgid "Buy 1,000 Tags for 100,000 Yen"
msgstr "Comprar 1.000 Etiquetas por 100.000 Yenes"

msgctxt "360_Bookie"
msgid "Never Mind"
msgstr "No importa"

