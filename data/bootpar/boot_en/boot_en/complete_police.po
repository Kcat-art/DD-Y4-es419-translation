msgctxt "210	NAME"
msgid "Police Scanner"
msgstr "Escáner policial"

msgctxt "249	EXPLANATION"
msgid "Help Akaishi and the Kamurocho Guard by solving the cases\n"
"you receive on the police scanner."
msgstr "Ayuda a Akaishi y a la policía de Kamurocho resolviendo los casos\n"
"que recibes en el escáner de la policía."

msgctxt "342	EXPLANATION"
msgid "Akaishi and the Kamurocho are in trouble. Help them out."
msgstr "Akaishi y la policía están en problemas. Ayúdalos."

msgctxt "399	EXPLANATION"
msgid "You helped Akaishi and the Kamurocho Guard by solving the\n"
"cases you received on the scanner."
msgstr "Ayudaste a Akaishi y a la policía de Kamurocho a resolver los\n"
"casos del escáner."

