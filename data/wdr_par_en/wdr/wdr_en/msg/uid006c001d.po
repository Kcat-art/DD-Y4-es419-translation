msgctxt "17940_Rio"
msgid "Oh, but..."
msgstr "Oh, pero..."

msgctxt "17952_Rio"
msgid "I have the feeling I'm not the only girl you've said that to."
msgstr "Tengo la sensación de que no soy la única a la que le ha dicho eso."

msgctxt "17964_Akiyama"
msgid "No, you're the first! I swear."
msgstr "No, tu eres la primera. Lo juro."

msgctxt "17976_Rio"
msgid "I believe you even less now."
msgstr "Ahora le creo mucho menos."

msgctxt "17988_Akiyama"
msgid "......"
msgstr "......"

msgctxt "18000_Rio"
msgid "Hehehe. Akiyama-saaan. <Color:7>♥<Color:Default>"
msgstr "Je,je,je. Akiyama‑saaaan. <Color:7>♥<Color:Default>"

