msgctxt "199	259"
msgid "This the place?"
msgstr "¿Este es el lugar?"

msgctxt "1366	1426"
msgid "You first."
msgstr "Tú primero."

msgctxt "1429	1526"
msgid "Me? How come?"
msgstr "¿Qué pasa? ¿Por qué yo?"

msgctxt "1549	1693"
msgid "Escapin' was your idea, not mine."
msgstr "Este escape fue planeado por ti."

msgctxt "1681	1790"
msgid "Only right you get goin' before me."
msgstr "Así que me temo que vas a ser el primero en escapar."

msgctxt "1792	1954"
msgid "Besides, if you don't make it out,\\nthis plan ain't worth shit to me."
msgstr "Además, si no lo logras,\\neste plan no tendría sentido para mí."

msgctxt "2000	2069"
msgid "The hell are you saying, man?"
msgstr "¿Qué estás diciendo?"

msgctxt "2086	2214"
msgid "I'm done makin' mistakes.\\nWonderin' how different things'd be."
msgstr "Ya me cansé de cometer errores."

msgctxt "2235	2333"
msgid "And I'm done regrettin', too."
msgstr "Y de lamentarme por todo."

msgctxt "2337	2466"
msgid "Yeah, ya might not be the nicest guy."
msgstr "Sí, podrías ser un idiota."

msgctxt "2471	2594"
msgid "But ya didn't stab me in the back."
msgstr "Pero no me has traicionado."

msgctxt "2609	2684"
msgid "That's all that matters now."
msgstr "Eso es todo lo único que me importa."

msgctxt "2727	2837"
msgid "Damn, man. You really\\nare stuck in the past."
msgstr "Oye, tú. Realmente hablas\\ncomo alguien de hace 25 años..."

msgctxt "2838	2960"
msgid "Just get movin'!\\nThe guards'll be here any second!"
msgstr "¡Apresúrate!\\n¡Los guardias estarán aquí en cualquier momento!"

msgctxt "4006	4066"
msgid "Saejima!"
msgstr "¡Saejima!"

msgctxt "4347	4409"
msgid "Saejima, get up here!"
msgstr "¡Saejima! ¡Date prisa!"

msgctxt "4421	4531"
msgid "Saejima! What the hell're you doing!? C'mon!"
msgstr "¡Saejima! ¡¿Qué estás haciendo?! ¡Vamos!"

msgctxt "4544	4619"
msgid "Listen. Don't wait up."
msgstr "¡Sigue adelante sin mí!"

msgctxt "4674	4724"
msgid "You outta your mind!?"
msgstr "¡¿Qué rayos estás diciendo?!"

msgctxt "4725	4811"
msgid "I'm gonna buy ya a bit of time."
msgstr "Yo los detendré por un rato."

msgctxt "4830	4944"
msgid "You start swimmin'. Go."
msgstr "Así puedes llegar al mar y escapar."

msgctxt "4976	5036"
msgid "Saejima..."
msgstr "Saejima..."

msgctxt "5113	5173"
msgid "Just move!"
msgstr "¡Apresúrate!"

