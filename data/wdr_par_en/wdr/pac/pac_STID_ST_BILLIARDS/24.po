msgctxt "232"
msgid "You're amazing, Uncle Kaz!"
msgstr "¡Eres asombroso, tío Kaz!"

msgctxt "244"
msgid "That was so cool!"
msgstr "¡Eso estuvo genial!"

msgctxt "280"
msgid "That was close!"
msgstr "¡Eso estuvo cerca!"

msgctxt "292"
msgid "But I wanted to see you play pool..."
msgstr "Pero quería verte jugar al billar..."

