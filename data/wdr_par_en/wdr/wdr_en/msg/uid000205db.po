msgctxt "2220"
msgid "Kiryu"
msgstr "Kiryu"

msgctxt "2224"
msgid "Player"
msgstr "Player"

msgctxt "2228"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "2232"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "100_Kiryu"
msgid "If you need a break, now's the time to do it. I can take\\r\n"\n"care of any errands you need run in the meantime."
msgstr "Si necesitas un descanso, ahora es el momento de hacerlo. Puedo\\r\n"\n"encargarme de cualquier tarea que necesites hacer mientras tanto."

msgctxt "124_Player"
msgid "No, it's okay."
msgstr "No, está bien."

msgctxt "136_Player"
msgid "Sorry, gonna have to take a rain check."
msgstr "Lo siento, pero lo dejaré para después."

msgctxt "148_Player"
msgid "Think I'm good."
msgstr "Creo que estoy bien."

msgctxt "160_Player"
msgid "Appreciate the offer, but I'm gonna have to pass."
msgstr "Aprecio la oferta, pero voy a tener que pasar."

msgctxt "172_Kiryu"
msgid "All right. Just don't overdo it, okay?"
msgstr "Está bien. Pero no tardes mucho, ¿de acuerdo?"

msgctxt "196_Player"
msgid "That's a good idea. Thanks, Kiryu."
msgstr "Es una buena idea. Gracias, Kiryu."

msgctxt "208_Player"
msgid "Sure, guess I wouldn't mind taking a little breather."
msgstr "Claro, supongo que no me importaría tomarme un pequeño respiro."

msgctxt "220_Player"
msgid "Yeah, gotta catch my breath."
msgstr "Sí, tengo que recuperar el aliento."

msgctxt "232_Player"
msgid "Thanks, I'll do that."
msgstr "Gracias, lo haré."

msgctxt "244_Kiryu"
msgid "Great. I'll be back later."
msgstr "Bien. Volveré más tarde."

msgctxt "268_Kiryu"
msgid "No, it's okay."
msgstr "No, está bien."

msgctxt "280_Kiryu"
msgid "Sure."
msgstr "Claro."

