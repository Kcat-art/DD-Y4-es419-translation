msgctxt "88_Man"
msgid "You! Stop right there. Congratulations! You've been carefully selected from a crowd of thousands!"
msgstr "¡Tú! ¡Detente ahí mismo! ¡Felicidades! ¡Has sido cuidadosamente seleccionado de entre miles!"

msgctxt "100_Man"
msgid "You're the one I'm gonna beat up today! Hooray! Lucky you! C'mon, show some enthusiasm!"
msgstr "¡Tú eres a quien voy a darle una paliza hoy! ¡Hurra! ¡Qué suerte tienes! Vamos, ¡muestra algo de entusiasmo!"

msgctxt "124_Man"
msgid "You're strong..."
msgstr "Eres fuerte..."

msgctxt "136_Man"
msgid "No, please－no more. Take this. I'm sorry I messed with you."
msgstr "No, por favor, ya no más. Toma esto. Lo siento por haberte molestado."

msgctxt "148_Man"
msgid "You got a passable %s."
msgstr "Obtuviste un %s."

msgctxt "184_Man"
msgid "Unh... You don't mess around."
msgstr "Unh... No te andas con tonterías."

