msgctxt "4556"
msgid "峰村七海：源氏名"
msgstr "峰村七海：源氏名"

msgctxt "4560"
msgid "Kiryu"
msgstr "Kiryu"

msgctxt "256_峰村七海：源氏名"
msgid "I love karaoke! Hmm... What should I sing?"
msgstr "¡Me encanta el karaoke! Hmm... ¿Qué debería cantar?"

msgctxt "268_峰村七海：源氏名"
msgid "Hmm... What should I sing?"
msgstr "Mmm... ¿Qué debo cantar?"

msgctxt "280_峰村七海：源氏名"
msgid "Mmm... That felt so good! I think I did pretty well!"
msgstr "Mmm... ¡Eso se sintió tan bien! ¡Creo que lo hice bastante bien!"

msgctxt "292_峰村七海：源氏名"
msgid "Why don't you sing something, too?"
msgstr "¿Por qué no cantas algo tú también?"

msgctxt "304_Kiryu"
msgid "\"Kamurocho Lullaby,\" then."
msgstr "Cantaré \"Kamurocho Lullaby\", entonces."

msgctxt "316_峰村七海：源氏名"
msgid "Oh, I know that one! It's one of my favorites!"
msgstr "¡Oh, conozco esa! ¡Es una de mis favoritas!"

msgctxt "328_Kiryu"
msgid "No, I'm good."
msgstr "No, estoy bien."

msgctxt "340_峰村七海：源氏名"
msgid "Huh? Are you sure? I really wanted to hear you sing..."
msgstr "¿Huh? ¿Estás seguro? Realmente quería escucharte cantar..."

msgctxt "352_峰村七海：源氏名"
msgid "You were completely off..."
msgstr "Estabas completamente fuera de lugar..."

msgctxt "364_Kiryu"
msgid "Sorry."
msgstr "Lo siento."

msgctxt "376_峰村七海：源氏名"
msgid "That felt so good! You really helped me get into it! <Color:7>♥<Color:Default>"
msgstr "That felt so good! You really helped me get into it! <Color:7>♥<Color:Default>"

msgctxt "388_峰村七海：源氏名"
msgid "You should sing, too!"
msgstr "¡Tú también deberías cantar!"

msgctxt "400_Kiryu"
msgid "\"Kamurocho Lullaby,\" then."
msgstr "Cantaré \"Kamurocho Lullaby\", entonces."

msgctxt "412_峰村七海：源氏名"
msgid "Oh, I know that one! It's one of my favorites!"
msgstr "¡Oh, conozco esa! ¡Es una de mis favoritas!"

msgctxt "424_Kiryu"
msgid "No, I'm good."
msgstr "No, estoy bien."

msgctxt "436_峰村七海：源氏名"
msgid "Huh? Are you sure? I really wanted to hear you sing..."
msgstr "¿Huh? ¿Estás seguro? Realmente quería escucharte cantar..."

msgctxt "448_峰村七海：源氏名"
msgid "That was cool! You're not half bad!"
msgstr "¡Eso fue genial! ¡No eres tan malo!"

msgctxt "460_峰村七海：源氏名"
msgid "Hey... You've been practicing on your own, haven't you?"
msgstr "Eh... Has estado practicando por tu cuenta, ¿verdad?"

msgctxt "472_Kiryu"
msgid "Are you kidding me?"
msgstr "Are you kidding me?"

msgctxt "484_峰村七海：源氏名"
msgid "Just imagining you practicing by yourself is hilarious!"
msgstr "Imaginarte practicando a solas es divertidísimo!"

msgctxt "496_Kiryu"
msgid "Heh... Yeah, I guess so."
msgstr "Je... Sí, supongo que sí."

msgctxt "508_峰村七海：源氏名"
msgid "Umm... Don't worry, we all have our off days."
msgstr "Umm... Don't worry, we all have our off days."

msgctxt "520_Kiryu"
msgid "Yeah..."
msgstr "Sí..."

msgctxt "532_峰村七海：源氏名"
msgid "Wow! I never knew you were such a good singer!\\r\n"\n"That was really impressive! <Color:7>♥<Color:Default>"
msgstr "Wow! I never knew you were such a good singer!\\r\n"\n"That was really impressive! <Color:7>♥<Color:Default>"

msgctxt "544_Kiryu"
msgid "Oh yeah? Thanks."
msgstr "¿Ah, sí? Gracias."

msgctxt "556_峰村七海：源氏名"
msgid "Sure."
msgstr "Claro."

msgctxt "568_峰村七海：源氏名"
msgid "Not me."
msgstr "Yo no."

msgctxt "580_峰村七海：源氏名"
msgid "Sure."
msgstr "Claro."

msgctxt "592_峰村七海：源氏名"
msgid "Not me."
msgstr "Yo no."

