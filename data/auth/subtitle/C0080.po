msgctxt "309	418"
msgid "Can't remember the last time\\nI was outside this time of day."
msgstr "No puedo recordar la última vez\\nque estuve fuera a esta hora del día."

msgctxt "428	512"
msgid "Answer me, Katsuragi!"
msgstr "¡Oye, respóndeme! ¡Katsuragi!"

msgctxt "524	599"
msgid "First, your end of the bargain."
msgstr "Primero, su parte del trato."

msgctxt "610	758"
msgid "You know where Yasuko Saejima-san is.\\nAnd you're going to tell me."
msgstr "Sabes dónde está Saejima Yasuko-san.\\nY me lo vas a decir."

msgctxt "1259	1319"
msgid "What are you doing?"
msgstr "¿Qué significa eso?"

msgctxt "1367	1485"
msgid "This 100 mil is all yours."
msgstr "Estos 100 millones son tuyos."

msgctxt "1499	1577"
msgid "In return, I want you to forget about Yasuko-san."
msgstr "A cambio, quiero que te olvides de Yasuko-san."

msgctxt "1728	1795"
msgid "She already left for Okinawa."
msgstr "Ella ya se fue a Okinawa."

msgctxt "1816	1899"
msgid "To see Taiga Saejima."
msgstr "Para ver a Saejima Taiga."

msgctxt "2041	2092"
msgid "What's so funny?"
msgstr "¿De qué te ríes?"

msgctxt "2109	2195"
msgid "She's through working for you!"
msgstr "¡Ella ya terminó de trabajar para ti!"

msgctxt "2274	2363"
msgid "I'm afraid it's all too late."
msgstr "Me temo que es demasiado tarde."

msgctxt "2407	2476"
msgid "Too late for Yasuko Saejima..."
msgstr "Demasiado tarde para Saejima Yasuko..."

msgctxt "2507	2567"
msgid "And too late for you."
msgstr "Y para ti también."

msgctxt "3068	3186"
msgid "What the hell?\\nWhat's going on?"
msgstr "¿Qué es esto...?\\n¿Qué está pasando?"

msgctxt "3601	3720"
msgid "Yasuko Saejima-san will just have to wait."
msgstr "Saejima Yasuko-san tendrá que esperar."

msgctxt "3734	3857"
msgid "The problem in front of me takes priority."
msgstr "Ahora mismo tú eres la prioridad."

msgctxt "3876	3984"
msgid "Katsuragi! You double-crossing..."
msgstr "¡Katsuragi! ¡Maldito!"

msgctxt "3995	4075"
msgid "Let me tell you this in your final moments."
msgstr "Déjame decirte esto en tus momentos finales."

msgctxt "4083	4274"
msgid "The one who killed those eighteen men,\\nall the way back in 1985..."
msgstr "El verdadero culpable que mató a 18 personas\\nen el incidente de hace 25 años."

msgctxt "4329	4389"
msgid "Well."
msgstr "Bueno."

msgctxt "4572	4632"
msgid "It was me."
msgstr "Fui yo."

msgctxt "4623	4683"
msgid "What!?"
msgstr "¡¿Qué?!"

msgctxt "4752	4858"
msgid "Katsuragi!\\nWe're not done here!"
msgstr "¡Katsuragi!\\n¡No hemos terminado de hablar!"

msgctxt "4895	4953"
msgid "Oh, yes."
msgstr "Oh, cierto..."

msgctxt "4950	5056"
msgid "You know that restaurant you love so much?\\nHomeland, was it?"
msgstr "¿Recuerdas esa tienda que frecuentas?"

msgctxt "5080	5208"
msgid "I've arranged for its owner to be \"taken care of.\""
msgstr "He arreglado para que su dueño tenga un \"pequeño infortunio.\""

msgctxt "5222	5279"
msgid "What!?"
msgstr "¡¿Qué dijiste?!"

msgctxt "5280	5372"
msgid "Better hurry before time runs out."
msgstr "Será mejor que te des prisa antes de que se acabe el tiempo."

msgctxt "5364	5420"
msgid "Or that Chinese gentleman..."
msgstr "O el dueño..."

msgctxt "5444	5539"
msgid "And his cute little daughter will be gone forever."
msgstr "Y su linda hijita se habrán ido para siempre."

msgctxt "5557	5617"
msgid "You son of a...!"
msgstr "¡Hijo de...!"

msgctxt "5628	5674"
msgid "My condolences."
msgstr "Adiós."

msgctxt "5675	5735"
msgid "Wait!"
msgstr "¡Espera!"

msgctxt "5734	5817"
msgid "Are you the one who murdered my father!?"
msgstr "¡¿Fuiste tú quien asesinó a mi padre?!"

msgctxt "5805	5900"
msgid "I want answers, Katsuragi!"
msgstr "¡Oye, respóndeme! ¡Katsuragi!"

msgctxt "5936	5996"
msgid "Hmm."
msgstr "Quién sabe..."

msgctxt "6015	6075"
msgid "Haven't the slightest idea."
msgstr "Ni idea."

msgctxt "6800	6860"
msgid "Break it up, slimeballs!"
msgstr "¡Alto ahí, se acabó!"

msgctxt "6879	6931"
msgid "Sugiuchi-san."
msgstr "Sugiuchi-san."

msgctxt "6932	6977"
msgid "Get the hell out of here!"
msgstr "¡Sal de aquí!"

msgctxt "6978	7056"
msgid "Or are you just gonna let\\nthat asshole off your friends?"
msgstr "¿Acaso tus amigos de la tienda\\nno están en peligro?"

msgctxt "7063	7123"
msgid "Right!"
msgstr "¡Voy!"

msgctxt "7153	7275"
msgid "We've got cells with all your names\\non 'em down at Homicide."
msgstr "¡Me encargaré de llevarlos a todos ustedes\\nal Departamento de Investigación de la Policía!"

msgctxt "7264	7310"
msgid "You're under arrest!"
msgstr "¡Están bajo arresto!"

