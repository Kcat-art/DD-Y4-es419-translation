msgctxt "56"
msgid "Shot Angle:\\r\n"\n"First, you must select the angle from which you will be striking the cue ball."
msgstr "Ángulo de Tiro:\\r\n"\n"Primero, debes seleccionar el ángulo desde el que golpearás la bola blanca."

msgctxt "68"
msgid "Use <Action:Button_LS_Up@Billard><Action:Button_LS_Down@Billard><Action:Button_LS_Left@Billard><Action:Button_LS_Right@Billard> to adjust the angle."
msgstr "Usa <Action:Button_LS_Up@Billard><Action:Button_LS_Down@Billard><Action:Button_LS_Left@Billard><Action:Button_LS_Right@Billard> para ajustar el ángulo."

