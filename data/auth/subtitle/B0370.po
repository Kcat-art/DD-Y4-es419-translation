msgctxt "431	491"
msgid "Good to see you, sir!"
msgstr "¡Qué bueno verlo, señor!"

msgctxt "586	676"
msgid "The fuzz ain't gettin' near us now."
msgstr "Con esto ni siquiera la policía puede acercarse."

msgctxt "685	754"
msgid "So. Let's roll."
msgstr "Bueno. Vamos."

msgctxt "1483	1544"
msgid "Where're you takin' me?"
msgstr "¿A dónde me llevas?"

msgctxt "1555	1636"
msgid "Our old stompin' grounds."
msgstr "A nuestro viejo patio de juegos."

msgctxt "1825	1885"
msgid "Still there, huh?"
msgstr "Ese lugar..."

msgctxt "1978	2096"
msgid "<Italic>Yoshida Batting Center</Italic>"
msgstr "<Italic>Centro de Bateo Yoshida</Italic>"

msgctxt "2104	2167"
msgid "C'mon, clock's tickin'."
msgstr "Bueno, andando."

msgctxt "2177	2257"
msgid "I could use a few swings."
msgstr "Al lugar de nuestros recuerdos."

