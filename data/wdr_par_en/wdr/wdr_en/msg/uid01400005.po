msgctxt "200"
msgid "The next roll came up even."
msgstr "La siguiente tirada será par."

msgctxt "212"
msgid "The next roll came up odd."
msgstr "La siguiente tirada será impar."

msgctxt "224"
msgid "The next roll was Snake Eyes."
msgstr "La siguiente tirada será Ojos de Serpiente."

msgctxt "236"
msgid "The gamblers' bets are becoming very lopsided."
msgstr "Las apuestas de los jugadores se están volviendo muy desiguales."

msgctxt "248"
msgid "An item cannot be used twice in one game."
msgstr "Un objeto no puede usarse dos veces en una misma partida."

msgctxt "260"
msgid "Nothing happened."
msgstr "No pasó nada."

msgctxt "272"
msgid "You need 40 chips to guess both dice rolls."
msgstr "Necesitas 40 fichas para adivinar el resultado de ambos dados."

msgctxt "284"
msgid "You need 100 chips to guess both dice rolls."
msgstr "Necesitas 100 fichas para adivinar el resultado de ambos dados."

msgctxt "296"
msgid "You need 160 chips to guess both dice rolls."
msgstr "Necesitas 160 fichas para adivinar el resultado de ambos dados."

msgctxt "308"
msgid "You need 200 chips to guess both dice rolls."
msgstr "Necesitas 200 fichas para adivinar el resultado de ambos dados."

