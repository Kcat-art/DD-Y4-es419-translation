msgctxt "56_Saejima"
msgid "(This was my family's turf. Ain't no sign of 'em now.)"
msgstr "(Este solía ser el territorio de mi familia. No hay señal de ellos)."

msgctxt "68_Saejima"
msgid "(S'pose I'll try askin' folks around here.)"
msgstr "(Probaré preguntándole a la gente de por aquí)."

