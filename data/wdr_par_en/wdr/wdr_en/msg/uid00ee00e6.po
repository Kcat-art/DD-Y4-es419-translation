msgctxt "2272"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "172_Dealer"
msgid "Welcome. Would you like to play roulette?"
msgstr "Bienvenido. ¿Le gustaría jugar a la ruleta?"

msgctxt "196_Player"
msgid "Sure, I'll play."
msgstr "Claro, jugaré."

msgctxt "220_Dealer"
msgid "How about playing the house, one-on-one sir? You won't able to place outside bets, but you get five spins with double the odds."
msgstr "¿Qué le parece jugar contra la casa uno contra uno, señor? No podrá hacer apuestas externas, pero tendrá cinco tiradas con el doble de probabilidades."

msgctxt "232_Player"
msgid "Hmm... Sure, sign me up."
msgstr "Mmm... Claro, apúntame."

msgctxt "256_Dealer"
msgid "Very good, sir. Please take your seat."
msgstr "Muy bien, señor. Por favor, tome asiento."

msgctxt "280_Dealer"
msgid "It looks like you don't have enough chips to play roulette, sir."
msgstr "Parece que no tiene suficientes fichas para jugar a la ruleta, señor."

msgctxt "292_Player"
msgid "Not right now."
msgstr "Ahora no."

msgctxt "304_Dealer"
msgid "All right. Come visit again sometime.\\r\n"
"Please play next time."
msgstr "Muy bien. Vuelva a visitarnos otra vez.\\r\n"
"Por favor juegue la próxima vez."

msgctxt "316_Dealer"
msgid "Play"
msgstr "Jugar"

msgctxt "328_Dealer"
msgid "Not Now"
msgstr "Ahora no"

msgctxt "340_Dealer"
msgid "Play Against the House"
msgstr "Jugar Contra la Casa"

msgctxt "352_Dealer"
msgid "Play a Standard Game"
msgstr "Jugar una Partida Estándar"

