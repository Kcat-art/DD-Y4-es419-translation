msgctxt "92_Morimoto"
msgid "Surprise, dipshit. Remember us?"
msgstr "Sorpresa, pedazo de mierda. ¿Te acuerdas de nosotros?"

msgctxt "104_Morimoto"
msgid "We told you you'd pay for siding with homeless filth.\\r\n"\n"Now you'll get taken out with the rest of the trash."
msgstr "Te advertimos que te saldría caro ponerte del bando de los sucios vagabundos. Ahora te sacaremos con el resto de la basura."

msgctxt "116_Smartass"
msgid "Just try another one of your punkass remarks now, old man.\\r\n"\n"You're way outnumbered."
msgstr "Prueba a soltar otra de tus frasecitas de mierda ahora, vejestorio. Somos muchos mas que antes."

msgctxt "128_Jackass"
msgid "You better apologize before we really kick your ass."
msgstr "Más te vale pedir disculpas antes de que te pateemos el culo."

msgctxt "140_Saejima"
msgid "Already told ya."
msgstr "Yo ya los dije."

msgctxt "152_Morimoto"
msgid "Told us what?"
msgstr "¿Decirnos qué?"

msgctxt "164_Saejima"
msgid "If ya can't fight a man one-on-one, you ain't nothin' but chickenshit."
msgstr "Si no te atreves a pelear cara a cara, eres un maldito cobarde."

msgctxt "176_Smartass"
msgid "I heard that, assclown!"
msgstr "¡Ya te escuchamos, payaso!"

msgctxt "188_Jackass"
msgid "He's really cruising for a bruising now."
msgstr "Ya lo está pidiendo a gritos."

msgctxt "200_Morimoto"
msgid "Just get him already!"
msgstr "¡Vamos a por él!"

