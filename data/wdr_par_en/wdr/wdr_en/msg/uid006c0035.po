msgid "%s? Excellent. Right this way, sir."
msgstr "¿%s? Excelente. Por aquí, señor."

msgctxt "508_Attendant"
msgid "I'm sorry. %s-san isn't working at the moment."
msgstr "Disculpe, %s-san no se encuentra trabajando en este momento."

