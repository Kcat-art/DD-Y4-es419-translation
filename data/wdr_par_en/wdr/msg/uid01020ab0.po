msgctxt "112"
msgid "Meet with Kido?"
msgstr "¿Ir con Kido?"

msgctxt "1356"
msgid "Akiyama"
msgstr "Akiyama"

msgctxt "100_Akiyama"
msgid "(This is where I'm supposed to meet Kido-chan. I can access the roof from here.)"
msgstr "(Aquí es donde se supone que tengo que encontrarme con Kido-chan. Puedo subir al techo desde aquí)."

msgctxt "148_Akiyama"
msgid "(Maybe later.)"
msgstr "(Tal vez más tarde)."

msgctxt "184_Akiyama"
msgid "(All right. Guess I'll go meet Kido-chan.)"
msgstr "(Muy bien. Creo que iré con Kido-chan)."

msgctxt "208_Akiyama"
msgid "Yes"
msgstr "Sí"

msgctxt "220_Akiyama"
msgid "No"
msgstr "No"

