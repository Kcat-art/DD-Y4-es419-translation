msgctxt "26\t117"
msgid "I'm as good as dead\\nif you don't do something!"
msgstr "¡A este paso voy a ser asesino por el Ueno Seiwa!"

msgctxt "125\t226"
msgid "Toss me in jail if you have to.\\nPlease, just save me!"
msgstr "Méteme en la cárcel o lo que sea.\\n¡Por favor, ayúdame!"

msgctxt "237\t338"
msgid "All right.\\nYou can shack up with me for now."
msgstr "Está bien.\\nPor ahora puedes venir conmigo a mi escondite."

msgctxt "339\t472"
msgid "Just until I can arrange some\\nmore official accommodations, that is."
msgstr "Puedes quedarte en ese lugar\\nhasta que la policía tenga listo todo..."

msgctxt "756\t816"
msgid "Who's there?"
msgstr "¿Quién es?"

msgctxt "1096\t1149"
msgid "Sugiuchi-san!"
msgstr "¡Sugiuchi-san!"

