msgctxt "2788"
msgid "Homeless Man"
msgstr "Hombre sin hogar"

msgctxt "2792"
msgid "Tanimura"
msgstr "Tanimura"

msgctxt "2796"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "2800"
msgid "Sync_Send"
msgstr "Sync_Send"

msgctxt "68_Homeless Man"
msgid "Are you Tanimura-san?"
msgstr "¿Tú eres Tanimura-san?"

msgctxt "80_Tanimura"
msgid "That I am. You the one who called me?"
msgstr "Así es. ¿Fuiste tú quien llamó?"

msgctxt "92_Homeless Man"
msgid "I don't know anything about a call... My boss just told me to come here and give this to you. Here, take it."
msgstr "No sé nada sobre una llamada... Mi jefe solo me dijo que viniera y te diera esto. Toma."

msgctxt "128_Tanimura"
msgid "What's this for?"
msgstr "¿A qué viene esto?"

msgctxt "140_Homeless Man"
msgid "Heheh... I dunno, maybe you got a secret admirer? Either way, it's yours now."
msgstr "Je, je... Quién sabe, de todas formas, ahora es tuyo."

msgctxt "164_Tanimura"
msgid "(A bouquet of flowers? I don't get it.)"
msgstr "(¿Un ramo de flores? No lo entiendo)."

msgctxt "176_Tanimura"
msgid "(Wait, there's a note inside. It says...)"
msgstr "(¿Mm? Hay una nota dentro)."

msgctxt "188_Tanimura"
msgid "(\"Well done, gumshoe. You take after your papa more than I expected. I suppose I should uphold my end of the bargain.\")"
msgstr "(\"Como era de esperarse del hijo del detective Tanimura, has superado la prueba. Aquí tienes la información que acordamos\")."

msgctxt "200_Tanimura"
msgid "(\"You'll be getting a call from Katsuragi soon. What you do next is up to you. Just see that you don't waste this chance.\")"
msgstr "(\"Dentro de poco, Katsuragi te contactará. Todo lo que suceda dependerá de tus habilidades de negociación. No lo desaproveches\")."

msgctxt "212_Tanimura"
msgid "(......)"
msgstr "(......)"

