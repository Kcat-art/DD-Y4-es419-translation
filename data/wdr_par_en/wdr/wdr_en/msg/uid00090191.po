msgctxt "152_Akiyama"
msgid "Shiobara?"
msgstr "¿Tú no eres Shiobara?"

msgctxt "176_Shiobara"
msgid "Oh, Akiyama-san."
msgstr "Oh, Akiyama-san."

msgctxt "188_Akiyama"
msgid "What are you doing on this side of town?"
msgstr "¿Qué haces por aquí?"

msgctxt "200_Shiobara"
msgid "Actually, I was just on my way to see you."
msgstr "En realidad, ahora mismo estaba yendo a verte."

msgctxt "212_Akiyama"
msgid "Me?"
msgstr "¿A mí?"

msgctxt "224_Shiobara"
msgid "Uh-huh."
msgstr "Así es."

msgctxt "236_Akiyama"
msgid "All right, let's head upstairs, then."
msgstr "Bueno, vamos a la oficina entonces."

