msgctxt "56	116"
msgid "Majima-san?"
msgstr "¿Majima-san?"

msgctxt "138	244"
msgid "Are you even listening to me?"
msgstr "¿Me estás escuchando?"

msgctxt "321	392"
msgid "My bro's already headin' over!"
msgstr "¡Mi hermano ya está en camino!"

msgctxt "393	480"
msgid "Ya expect me to just sit on my hands here!?"
msgstr "¡¿Y esperas que no haga nada?!"

msgctxt "481	524"
msgid "Majima-san!"
msgstr "¡Majima-san!"

msgctxt "525	610"
msgid "You sayin' I should knife my boy in the back!?"
msgstr "¡¿Me estás diciendo que traicione a mi kyoudai?!"

msgctxt "611	699"
msgid "Do nothin' while he goes on a suicide mission!?"
msgstr "¡¿Que no haga nada mientras él va a una misión suicida?!"

msgctxt "700	785"
msgid "Please, calm down!"
msgstr "¡Cálmate! ¡Cálmate!"

msgctxt "786	835"
msgid "I'm goin'."
msgstr "Voy para allá."

msgctxt "836	926"
msgid "You and your plan can suck it."
msgstr "Me importa un mierda lo que pase después."

msgctxt "927	1064"
msgid "I'm not leavin' the only brother I've ever had to die."
msgstr "Saejima es el único hermano que tengo en este mundo."

msgctxt "1065	1177"
msgid "Majima-san.\\nYou won't make it out alive, either."
msgstr "Majima-san.\\nSi vas estarías firmando tu sentencia de muerte..."

msgctxt "1178	1250"
msgid "The flyin' fuck I care about that!?"
msgstr "¡Cállate! ¡¿Acaso crees que me importa?!"

msgctxt "1251	1419"
msgid "I been ready to toss my life away\\never since I swore my oath."
msgstr "He estado listo para morir\\ndesde hace mucho tiempo."

msgctxt "1503	1557"
msgid "Is that so?"
msgstr "Con que así son las cosas."

msgctxt "1558	1638"
msgid "Then I guess I don't have a choice."
msgstr "Supongo que no tengo otra opción."

msgctxt "1661	1721"
msgid "Boys!"
msgstr "¡Vengan!"

msgctxt "2020	2118"
msgid "I was hoping we could keep this peaceful."
msgstr "Esperaba no tener que llegar a esto..."

msgctxt "2119	2178"
msgid "Shame."
msgstr "Una lástima."

msgctxt "2274	2348"
msgid "Shibata!"
msgstr "¡Shibata!"

msgctxt "2402	2543"
msgid "Make yourself nice and cozy.\\nThis'll be your home for a while."
msgstr "Ponte cómodo.\\nEste será tu hogar por un tiempo."

msgctxt "2575	2693"
msgid "Shibata!"
msgstr "¡Shibata!"

