msgctxt "116_峰村七海：源氏名"
msgid "Ooh, I've been craving karaoke all day!"
msgstr "¡Ay! Que bien. ¡Estuve ansiando venir al karaoke todo el día!"

msgctxt "128_Talk_Yes"
msgid "Come on, let's go inside."
msgstr "Vamos, entremos."

msgctxt "140_Tanimura"
msgid "All right."
msgstr "Está bien."

msgctxt "164_峰村七海：源氏名"
msgid "Ooh, I've been craving karaoke all day!"
msgstr "¡Ay! Que bien. ¡Estuve ansiando venir al karaoke todo el día!"

msgctxt "176_Talk_Yes"
msgid "Come on, let's go inside."
msgstr "Vamos, entremos."

msgctxt "188_Tanimura"
msgid "Hold on... Seems I didn't bring enough money."
msgstr "Espera... Parece que no traje suficiente dinero."

msgctxt "200_峰村七海：源氏名"
msgid "I'm sorry, I must have misheard you. What did you say?"
msgstr "Disculpe, creo que no lo escuche bien. ¿Qué dijo?"

msgctxt "212_Tanimura"
msgid "Um... I mean... Sorry."
msgstr "Eh... Quiero decir... Perdón."

msgctxt "224_峰村七海：源氏名"
msgid "Wow! You can't manage your own finances? How do you even survive as an adult? I'm going home."
msgstr "¡Vaya! ¿Acaso no sabe manejar su dinero? ¿Cómo es que logra sobrevivir siendo adulto? Me voy a casa."

msgctxt "236_Tanimura"
msgid "(I should've checked my money earlier...)"
msgstr "(Debí haber revisado mi dinero antes...)"

msgctxt "344_峰村七海：源氏名"
msgid "That felt so great! What did you think of my singing?"
msgstr "¡La pasé genial! ¿Qué le pareció mi canto?"

msgctxt "356_Tanimura"
msgid "You were really good."
msgstr "Estuviste muy bien."

msgctxt "368_峰村七海：源氏名"
msgid "Haha, thank you! With an audience like you, it felt so easy."
msgstr "Ja, ja, ¡muchas gracias! Ante un público como usted, todo fue mucho más fácil."

msgctxt "380_峰村七海：源氏名"
msgid "Well, bye!"
msgstr "Bueno, ¡adiós!"

msgctxt "404_峰村七海：源氏名"
msgid "Whew! That was fun. What did you think of my singing?"
msgstr "¡Uf! Qué divertido. ¿Qué le pareció mi canto?"

msgctxt "416_Tanimura"
msgid "You were really good."
msgstr "Estuviste muy bien."

msgctxt "428_峰村七海：源氏名"
msgid "Thanks. I'm usually better than that, though...  I think I messed up a little today."
msgstr "Gracias. Por lo general, suelo hacerlo mejor... Pero creo que hoy tuve unos cuantos fallos."

msgctxt "440_峰村七海：源氏名"
msgid "Well, take me out again sometime. See you later."
msgstr "Invíteme a salir de nuevo, ¿sí? Nos vemos."

msgctxt "464_峰村七海：源氏名"
msgid "That's weird. I just couldn't get into it today..."
msgstr "Qué raro. Hoy no me pude concentrar del todo..."

msgctxt "476_Tanimura"
msgid "Oh? I didn't notice."
msgstr "¿Eh? No me había dado cuenta."

msgctxt "488_峰村七海：源氏名"
msgid "I'd better get home. I'll see you at the club."
msgstr "Será mejor que regrese a casa. Nos vemos en el club."

msgctxt "596_峰村七海：源氏名"
msgid "Ooh, I've been craving karaoke all day!"
msgstr "¡Ay! Que bien. ¡Estuve ansiando venir al karaoke todo el día!"

msgctxt "608_Talk_Yes"
msgid "Come on, let's go inside."
msgstr "Vamos, entremos."

msgctxt "620_Tanimura"
msgid "All right."
msgstr "Está bien."

msgctxt "644_峰村七海：源氏名"
msgid "Ooh, I've been craving karaoke all day!"
msgstr "¡Ay! Que bien. ¡Estuve ansiando venir al karaoke todo el día!"

msgctxt "656_Talk_Yes"
msgid "C'mon, let's go!"
msgstr "¡Vamos!"

msgctxt "668_Tanimura"
msgid "Hold on... Seems I didn't bring enough money."
msgstr "Espera... Parece que no traje suficiente dinero."

msgctxt "680_峰村七海：源氏名"
msgid "I'm sorry, I must have misheard you. What did you say?"
msgstr "Disculpe, creo que no lo escuche bien. ¿Qué dijo?"

msgctxt "692_Tanimura"
