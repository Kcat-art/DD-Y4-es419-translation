msgid "......"
msgstr "......"

msgctxt "17868_Akiyama"
msgid "Maybe we should change the subject."
msgstr "Quizás deberíamos cambiar el tema."

msgctxt "17880_Akiyama"
msgid "I'm looking at my type of girl right now."
msgstr "Estoy mirando mi tipo de chica en este momento."

msgctxt "17892_Rio"
