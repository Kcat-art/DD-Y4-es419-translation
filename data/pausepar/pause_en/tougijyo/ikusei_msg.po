msgctxt "80	MSG"
msgid "Set Training Menu."
msgstr "Configurar menú de entrenamientos."

msgctxt "99	MSG"
msgid "Read comments from Sodachi."
msgstr "Leer comentarios de Sodachi."

msgctxt "127	MSG"
msgid "Read comments from apprentices."
msgstr "Leer comentarios de los aprendices."

msgctxt "159	MSG"
msgid "Equip apprentice with acquired Skills and Finishing Moves."
msgstr "Equipar al aprendiz con habilidades adquiridas y movimientos de finalización."

msgctxt "218	MSG"
msgid "Check dojo status."
msgstr "Comprueba el estado del dojo."

msgctxt "237	MSG"
msgid "Spend funds to enhance dojo facilities."
msgstr "Invertir fondos para mejorar las instalaciones del dojo."

msgctxt "277	MSG"
msgid "Quit training."
msgstr "Salir del entrenamiento."

msgctxt "292	MSG"
msgid "Please set a schedule."
msgstr "Por favor, establezca una rutina."

msgctxt "315	MSG"
msgid "Begin training."
msgstr "Comenzar entrenamiento."

msgctxt "331	MSG"
msgid "You must finish setting the schedule."
msgstr "Primero debes terminar de establecer un cronograma."

msgctxt "369	MSG"
msgid "Equip apprentice with acquired Skills."
msgstr "Equipar al aprendiz con una habilidad adquirida."

msgctxt "408	MSG"
msgid "Equip apprentice with acquired Finishing Moves."
msgstr "Equipar al aprendiz con un movimiento finalizador adquirido."

msgctxt "456	MSG"
msgid "You have not acquired this Skill yet."
msgstr "Todavía no has adquirido esta habilidad."

msgctxt "494	MSG"
msgid "You have not acquired this Finishing Move yet."
msgstr "Todavía no has adquirido este movimiento finalizador."

msgctxt "541	MSG"
msgid "You can only select Rest. Your apprentice is injured."
msgstr "Puedes seleccionar descansar. Si tu aprendiz está herido."

msgctxt "595	MSG"
msgid "You can only select Tournament as this is your final turn."
msgstr "Como este es tu último turno, solo puedes seleccionar el Torneo."

msgctxt "654	MSG"
msgid "You must enter a Tournament as this is your final turn."
msgstr "Como este es último turno, tienes que entrar en un Torneo."

msgctxt "710	MSG"
msgid "You cannot return until you start training."
msgstr "No podrás volver hasta que empieces el entrenamiento."

msgctxt "754	MSG"
msgid "Special menu items cannot be changed."
msgstr "No puedes cambiar elementos especiales del menú."

msgctxt "792	MSG"
msgid "There are no Finishing Moves that you can teach."
msgstr "No hay movimientos finalizadores que puedas enseñar."

msgctxt "841	MSG"
msgid "You cannot upgrade this facility without renovating. "
msgstr "No puedes mejorar el establecimiento sin hacer renovaciones. "

msgctxt "895	MSG"
msgid "You cannot upgrade this facility yet."
msgstr "Aun no puedes mejorar el establecimiento."

