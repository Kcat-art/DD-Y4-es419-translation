msgctxt "116_Man"
msgid "You look pretty strong! I gotta say, you got my attention!"
msgstr "¡Te ves muy fuerte! ¡Tengo que decir que has captado mi atención!"

msgctxt "128_Man"
msgid "Okay, enough small talk. Time for us to fight!"
msgstr "Bueno, basta de charla. ¡Es hora de luchar!"

msgctxt "152_Man"
msgid "Phew... You're strong all right－just like I thought."
msgstr "Uf... Eres fuerte, justo como pensaba."

msgctxt "164_Man"
msgid "Sorry I sprung that on you. Here, take this."
msgstr "Lo siento por haberte sorprendido con eso. Ten, toma esto."

msgctxt "176_Man"
msgid "You got a well-made %s."
msgstr "Obtuviste un %s."

msgctxt "212_Man"
msgid "Let's fight again sometime."
msgstr "Volvamos a pelear alguna vez."

