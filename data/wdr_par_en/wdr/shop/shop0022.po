msgctxt "196"
msgid "Quit"
msgstr "Salir"

msgctxt "201"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "219"
msgid "Order"
msgstr "Pagar"

msgctxt "225"
msgid "Order the currently selected item.  "
msgstr "Pedir el objeto actualmente seleccionado.  "

msgctxt "262"
msgid "(I haven't picked anything.)  "
msgstr "(No he escogido nada)"

msgctxt "293"
msgid "(I'm short on cash.)  "
msgstr "(Me hace falta dinero)"

msgctxt "316"
msgid "Thank you. That'll be %s."
msgstr "Gracias. Eso sería %s."

msgctxt "342"
msgid "(I can't carry any more stuff.)"
msgstr "(No puedo llevar más cosas)."

msgctxt "374"
msgid "(They're sold out.)"
msgstr "(Están agotados)."

msgctxt "394"
msgid "A good match for a cute look. A great present\n"
"for those who like this style."
msgstr "Una buena opción para un lindo look. Un buen regalo\n"
"para quienes les gusta este estilo."

msgctxt "471"
msgid "A necklace with a wild feel to it. A great\n"
"present for those who like this style."
msgstr "Un collar con una sensación salvaje. Un gran\n"
"regalo para quienes les gusta este estilo."

