msgctxt "40	130"
msgid "What do you think?"
msgstr "¿Qué piensas?"

msgctxt "170	225"
msgid "Is this a bit much?"
msgstr "¿Es demasiado?"

msgctxt "270	355"
msgid "Really?  Thanks..."
msgstr "¿En serio? Gracias..."

msgctxt "430	540"
msgid "Oh, don't stare at me\\nlike that!"
msgstr "¡Oh, no me mires de\\nesa forma!"

msgctxt "615	695"
msgid "You have a weird look\\non your face."
msgstr "Tienes un aspecto extraño\\nen tu cara."

msgctxt "715	775"
msgid "You're embarrassing me!"
msgstr "¡Me estás avergonzando!"

msgctxt "830	870"
msgid "You're such a perv!"
