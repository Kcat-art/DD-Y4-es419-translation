msgctxt "1540"
msgid "Customer"
msgstr "Cliente"

msgctxt "1544"
msgid "Player"
msgstr "Jugador"

msgctxt "1548"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "1552"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "112_Customer"
msgid "Wanting to play a game of mahjong? You need 25,000 sticks or it's a no go. You can buy 'em over at the desk."
msgstr "¿Quieres jugar al mahjong? Necesitas 25,000 fichas o no hay partida. Puedes comprarlas en el mostrador."

msgctxt "124_Customer"
msgid "Wanting to play a game of mahjong? Goes without sayin', but we're pretty dang good."
msgstr "¿Quieres jugar al mahjong? No es por presumir, pero se nos da bastante bien."

msgctxt "136_Customer"
msgid "Yeah, I'll play."
msgstr "Sí, jugaré."

msgctxt "148_Customer"
msgid "That's what I'm talkin' about! Let's get started, then!"
msgstr "¡Así se habla! ¡Dale, comencemos!"

msgctxt "172_Customer"
msgid "Not right now."
msgstr "Ahora no."

msgctxt "184_Customer"
msgid "Aw, come on... Well, just say the word. We'll take you on anytime."
msgstr "Lástima... Pero ya sabes, solo habla y te aceptamos el reto cuando sea."

msgctxt "196_Customer"
msgid "Play"
msgstr "Jugar"

msgctxt "208_Customer"
msgid "Not Now"
msgstr "Ahora no"

