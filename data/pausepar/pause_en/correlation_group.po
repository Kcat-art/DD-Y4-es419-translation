msgctxt "210	GROUP"
msgid "All"
msgstr "Todos"

msgctxt "216	GROUP"
msgid "Tojo and Ueno Seiwa Clan War"
msgstr "Guerra entre el Tojo y Clan Ueno Seiwa"

msgctxt "247	GROUP"
msgid "Kamurocho Serial Murders"
msgstr "Asesinos Seriales de Kamurocho"

msgctxt "274	GROUP"
msgid "Yoshiharu Ueno Assassination"
msgstr "Asesinato de Yoshiharu Ueno"

msgctxt "305	GROUP"
msgid "Tojo Clan's Missing 10 Billion"
msgstr "Los 10 Mil Millones Desaparecidos Del Clan Tojo"

msgctxt "426	EXPLANATION"
msgid "People living in Kamurocho as of March 2010."
msgstr "Personas viviendo en Kamurocho en Marzo de 2010."

msgctxt "473	EXPLANATION"
msgid "People related to the events taking place in Kamurocho as of March 2010."
msgstr "Personas relacionadas a los eventos de Kamurocho en Marzo de 2010."

msgctxt "548	EXPLANATION"
msgid "People who live in Kamurocho and the people related to them."
msgstr "Gente viviendo en Kamurocho y personas relacionadas a ellos."

msgctxt "611	EXPLANATION"
msgid "People involved in the Tojo and Ueno Seiwa Clan\n"
"war, which started when Arai of Kanemura\n"
"Enterprises fatally shot Ihara of the Ueno Seiwa Clan."
msgstr "Personas involucradas en la guerra deñ clan Tojo y Ueno Seiwa, que comenzó cuando Arai de Empresas Kanemura\n"
"mataron a tiros a Ihara, del clan Ueno Seiwa."

msgctxt "757	EXPLANATION"
msgid "People involved in a recent string of mysterious\n"
"murders that took place in Kamurocho."
msgstr "Personas involucradas en la reciente serie de misteriosos asesinatos en Kamurocho."

msgctxt "846	EXPLANATION"
msgid "People involved in the incident 25 years ago when\n"
"Saejima of the Sasai Family gunned down 18 Ueno\n"
"Seiwa Clan members, including Chairman Ueno."
msgstr "Personas involucradas en el incidente hace 25 años, cuando Saejima de la familia Sasai mató a tiros a 18 Ueno\n"
"Miembros del Clan Seiwa, incluido el Presidente Ueno."

msgctxt "991	EXPLANATION"
msgid "People involved in the incident 5 years ago when 10\n"
"billion yen went missing from the Tojo Clan－leading\n"
"to the explosion at the Millennium Tower."
msgstr "Las personas involucradas en el incidente hace 5 años, cuando 10 mil millones de yenes desaparecieron del Clan Tojo- llevando a la explosión en la Torre Millennium."

