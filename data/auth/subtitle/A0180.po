msgctxt "27	93"
msgid "The hell do you think you're doing!?"
msgstr "¡¿Qué demonios crees que estás haciendo?!"

msgctxt "149	234"
msgid "Oh, brother.\\nJust what I needed."
msgstr "Oh, rayos.\\nEsto es malo..."

msgctxt "226	367"
msgid "Another yakuza brawl, Akiyama? Really?"
msgstr "¿Akiyama, otra vez peleando con yakuzas? ¡¿Ah?!"

msgctxt "385	465"
msgid "Guess my warning didn't get through to you."
msgstr "¿Olvidaste la advertencia que te di en la mañana?"

msgctxt "488	536"
msgid "Sugiuchi-san..."
msgstr "Sugiuchi-san..."

msgctxt "537	597"
msgid "Spare me."
msgstr "Ni modo."

msgctxt "593	658"
msgid "You can weave your yarn down at the precinct."
msgstr "Escucharé tus excusas cuando estemos en la comisaría."

msgctxt "670	730"
msgid "I'd really rather not."
msgstr "Eh, no creo que pueda..."

msgctxt "749	840"
msgid "And come on, I'm the victim here."
msgstr "Y vamos, yo soy la víctima aquí."

msgctxt "846	906"
msgid "Can it!\\nI didn't ask for your opinion!"
msgstr "¡Cállate!\\n¡No pedí tu opinión!"

msgctxt "919	979"
msgid "Take him in, boys!"
msgstr "¡Arréstenlo! ¡Que no se escape!"

msgctxt "1011	1071"
msgid "Not today!"
msgstr "¡Esto es malo!"

