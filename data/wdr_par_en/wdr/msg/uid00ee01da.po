msgctxt "660_Employee"
msgid "Welcome, sir.\\r\n"\n"Do you know the password you can get in 777town?"
msgstr "Welcome, sir.\\r\n"\n"Do you know the password you can get in 777town?"

msgctxt "672_Employee"
msgid "Oh, no...\\r\n"\n"I don't know the password."
msgstr "Oh, no...\\r\n"\n"I don't know the password."

msgctxt "684_Employee"
msgid "Is that so? Please visit www.777town.net/ryu/ to find it."
msgstr "Is that so? Please visit www.777town.net/ryu/ to find it."

msgctxt "696_Employee"
msgid "Yeah, I know it."
msgstr "Yeah, I know it."

msgctxt "708_Employee"
msgid "Very well, then let's proceed to the password.\\r\n"\n"It is seven characters in total.\\r\n"\n"What is the first character?"
msgstr "Very well, then let's proceed to the password.\\r\n"\n"It is seven characters in total.\\r\n"\n"What is the first character?"

msgctxt "732_Employee"
msgid "All right.\\r\n"\n"What's the second character?"
msgstr "All right.\\r\n"\n"What's the second character?"

msgctxt "756_Employee"
msgid "Oh ho...\\r\n"\n"Right then, what's the third character?"
msgstr "Oh ho...\\r\n"\n"Right then, what's the third character?"

msgctxt "780_Employee"
msgid "There we go!\\r\n"\n"What's the fourth character?"
msgstr "There we go!\\r\n"\n"What's the fourth character?"

msgctxt "804_Employee"
msgid "Hmmm, I see.\\r\n"\n"Three characters left!\\r\n"\n"Please tell me the fifth character."
msgstr "Hmmm, I see.\\r\n"\n"Three characters left!\\r\n"\n"Please tell me the fifth character."

msgctxt "828_Employee"
msgid "Okay, two characters left!\\r\n"\n"What's the sixth character?"
msgstr "Okay, two characters left!\\r\n"\n"What's the sixth character?"

msgctxt "852_Employee"
msgid "Okay, time for the seventh and final character!"
msgstr "Okay, time for the seventh and final character!"

msgctxt "876_Employee"
msgid "All right!\\r\n"\n"Let's see if it's correct or not!\\r\n"\n"If you get all seven characters right, you'll get a special prize!"
msgstr "All right!\\r\n"\n"Let's see if it's correct or not!\\r\n"\n"If you get all seven characters right, you'll get a special prize!"

msgctxt "888_Employee"
msgid "......"
msgstr "......"

msgctxt "912_Employee"
msgid "Oh, I'm sorry, sir! You'll have to try again!"
msgstr "Oh, I'm sorry, sir! You'll have to try again!"

msgctxt "924_Employee"
msgid "Amazing! You're absolutely right!\\r\n"\n"Congratulations!"
msgstr "Amazing! You're absolutely right!\\r\n"\n"Congratulations!"

msgctxt "936_Employee"
msgid "Here is your fabulous gift!"
msgstr "Here is your fabulous gift!"

