msgctxt "80_Takasu"
msgid "What's all the commotion? You two. What business do you have with me?"
msgstr "¿A qué se debe todo este alboroto? Ustedes dos. ¿Qué es lo que quieren?"

msgctxt "92_Tadashi"
msgid "So you're Takasu! My sister... Gimme back my sister!"
msgstr "¡Así que tú eres Takasu! Mi hermana... ¡Devuélveme a mi hermana!"

msgctxt "104_Takasu"
msgid "I beg your pardon?"
msgstr "¿Cómo?"

msgctxt "128_Fuse"
msgid "Please, sir, leave this to me."
msgstr "Por favor, señor, déjeme esto a mí."

msgctxt "152_Saejima"
msgid "Get behind me, Tadashi."
msgstr "Quédate atrás, Tadashi."

msgctxt "176_Fuse"
msgid "I don't know what you want, but don't think you can\\r\n"
"smash up a yakuza office and waltz right on out again."
msgstr "No sé cuál es tu problema, pero no creas que puedes\n"
"destrozar nuestra oficina e irte como si nada."

msgctxt "188_Saejima"
msgid "Don't worry. I ain't waltzin' nowhere."
msgstr "No te preocupes. No voy a irme a ninguna parte."

