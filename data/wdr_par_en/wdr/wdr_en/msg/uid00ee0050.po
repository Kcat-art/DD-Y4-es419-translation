msgctxt "2312"
msgid "Tobe"
msgstr "Tobe"

msgctxt "2316"
msgid "Talk_Ojigi"
msgstr "Talk_Ojigi"

msgctxt "140_Tobe"
msgid "Welcome, Kiryu-san! Have you decided what you want?"
msgstr "¡Bienvenido, Kiryu! ¿Has decidido lo que quieres?"

msgctxt "188_Tobe"
msgid "Kiryu-san, I think you've had too much to drink. I'd stop now if I were you."
msgstr "Kiryu-san, creo que has bebido demasiado. Yo pararía ahora si fuera tú."

msgctxt "200_Tobe"
msgid "Can I get you another drink?"
msgstr "¿Te traigo otra copa?"

msgctxt "212_Tobe"
msgid "All right. Please stop by again soon."
msgstr "De acuerdo. Por favor, vuelva pronto."

msgctxt "236_Tobe"
msgid "Welcome. Have you decided what you want?"
msgstr "Bienvenido. ¿Has decidido lo que quieres?"

msgctxt "284_Tobe"
msgid "I think you've already had enough to drink. I'd stop now if I were you."
msgstr "Creo que ya has bebido bastante. Yo que tú pararía ahora."

msgctxt "296_Tobe"
msgid "Another drink, sir?"
msgstr "¿Otra bebida, señor?"

msgctxt "308_Tobe"
msgid "All right. Please stop by again soon."
msgstr "De acuerdo. Por favor, vuelva pronto."

