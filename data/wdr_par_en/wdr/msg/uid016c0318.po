msgctxt "816_Player"
msgid "\"You like expensive places, don't you?\""
msgstr "\"You like expensive places, don't you?\""

msgctxt "828_Player"
msgid "\"Would you want to live in a high-rise apartment?\""
msgstr "\"Would you want to live in a high-rise apartment?\""

msgctxt "840_Player"
msgid "\"Taking care of a yard is a pain, isn't it?\""
msgstr "\"Cuidar un jardín es una molestia, ¿no?\""

msgctxt "852_Player"
msgid "\"You were the one being unreasonable.\""
msgstr "\"You were the one being unreasonable.\""

msgctxt "864_Player"
msgid "\"Champagne is asking a little too much...\""
msgstr "\"Champagne is asking a little too much...\""

msgctxt "876_Player"
msgid "\"All men are pervs deep down.\""
msgstr "\"Todos los hombres son pervertidos en el fondo.\""

msgctxt "888_Player"
msgid "\"That's incredibly expensive.\""
msgstr "\"Eso es exageradamente caro.\""

msgctxt "900_Player"
msgid "\"You're making a good living. It's not so bad.\""
msgstr "\"Estás viviendo bien. No es para tanto.\""

msgctxt "912_Player"
msgid "\"I hate it when people cancel on me suddenly.\""
msgstr "\"Odio cuando la gente me cancela de repente\"."

msgctxt "924_Player"
msgid "\"You can't fool me anymore.\""
msgstr "\"Ya no puedes engañarme.\""

msgctxt "936_Player"
msgid "\"I look forward to seeing you again.\""
msgstr "\"Espero volver a verte pronto.\""

msgctxt "948_Player"
msgid "\"I'm serious about you, too.\""
msgstr "\"Yo también voy en serio contigo.\""

msgctxt "960_Player"
msgid "\"You're a really interesting girl.\""
msgstr "\"Eres una chica muy interesante.\""

msgctxt "972_Player"
msgid "\"Sorry I'm not rich.\""
msgstr "\"Lo siento no soy millonario.\""

msgctxt "984_Player"
msgid "\"I'll go see you again soon.\""
msgstr "\"Volveré a verte pronto.\""

