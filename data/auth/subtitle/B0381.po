msgctxt "195	254"
msgid "Thank god."
msgstr "Me siento aliviado."

msgctxt "255	347"
msgid "I was half expectin' ya to be all flab."
msgstr "Estaba esperando verte todo flácido."

msgctxt "361	478"
msgid "Wouldn't have survived all these years\\nwithout a way to fight back."
msgstr "He sobrevivido 25 años en prisión,\\naprendiendo y entrenando todos los días."

msgctxt "483	582"
msgid "You're the one livin' it easy."
msgstr "A diferencia de ti, que has tenido una vida fácil."

msgctxt "589	741"
msgid "Then I guess I don't gotta pull any punches."
msgstr "Entonces supongo que no necesito tomármelo con calma."

msgctxt "750	818"
msgid "Least we agree on that."
msgstr "Tómalo como quieras."

msgctxt "823	904"
msgid "Let's do this, brother!"
msgstr "¡Vamos, Kyoudai!"

