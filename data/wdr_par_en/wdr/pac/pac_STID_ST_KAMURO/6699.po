msgctxt "56"
msgid "Equal opportunity is paramount."
msgstr "La igualdad de oportunidades es fundamental."

msgctxt "68"
msgid "We reduce spending\\r\n"
"and rebuild finances."
msgstr "Reducimos el gasto\\r\n"
"y reconstruimos las finanzas."

msgctxt "80"
msgid "Politics need to be\\r\n"
"open to the public."
msgstr "La política tiene que ser\\r\n"
"abierta al público."

msgctxt "92"
msgid "No corporate handouts.\\r\n"
"Let's end corruption!"
msgstr "No a las ayudas corporativas.\\r\n"
"¡Acabemos con la corrupción!"

msgctxt "104"
msgid "Unfortunately, tax hikes\\r\n"
"will have to continue."
msgstr "Desafortunadamente, la subida\n"
"de impuestos tendrá que continuar."

