msgctxt "2880\t2924"
msgid "The hell was that?"
msgstr "¿Qué rayos fue eso?"

msgctxt "2926\t3015"
msgid "Who's makin' that noise?"
msgstr "¿Quién está haciendo tanto ruido?"

msgctxt "3057\t3110"
msgid "Hey, I was sleeping..."
msgstr "Oye, estaba durmiendo..."

msgctxt "3129\t3175"
msgid "What's going on in here!?"
msgstr "¡¿Qué es todo ese alboroto?!"

msgctxt "3177\t3240"
msgid "Who's responsible for this?\\nCome forward, now!"
msgstr "¿Quién es responsable de esto?\\n¡Salga, ahora!"

msgctxt "3505\t3565"
msgid "That's..."
msgstr "Él es..."

msgctxt "3579\t3639"
msgid "Saejima."
msgstr "Saejima."

msgctxt "3657\t3728"
msgid "You better have a good reason for this, Saejima!"
msgstr "¿Por qué haces todo esto, Saejima?"

msgctxt "4252\t4336"
msgid "How did you get out of your cell?"
msgstr "¿Cómo saliste de tu celda?"

msgctxt "4389\t4462"
msgid "You don't really think you can escape?"
msgstr "¿Acaso estás tratando de escapar?"

msgctxt "4530\t4641"
msgid "You realize what happens\\nwhen you step out of line, yeah?"
msgstr "Te das cuenta de lo que significa\\nhacer todo esto, ¿no?"

msgctxt "4733\t4823"
msgid "Hey! Lemme out, too!"
msgstr "¡Oye! ¡Déjame escapar también!"

msgctxt "4833\t4934"
msgid "No hole for you this time."
msgstr "La cámara de tortura no es suficiente para ti."

msgctxt "4943\t5029"
msgid "We're gonna bash your brains in right here."
msgstr "Voy a tener que matarte ahora mismo en este lugar."

msgctxt "5053\t5118"
msgid "Hope you're ready."
msgstr "¿Tienes alguna queja?"

msgctxt "5174\t5278"
msgid "Okay, boys. Time to put this stray down."
msgstr "Muchachos, no hay necesidad de contenerse."

msgctxt "5286\t5388"
msgid "His execution date's come early."
msgstr "No dejen que salga vivo de esta habitación."

msgctxt "5642\t5702"
msgid "Do it!"
msgstr "¡Adelante!"

