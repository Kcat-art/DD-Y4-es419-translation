msgctxt "476"
msgid "Quit"
msgstr "Salir"

msgctxt "481"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "499"
msgid "Order"
msgstr "Pagar"

msgctxt "505"
msgid "Order the currently selected item.  "
msgstr "Pedir el objeto actualmente seleccionado.  "

msgctxt "542"
msgid "(I haven't picked anything.)  "
msgstr "(No he escogido nada)"

msgctxt "573"
msgid "(I'm short on cash.)  "
msgstr "(Me hace falta dinero)"

msgctxt "596"
msgid "Thank you. That'll be %s."
msgstr "Gracias. Eso sería %s."

msgctxt "622"
msgid "(I can't carry any more stuff.)"
msgstr "(No puedo llevar más cosas)."

msgctxt "654"
msgid "(They're sold out.)"
msgstr "(Están agotados)."

msgctxt "674"
msgid "A one-stop hangover cure. It's full of natural\n"
"ingredients like turmeric."
msgstr "Una cura para la resaca todo en uno. Está\n"
"lleno de ingredientes naturales como la\n"
"cúrcuma."

msgctxt "748"
msgid "Should help you get back on your feet when you're\n"
"low on health and Heat."
msgstr "Esto debería ayudarte a recuperarte cuando tengas\n"
"poca salud y Heat."

msgctxt "822"
msgid "More effective at revitalizing your health and Heat\n"
"than a regular Staminan X."
msgstr "Más efectivo para revitalizar tu salud y Heat que\n"
"el Staminan normal."

msgctxt "901"
msgid "One of the most potent energy drinks on the market.\n"
"It'll dramatically restore your health and Heat."
msgstr "Uno de los energizantes más potentes en el mercado.\n"
"Restaurará dramáticamente tu salud y Heat."

msgctxt "1002"
msgid "This should help increase your Heat when you're\n"
"feeling down."
msgstr "Esto debería aumentar tu Heat cuando estés desanimado."

msgctxt "1064"
msgid "This will give you a bigger Heat boost than the regular\n"
"Tauriner."
msgstr "Esto te dará un aumento de Heat mayor que el Tauriner \n"
"habitual."

msgctxt "1130"
msgid "This thing is no joke. It'll significantly boost your Heat."
msgstr "Esta cosa no es broma. Aumentará significativamente tu Heat."

msgctxt "1190"
msgid "Has all the nutrients you need to restore your health."
msgstr "Contiene todos los nutrientes que necesitas para\n"
"restaurar tu salud."

msgctxt "1245"
msgid "Packed with even more nutrients for a larger health\n"
"boost."
msgstr "Repleto de aún más nutrientes para obtener un\n"
"aumento de salud mayor."

msgctxt "1304"
msgid "Really lives up to its name. It's got enough nutrients\n"
"and supplements to revive an elephant."
msgstr "Realmente hace honor a su nombre. Tiene suficientes\n"
"nutrientes y suplementos como para revivir a un elefante."

msgctxt "1398"
msgid "Excuse me, sir. You don't look like someone who\n"
"needs contact lenses."
msgstr "Disculpe, señor. No te ves como alguien que\n"
"necesita lentes de contacto."

msgctxt "1468"
msgid "Useful for patching yourself up. Are you injured, sir?"
msgstr "Útil para curarte. ¿Está herido, señor?"

