msgctxt "2620"
msgid "Akiyama"
msgstr "Akiyama"

msgctxt "2624"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "2628"
msgid "Player"
msgstr "Player"

msgctxt "2632"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "112_Akiyama"
msgid "Taking Haruka-chan out for a stroll? Enjoy."
msgstr "¿Vas a llevar a Haruka-chan a pasear? Diviértanse."

msgctxt "124_Akiyama"
msgid "Why don't you take a little breather, %s-san? Be glad to take care of any errands you need doing."
msgstr "¿Por qué no te tomas un respiro, %s-san? Estaré encantado de ayudarte con cualquier tarea que necesites."

msgctxt "148_Player"
msgid "I'll be okay on my own for now."
msgstr "Estaré bien por ahora."

msgctxt "160_Player"
msgid "Sorry, gonna have to pass."
msgstr "Lo siento, voy a tener que pasar."

msgctxt "172_Player"
msgid "I'm good."
msgstr "Estoy bien."

msgctxt "184_Player"
msgid "Nah, I'm fine."
msgstr "No, estoy bien."

msgctxt "196_Akiyama"
msgid "Oh, all right. Don't go pushing yourself too hard, okay?"
msgstr "Oh, perfecto. No te sobre esfuerces, ¿sí?"

msgctxt "220_Player"
msgid "That's a good idea. Go ahead."
msgstr "Buena idea. Adelante."

msgctxt "232_Player"
msgid "Sure, why not. I'm always down to chill for a bit."
msgstr "Claro, por qué no. Siempre estoy dispuesto a relajarme un poco."

msgctxt "244_Player"
msgid "Guess I don't mind catchin' my breath."
msgstr "Supongo que no me importa recuperar el aliento."

msgctxt "256_Player"
msgid "All right, I'll let you take things from here."
msgstr "Muy bien, dejaré que tomes las riendas a partir de aquí."

msgctxt "268_Akiyama"
msgid "Great. Rest up while I'm gone... I'll be back to snag a break before you know it."
msgstr "Bien. Descansa mientras yo no esté... Volveré antes de que te des cuenta."

msgctxt "292_Akiyama"
msgid "Cancel"
msgstr "Cancelar"

msgctxt "304_Akiyama"
msgid "Switch to Akiyama"
msgstr "Cambiar a Akiyama"

