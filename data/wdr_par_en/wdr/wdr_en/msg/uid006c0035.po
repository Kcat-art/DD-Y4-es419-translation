msgctxt "172_Attendant"
msgid "Hello. Thank you for coming."
msgstr "Hola. Gracias por venir."

msgctxt "184_Attendant"
msgid "Will you be enjoying our club today?"
msgstr "¿Piensa visitar nuestro club hoy?"

msgctxt "196_Attendant"
msgid "Welcome, sir."
msgstr "Bienvenido, señor."

msgctxt "208_Attendant"
msgid "(Uh-oh. I don't have enough money.)"
msgstr "(Oh, no. No tengo suficiente dinero.)"

msgctxt "220_Attendant"
msgid "Wait a second!"
msgstr "¡Un momento!"

msgctxt "232_Attendant"
msgid "What is it sir?"
msgstr "¿Qué sucede, señor?"

msgctxt "244_Attendant"
msgid "Sorry, I'll come back later..."
msgstr "Lo siento, volveré luego..."

msgctxt "256_Attendant"
msgid "(I should bring at least 20,000 yen...)"
msgstr "(Debería traer al menos, 20 000 yenes...)."

msgctxt "292_Attendant"
msgid "Ah, I see you have a copy of Night Magazine. Would you like to use it?"
msgstr "Veo que lleva una revista Naimaga. ¿Le gustaría hacer uso de ella?"

msgctxt "304_Attendant"
msgid "Excellent. Using your copy of Night Magazine entitles you to a 1,000 yen discount."
msgstr "Excelente. Presentando esta copia de revista Naimaga, recibirá un descuento de 1 000 yenes."

msgctxt "316_Attendant"
msgid "Very well."
msgstr "Entendido."

msgctxt "328_Attendant"
msgid "Do you wish to request someone?"
msgstr "¿Desea solicitar a alguien en particular?"

msgctxt "340_Attendant"
msgid "Hmm..."
msgstr "Mmm..."

msgctxt "436_Attendant"
msgid "Very well. Please come again."
msgstr "Está bien. Por favor, vuelva pronto."

msgctxt "460_Attendant"
msgid "No preference? Yes sir. Please come this way."
msgstr "¿No tiene preferencia? Claro, señor, acompáñeme."

