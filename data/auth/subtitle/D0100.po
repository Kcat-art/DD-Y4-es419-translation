msgctxt "512	598"
msgid "You two go on ahead."
msgstr "Ustedes dos sigan adelante."

msgctxt "686	764"
msgid "This mess is mine to handle."
msgstr "Este es mi problema y yo me haré cargo."

msgctxt "777	885"
msgid "And besides.\\nYour brother's waiting for you."
msgstr "Además, tú tienes que apurarte\\ny encontrarte con Saejima."

msgctxt "894	954"
msgid "Hamazaki-san!"
msgstr "¡Hamazaki-san!"

msgctxt "966	1022"
msgid "Are you sure?"
msgstr "Tú..."

msgctxt "1025	1196"
msgid "Dunno why, Yasuko-san...\\nbut someone's out for your head."
msgstr "No sé por qué, Yasuko-san...\\npero al parecer alguien te está persiguiendo."

msgctxt "1297	1339"
msgid "Kiryu."
msgstr "Kiryu."

msgctxt "1350	1410"
msgid "Got it."
msgstr "Sí. Entiendo."

msgctxt "1423	1501"
msgid "I'll make sure she gets to Kamurocho."
msgstr "Iré contigo a Kamurocho."

msgctxt "1543	1720"
msgid "Sorry 'bout this.\\nMaking you leave the kids behind and all."
msgstr "Lo siento.\\nNo quería hacer que dejaras a esos niños atrás."

msgctxt "1729	1823"
msgid "I'm not doing it because you asked me to."
msgstr "No lo estoy haciendo porque me lo pides."

msgctxt "1825	1925"
msgid "Me going to Kamurocho is my own choice."
msgstr "Voy a Kamurocho por elección propia."

msgctxt "2017	2134"
msgid "Then get moving!\\nI'll hold down the fort."
msgstr "¡Apúrate y vete!\\nNo preocupes por mí."

msgctxt "2143	2194"
msgid "Okay."
msgstr "Está bien."

msgctxt "2198	2261"
msgid "Let's go, Yasuko-san."
msgstr "Vamos, Yasuko-san."

msgctxt "2264	2324"
msgid "Right."
msgstr "Sí."

msgctxt "2331	2364"
msgid "Hamazaki-san..."
msgstr "Hamazaki-san..."

msgctxt "2373	2437"
msgid "I can't thank you enough."
msgstr "Muchísimas gracias."

msgctxt "2450	2616"
msgid "I'm... proud to know my brother\\nhas a friend like you."
msgstr "Estoy... orgullosa de saber que mi hermano\\ntiene un amigo como tú."

msgctxt "2626	2722"
msgid "Quit it with the flattery. Please."
msgstr "Para. No es necesario."

msgctxt "2726	2832"
msgid "I'll tell Taiga about\\neverything you've done for me."
msgstr "Le contaré a mi hermano sobre\\ntodo lo que has hecho por mí."

msgctxt "2853	2913"
msgid "Just go already!"
msgstr "¡Ya váyanse!"

msgctxt "2945	3010"
msgid "He's right. Come on."
msgstr "Tiene razón. Vamos."

msgctxt "3543	3753"
msgid "Guess I... went a little too soft..."
msgstr "Supongo que yo... también me he suavizado un poco..."

