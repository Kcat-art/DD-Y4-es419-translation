msgctxt "766	828"
msgid "Katsuragi!"
msgstr "¡Katsuragi!"

msgctxt "951	1052"
msgid "I'm impressed you made it up here."
msgstr "No pensé que llegarías tan lejos..."

msgctxt "1081	1193"
msgid "I suppose not all legends are mere fiction."
msgstr "Supongo que no todas las leyendas son mera ficción."

msgctxt "1199	1293"
msgid "Enough games.\\nLet's finish this."
msgstr "El juego acabó.\\nAcepta el trato."

msgctxt "1298	1345"
msgid "Fine by me."
msgstr "Bah, está bien."

msgctxt "1348	1410"
msgid "I'm a man of my word, after all."
msgstr "Fue una promesa, después de todo."

msgctxt "1422	1529"
msgid "What I lack in brawn,\\nI make up for with honor."
msgstr "No seré un buen luchador,\\npero lo compenso con mi honor."

msgctxt "1571	1645"
msgid "Here's the file you want."
msgstr "Aquí está el archivo que quieres."

msgctxt "1653	1768"
msgid "Now let those two go.\\nAnd hand over the hundred billion!"
msgstr "Ahora deja ir a esos dos.\\n¡Y entrega los cien billones!"

msgctxt "1781	1985"
msgid "Relax, relax. A mountain of cash that big\\nisn't the easiest thing to move around."
msgstr "Tranquilo, no te apresures. Cien billones\\nes mucho dinero, no es fácil de transportar."

msgctxt "1999	2082"
msgid "Sounds like it's just arriving now."
msgstr "Debería de llegar pronto."

msgctxt "2651	2708"
msgid "Sorry for the wait."
msgstr "Disculpe la demora."

msgctxt "2716	2825"
msgid "Here's the cash, as promised.\\nAll one hundred bil."
msgstr "Aquí está el dinero prometido.\\nLos cien billones en efectivo."

msgctxt "3220	3293"
msgid "So, you're Kido."
msgstr "Entonces, tú eres Kido."

msgctxt "3336	3401"
msgid "And you must be Kazuma Kiryu."
msgstr "Y tú debes ser Kiryu Kazuma, ¿no?"

msgctxt "3425	3541"
msgid "It's an honor to meet you. Truly."
msgstr "Es un honor conocerlo de esta manera."

msgctxt "3560	3729"
msgid "Now that introductions are out of the way,\\nlet's get down to business."
msgstr "Ahora que las presentaciones terminaron,\\nempecemos con el trato."

msgctxt "3749	3785"
msgid "Fine."
msgstr "Bien."

msgctxt "3816	3895"
msgid "We'll do this one step at a time."
msgstr "Haremos esto paso a paso."

msgctxt "4631	4705"
msgid "First, Yasuko Saejima."
msgstr "Comencemos con Saejima Yasuko."

msgctxt "4713	4796"
msgid "Don't take a single step from that spot."
msgstr "No te muevas del lugar."

msgctxt "4858	5019"
msgid "When Kido comes to you, he'll hand over the girl\\nand you'll give him the file."
msgstr "Cuando Kido vaya a ti, te entregará a la chica\\ny le darás el archivo."

msgctxt "5029	5246"
msgid "Once I've confirmed its contents, we'll leave you\\nhere with Saejima and the money. And that'll be it."
msgstr "Una vez confirmado su contenido, te dejaremos\\naquí con Saejima y los cien billones. Luego de eso nos iremos."

msgctxt "5262	5320"
msgid "All right."
msgstr "Está bien."

msgctxt "5345	5517"
msgid "Impressive resolve. Not a sliver of doubt,\\neven at a time like this."
msgstr "Tal y como esperaba. Incluso en una situación\\ncomo esta no muestras ni una pizca de inquietud."

msgctxt "5574	5615"
msgid "Fine, then."
msgstr "Bien, entonces."

msgctxt "5628	5672"
msgid "Go."
msgstr "Ve."

msgctxt "6309	6372"
msgid "Sorry about all this."
msgstr "Lo siento."

msgctxt "6518	6578"
msgid "The file."
msgstr "El archivo."

msgctxt "7040	7076"
msgid "Are you okay?"
msgstr "¿Estás bien?"

msgctxt "7078	7195"
msgid "I'm sorry.\\nI should've listened to you."
msgstr "Lo siento.\\nDebí haberte escuchado."

msgctxt "7200	7299"
msgid "What's done is done.\\nDid you talk to your brother?"
msgstr "No te preocupes.\\n¿Llegaste a hablar con tu hermano?"

msgctxt "7312	7428"
msgid "Yes. We had plenty of time\\nwhile we were locked up together."
msgstr "Sí. Tuvimos mucho tiempo\\nmientras estábamos encerrados juntos."

msgctxt "7443	7500"
msgid "Glad to hear it."
msgstr "Ya veo."

msgctxt "8144	8198"
msgid "You're bigger fools than I realized!"
msgstr "¡Felicidades chicos!"

msgctxt "8205	8350"
msgid "Did you really believe I'd let you\\nwalk out of here alive?"
msgstr "¿Realmente creyeron que les\\ndejaría ir a casa con vida?!"

msgctxt "8357	8407"
msgid "Katsuragi!"
msgstr "¡Katsuragi!"

msgctxt "8418	8497"
msgid "Kido... Do it!"
msgstr "Kido... ¡Dispara!"

msgctxt "9072	9145"
msgid "Why...?"
msgstr "¿Por qué...?"

msgctxt "9654	9725"
msgid "Watch close."
msgstr "Miren con atención."

msgctxt "9989	10075"
msgid "You!"
msgstr "Tú..."

msgctxt "10093	10190"
msgid "It's him... Arai."
msgstr "Ese de ahí, es Arai..."

msgctxt "10197	10248"
msgid "Arai!?"
msgstr "¿Arai?"

msgctxt "10553	10612"
msgid "Katsuragi-san."
msgstr "Katsuragi-san."

msgctxt "10617	10726"
msgid "You should've known I'm not the kinda guy\\nto stab his aniki in the back."
msgstr "¿Acaso pensaste que\\ntraicionaría a mi aniki?"

msgctxt "10821	10900"
msgid "Aniki. Here it is."
msgstr "Aniki. Aquí está."

msgctxt "11069	11130"
msgid "I knew I could count on you."
msgstr "Como era de esperar de mi kyoudai."

msgctxt "11135	11193"
msgid "Nicely done, Kido."
msgstr "Buen trabajo, Kido."

msgctxt "11206	11266"
msgid "Thanks!"
msgstr "¡Gracias!"

msgctxt "11622	11684"
msgid "Ani...ki?"
msgstr "¿Ani...ki?"

msgctxt "12204	12282"
msgid "Aniki..."
msgstr "Aniki..."

msgctxt "12282	12360"
msgid "You..."
msgstr "Aniki..."

msgctxt "12806	12866"
msgid "How could you?"
msgstr "Tú..."

msgctxt "13005	13071"
msgid "Kazuma Kiryu-san, yes?"
msgstr "Kazuma Kiryu-san, ¿verdad?"

msgctxt "13089	13254"
msgid "I'm the captain of Kanemura Enterprises,\\nunder the Tojo's Shibata Family. The name's Arai."
msgstr "Soy Arai, Capitán de Kanemura Enterprises.\\nPerteneciente al Grupo Shibata del Clan Tojo."

msgctxt "13311	13396"
msgid "I'm honored to finally meet you face-to-face."
msgstr "Es un honor conocerte."

msgctxt "13405	13470"
msgid "Don't talk to me about honor."
msgstr "¿Crees que esto es una broma?"

msgctxt "13485	13616"
msgid "Do you have any idea what you just did?"
msgstr "¿Tienes alguna idea de lo que acabas de hacer?"

msgctxt "13625	13761"
msgid "There's nothing more disgraceful\\nthan betraying a sworn brother."
msgstr "Justo ahora acabas de\\ntraicionar a tu propio kyoudai."

msgctxt "13762	13844"
msgid "You understand me!?"
msgstr "¡¿Acaso no sabes lo que eso significa?!"

msgctxt "13858	14000"
msgid "I do, in fact.\\nBetter than you realize."
msgstr "Sí, lo sé.\\nMejor de lo que crees."

msgctxt "14097	14163"
msgid "Listen, Arai!"
msgstr "¡Oye, Arai!"

msgctxt "14199	14295"
msgid "The Tojo Clan will never be yours."
msgstr "No te entregaré el Clan Tojo."

msgctxt "14297	14445"
msgid "I'll see to that myself.\\nNo matter what it takes."
msgstr "Te voy a detener.\\nSin importar lo que cueste."

msgctxt "14448	14510"
msgid "Hear me?"
msgstr "¿Escuchaste?"

msgctxt "14523	14591"
msgid "You're too late."
msgstr "Es demasiado tarde."

msgctxt "14662	14741"
msgid "You're always too late."
msgstr "Siempre llegas demasiado tarde."

msgctxt "14751	14816"
msgid "That's why these things happen."
msgstr "Por eso suceden estas cosas."

msgctxt "14878	14938"
msgid "Bye now."
msgstr "Adiós."

msgctxt "15074	15125"
msgid "Taiga!"
msgstr "¡Hermano!"

msgctxt "15343	15393"
msgid "Yasuko, hurry!"
msgstr "¡Yasuko, date prisa!"

msgctxt "15412	15460"
msgid "The bastard's still breathin'!"
msgstr "¡Ese bastardo todavía está vivo!"

msgctxt "15477	15537"
msgid "Katsuragi!"
msgstr "¡Katsuragi!"

msgctxt "15674	15738"
msgid "Good for you."
msgstr "Bien por ti."

msgctxt "15743	15873"
msgid "You're not the same dumb ox\\nyou were twenty-five years ago."
msgstr "Eres más inteligente que hace 25 años."

msgctxt "15902	15968"
msgid "What was that?"
msgstr "¡¿Qué dijiste?!"

msgctxt "16030	16187"
msgid "But in the end...\\nyou didn't snuff out a single life that day."
msgstr "Al final,\\nno pudiste matar ni a una mosca."

msgctxt "16189	16282"
msgid "A total failure of a hitman."
msgstr "Eres un fracaso como asesino."

msgctxt "16394	16495"
msgid "I feel sorry for that fool Sasai."
msgstr "Siento pena por Sasai."

msgctxt "16500	16606"
msgid "Footing the bill on a halfwit like you."
msgstr "Por tener a un idiota como tú."

msgctxt "17143	17203"
msgid "Not today."
msgstr "Hoy no."

msgctxt "17288	17405"
msgid "Scum low as you ain't even worth killin'."
msgstr "No quiero matar a una escoria como tú."

msgctxt "17434	17505"
msgid "You can lie there till ya rot."
msgstr "Puedes quedarte en ese lugar por el resto de tu vida."

msgctxt "17896	17950"
msgid "Taiga!"
msgstr "¡Hermano!"

msgctxt "17983	18088"
msgid "You... fuckin' coward!"
msgstr "Este... ¡maldito cobarde!"

msgctxt "18288	18390"
msgid "Yasuko?\\nHey, Yasuko?"
msgstr "¿Yasuko?\\nOye, Yasuko."

msgctxt "18391	18437"
msgid "Yasuko!"
msgstr "¡Yasuko!"

msgctxt "18494	18586"
msgid "Give me... a minute."
msgstr "Dame... un minuto."

msgctxt "18689	18767"
msgid "Yasuko? Wait..."
msgstr "¿Yasuko? Oye..."

msgctxt "18781	18877"
msgid "What're ya doin'? Answer me!"
msgstr "¡¿Qué estás haciendo?! ¡Oye!"

msgctxt "18948	19057"
msgid "I... I don't get it."
msgstr "¿Qué? ¿Qué vas a...?"

msgctxt "19416	19457"
msgid "Get back..."
msgstr "Atrás..."

msgctxt "19459	19519"
msgid "Get back!"
msgstr "¡Atrás!"

msgctxt "20289	20420"
msgid "What are you doing... with that?"
msgstr "¿Por qué traes un arma...?"

msgctxt "20426	20515"
msgid "Tanimura-san gave it to me."
msgstr "Tanimura-san me la dio."

msgctxt "20556	20619"
msgid "This gun..."
msgstr "Esta arma..."

msgctxt "20620	20825"
msgid "Is going to avenge his father's death.\\nI owe him that much at least."
msgstr "De seguro me fue confiada para\\nvengar la muerte de su padre."

msgctxt "21033	21121"
msgid "Wait! Ya can't do this!"
msgstr "Oye, ¡¿Qué crees que estás haciendo?!"

msgctxt "21123	21179"
msgid "Stay back."
msgstr "¡No te acerques!"

msgctxt "21280	21389"
msgid "Thank you, Taiga."
msgstr "Gracias, hermano."

msgctxt "21410	21487"
msgid "It may have just been today..."
msgstr "Tal vez solo haya sido un día..."

msgctxt "21508	21627"
msgid "But I'm glad I got to see you one last time."
msgstr "Pero fue agradable hablar otra vez con mi hermano."

msgctxt "21708	21760"
msgid "Yasuko."
msgstr "Hey, Yasuko."

msgctxt "21765	21885"
msgid "You're an innocent man, Taiga."
msgstr "Eres una persona inocente, hermano."

msgctxt "21887	21953"
msgid "But me..."
msgstr "Pero yo..."

msgctxt "21957	22054"
msgid "I already have so much blood on my hands."
msgstr "Ya he matado a mucha gente."

msgctxt "22068	22193"
msgid "That's why... it has to be me."
msgstr "Así que... déjame hacerlo."

msgctxt "22228	22266"
msgid "N-No!"
msgstr "¡Para!"

msgctxt "22268	22318"
msgid "You can't!"
msgstr "¡Detente!"

msgctxt "22345	22513"
msgid "This is the only way...\\nI can repay you for all you've done."
msgstr "Esta es la única manera...\\nDe pagarte por todo lo que has hecho."

msgctxt "22530	22579"
msgid "Forgive me."
msgstr "Perdóname."

msgctxt "22926	22993"
msgid "Yasuko!"
msgstr "¡Yasuko!"

msgctxt "23033	23129"
msgid "Hey, Yasuko?\\nYasuko!?"
msgstr "Oye, ¿Yasuko?\\n¡¿Yasuko?!"

msgctxt "23130	23207"
msgid "Say somethin', please!"
msgstr "¡Di algo, por favor!"

msgctxt "23228	23315"
msgid "I'm... sorry."
msgstr "Lo siento..."

msgctxt "23380	23509"
msgid "Tai...ga..."
msgstr "Hermano..."

msgctxt "23522	23601"
msgid "Hey! Yasuko?"
msgstr "¡Oye! ¿Yasuko?"

msgctxt "23606	23728"
msgid "Yasuko! Wake up!"
msgstr "¡Yasuko! ¡Oyeee!"

