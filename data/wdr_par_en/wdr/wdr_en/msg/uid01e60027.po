msgctxt "92_Rio"
msgid "Akiyama-san? This is Rio! I need to talk to you!"
msgstr "Akiyama-san? This is Rio! I need to talk to you!"

msgctxt "104_Rio"
msgid "That photographer called. The president of the agency wants to meet me!"
msgstr "That photographer called. The president of the agency wants to meet me!"

msgctxt "116_Akiyama"
msgid "That's kinda sudden... What was the agency called again?"
msgstr "That's kinda sudden... What was the agency called again?"

msgctxt "128_Rio"
msgid "Shino Productions. Have you heard of it?"
msgstr "Shino Productions. Have you heard of it?"

msgctxt "140_Akiyama"
msgid "Never heard of it."
msgstr "Nunca escuché de ello."

msgctxt "152_Rio"
msgid "I'm going to their office to see what the president has to say before making my decision."
msgstr "I'm going to their office to see what the president has to say before making my decision."

msgctxt "164_Akiyama"
msgid "Makes sense. Good luck!"
msgstr "Makes sense. Good luck!"

msgctxt "176_Rio"
msgid "Thanks!"
msgstr "¡Gracias!"

msgctxt "236_Talk_Phone_st"
msgid "(Shino Productions, huh? The <Color:7>manager over at Asia<Color:Default> knows a lot about this kind of thing. I should ask him about it.)"
msgstr "(Shino Productions, huh? The <Color:7>manager over at Asia<Color:Default> knows a lot about this kind of thing. I should ask him about it.)"

