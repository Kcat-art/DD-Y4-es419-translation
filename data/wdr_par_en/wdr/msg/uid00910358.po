msgctxt "748"
msgid "Kiryu"
msgstr "Kiryu"

msgctxt "752"
msgid "Businesswoman"
msgstr "Mujer de negocios"

msgctxt "84_Kiryu"
msgid "What happened?"
msgstr "¿Por qué?"

msgctxt "96_Businesswoman"
msgid "The kid who works at that sushi shop just got dragged off by a bunch of dangerous looking guys."
msgstr "Un puñado de tipos con pinta peligrosa se acban de \\r llevar a rastras al chico que trabaja en esa tienda de sushi."

msgctxt "108_Businesswoman"
msgid "They went off toward <Color:7>Nakamichi Street.<Color:Default> Hope that kid's okay..."
msgstr "Se fueron hacia <Color:7>Nakamichi Street.<Color:Default> \\r Espero que el chico esté bien..."

msgctxt "120_Kiryu"
msgid "(Could that be Kotaro? I should check out <Color:7>Nakamichi Street.<Color:Default>)"
msgstr "(¿Será Kotaro? Debería ir a <Color:7>Calle Nakamichi<Color:Default>.)"

