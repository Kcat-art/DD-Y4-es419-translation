msgstr ""

#. y4:line_status=todo
msgctxt "3236\t3346"
msgid "Do you really want to try\\nexplaining that to the cops?"
msgstr ""

#. y4:line_status=todo
msgctxt "3362\t3422"
msgid "Who are you?"
msgstr ""

#. y4:line_status=todo
msgctxt "3535\t3637"
msgid "I'm guessing you're not yakuza."
