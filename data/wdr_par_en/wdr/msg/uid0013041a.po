msgctxt "796"
msgid "Watanabe"
msgstr "Watanabe"

msgctxt "120_Watanabe"
msgid "Oh, hey..."
msgstr "Eh, b-buenas..."

msgctxt "132_Watanabe"
msgid "Hello."
msgstr "Hola."

msgctxt "144_Watanabe"
msgid "Hello, Saejima-san."
msgstr "Hola, Saejima-san."

msgctxt "156_Watanabe"
msgid "Saejima-san! I'm looking forward to training with you today! I'll give it my best!"
msgstr "¡Saejima-san, cuento con usted hoy también! ¡Haré mi mejor esfuerzo!"

msgctxt "168_Watanabe"
msgid "Saejima-san, thank you for everything! I'm honored to call myself your apprentice!"
msgstr "¡Saejima-san... de verdad, siempre le estaré agradecido! ¡Me alegra haberme convertido en su aprendiz!"

