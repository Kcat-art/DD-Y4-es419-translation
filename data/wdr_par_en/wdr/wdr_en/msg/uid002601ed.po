msgctxt "84_Injured Man"
msgid "Urgh..."
msgstr "Urgh..."

msgctxt "96_Kiryu"
msgid "Hey, you all right?"
msgstr "Oye, ¿te encuentras bien?"

msgctxt "108_Injured Man"
msgid "Help..."
msgstr "Ayuda..."

msgctxt "120_Kiryu"
msgid "You're beat up pretty bad. What happened to you?"
msgstr "Estás hecho polvo. ¿Qué te pasó?"

msgctxt "132_Injured Man"
msgid "......"
msgstr "......"

msgctxt "144_Kiryu"
msgid "What's the matter? Is it something you can't talk about?"
msgstr "¿Qué pasa? ¿Es algo de lo que no puedes hablar?"

msgctxt "156_Injured Man"
msgid "......"
msgstr "......"

msgctxt "168_Kiryu"
msgid "All right, have it your way. I'll call an ambulance, and you can deal with the rest."
msgstr "Está bien, como quieras. Llamaré a una ambulancia y tú te encargas del resto."

msgctxt "192_Kiryu"
msgid "I should let the police know, too."
msgstr "Creo que debería avisar a la policía también."

msgctxt "204_Injured Man"
msgid "No!"
msgstr "¡No!"

msgctxt "216_Kiryu"
msgid "Huh?"
msgstr "Uh, ¿y eso?"

msgctxt "228_Injured Man"
msgid "No police!"
msgstr "¡Nada de policía!"

msgctxt "240_Kiryu"
msgid "I see... This smells like trouble."
msgstr "Ya veo... Esto huele a problemas."

msgctxt "252_Injured Man"
msgid "......"
msgstr "......"

msgctxt "264_Kiryu"
msgid "(Guess I can bring him to Emoto Medical Clinic. Maybe Doc Emoto can help him there.)"
msgstr "(Podría llevarlo a la Clínica Médica Emoto. Tal vez el Doctor Emoto pueda ayudarlo allí.)"

