msgctxt "329	408"
msgid "Where the fuck are ya, bro?"
msgstr "¿En dónde demonios estás, hermano?"

msgctxt "407	450"
msgid "Late-ass..."
msgstr "Joder..."

msgctxt "970	1081"
msgid "It's me.\\nSaejima, Sasai Family."
msgstr "Soy yo.\\nSaejima, de la Familia Sasai."

msgctxt "1092	1190"
msgid "Majima was s'posed to be here by now."
msgstr "Majima debería haberse reunido conmigo para este momento."

msgctxt "1191	1249"
msgid "What's holdin' him up?"
msgstr "¿Qué le ha pasado?"

msgctxt "1262	1336"
msgid "Yup. I'll be－"
msgstr "Sí. Estaré－"

msgctxt "1451	1497"
msgid "They're here."
msgstr "Han llegado."

msgctxt "1525	1630"
msgid "Never mind, I'm good.\\nLater."
msgstr "Ya da igual, estaré bien.\\nDebo irme."

msgctxt "1768	1821"
msgid "Goddamn."
msgstr "Mierda."

msgctxt "1838	1920"
msgid "That ain't 10.\\nThat's a fuckin' army."
msgstr "¿Menos de 10?\\nPero si es casi el doble."

msgctxt "5094	5138"
msgid "You're gonna pay for this!"
msgstr "¡Lo vas a lamentar!"

msgctxt "6053	6131"
msgid "No! Stay back!"
msgstr "¡No! ¡Detente ahora!"

msgctxt "7760	7820"
msgid "Please..."
msgstr "Te lo suplico..."

msgctxt "7822	7867"
msgid "Not the boss."
msgstr "No al jefe."

msgctxt "7868	7985"
msgid "I swore I'd protect him with my life!"
msgstr "¡Juré protegerlo con mi vida de ser necesario!"

msgctxt "8339	8399"
msgid "Sorry..."
msgstr "Lo siento..."

msgctxt "8414	8498"
msgid "But I got my orders too."
msgstr "Pero yo también tengo un jefe y ordenes que cumplir."

msgctxt "8515	8575"
msgid "Ueno-san."
msgstr "Ueno-san."

msgctxt "8588	8648"
msgid "It's nothin' personal."
msgstr "No se lo tome personal."

msgctxt "8662	8721"
msgid "Someone help...!"
msgstr "¡Quien sea, ayuda...!"

