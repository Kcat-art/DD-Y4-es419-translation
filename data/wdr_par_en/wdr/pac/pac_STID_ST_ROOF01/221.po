msgctxt "56"
msgid "（確か、サキちゃんの言った場所は\\r\n"
"　この辺でいいはずだが……）"
msgstr "（確か、サキちゃんの言った場所は\\r\n"
"　この辺でいいはずだが……）"

msgctxt "68"
msgid "お待たせ♪"
msgstr "お待たせ♪"

msgctxt "80"
msgid "っ！　驚かすなよ……"
msgstr "っ！　驚かすなよ……"

msgctxt "92"
msgid "ウフ、ごめんなさいね♪\\r\n"
"……今回ばかりはちょっとヤバかったから\\r\n"
"私もちょっと警戒中。"
msgstr "ウフ、ごめんなさいね♪\\r\n"
"……今回ばかりはちょっとヤバかったから\\r\n"
"私もちょっと警戒中。"

msgctxt "104"
msgid "大丈夫なのか？"
msgstr "大丈夫なのか？"

msgctxt "116"
msgid "言ったでしょ、一蓮托生って。\\r\n"
"ま、危ない橋を渡った甲斐はあったわ。"
msgstr "言ったでしょ、一蓮托生って。\\r\n"
"ま、危ない橋を渡った甲斐はあったわ。"

msgctxt "128"
msgid "何が分かったんだ？"
msgstr "何が分かったんだ？"

msgctxt "140"
msgid "偽装結婚の斡旋、偽装パスボートの製造、\\r\n"
"現地での女の調達、全てを仕切ってるのは、\\r\n"
"津川という男だそうよ。"
msgstr "偽装結婚の斡旋、偽装パスボートの製造、\\r\n"
"現地での女の調達、全てを仕切ってるのは、\\r\n"
"津川という男だそうよ。"

msgctxt "152"
msgid "そいつが、「ブリッジ」なのか。"
msgstr "そいつが、「ブリッジ」なのか。"

msgctxt "164"
msgid "いや、ブリッジとは違うわ。"
msgstr "いや、ブリッジとは違うわ。"

msgctxt "176"
msgid "津川は「アーバン・フーズ」という\\r\n"
"貿易会社を経営しているの。\\r\n"
"主にアジア各地から食品を輸入している会社よ。"
msgstr "津川は「アーバン・フーズ」という\\r\n"
"貿易会社を経営しているの。\\r\n"
"主にアジア各地から食品を輸入している会社よ。"

msgctxt "188"
msgid "それで現地の事情に詳しいわけだな。"
msgstr "それで現地の事情に詳しいわけだな。"

msgctxt "200"
msgid "駐在員は女のスカウトもしているそうよ。"
msgstr "駐在員は女のスカウトもしているそうよ。"

msgctxt "212"
msgid "よく短時間でそこまで調べ上げたもんだ。\\r\n"
"さすが、もと凄腕のデカだ……"
msgstr "よく短時間でそこまで調べ上げたもんだ。\\r\n"
"さすが、もと凄腕のデカだ……"

msgctxt "224"
msgid "ところで、ひとつ聞きたいことがあるんだが……"
msgstr "ところで、ひとつ聞きたいことがあるんだが……"

msgctxt "236"
msgid "なに？"
msgstr "なに？"

msgctxt "248"
msgid "話はすべて聞かせてもらった。"
msgstr "話はすべて聞かせてもらった。"

msgctxt "260"
msgid "！"
msgstr "！"

msgctxt "272"
msgid "何だか怪しい野郎だなと思っていたら\\r\n"
"デカとつるんでいたわけか。"
msgstr "何だか怪しい野郎だなと思っていたら\\r\n"
"デカとつるんでいたわけか。"

msgctxt "284"
msgid "……バレバレってわけね。\\r\n"
"私の腕も落ちたもんだわ。"
msgstr "……バレバレってわけね。\\r\n"
"私の腕も落ちたもんだわ。"

msgctxt "296"
msgid "サキちゃん。　逃げろ。"
msgstr "サキちゃん。　逃げろ。"

msgctxt "308"
msgid "けど……"
msgstr "けど……"

msgctxt "320"
msgid "悪いけど、足手まといだ。"
msgstr "悪いけど、足手まといだ。"

msgctxt "332"
msgid "……分かったわ。"
msgstr "……分かったわ。"

msgctxt "344"
msgid "こっちは忙しいんだ。\\r\n"
"早いとこ片付けさせてもらうぜ。"
msgstr "こっちは忙しいんだ。\\r\n"
"早いとこ片付けさせてもらうぜ。"

