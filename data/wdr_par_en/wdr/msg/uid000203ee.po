msgctxt "1140"
msgid "Worker Kawasaki"
msgstr "Trabajador Kawasaki"

msgctxt "1144"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "1148"
msgid "Worker Omori"
msgstr "Trabajador Omori"

msgctxt "1152"
msgid "Saejima"
msgstr "Saejima"

msgctxt "56_Worker Kawasaki"
msgid "Something isn't right with that manhole."
msgstr "Algo anda mal con esa alcantarilla."

msgctxt "68_Worker Omori"
msgid "I know, it's creeping me out. I keep hearing noises\\r\n"\n"coming from beyond the blocked-off area."
msgstr "Lo sé, da miedo. Sigo escuchando sonidos\\r\n"\n"que vienen desde el área bloqueada."

msgctxt "80_Worker Kawasaki"
msgid "Yeah, me too. And if I didn't know any better, I'd swear\\r\n"\n"I saw footprints leading in and out of the darn thing."
msgstr "Yo igual. Además, juraría que vi huellas\\r\n"\n"que van y vienen de la cosa esa."

msgctxt "92_Worker Omori"
msgid "Oh, they're real. But I took a closer look, and get this:\\r\n"\n"they're not work boots like ours, they're dress shoes."
msgstr "Oh, son reales. Las miré más de cerca, y escucha esto:\\r\n"\n"No son de botas de trabajo como las nuestras, son de zapatos de vestir."

msgctxt "104_Saejima"
msgid "(What're dressed-up folks doing crawlin' down a manhole?)"
msgstr "(¿Qué hace gente de traje arrastrándose por una alcantarilla?)."

