msgctxt "40	165"
msgid "Your bod is totally amazing.\\nI bet girls love you."
msgstr "Tu cuerpo es totalmente increíble.\\nApuesto a que las chicas te aman."

msgctxt "235	350"
msgid "No way.\\nYou're pulling my leg."
msgstr "No es posible.\\nMe estás tomando el pelo."

msgctxt "430	545"
msgid "You're...\\nlike my kinda guy..."
msgstr "Eres...\\nmi tipo de chico..."

msgctxt "630	720"
msgid "Are you enjoying my\\nfoot massage?"
msgstr "¿Estás disfrutando mi\\nmasaje de pies?"

msgctxt "765	840"
msgid "What? You want me\\nto step on you more?"
msgstr "¿Qué? ¿Quieres que\\nte pisotee más?"

msgctxt "870	970"
msgid "Hey mister, are you some\\nkind of weirdo?"
msgstr "Hola señor, ¿eres una\\n especie de tipo raro?"

msgctxt "1065	1155"
msgid "Oh, so this is your\\nweak spot!"
msgstr "¡Oh, así que este es tu\\npunto débil!"

msgctxt "1240	1315"
msgid "No way, you like it like that\\nright here?"
msgstr "Ni lo sueñes, ¿te gusta\\nasí aquí?"

msgctxt "1385	1440"
msgid "Mister, you're really into this."
msgstr "Señor, está muy metido en esto."

msgctxt "1565	1625"
msgid "Are you not feeling well?"
msgstr "¿No te sientes bien?"

msgctxt "1670	1750"
msgid "Hmmm, you feel a little hot."
msgstr "Hmmm, sientes un poco de calor."

msgctxt "1800	1890"
msgid "I'll check your temperature\\nwith my forehead."
msgstr "Te tomaré la temperatura\\ncon mi frente."

msgctxt "1950	2030"
msgid "Oh wow.\\nYour body feels hotter..."
msgstr "Vaya.\\nTu cuerpo está más caliente..."

msgctxt "2100	2200"
msgid "You're so hot.\\nMaybe you need a shot!"
msgstr "Estás tan caliente.\\n¡Tal vez te hace falta un chupito!"

msgctxt "2260	2330"
msgid "I'm kidding."
msgstr "Estoy bromeando."

msgctxt "2370	2405"
msgid "Sorry, sorry!"
msgstr "¡Lo siento, lo siento!"

msgctxt "2420	2520"
msgid "You're so cute when you're angry."
msgstr "Eres tan lindo cuando estás enojado."

