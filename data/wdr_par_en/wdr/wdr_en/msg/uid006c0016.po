msgstr "Disfrute su estadía aquí. <Color:7>♥<Color:Default>"

msgctxt "18432_Shizuka"
msgid "Let me make your drink."
msgstr "Déjame prepararle su bebida."

msgctxt "18444_Shizuka"
msgid "Thanks."
msgstr "Gracias."

msgctxt "18480_Shizuka"
msgid "I'm Shizuka. A pleasure to make your acquaintance."
msgstr "Me llamo Shizuka. Es un placer conocerle."

msgctxt "18492_Shizuka"
msgid "Same here."
msgstr "Igualmente."

msgctxt "18504_Shizuka"
msgid "<Color:8>\\r\n"\n"<Color:Default>"
msgstr "<Color:8>\\r\n"\n"<Color:Default>"

