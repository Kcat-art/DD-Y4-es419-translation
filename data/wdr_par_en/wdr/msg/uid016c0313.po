msgctxt "816_Player"
msgid "\"Be sure to treat your fans well.\""
msgstr ""

msgctxt "828_Player"
msgid "\"You really are a model, huh?\""
msgstr ""

msgctxt "840_Player"
msgid "\"You'll have to wear a disguise or something.\""
msgstr ""

msgctxt "852_Player"
msgid "\"Staying busy helps keep you healthy.\""
msgstr "\"Mantenerse ocupado ayuda a estar sano.\""

msgctxt "864_Player"
msgid "\"Do you think you can really go to bed early?\""
msgstr "\"¿De verdad crees que puedes acostarte temprano?\""

msgctxt "876_Player"
msgid "\"Do you want me to give you a wakeup call?\""
msgstr "\"¿Quieres que te llame en la mañana?\""

msgctxt "888_Player"
msgid "\"What's the point? Kids grow up so fast.\""
msgstr "\"¿Cuál es el punto? Los niños crecen muy rápido.\""

msgctxt "900_Player"
msgid "\"Maybe the kid didn't like it.\""
msgstr "\"Quizás al niño no le guste.\""

msgctxt "912_Player"
msgid "\"Do you want children of your own?\""
msgstr "\"¿Quieres tener hijos propios?\""

msgctxt "924_Player"
msgid "\"Being a model sounds fun.\""
msgstr "\"Ser una modelo suena divertido.\""

msgctxt "936_Player"
msgid "\"You're a lightweight. Don't over do it.\""
msgstr "\"Eres una peso ligero. No te excedas.\""

msgctxt "948_Player"
msgid "\"Tell me all about it next time.\""
msgstr "\"Cuéntame todos los detalles la próxima vez.\""

msgctxt "960_Player"
msgid "\"I wanted to see you, too.\""
msgstr "\"Yo también quiero verte.\""

msgctxt "972_Player"
msgid "\"I could sense what you wanted.\""
msgstr "\"Podía sentir lo que querías.\""

msgctxt "984_Player"
msgid "\"I hope we have a long future ahead of us.\""
msgstr "\"Espero que tengamos un gran futuro por delante.\""

