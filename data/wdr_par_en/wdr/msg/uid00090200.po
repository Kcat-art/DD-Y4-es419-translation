msgctxt "1820"
msgid "Find Mi-Youn"
msgstr "Encuentra a Mi-Youn"

msgctxt "68_Tanimura"
msgid "Mi-Youn. We need to talk."
msgstr "Mi-Youn. Tenemos que hablar."

msgctxt "92_Mi-Youn"
msgid "Eeek!"
msgstr "¡Ay!"

msgctxt "140_Tanimura"
msgid "Hey, wait a second!"
msgstr "¡Oye, espera!"

msgctxt "152_Tanimura"
msgid "(I swear... These kids are way too sneaky for their own good. I guess I'll just have to keep looking.)"
msgstr "(Lo juro... Estos niños son demasiado astutos por sí solos. Supongo que tendré que seguir buscando)."

msgctxt "164_Find Mi-Youn"
msgid "When you find out where Mi-Youn is hiding, press <Action:Button_R3@Adventure> to switch to a first-person perspective. Just looking at her will make her come out of hiding."
msgstr "Cuando descubras dónde se esconde Mi-Youn, presiona <Action:Button_R3@Adventure> para cambiar a una perspectiva en primera persona. Solo con mirarla la hará salir de su escondite."

