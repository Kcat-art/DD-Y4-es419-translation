msgctxt "80_Arima"
msgid "Setsuko! What's this I hear about a job hunt!?"
msgstr "¡Setsuko! ¡¿Cómo es eso de que andas buscando trabajo por toda la ciudad?!"

msgctxt "92_Arima"
msgid "What the hell's going on!?"
msgstr "¡¿Qué diablos crees que haces?!"

msgctxt "104_Setsuko"
msgid "Well..."
msgstr "Bueno..."

msgctxt "116_Arima"
msgid "Look, don't worry about the company. Shiobara and I were\\r\n"\n"just putting the finishing touches on our partnership\\r\n"\n"agreement."
msgstr "No tienes que preocuparte por la empresa. Shiobara y yo\\r\n"\n"estamos firmando los últimos acuerdos de nuestra\\r\n"\n"colaboración."

msgctxt "128_Shiobara"
msgid "Hello?"
msgstr "¿Hola?"

msgctxt "152_Arima"
msgid "Shiobara-san! What are you doing here?"
msgstr "¡Shiobara-san! ¿Qué está haciendo aquí?"

msgctxt "164_Shiobara"
msgid "I could ask you the same thing, disappearing in the middle\\r\n"\n"of signing our agreement."
msgstr "Podría preguntarle lo mismo, Arima-san. Desapareciste\\r\n"\n"en medio de la firma de nuestro acuerdo."

msgctxt "176_Shiobara"
msgid "Oh, I see your wife is here, too. What's going on?"
msgstr "Ah, veo que tu mujer también está aquí. ¿Qué está pasando?"

msgctxt "188_Arima"
msgid "Nothing. Nothing at all. Let's head back and finish up that\\r\n"\n"paperwork."
msgstr "Nada, no pasa nada. Regresemos y terminemos con el\\r\n"\n"papeleo."

msgctxt "200_Arima"
msgid "Just don't embarrass me anymore. Got it?"
msgstr "Solo no me vuelvas a avergonzar. ¡¿Entendiste?!"

msgctxt "212_Akiyama"
msgid "Who's embarrassing whom?"
msgstr "¿Quién está avergonzando a quién?"

msgctxt "236_Shiobara"
msgid "Akiyama-san!"
msgstr "¡Akiyama-san!"

msgctxt "248_Setsuko"
msgid "...!?"
msgstr "¡¿...?!"

msgctxt "260_Arima"
msgid "Why are you here, anyway?"
msgstr "¿Por qué estás aquí?"

msgctxt "272_Akiyama"
msgid "I own the place."
msgstr "Este es mi club."

msgctxt "284_Arima"
msgid "What!?"
msgstr "¡¿Qué?!"

msgctxt "296_Setsuko"
msgid "Oh!"
msgstr "¡Oh!"

msgctxt "308_Akiyama"
msgid "What you do with Shiobara is none of my concern, but this\\r\n"\n"lady here is my customer."
msgstr "No es de mi incumbencia lo que hagas con Shiobara,\\r\n"\n"pero Setsuko-san es mi cliente."

msgctxt "320_Akiyama"
msgid "Stay out of her way, and let her finish her test!"
msgstr "¡Mantente fuera de su camino y deja que termine su prueba!"

msgctxt "332_Arima"
msgid "How dare you!"
msgstr "¡¿Cómo dices?!"

msgctxt "344_Shiobara"
msgid "Why would you be taking his test?"
msgstr "¿Por qué la propietaria está haciendo una de tus pruebas?"

msgctxt "356_Akiyama"
msgid "You probably haven't realized this yet, but Tenjin Loans\\r\n"\n"is... well..."
msgstr "Probablemente no te hayas dado cuenta, pero Préstamos\\r\n"\n"Tenjin está..."

msgctxt "368_Arima"
msgid "Shut up!"
msgstr "¡Cállate!"

msgctxt "380_Arima"
msgid "C'mon, guys! Get him!"
msgstr "¡Vamos, chicos! ¡A por él!"

