msgctxt "84_Tanimura"
msgid "You're those robbers, aren't you? You're all\\r\n"
"under arrest. Don't try anything funny."
msgstr "Ustedes son los ladrones, ¿no es así? ¡Están todos\\r\n"
"bajo arresto! ¡No se les ocurra resistirse!"

msgctxt "96_Robber"
msgid "Goddamnit... The cops followed us here?"
msgstr "Tch... ¡Maldita sea! Nos siguió hasta aquí."

msgctxt "108_Robber"
msgid "Everyone, run for it!"
msgstr "¡Todos, corran!"

msgctxt "120_Tanimura"
msgid "Hey, get back here! Damn!"
msgstr "¡Eh, vuelvan aquí! ...¡Mierda!"

msgctxt "132_Tanimura"
msgid "We've got the exits covered, so they shouldn't be able to make it out of the garage."
msgstr "Tenemos las salidas completamente cubiertas, así que es imposible que salgan del garaje."

msgctxt "144_Tanimura"
msgid "I'll hunt them down and take all the credit!"
msgstr "Los encontraré y los atraparé a todos... ¡Todo el mérito será mío!"

