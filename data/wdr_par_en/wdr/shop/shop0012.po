msgctxt "392"
msgid "Quit"
msgstr "Salir"

msgctxt "397"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "415"
msgid "Order"
msgstr "Pagar"

msgctxt "421"
msgid "Order the currently selected item.  "
msgstr "Pedir el objeto actualmente seleccionado.  "

msgctxt "458"
msgid "(I haven't picked anything.)  "
msgstr "(No he escogido nada)"

msgctxt "489"
msgid "(I'm short on cash.)  "
msgstr "(Me hace falta dinero)"

msgctxt "512"
msgid "Will that be all for you?"
msgstr "¿Eso será todo?"

msgctxt "538"
msgid "(I can't carry any more stuff.)"
msgstr "(No puedo llevar más cosas)."

msgctxt "570"
msgid "(They're sold out.)"
msgstr "(Están agotados)."

msgctxt "590"
msgid "The king of champagnes. Sure to turn heads."
msgstr "El rey de los champagnes. Seguro que atraerá\n"
"todas las miradas."

msgctxt "634"
msgid "Classy champagne for a classy man."
msgstr "Champán con clase para un hombre con clase."

msgctxt "669"
msgid "A slightly more premium champagne for the\n"
"discerning customer."
msgstr "Un champán ligeramente prémium para un\n"
"cliente más exigente."

msgctxt "732"
msgid "A middle-of-the-road champagne. Not bad, but\n"
"nothing too special."
msgstr "Un champán de calidad media. No está mal, pero\n"
"nada demasiado especial."

msgctxt "798"
msgid "A Yamazaki whisky made with carefully selected,\n"
"mature malts for a flavorful, smooth finish."
msgstr "Un whisky Yamazaki elaborado con maltas\n"
"cuidadosamente seleccionadas y maduras, que\n"
"ofrecen un sabor rico y un final suave."

msgctxt "891"
msgid "A simple draft beer with a nice head of foam."
msgstr "Una cerveza de barril sencilla con una buena\n"
"espuma."

msgctxt "937"
msgid "This is a cocktail of crème de cassis liqueur and \n"
"orange juice."
msgstr "Este es un cóctel de licor de crème de cassis y \n"
"jugo de naranja."

msgctxt "1003"
msgid "Plain old orange juice, pulp and all."
msgstr "Jugo de naranja, con pulpa y todo."

msgctxt "1041"
msgid "A clean spring water soju made with premier Korean\n"
"barley."
msgstr "Un soju de agua de manantial limpia elaborado con cebada coreana de primera calidad."

