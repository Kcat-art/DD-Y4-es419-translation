msgctxt "33	195"
msgid "When I saw that cash at Akiyama-san's place,\\nI knew my big chance had finally come."
msgstr "Cuando vi todo ese dinero en la oficina de Akiyama-san,\\nme di cuenta que mi gran oportunidad había llegado."

msgctxt "225	310"
msgid "It's just like you told me, Saejima-san."
msgstr "Justo como me dijiste, Saejima-san."

msgctxt "354	459"
msgid "You only get one shot in this line of work."
msgstr "Solo tienes una oportunidad para volverte un yakuza."

msgctxt "549	631"
msgid "And my time is now."
msgstr "Y mi oportunidad es ahora."

msgctxt "689	798"
msgid "Never felt so sure of anything."
msgstr "Nunca había estado tan seguro como ahora."

msgctxt "828	886"
msgid "Oh yeah?"
msgstr "Ya veo."

msgctxt "891	1027"
msgid "If ya think you got what it takes,\\nI'll put ya to the test!"
msgstr "¡Entonces aceptaré\\napropiadamente tus ideales!"

msgctxt "1045	1119"
msgid "It would be an honor."
msgstr "Por favor, no te contengas."

msgctxt "1133	1241"
msgid "Same. No holdin' back, kid."
msgstr "Sí. Tú tampoco lo hagas."

msgctxt "1256	1354"
msgid "And no cryin' like a baby\\nif I break you in half."
msgstr "Podrías morir ahora.\\nY no quiero quejas."

msgctxt "1356	1395"
msgid "Got that?"
msgstr "¿Lo entiendes?"

msgctxt "1459	1515"
msgid "Yes, sir."
msgstr "¡Sí!"

msgctxt "1520	1603"
msgid "Balls out, Kido!"
msgstr "¡Dalo todo! ¡Kido!"

