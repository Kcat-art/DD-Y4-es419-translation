msgctxt "360	426"
msgid "Ya ain't half bad."
msgstr "Nada mal."

msgctxt "437	555"
msgid "Same to you.\\nI'm honestly surprised."
msgstr "Lo mismo para ti.\\nSinceramente estoy sorprendido."

msgctxt "775	858"
msgid "What are you doing?\\nUncle Kaz!"
msgstr "¿Qué estás haciendo?\\n¡Tío Kaz!"

msgctxt "1008	1143"
msgid "What's wrong with you!?\\nStop it, please!"
msgstr "¡¿Qué creen que están haciendo?!\\n¡Deténganse, los dos!"

msgctxt "1197	1257"
msgid "Haruka!"
msgstr "¡Haruka!"

msgctxt "1376	1466"
msgid "Mister! Mister, are you okay?"
msgstr "¡Señor! Señor, ¿está bien?"

msgctxt "1509	1569"
msgid "Shit..."
msgstr "Mierda..."

msgctxt "1585	1645"
msgid "How am I..."
msgstr "Como se supone..."

msgctxt "1660	1772"
msgid "Gonna face Hamazaki now...?"
msgstr "Que pueda ver a Hamazaki estando así."

msgctxt "1793	1853"
msgid "Hamazaki?"
msgstr "¿Hamazaki?"

msgctxt "1947	2007"
msgid "Dammit."
msgstr "Maldita sea..."

msgctxt "2014	2120"
msgid "Body's... so heavy..."
msgstr "No puedo ni soportar mi propio peso..."

msgctxt "2263	2352"
msgid "Uncle Kaz, who is he?"
msgstr "Tío Kaz, ¿quién es él?"

