msgctxt "140"
msgid "You got <Color:8>Original Curry Take-home Pack<Color:Default>."
msgstr "Has obtenido un <Color:8>pack de curry original para llevar<Color:Default>."

msgctxt "2292"
msgid "Matsuya Staff"
msgstr "Personal de Matsuya"

msgctxt "2296"
msgid "Talk_Ojigi"
msgstr "Talk_Ojigi"

msgctxt "2300"
msgid "Kiryu"
msgstr "Kiryu"

msgctxt "56_Matsuya Staff"
msgid "Welcome to Matsuya, sir! How many will it be?"
msgstr "¡Bienvenido a Matsuya, señor!"

msgctxt "68_Kiryu"
msgid "I was actually wondering if you guys do takeout. I need curry, stat."
msgstr "¿Tiene comida para llevar? Necesito curry, y lo necesito urgentemente."

msgctxt "80_Matsuya Staff"
msgid "Oh, of course. A take-home pack of our original curry would\r\n"
"fit your needs to a T."
msgstr "Oh, claro. Un paquete para llevar de nuestro curry original sería\r\n"
"perfecto para lo que necesitas."

msgctxt "92_Kiryu"
msgid "Perfect, I'll take one."
msgstr "Perfecto, quiero uno."

msgctxt "104_Matsuya Staff"
msgid "That'll be 300 yen."
msgstr "Serían 300 yenes."

msgctxt "164_Matsuya Staff"
msgid "Thank you very much."
msgstr "Muchas gracias."

msgctxt "176_Kiryu"
msgid "(I know you're supposed to heat this stuff up before you eat it... but I don't have time for that. Gotta get this to him, ASAP.)"
msgstr "(Normalmente se calienta antes de comerlo... pero no tengo tiempo para eso. Debo llevárselo lo antes posible)."

msgctxt "212_Kiryu"
msgid "(Dammit, I don't have the cash.)"
msgstr "(Maldita sea, no tengo el dinero)."

msgctxt "224_Kiryu"
msgid "Sorry, can I actually cancel that? Something came up."
msgstr "Disculpa, ¿puedo cancelarlo? Surgió algo."

msgctxt "236_Matsuya Staff"
msgid "Oh, no problem at all. Please come again!"
msgstr "¡Oh, no hay problema! ¡Vuelva pronto!"

