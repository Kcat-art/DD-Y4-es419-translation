msgctxt "1588"
msgid "Customer"
msgstr "Cliente"

msgctxt "1592"
msgid "Player"
msgstr "Player"

msgctxt "1596"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "1600"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "140_Customer"
msgid "You wanna play a game of mahjong, man? Gotta have 25,000 sticks on you. You can buy 'em over at the desk."
msgstr "¿Quieres jugar una partida de mahjong? Necesitas 25.000 palos. Puedes comprarlos en el mostrador."

msgctxt "152_Customer"
msgid "Yo, play some mahjong with us? Just to warn you, we all suck at this game, heh."
msgstr "Oye, ¿quieres jugar al mahjong con nosotros? Pero te advierto, somos muy malos a este juego, je."

msgctxt "164_Customer"
msgid "Yeah, I'll play."
msgstr "Sí, jugaré."

msgctxt "176_Customer"
msgid "Okay, let's get started, then!"
msgstr "¡Bien, empecemos entonces!"

msgctxt "200_Customer"
msgid "Not right now."
msgstr "Ahora no."

msgctxt "212_Customer"
msgid "Aw, man... Well, come talk to me if you're feeling up to it later."
msgstr "Ay, hombre... Bueno, ven a hablar conmigo si te sientes con ganas más tarde."

msgctxt "224_Customer"
msgid "Play"
msgstr "Jugar"

msgctxt "236_Customer"
msgid "Don't Play"
msgstr "No jugar"

