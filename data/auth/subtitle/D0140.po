msgctxt "1041	1097"
msgid "Majima-san..."
msgstr "Majima-san..."

msgctxt "1430	1485"
msgid "Majima-san!"
msgstr "¡Majima-san!"

msgctxt "1549	1596"
msgid "Kiryu-chan."
msgstr "Kiryu-chan."

msgctxt "1623	1666"
msgid "Hey, don't move!"
msgstr "Hey, ¿a dónde vas?"

msgctxt "1671	1700"
msgid "That's far enough!"
msgstr "¡No te muevas!"

msgctxt "1712	1752"
msgid "What happened here?"
msgstr "¿Qué pasó aquí?"

msgctxt "1766	1922"
msgid "They trapped me like a freakin' rat.\\nGuess I'm gettin' cropped out for a while."
msgstr "Alguien me ha entregado como a una maldita rata.\\nSupongo que no podré moverme por un tiempo."

msgctxt "1932	1977"
msgid "Who's behind this?"
msgstr "¿Quién está detrás de esto?"

msgctxt "2005	2041"
msgid "Daigo."
msgstr "Daigo."

msgctxt "2052	2091"
msgid "What!?"
msgstr "¿Qué?"

msgctxt "2107	2163"
msgid "Daigo Dojima."
msgstr "Dojima Daigo."

msgctxt "2199	2247"
msgid "But why would he...?"
msgstr "¿Por qué Daigo...?"

msgctxt "2258	2320"
msgid "That's enough chit-chat!"
msgstr "¡Oye! ¡Ya deja de hablar!"

msgctxt "2325	2375"
msgid "You there, stay back!"
msgstr "¡Tú, fuera de aquí!"

msgctxt "2380	2463"
msgid "Unless you want to get hauled in, too!"
msgstr "¡O te arrestaré por obstrucción a la justicia!"

msgctxt "2596	2659"
msgid "Better hurry, Kiryu-chan."
msgstr "Mejor date prisa, Kiryu-chan."

msgctxt "2719	2797"
msgid "It's all one big spider web."
msgstr "Todos los incidentes están conectados."

msgctxt "2807	2928"
msgid "The hit back in '85.\\nThe ten billion yen."
msgstr "El día de hace 25 años.\\nEl incidente de los 10 mil millones..."

msgctxt "2929	2990"
msgid "Even Yasuko-chan."
msgstr "Incluso Yasuko-chan."

msgctxt "3007	3065"
msgid "What!?"
msgstr "¿Qué?"

msgctxt "3079	3206"
msgid "If we don't do somethin'...\\nthe Tojo's gonna bite the dust."
msgstr "Si no hacemos algo,\\nnuestro Clan Tojo será destruido."

msgctxt "3207	3308"
msgid "Yasuko-chan's in danger, too."
msgstr "Además, Yasuko-chan también está en peligro."

msgctxt "3357	3417"
msgid "This is on you."
msgstr "Esto depende de ti."

msgctxt "3434	3510"
msgid "You're all we got."
msgstr "Eres todo lo que tenemos."

