msgctxt "414	EXPLANATION"
msgid "Unlock all 100 lockers, both above and underground."
msgstr "Abre los 100 casilleros, tanto los de la superficie arriba\n"
"como los del subterráneo."

msgctxt "466	EXPLANATION"
msgid "Order everything on the menu at every restaurant."
msgstr "Pide todo el menú de cada restaurante."

msgctxt "516	EXPLANATION"
msgid "Make all weapons and gear for both Kamiyama Works shops."
msgstr "Fabrica todas las armas y equipos de las dos tiendas\n"
"de Kamiyama Works."

msgctxt "573	EXPLANATION"
msgid "Befriend everyone you can in the city."
msgstr "Hazte amigo de todos los que puedas en la ciudad."

msgctxt "612	EXPLANATION"
msgid "See all Revelations."
msgstr "Observa todas las revelaciones."

msgctxt "633	EXPLANATION"
msgid "Complete every minigame. Each minigame's completion status can\n"
"be viewed with <Action:Button_Cross@UI>."
msgstr "Completa todos los minijuegos. El estado de finalización de\n"
"cada minijuego puede ser visto con <Action:Button_Cross@UI>."

msgctxt "737	EXPLANATION"
msgid "Complete all hostess substories."
msgstr "Completa todas las subhistorias de las hostess."

msgctxt "770	EXPLANATION"
msgid "Complete all Hostess Maker hostess substories."
msgstr "Completa todas las subhistorias de las chicas del creador\n"
"de hostess."

msgctxt "817	EXPLANATION"
msgid "Train all Hostess Maker hostesses to be number one."
msgstr "Entrena a todas las chicas del Creador de Hostess para\n"
"convertirla en la número uno."

msgctxt "869	EXPLANATION"
msgid "Clear all of Saigo's training courses."
msgstr "Completa todas las lecciones del entrenamiento de Saigo."

msgctxt "908	EXPLANATION"
msgid "Complete all of Master's tasks."
msgstr "Complete todas las tareas del Sennin."

msgctxt "940	EXPLANATION"
msgid "Help Nair reach her objective."
msgstr "Ayuda a Nair para que pueda alcanzar su objetivo."

msgctxt "971	EXPLANATION"
msgid "Win all tournaments at the Coliseum."
msgstr "Gana todos los torneos en el coliseo."

msgctxt "1008	EXPLANATION"
msgid "All your apprentices must win the Rookie Tournament."
msgstr "Todos tus aprendices deben ganar el Torneo de Novatos."

msgctxt "1061	EXPLANATION"
msgid "Resolve specific cases heard on the police scanner."
msgstr "Resuelve casos específicos escuchados en el escáner de la policía."

msgctxt "1113	EXPLANATION"
msgid "Defeat all gangs."
msgstr "Derrota a todas las pandillas."

msgctxt "1131	EXPLANATION"
msgid "Defeat all enemies."
msgstr "Derrota a todos los enemigos."

msgctxt "1151	EXPLANATION"
msgid "Use every Heat Action."
msgstr "Usa todas las Acciones Heat."

