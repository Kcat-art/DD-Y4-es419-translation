msgctxt "80"
msgid "\"My three apprentices and I will be waiting.\"\\r\n"\n"　　　　　　　　　　　　　-Jo Amon"
msgstr "\"Mis tres aprendices y yo te estaremos esperando.\"\\r\n"\n"　　　　　　　　　　　　　 -Jo Amon"

msgctxt "760"
msgid "Kiryu"
msgstr "Kiryu"

msgctxt "56_Kiryu"
msgid "(That letter...)"
msgstr "(Esta carta...)."

msgctxt "68_Kiryu"
msgid "\"It's been a while, Kazuma Kiryu. But the time has come. A car will be waiting for you in the underground parking lot. Come to the arena on the edge of town at nightfall.\""
msgstr "\"Ha pasado un tiempo, Kazuma Kiryu. Pero ha llegado el momento. He preparado un auto en el estacionamiento subterráneo. Lo espero esta noche en la arena en las afueras de la ciudad.\""

msgctxt "92_Kiryu"
msgid "(This is going to be a hard battle. I can't get these guys involved.)"
msgstr "(Parece que será una pelea difícil. No puedo permitir que ellos se vean involucrados...)."

