msgctxt "940"
msgid "Tanimura"
msgstr "Tanimura"

msgctxt "68_Tanimura"
msgid "(So this is what Yabe gave his life for... a pile of papers.)"
msgstr "(Así que esto es por lo que Yabe dio su vida... un montón de papeles.)"

msgctxt "80_Tanimura"
msgid "(Hm? There's something else in here...)"
msgstr "(Hm? Hay algo más aquí...)"

msgctxt "92_Tanimura"
msgid "(A ring and a letter... It says, \"To Mitsuko.\" That's the bartender...)"
msgstr "(Un anillo y una carta... Dice \"A Mitsuko\". Esa es la bartender...)"

msgctxt "104_Tanimura"
msgid "(I should take these to her.)"
msgstr "(Debería llevárselos a ella.)"

