msgctxt "1632"
msgid "Zhao"
msgstr "Zhao"

msgctxt "1636"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "1640"
msgid "Tanimura"
msgstr "Tanimura"

msgctxt "1644"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "116_Zhao"
msgid "Ma-chan, you ready to go meet with Katsuragi tomorrow? You can rest here until then."
msgstr "Ma-chan, ¿estás listo para reunirte con Katsuragi mañana? Puedes descansar aquí hasta entonces."

msgctxt "128_Tanimura"
msgid "(Hmm...)"
msgstr "(Mmm...)"

msgctxt "140_Tanimura"
msgid "No, I have a couple things to do first. Be back later."
msgstr "No, primero tengo que hacer un par de cosas. Vuelvo más tarde."

msgctxt "152_Zhao"
msgid "Okay. Talk to me whenever you're ready."
msgstr "Bien. Habla conmigo cuando estés listo."

msgctxt "164_Tanimura"
msgid "Sounds like a good idea. Thanks."
msgstr "Suena como una buena idea. Gracias."

msgctxt "176_Zhao"
msgid "Sure. You take it easy now."
msgstr "Seguro. Ahora te lo tomas con calma."

msgctxt "224_Zhao"
msgid "No, I'm not ready yet."
msgstr "No, aún no estoy listo."

msgctxt "236_Zhao"
msgid "Okay, I'll stay here."
msgstr "De acuerdo, me quedaré aquí."

