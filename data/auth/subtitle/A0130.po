msgctxt "750	840"
msgid "Don't forget to eat, Chief! ⑮"
msgstr "¡No se olvide de comer, Jefe! ⑮"

msgctxt "1259	1368"
msgid "It's ice cold."
msgstr "La grasita ya se puso toda fría."

msgctxt "2078	2214"
msgid "Hm? Where'd I put that lighter...?"
msgstr "¿Eh? El encendedor...\\n¿dónde puse el encendedor?"

msgctxt "2284	2344"
msgid "The hell?"
msgstr "¿Dónde?"

msgctxt "3015	3075"
msgid "Stupid."
msgstr "¡Mierda!"

msgctxt "3475	3535"
msgid "Excuse me."
msgstr "Disculpe."

msgctxt "3546	3654"
msgid "Ah, hello there!\\nHow can I help you?"
msgstr "¡Oh, lo siento!\\n¿Eres un cliente?"

msgctxt "3680	3740"
msgid "Come in, come in."
msgstr "Pase, pase."

msgctxt "3803	3863"
msgid "Um..."
msgstr "Em..."

msgctxt "3883	3943"
msgid "Yes?"
msgstr "¿Sí?"

msgctxt "3961	4110"
msgid "I'm looking for Sky Finance.\\nAm I in the right place?"
msgstr "Estoy buscando Sky Finance.\\n¿Estoy en el lugar correcto?"

msgctxt "4121	4181"
msgid "Sure are."
msgstr "¡Sí!"

msgctxt "4178	4290"
msgid "Sorry, I know it's a bit of a hassle to find."
msgstr "Ah, de seguro te fue difícil encontrar este lugar, ¿verdad?"

msgctxt "4311	4377"
msgid "Please, please.\\nHave a seat."
msgstr "Pase, pase.\\nPor favor, tome asiento."

msgctxt "4387	4447"
msgid "Thank you."
msgstr "Gracias."

msgctxt "5012	5055"
msgid "So..."
msgstr "Entonces..."

msgctxt "5058	5080"
msgid "Yes?"
msgstr "¿Sí?"

msgctxt "5115	5233"
msgid "Are you... here for a loan?"
msgstr "¿Estás aquí por un préstamo?"

msgctxt "5254	5347"
msgid "Yes, I..."
msgstr "Sí, yo..."

msgctxt "5611	5652"
msgid "Um..."
msgstr "Em..."

msgctxt "5665	5685"
msgid "Yeah?"
msgstr "¿Sí?"

msgctxt "5702	5809"
msgid "Do you mind if I smoke?"
msgstr "¿Te importa si fumo?"

msgctxt "5823	5924"
msgid "Oh, not at all.\\nGo right ahead."
msgstr "Oh, para nada.\\nAdelante."

msgctxt "5934	6112"
msgid "Sorry about the mess.\\nMy secretary usually handles the customers."
msgstr "Perdona, pero suelo delegar\\nel trato con los clientes a mi secretaria."

msgctxt "6122	6206"
msgid "I never think to clean this stuff up."
msgstr "Nunca pienso en limpiar y esas cosas."

msgctxt "6731	6791"
msgid "Be my guest."
msgstr "Adelante."

msgctxt "6809	6869"
msgid "Thank you."
msgstr "Gracias."

msgctxt "7154	7214"
msgid "Now, uh..."
msgstr "Ahora, uh..."

msgctxt "7230	7272"
msgid "Yes?"
msgstr "¿Sí?"

msgctxt "7273	7370"
msgid "About that loan you wanted."
msgstr "Sobre ese préstamo que querías."

msgctxt "7380	7534"
msgid "Oh, yes. The truth is..."
msgstr "Oh, sí. La verdad es que..."

msgctxt "7605	7654"
msgid "Um..."
msgstr "Em..."

msgctxt "7655	7715"
msgid "Go on."
msgstr "Dime."

msgctxt "7736	7827"
msgid "Well, um..."
msgstr "Bueno, yo..."

msgctxt "7897	8043"
msgid "I heard you offer limitless loans.\\nNo guarantor, no collateral needed."
msgstr "Escuché que ofrecen préstamos ilimitados.\\nSin aval y sin necesidad de garantía."

msgctxt "8053	8113"
msgid "Is that true?"
msgstr "¿Es eso cierto?"

msgctxt "8219	8310"
msgid "Limitless, huh?"
msgstr "¿Ilimitados, dices?"

msgctxt "8363	8432"
msgid "And where did you hear that?"
msgstr "¿Dónde escuchaste eso?"

msgctxt "8589	8664"
msgid "Can't say, huh?"
msgstr "Así que no puedes decirlo..."

msgctxt "8681	8740"
msgid "Well, it's fine."
msgstr "Bueno, no importa."

msgctxt "8738	8925"
msgid "I imagine some other lender who\\nturned you down pointed you my way."
msgstr "Imagino que algún otro prestamista\\nque te rechazó te dijo eso."

msgctxt "8935	9108"
msgid "Fed you a line like, \"We can't give you\\na loan, but Sky Finance just might.\""
msgstr "Algo como, \"No podemos darle un préstamo,\\npero seguro en ese lugar lo harán\"."

msgctxt "9118	9215"
msgid "That and half a dozen other things, I bet."
msgstr "Me pregunto que otras cosas más te habrán dicho."

msgctxt "9225	9386"
msgid "We're not exactly popular\\nwith the rest of the industry, you see."
msgstr "Como habrás podido notar, no tenemos una\\nbonita reputación con el resto de la industria."

msgctxt "9578	9700"
msgid "So, how much do you need?"
msgstr "Entonces, ¿cuánto necesitas?"

msgctxt "9780	9936"
msgid "Um..."
msgstr "Em..."

msgctxt "9937	10043"
msgid "Hey, mind if I borrow your lighter?"
msgstr "Disculpa, ¿puedo tomar prestado tu encendedor?"

msgctxt "10086	10165"
msgid "Yes, be my guest."
msgstr "Adelante."

msgctxt "10467	10527"
msgid "Drama Queen?"
msgstr "¿Gran Estrella?"

msgctxt "10649	10839"
msgid "Sorry, you just don't see many places\\nwith names like that in Kamurocho."
msgstr "Lo siento, simplemente no ves muchos lugares\\ncon nombres como ese en Kamurocho."

msgctxt "10866	10951"
msgid "Is that where you work?"
msgstr "¿Es un encendedor de tu lugar de trabajo?"

msgctxt "10975	11046"
msgid "Oh, no."
msgstr "Oh, en realidad no..."

msgctxt "11115	11235"
msgid "That is, I don't work there anymore."
msgstr "Quiero decir, ya no trabajo en ese lugar."

msgctxt "11334	11405"
msgid "Have you been in the business long?"
msgstr "¿Hace mucho que trabajas en el negocio?"

msgctxt "11415	11585"
msgid "Yes. A while, I suppose."
msgstr "Sí. Un tiempo, supongo."

msgctxt "11722	11810"
msgid "So. Name your figure."
msgstr "Entonces, ¿cuánto necesitas?"

msgctxt "11926	12117"
msgid "There's no way I can help you\\nif you don't tell me how much you need."
msgstr "No hay forma de seguir con esta\\nconversación si no me dices cuánto necesitas."

msgctxt "12342	12421"
msgid "A hundred... million."
msgstr "Cien... millones."

msgctxt "12568	12680"
msgid "That's the amount, in cash."
msgstr "Cien millones, en efectivo..."

msgctxt "12687	12832"
msgid "Within the next ten days,\\nif that's at all possible."
msgstr "Dentro de los próximos diez días,\\nsi eso es posible."

msgctxt "12905	13006"
msgid "A hundred million."
msgstr "¿Cien millones?"

msgctxt "13016	13076"
msgid "Yes, sir."
msgstr "Sí."

msgctxt "13192	13252"
msgid "And your guarantor?"
msgstr "¿Y el avalista?"

msgctxt "13310	13363"
msgid "I don't have one."
msgstr "No tengo uno."

msgctxt "13364	13424"
msgid "Any collateral?"
msgstr "¿Alguna garantía?"

msgctxt "13425	13485"
msgid "No, sir."
msgstr "No hay."

msgctxt "13765	13890"
msgid "No guarantor. No collateral."
msgstr "Sin avalista. Sin garantías."

msgctxt "13901	14023"
msgid "And you want it all at once, in cash."
msgstr "Y quieres cien millones en efectivo."

msgctxt "14092	14236"
msgid "Do you realize just how much you're asking for?"
msgstr "¿Estás consciente de lo que me estás pidiendo?"

msgctxt "14266	14358"
msgid "I'm sorry, this is crazy."
msgstr "Lo siento, sabía que era algo imposible."

msgctxt "14344	14423"
msgid "I should never have brought it up."
msgstr "Perdóneme por molestarlo."

msgctxt "14433	14577"
msgid "It was foolish of me to impose.\\nPlease, just forget this ever happened."
msgstr "No estaba pensando con claridad.\\nPor favor, olvide esta conversación."

msgctxt "14650	14760"
msgid "I'm sorry to have wasted your time.\\nNow if you'll excuse me..."
msgstr "Siento haber desperdiciado su tiempo.\\nAhora, si me disculpa..."

msgctxt "14763	14823"
msgid "Hold on."
msgstr "Espera."

msgctxt "14843	14930"
msgid "I never said I wouldn't lend you the money."
msgstr "Nunca dije que no te prestaría el dinero."

msgctxt "14940	15080"
msgid "Now sit. Let's talk about this over tea."
msgstr "¿Por qué no hablamos tranquilamente\\nde ello mientras tomamos un té?\""

