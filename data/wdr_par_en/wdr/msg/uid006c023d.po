msgid "(I should've made sure I had some cash...)"
msgstr "(Debería haberme asegurado de tener algo de dinero...)"

msgctxt "320_Erena"
msgid "That was great! I totally sang my heart out."
msgstr "¡Fue increíble! Le puse todo el corazón al cantar."

msgctxt "332_Player"
msgid "That was a good song."
msgstr "Ah, qué buena canción."

msgctxt "344_Erena"
msgid "Thanks. You did a great job cheering me on. <Color:7>♥<Color:Default>"
msgstr "Gracias. Fuiste increíble animándome. <Color:7>♥<Color:Default>"

