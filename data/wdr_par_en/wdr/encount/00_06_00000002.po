msgctxt "116_Man"
msgid "You lookin' at me, buddy?"
msgstr "¿Me estás mirando, colega?"

msgctxt "128_Man"
msgid "What, you got a starin' problem or somethin'? Cut it out!"
msgstr "¿Qué pasa, tienes un problema con mirar o algo así? ¡Basta ya!"

msgctxt "152_Man"
msgid "I didn't stand a chance..."
msgstr "No tuve ninguna oportunidad..."

msgctxt "164_Man"
msgid "Sorry I went off on you like that."
msgstr "Siento haberme ido así de la lengua."

msgctxt "176_Man"
msgid "You got a goopy %s."
msgstr "Obtuviste un %s."

msgctxt "212_Man"
msgid "With someone like you lookin' at me, well, I can't help feelin' a little bashful."
msgstr "Con alguien como tú mirándome, bueno, no puedo evitar sentirme un poco tímido."

