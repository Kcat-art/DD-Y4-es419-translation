msgctxt "206\t284"
msgid "Hello? Anyone home?"
msgstr "¿Hola? ¿Alguien en casa?"

msgctxt "493\t553"
msgid "Can I help you?"
msgstr "¿En qué te puedo ayudar?"

msgctxt "562\t641"
msgid "Are you... Akiyama-san?"
msgstr "¿Tú eres... Akiyama-san?"

msgctxt "654\t716"
msgid "Last I checked."
msgstr "Así es."

msgctxt "886\t971"
msgid "Do I know you from somewhere?"
msgstr "¿Te conozco de alguna parte...?"

msgctxt "1069\t1159"
msgid "Wait, you're that guy!"
msgstr "¡Espera, eres ese tipo!"

msgctxt "1327\t1463"
msgid "Huh. So you're the one who\\nlent Yasuko-san that 100 mil."
msgstr "Ya veo. Así que tú eres la persona\\nque le prestó 100 millones a Yasuko-san."

msgctxt "1470\t1521"
msgid "Yasuko?"
msgstr "¿Yasuko?"

msgctxt "1522\t1603"
msgid "Don't you mean Lily-chan?"
msgstr "¿Por Yasuko, te refieres a Lily-chan?"

msgctxt "1613\t1704"
msgid "How do you know her real name?"
msgstr "¿Cómo sabes su verdadero nombre?"

