msgctxt "116_Chihiro"
msgid "I love the yakiniku here. I can't wait to stuff myself!"
msgstr "Me encanta el yakiniku de este lugar. ¡No puedo esperar para comer hasta saciarme!"

msgctxt "128_Player"
msgid "Let's go in, then."
msgstr "Let's go in, then."

msgctxt "140_Chihiro"
msgid "Okay!"
msgstr "¡Está bien!"

msgctxt "164_Chihiro"
msgid "I love the yakiniku here. I can't wait to stuff myself!"
msgstr "Me encanta el yakiniku de este lugar. ¡No puedo esperar para comer hasta saciarme!"

msgctxt "176_Player"
msgid "Hold on a sec... Um, looks like I'm low on cash."
msgstr "Un segundo... Mmm, parece que no tengo dinero."

msgctxt "188_Chihiro"
msgid "What? You are!?"
msgstr "¿Qué? ¡¿En serio?!"

msgctxt "200_Player"
msgid "Yeah. Sorry."
msgstr "Sí. Lo siento."

msgctxt "212_Chihiro"
msgid "That's a shame. I guess that's it today.\\r\n"
"\\r\n"
"Goodbye for now."
msgstr "Es una pena. Supongo que esto será todo por hoy.\\r\n"
"\\r\n"
"Nos vemos."

msgctxt "224_Player"
msgid "(I better find some money...)"
msgstr "(Será mejor que encuentre algo de dinero...)."

msgctxt "332_Chihiro"
msgid "That was so yummy! I think I ate too much, though."
msgstr "¡Estuvo delicioso! Aunque, creo que comí de más."

msgctxt "344_Player"
msgid "Heh, I'm glad you liked it."
msgstr "Je, me alegra que te haya gustado."

msgctxt "356_Chihiro"
msgid "Thank you."
msgstr "Gracias."

msgctxt "380_Talk_Ojigi"
msgid "See you at the club! <Color:7>♥<Color:Default>"
msgstr "¡Nos vemos en el club! <Color:7>♥<Color:Default>"

msgctxt "404_Chihiro"
msgid "That wasn't bad. I think I ate a little too much, though."
msgstr "No estuvo mal. Aunque, creo que comí de más."

msgctxt "416_Player"
msgid "Heh, that's okay."
msgstr "Je, no pasa nada."

msgctxt "428_Chihiro"
msgid "Well, goodbye. I'll see you at the club!"
msgstr "Bueno, nos vemos. ¡Lo veré en el club!"

