msgctxt "2304"
msgid "Tanimura"
msgstr "Tanimura"

msgctxt "2308"
msgid "Player"
msgstr "Player"

msgctxt "2312"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "2316"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "128_Tanimura"
msgid "Oh, %s-san. I'd be glad to head out for you if there's\\r\n"
"something you need taken care of."
msgstr "Oh, %s-san. Estaré encantado de salir por ti si quieres que me encargue de algo."

msgctxt "152_Player"
msgid "No, it's okay."
msgstr "No, está bien."

msgctxt "164_Player"
msgid "Sorry, gonna have to take a rain check."
msgstr "Lo siento, pero lo dejaré para después."

msgctxt "176_Player"
msgid "Think I'm good."
msgstr "Creo que estoy bien."

msgctxt "188_Player"
msgid "Appreciate the offer, but I'm gonna have to pass."
msgstr "Aprecio la oferta, pero voy a tener que pasar."

msgctxt "200_Tanimura"
msgid "Oh, all right. Just try to take care of yourself, okay?"
msgstr "Oh, está bien. Solo trata de cuidarte, ¿de acuerdo?"

msgctxt "224_Player"
msgid "That's a good idea. Thanks, Tanimura."
msgstr "Es una buena idea. Gracias, Tanimura."

msgctxt "236_Player"
msgid "Sure, guess I wouldn't mind taking a little breather."
msgstr "Claro, supongo que no me importaría tomarme un pequeño respiro."

msgctxt "248_Player"
msgid "Yeah, gotta catch my breath."
msgstr "Sí, tengo que recuperar el aliento."

msgctxt "260_Player"
msgid "Thanks, I'll do that."
msgstr "Gracias, lo haré."

msgctxt "272_Tanimura"
msgid "Great. I'll take it from here."
msgstr "Perfecto. Yo me encargo de esto"

msgctxt "296_Tanimura"
msgid "No, it's okay."
msgstr "No, está bien."

msgctxt "308_Tanimura"
msgid "Sure."
msgstr "Claro."

