msgctxt "516	576"
msgid "Um..."
msgstr "Em..."

msgctxt "560	744"
msgid "The manager said you wanted to\\nsee me about something...?"
msgstr "El gerente dijo que querías\\nconversar conmigo de algo..."

msgctxt "831	891"
msgid "Incredible."
msgstr "Estoy sorprendido."

msgctxt "938	1067"
msgid "Some people hardly change.\\nEven after 25 years."
msgstr "Algunas personas apenas cambian.\\nIncluso después de 25 años."

msgctxt "1092	1141"
msgid "Excuse me?"
msgstr "¿Disculpe?"

msgctxt "1142	1260"
msgid "I've been looking for you.\\nFor a long, long time."
msgstr "Por fin te encontré.\\nTe he estado buscando por un largo tiempo."

