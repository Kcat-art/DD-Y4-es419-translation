msgctxt "116_Man"
msgid "Pardon me. Got a second? I'm conducting a survey."
msgstr "Disculpa, ¿tienes un momentito? Estoy haciendo una encuesta."

msgctxt "128_Man"
msgid "How do you like getting your ass kicked? And remember, this is for posterity, so be honest!"
msgstr "¿Cómo te gusta que te pateen el culo? Y recuerda, esto es para la posteridad, ¡así que sé sincero!"

msgctxt "152_Man"
msgid "That's enough! Thank you for your valuable contribution to my research!"
msgstr "¡Eso es suficiente! ¡Gracias por tu valiosa contribución a mi investigación!"

msgctxt "164_Man"
msgid "This is for you－for helping with my survey."
msgstr "Esto es para ti, por ayudar con mi encuesta."

msgctxt "176_Man"
msgid "You got a stimulating %s."
msgstr "Obtuviste un %s."

msgctxt "212_Man"
msgid "The survey's closed..."
msgstr "La encuesta ha cerrado..."

