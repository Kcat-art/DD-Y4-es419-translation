msgctxt "39\t203"
msgid "Great. Everyone go do their own thing,\\nand we'll reconvene here."
msgstr "Bien. Cada uno vaya a hacer lo suyo,\\n volveremos a reunirnos aquí."

msgctxt "302\t392"
msgid "Can we not?\\nThe whole \"go team\" thing is corny."
msgstr "¿De verdad quieres hacer eso?\\nEs algo anticuado."

msgctxt "395\t497"
msgid "Oh, get over yourself.\\nThis is important!"
msgstr "Vamos, vamos.\\nEste tipo de cosas son importantes."

msgctxt "498\t561"
msgid "Now gimme those hands."
msgstr "Ahora, pongan esas manos."

msgctxt "647\t712"
msgid "Yeah, whatever."
msgstr "Sí, lo que sea."

msgctxt "874\t934"
msgid "Saejima-san?"
msgstr "¿Saejima-san?"

msgctxt "1031\t1108"
msgid "I know I made it sound simple..."
msgstr "Hablé de ello como algo simple, pero..."

msgctxt "1113\t1218"
msgid "But one misstep and we're all breathing our last."
msgstr "Un paso en falso y podrían terminar muertos."

msgctxt "1237\t1297"
msgid "Everyone gets that, yeah?"
msgstr "¿Realmente están listos para ello?"

msgctxt "1878\t1938"
msgid "Well then."
msgstr "Bien, entonces."

