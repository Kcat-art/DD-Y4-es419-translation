msgctxt "3728"
msgid "Haruka"
msgstr "Haruka"

msgctxt "3732"
msgid "Kiryu"
msgstr "Kiryu"

msgctxt "256_Haruka"
msgid "I love going to karaoke with you, Uncle Kaz! Now, what should I sing today?"
msgstr "¡Me encanta ir al karaoke contigo, Tío Kaz! Ahora, ¿qué debería cantar hoy?"

msgctxt "268_Haruka"
msgid "I think I'll sing \"Otomeiro My Life.\" But wait, I kind of wanna sing something else, too. There are so many songs I like! I can't decide!"
msgstr "¡Creo que cantaré \"Otomeiro My Life\"! Pero espera, también quiero cantar otra cosa. ¡Hay tantas canciones que me gustan! ¡No puedo decidir!"

msgctxt "280_Haruka"
msgid "I wonder how I did?"
msgstr "Me pregunto cómo me habrá ido."

msgctxt "292_Haruka"
msgid "C'mon, you sing too! I wanna hear you sing!"
msgstr "¡Vamos, tú también canta! ¡Quiero escucharte!"

msgctxt "304_Haruka"
msgid "Hooray! I can't wait!"
msgstr "¡Hurra! ¡No puedo esperar!"

msgctxt "316_Haruka"
msgid "Oh, all right..."
msgstr "Oh, está bien..."

msgctxt "328_Haruka"
msgid "You made it so hard to sing..."
msgstr "Hiciste que cantar fuera tan difícil..."

msgctxt "340_Kiryu"
msgid "Sorry... I meant well though."
msgstr "Perdóname... No era mi intencion."

msgctxt "352_Haruka"
msgid "That was amazing! Thanks, Uncle Kaz."
msgstr "¡Eso fue increíble! Gracias, Tío Kaz."

msgctxt "364_Haruka"
msgid "C'mon, you sing too! I wanna hear you sing!"
msgstr "¡Vamos, tú también canta! ¡Quiero escucharte!"

msgctxt "376_Haruka"
msgid "Hooray! I can't wait!"
msgstr "¡Hurra! ¡No puedo esperar!"

msgctxt "388_Haruka"
msgid "Oh, all right..."
msgstr "Oh, está bien..."

msgctxt "400_Haruka"
msgid "Uncle Kaz, you're really good at singing. You're so cool!"
msgstr "¡Tío Kaz, eres muy bueno cantando! ¡Eres tan genial!"

msgctxt "412_Kiryu"
msgid "Heh. Thanks."
msgstr "Je. Gracias."

msgctxt "424_Haruka"
msgid "Uncle Kaz?"
msgstr "¿Tío Kaz?"

msgctxt "436_Kiryu"
msgid "Uh, my throat's been acting up..."
msgstr "Uh, mi garganta me ha estado molestando..."

msgctxt "448_Haruka"
msgid "You're so cool, Uncle Kaz! You sounded like a pro!"
msgstr "¡Eres tan genial, Tío Kaz! ¡Sonaste como todo un profesional!"

msgctxt "460_Kiryu"
msgid "Heh. It was nothing."
msgstr "Je, je. No fue nada."

msgctxt "472_Haruka"
msgid "Sure."
msgstr "Claro."

msgctxt "484_Haruka"
msgid "Not me."
msgstr "Yo no."

msgctxt "496_Haruka"
msgid "Sure."
msgstr "Claro."

msgctxt "508_Haruka"
msgid "Not me."
msgstr "Yo no."

