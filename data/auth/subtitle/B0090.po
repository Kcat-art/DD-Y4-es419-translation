msgctxt "1295\t1355"
msgid "As promised."
msgstr "Justo como prometí."

msgctxt "1391\t1552"
msgid "Had a buddy copy one for you.\\nGuy was a pro before he got tossed in here."
msgstr "Una copia para ti.\\nFabricada por un conocido que también terminó aquí."

msgctxt "1582\t1683"
msgid "That cell won't keep you cooped up anymore."
msgstr "Esa celda tuya ya no podrá mantenerte a raya."

msgctxt "1728\t1809"
msgid "Still didn't say I'd do it."
msgstr "Nunca te dije que lo haría."

msgctxt "1869\t1978"
msgid "No problem there.\\nYou'll do it."
msgstr "No es necesario que lo digas.\\nVas a hacerlo."

msgctxt "2014\t2090"
msgid "You don't have a choice."
msgstr "¿Acaso tienes otra opción?"

