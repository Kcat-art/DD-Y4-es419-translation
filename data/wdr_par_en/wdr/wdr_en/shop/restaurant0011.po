msgctxt "588"
msgid "Quit"
msgstr "Salir"

msgctxt "593"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "611"
msgid "Order"
msgstr "Pagar"

msgctxt "617"
msgid "Order the currently selected item."
msgstr "Pagar el objeto seleccionado actualmente."

msgctxt "652"
msgid "(I haven't picked anything.)"
msgstr "(No he escogido nada)"

msgctxt "681"
msgid "(I'm short on cash.)"
msgstr "(Me hace falta dinero)"

msgctxt "702"
msgid "Very well, sir."
msgstr "Muy bien, señor."

msgctxt "718"
msgid "(I can't eat anymore...)"
msgstr "(No puedo comer más...)"

msgctxt "762"
msgid "This gin-based cocktail is mixed with ginger ale and a\n"
"squeeze of lime."
msgstr "Este cóctel a base de ginebra se mezcla con ginger ale\n"
"y un chorrito de lima."

msgctxt "834"
msgid "A Tequila Rickey is tequila mixed with soda and \n"
"plenty of lime."
msgstr "Un Tequila Rickey es tequila mezclado con soda y \n"
"mucha lima."

msgctxt "899"
msgid "This cocktail is a mixture of tequila with bittersweet\n"
"blood orange juice."
msgstr "Este cóctel es una mezcla de tequila con jugo de\n"
"naranja sanguina agridulce."

msgctxt "974"
msgid "Campari & soda is loved the world over for its \n"
"bittersweet magic."
msgstr "Campari & soda es amado en todo el mundo por su \n"
"magia agridulce."

msgctxt "1041"
msgid "A mixture of Kahlua liqueur and milk for everyone's \n"
"favorite cocktail."
msgstr "Una mezcla de licor Kahlua y leche para el cóctel \n"
"favorito de todos."

msgctxt "1113"
msgid "A nice mix of Kakubin, lemon, and soda water. The \"XL\"\n"
"refers to its size, so you can take your time drinking it."
msgstr "Una agradable mezcla de Kakubin, limón y agua con gas. El \"XL\"\n"
"se refiere a su tamaño, para que puedas tomártelo con calma."

msgctxt "1227"
msgid "A slightly less alcoholic version of the regular Kakubin\n"
"highball."
msgstr "Una versión ligeramente menos alcohólica del highball Kakubin regular."

msgctxt "1294"
msgid "One of our most popular cocktails. The coconut flavor\n"
"will send you straight to a tropical paradise."
msgstr "Uno de nuestros cócteles más populares. El sabor a coco\n"
"te llevará directamente a un paraíso tropical."

msgctxt "1395"
msgid "Yamazaki whisky mixed with lemon and soda. Served\n"
"in a copper tumbler to keep it cold."
msgstr "Whisky Yamazaki mezclado con limón y soda. Servido\n"
"en un vaso de cobre para mantenerlo frío."

msgctxt "1482"
msgid "This is Yamazaki 12 Years. Carefully selected, mature\n"
"malts were used to produce this smooth, rich flavor\n"
"acknowledged the world over."
msgstr "Este es Yamazaki 12 años. Cuidadosamente seleccionado,\n"
"con maltas maduras que se utilizaron para producir este\n"
"sabor suave y rico reconocible en todo el mundo."

msgctxt "1617"
msgid "This is Bowmore 12 Years. It's aged in sherry barrels,\n"
"giving it a ripe aroma and floral taste. Standard fare\n"
"for Bowmore whisky."
msgstr "Este es Bowmore 12 Años. Ha sido envejecido en barriles\n"
"de jerez, lo que le otorga un aroma maduro y un sabor\n"
"floral. Un producto estándar para el whisky Bowmore."

msgctxt "1747"
msgid "This is Laphroaig 10 Years, known for its smoky and\n"
"dry, yet smooth flavor."
msgstr "Este es el Laphroaig 10 Años, conocido por su sabor\n"
"ahumado y seco, pero suave."

msgctxt "1823"
msgid "Suntory Old Whisky is an old favorite in Japan,\n"
"affectionately called \"Daruma\" for the bottle's\n"
"Daruma doll shape."
msgstr "El Suntory Old Whisky es un viejo favorito en Japón,\n"
"cariñosamente llamado \"Daruma\" por la botella\n"
"en forma de muñeca Daruma."

msgctxt "1938"
msgid "Early Times first hit the market in 1860. At 150 years\n"
"old, it's truly the face of bourbon."
msgstr "Early Times llegó por primera vez al mercado en 1860.\n"
"Hace unos 150 años, es realmente la cara del bourbon."

