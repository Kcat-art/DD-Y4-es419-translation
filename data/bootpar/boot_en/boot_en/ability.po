msgctxt "60804	EXPLANATION"
msgid "Shower kick enemy you sent flying with previous\n"
"kick. <Color:255,100,100,255>No further techniques can be unlocked.<Color:Default>"
msgstr "Patea a un enemigo que mandaste a volar con un puntapié.\n"
"<Color:255,100,100,255>No se pueden desbloquear más técnicas.<Color:Default>"

msgctxt "60935	EXPLANATION"
msgid "A skillful technique where you armbar an enemy\n"
"that is trying to get up."
msgstr "Una técnica hábil en la que agarras a un enemigo\n"
