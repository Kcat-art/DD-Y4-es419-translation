msgctxt "460"
msgid "Quit"
msgstr "Salir"

msgctxt "465"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "483"
msgid "Order"
msgstr "Pagar"

msgctxt "489"
msgid "Order the currently selected item."
msgstr "Pagar el objeto seleccionado actualmente."

msgctxt "524"
msgid "(I haven't picked anything.)"
msgstr "(No he escogido nada)"

msgctxt "553"
msgid "(I'm short on cash.)"
msgstr "(Me hace falta dinero)"

msgctxt "574"
msgid "Very well, sir."
msgstr "Muy bien, señor."

msgctxt "590"
msgid "(I can't eat anymore...)"
msgstr "(No puedo comer más...)"

msgctxt "634"
msgid "Nothing like a swig of grapefruit juice to cool you down.\n"
"Tangy, refreshing, and full of vitamins."
msgstr "Nada como un trago de jugo de toronja para refrescarse.\n"
"Ácido, refrescante y lleno de vitaminas."

msgctxt "733"
msgid "Made from Italian oranges with a refreshing blend of\n"
"sweet and sour flavors."
msgstr "Hecho de naranjas italianas con una refrescante mezcla de\n"
"sabores dulces y agrios."

msgctxt "810"
msgid "Made with only the finest Brazilian coffee beans for a\n"
"rich, authentic flavor."
msgstr "Elaborado únicamente con los mejores granos de café brasileños para obtener un sabor rico y auténtico."

msgctxt "889"
msgid "Made with only the finest Brazilian coffee beans.\n"
"Watered down to alleviate the bitterness."
msgstr "Elaborado con los mejores granos de café brasileños. Con mucha agua para suavizar el amargor."

msgctxt "981"
msgid "A perfect marriage of rich milk and Brazilian coffee\n"
"beans. Truly a match made in heaven."
msgstr "Una combinación perfecta de rica leche y granos de\n"
"café brasileños. Una combinación perfecta."

msgctxt "1071"
msgid "A classic blend of rich espresso and frothy milk."
msgstr "Una mezcla clásica de un rico expreso y leche espumosa."

msgctxt "1121"
msgid "A popular drink made with espresso, chocolate, and\n"
"cocoa. Smooth and chocolatey."
msgstr "Una bebida popular a base de espresso, chocolate y \n"
"cacao. Suave y achocolatada."

msgctxt "1202"
msgid "A rich, refreshing beverage made with fresh milk.\n"
"The aroma alone will melt all your worries away."
msgstr "Una bebida rica y refrescante hecha con leche fresca.\n"
"Solo el aroma derretirá todas tus preocupaciones."

msgctxt "1301"
msgid "Nothing like a refreshing, nutritious glass of milk."
msgstr "Nada como un refrescante y nutritivo vaso de leche."

msgctxt "1354"
msgid "Rich, tasty cocoa brewed with hand-picked cacao beans."
msgstr "Cacao rico y sabroso elaborado con frutos de cacao seleccionados a mano."

