msgctxt "188"
msgid "You got <Color:8>Large Curry Take-home Packs<Color:Default>."
msgstr "Has obtenido un <Color:8>pack de curry para llevar<Color:Default>."

msgctxt "2080"
msgid "Matsuya Staff"
msgstr "Personal de Matsuya"

msgctxt "2084"
msgid "Talk_Ojigi"
msgstr "Talk_Ojigi"

msgctxt "2088"
msgid "Kiryu"
msgstr "Kiryu"

msgctxt "2092"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "56_Matsuya Staff"
msgid "Hello, sir."
msgstr "Hola, señor."

msgctxt "68_Kiryu"
msgid "I need to get some curry."
msgstr "Necesito conseguir un poco de curry."

msgctxt "80_Matsuya Staff"
msgid "All right, certainly. What kind would you like?"
msgstr "Muy bien, sin duda. ¿De qué tipo le gustaría?"

msgctxt "92_Kiryu"
msgid "Can I order it to go? And if you have them, some of those packs of just the sauce would be great."
msgstr "¿Puedo pedirlo para llevar? Y si tienen, me gustaría unos de sos paquetes que solo llevan salsa. (este dudo mucho que este correcto)."

msgctxt "104_Matsuya Staff"
msgid "How about our Original Curry take-home packs? They are easy to prepare and can be enjoyed in the comfort of your home."
msgstr "¿Qué le parecen nuestros packs de curry original para llevar a casa? Son fáciles de preparar y se pueden disfrutar en la comodidad de su hogar."

msgctxt "116_Kiryu"
msgid "Sounds good. Can you get me a big box of them?"
msgstr "Suena bien. ¿Puedes conseguirme una caja grande de esos?"

msgctxt "128_Matsuya Staff"
msgid "Certainly. Just a moment, please."
msgstr "Ciertamente. Un momento, por favor."

msgctxt "176_Matsuya Staff"
msgid "Here you go, sir."
msgstr "Aqui tiene, señor."

msgctxt "212_Kiryu"
msgid "Thanks."
msgstr "Gracias."

msgctxt "224_Matsuya Staff"
msgid "Thank you for visiting Matsuya!"
msgstr "¡Gracias por visitar Matsuya!"

