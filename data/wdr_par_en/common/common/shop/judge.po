msgctxt "This text has no context info. The text is used in judge.po. Position in file: 2"
msgid "Cancel"
msgstr "Cancelar"

msgctxt "4"
msgid "Don't ask for an appraisal."
msgstr "No pedir tasación."

msgctxt "8"
msgid "Appraise"
msgstr "Tasar"

msgctxt "12"
msgid "Ask for an appraisal."
msgstr "Pedir una tasación."

msgctxt "16"
msgid "(I don't have anything to get appraised.)"
msgstr "(No tengo nada que se pueda tasar)."

msgctxt "20"
msgid "%d, huh? Want an appraisal?"
msgstr "%d, ¿eh? ¿Quieres que tase algo?"

msgctxt "24"
msgid "That comes to %d points. Thanks."
msgstr "Eso serían unos %d puntos. Gracias."

