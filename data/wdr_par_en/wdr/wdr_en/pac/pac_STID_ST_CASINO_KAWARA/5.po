msgctxt "232"
msgid "You're amazing, Uncle Kaz!"
msgstr "¡Eres asombroso, tío Kaz!"

msgctxt "244"
msgid "You got a ton of chips!"
msgstr "¡Tienes un montón de fichas!"

msgctxt "280"
msgid "Oh, you were so close!"
msgstr "Oh, estuviste tan cerca!"

msgctxt "292"
msgid "You just had some bad luck."
msgstr "Solo tuviste mala suerte."

msgctxt "304"
msgid "I wanted you to play poker..."
msgstr "Quería que jugaras al póker..."

msgctxt "352"
msgid "Uncle Kaz!"
msgstr "¡Tío Kaz!"

msgctxt "364"
msgid "Get 5,000 points in poker!"
msgstr "¡Consigue 5000 puntos en póker!"

msgctxt "388"
msgid "Uncle Kaz!"
msgstr "¡Tío Kaz!"

msgctxt "400"
msgid "Get 2,000 points in poker!"
msgstr "¡Obtén 2000 puntos en póker!"

