msgctxt "1356"
msgid "Chihiro"
msgstr "Chihiro"

msgctxt "1360"
msgid "Tanimura"
msgstr "Tanimura"

msgctxt "120_Chihiro"
msgid "Here goes!\\r\n"
"Now you get to hear the results of my voice training! <Color:7>♥<Color:Default>"
msgstr "¡Ahora sí!\\r\n"
"¡Tendrá que escuchar los resultados de mis clases de canto! <Color:7>♥<Color:Default>"

msgctxt "132_Chihiro"
msgid "Hmm, what should I sing?\\r\n"
"How about \"Get to the Top\"? <Color:7>♥<Color:Default>"
msgstr "Mmm, ¿qué debería cantar?\\r\n"
"¡Ah! ¿Qué tal si canto: \"Get to the Top\"? <Color:7>♥<Color:Default>"

msgctxt "144_Chihiro"
msgid "Hehe, thanks!"
msgstr "Je, je, ¡gracias!"

msgctxt "156_Chihiro"
msgid "You made it really hard to sing..."
msgstr "Hiciste que cantar se me hiciera mucho más difícil..."

msgctxt "168_Tanimura"
msgid "Sorry."
msgstr "Lo siento."

msgctxt "180_Chihiro"
msgid "That felt SO good! <Color:7>♥<Color:Default>\\r\n"
"And it's all thanks to you cheering me on! <Color:7>♥<Color:Default>"
msgstr "¡Eso estuvo BUENÍSIMO! <Color:7>♥<Color:Default>\\r\n"
"¡Y todo gracias a que usted estaba animándome! <Color:7>♥<Color:Default>"

