msgstr "Talk_Yes"

msgctxt "6024"
msgid "Minami"
msgstr "Minami"

msgctxt "72_Saejima"
msgid "(Tonight's the showdown with ol' Majima.)"
msgstr "(Esta noche me reuniré de nuevo con Majima)."

msgctxt "84_Kido"
msgid "Kamurocho's still swarming with cops, Saejima-san.\\r\n"
"You can't risk moving aboveground."
msgstr "Saejima-san, aún hay muchos policías en Kamurocho.\\r\n"
"Ir a la superficie es peligroso."

msgctxt "96_Kido"
msgid "If you're meeting Minami at the Millennium Tower tonight,\\r\n"
"then maybe you should rest here until nightfall."
msgstr "Si te reunirás con Minami en la Torre Millennium esta noche,\\r\n"
"deberías descansar hasta que llegue la hora."

msgctxt "108_Kido"
msgid "In the meantime, I'll go scope out the best route\\r\n"
"to get you there in one piece."
msgstr "Mientras descansas, buscaré la mejor ruta para\\r\n"
"llegar a la Torre Millennium para ti."

msgctxt "120_Saejima"
msgid "Much obliged."
msgstr "Sí, por favor."

msgctxt "132_Kido"
msgid "Just lemme know when you want to rest up.\\r\n"
"I'll stay put until then."
msgstr "Avísame cuando vayas a descansar.\\r\n"
"Estaré aquí hasta entonces."

msgctxt "144_Saejima"
msgid "(Guess I got some time till sundown.)"
msgstr "(Aún falta para que llegue la noche)."

msgctxt "168_Minami"
msgid "Whoa, down boy. Didn't come here lookin' for a fight."
msgstr "Oye, calmado. No vine buscando pelea."

msgctxt "180_Minami"
msgid "It's just when I came in to say hi, gramps and his\\r\n"
"lame-ass friends jumped me. So I, ya know..."
msgstr "Solo venía a buscarte, cuando estos tipos se\\r\n"
"lanzaron sobre mí, así que pues... ya sabes."

msgctxt "192_Saejima"
msgid "Whaddya want?"
msgstr "¿Qué pasa?"

msgctxt "204_Minami"
msgid "The boss is askin' for ya. Word is you two were bros\\r\n"
"back in the day."
msgstr "El jefe quiere verte. Dicen que ustedes eran\\r\n"
"compañeros hace tiempo."

msgctxt "216_Saejima"
msgid "Majima wants to meet?"
msgstr "¡¿Majima...?!"

msgctxt "228_Minami"
msgid "Says to stop by the office tomorrow night."
msgstr "Así que ven mañana por la noche a la oficina."

msgctxt "240_Saejima"
msgid "Where?"
msgstr "¿Dónde?"

msgctxt "252_Minami"
msgid "The Millennium Tower－ Y'know, that eyesore scrapin' the sky like it's nobody's business?"
msgstr "La Torre Millennium－Esa torre gigantesca en medio de la ciudad."

msgctxt "264_Saejima"
msgid "Fine."
msgstr "Bien."

msgctxt "276_Minami"
msgid "Knowin' the boss, he's prolly got some fucked up shit\\r\n"
"waitin' for ya on the top floor."
msgstr "Conociendo al jefe, te estará esperando en la cima."

msgctxt "288_Minami"
msgid "I'd come prepared if I was you."
msgstr "Yo que tú voy preparado."

msgctxt "312_Saejima"
msgid "Hey."
msgstr "Oye."

msgctxt "324_Minami"
msgid "'Sup?"
msgstr "¿Qué?"

msgctxt "336_Saejima"
msgid "Give a message to Majima."
msgstr "Dile a Majima..."

msgctxt "348_Saejima"
msgid "He best have some damn good answers ready.\\r\n"
"If not, he's gettin' his shit kicked in."
msgstr "Que será mejor que tenga respuestas,\\r\n"
"de lo contrario, le cortaré las pelotas."

msgctxt "360_Minami"
msgid "Heh. Think you can go all medieval on the bossman?"
msgstr "Je, ¿crees que le das la talla al jefe?"

msgctxt "372_Minami"
msgid "No dig, but he'll straight up kill ya."
msgstr "Tal vez te llegue a matar."

msgctxt "384_Minami"
msgid "See ya."
msgstr "Hasta luego."

msgctxt "408_Saejima"
msgid "(Best grab some shuteye before I settle the score tomorrow night.)"
msgstr "(Creo que descansaré por hoy. Mañana resolveré los problemas de hace 25 años)."

