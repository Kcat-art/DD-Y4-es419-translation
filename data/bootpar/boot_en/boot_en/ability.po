msgctxt "61841	CONTROL_EXPLANATION"
msgid "<Action:Button_LS_Up@Adventure><Action:Button_LS_Down@Adventure><Action:Button_LS_Left@Adventure><Action:Button_LS_Right@Adventure>"
msgstr "<Action:Button_LS_Up@Adventure><Action:Button_LS_Down@Adventure><Action:Button_LS_Left@Adventure><Action:Button_LS_Right@Adventure>"

msgctxt "61973	CONTROL_EXPLANATION"
msgid "Hold <Action:Battle_Fight_Stance@Combat>"
msgstr "Mantén pulsado <Action:Battle_Fight_Stance@Combat>"

msgctxt "62014	CONTROL_EXPLANATION"
msgid "<Action:Battle_Drop_Weapon@Combat> near an enemy"
msgstr "<Action:Battle_Drop_Weapon@Combat> cerca de un enemigo"

msgctxt "62063	CONTROL_EXPLANATION"
