msgctxt "12016"
msgid "Receptionist"
msgstr "Recepcionista"

msgctxt "12020"
msgid "The Underground Coliseum"
msgstr "El Coliseo Subterráneo"

msgctxt "740_Receptionist"
msgid "This facility is for members only."
msgstr "Este lugar es solo para miembros."

msgctxt "752_Receptionist"
msgid "I'm sorry, only registered customers can enter this facility."
msgstr "Lo siento, solo los clientes registrados pueden entrar a este lugar."

msgctxt "764_Receptionist"
msgid "Thank you very much. Come back when you want to fight again."
msgstr "Muchas gracias. Vuelve cuando quieras volver a pelear."

msgctxt "800_Receptionist"
msgid "Congratulations. Here is your reward for winning."
msgstr "¡Felicidades! Aquí tienes tu recompensa."

msgctxt "836_Receptionist"
msgid "Congratulations!"
msgstr "¡Felicidades!"

msgctxt "848_Receptionist"
msgid "Your nickname has been upgraded! You can check it out from the menu."
msgstr "¡Tu apodo ha sido actualizado! Puedes comprobarlo en el menú."

msgctxt "860_Receptionist"
msgid "Welcome. This is the Underground Coliseum."
msgstr "Bienvenido al Coliseo Subterráneo."

msgctxt "872_Receptionist"
msgid "Is this your first time here? We will have to register you first.\\r\n"\n"Have a look at the rules while you wait."
msgstr "¿Es tu primera vez aquí? Tendrás que registrarte antes de poder luchar.\\r\n"\n"Echa un vistazo a las reglas mientras esperas."

msgctxt "896_Receptionist"
msgid "Your registration is complete."
msgstr "Su registro está completo."

msgctxt "908_Receptionist"
msgid "This information has been added as a <Color:14>memo<Color:Default>.\\r\n"\n"Read <Color:14>memos<Color:Default> by selecting <Color:14>Memos<Color:Default> in the Pause Menu.\\r\n"\n"You can access the Pause Menu with the <Action:Button_Options@Adventure> button."
msgstr "Esta información ha sido añadida como una <Color:14>nota<Color:Default>.\\r\n"\n"Lee las <Color:14>notas<Color:Default> seleccionando <Color:14>Notas<Color:Default> en el menú de pausa.\\r\n"\n"Puedes acceder al menú de pausa con el botón <Action:Button_Options@Adventure>."

msgctxt "920_Receptionist"
msgid "What would you like to do?"
msgstr "¿Qué te gustaría hacer?"

msgctxt "932_Receptionist"
msgid "What would you like to ask about?"
msgstr "¿Qué le gustaría hacer ahora?"

msgctxt "944_Receptionist"
msgid "What would you like to view?"
msgstr "¿Qué te gustaría ver?"

msgctxt "956_Receptionist"
msgid "Be forewarned: you will not be able to use any weapons or defensive gear."
msgstr "Estás prevenido: no podrás usar armas ni equipo defensivo."

msgctxt "968_Receptionist"
msgid "Please select a tournament."
msgstr "Por favor, seleccione un torneo."

msgctxt "1004_Receptionist"
msgid "Best of luck, and have a good fight."
msgstr "Lo mejor de la suerte, y ten una buena pelea."

msgctxt "1028_Receptionist"
msgid "Here are the rules of the Underground Coliseum."
msgstr "Estas son las reglas del Coliseo Subterráneo."

msgctxt "1052_Receptionist"
msgid "What information would you like to view?"
msgstr "¿Qué información desea consultar?"

msgctxt "1064_Receptionist"
msgid "Here is information on individual match opponents."
msgstr "Aquí encontrará información sobre los rivales de cada combate."

msgctxt "1088_Receptionist"
msgid "Here is information on tag match opponents."
msgstr "Aquí tienes información sobre los oponentes de los combates por equipo."

msgctxt "1112_Receptionist"
msgid "You can trade points here for items and other things."
msgstr "Puedes intercambiar puntos aquí por objetos y otras cosas."

msgctxt "1124_Receptionist"
msgid "What would you like to trade for?"
msgstr "¿Para qué desea comerciar?"

msgctxt "1148_Receptionist"
msgid "These are your fight stats."
msgstr "Estas son tus estadísticas de combate."

msgctxt "1172_Receptionist"
msgid "This is a compilation of information about popularity in the Underground Coliseum."
msgstr "Esta es una compilación de información sobre la popularidad en el Coliseo Subterráneo."

msgctxt "1196_Receptionist"
msgid "This is a compilation of information about tag matches."
msgstr "Esta es una compilación de información sobre las coincidencias de etiquetas."

msgctxt "1220_Receptionist"
msgid "Thank you. Please come again."
msgstr "Muchas gracias. Por favor, vuelva otra vez."

msgctxt "1244_Receptionist"
msgid "This information has been added as a <Color:14>memo<Color:Default>.\\r\n"\n"Read <Color:14>memos<Color:Default> by selecting <Color:14>Memos<Color:Default> in the Pause Menu.\\r\n"\n"You can access the Pause Menu with the <Action:Button_Options@Adventure> button."
