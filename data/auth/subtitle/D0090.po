msgctxt "324\t435"
msgid "Dammit... We're too late."
msgstr "Rayos... Llegamos demasiado tarde."

msgctxt "597\t657"
msgid "Those aren't cops."
msgstr "¿No son la policía?"

msgctxt "680\t740"
msgid "But then who are they?"
msgstr "¿Entonces, quiénes son?"

msgctxt "946\t1003"
msgid "That's..."
msgstr "Esa persona de ahí..."

msgctxt "1193\t1285"
msgid "Finally found you, Hamazaki."
msgstr "Te encontré, Hamazaki."

msgctxt "1335\t1412"
msgid "Surprised you're still breathing."
msgstr "No pensé que seguirías con vida."

