#. y4:line_status=translated
msgctxt "1052"
msgid "Kiryu"
msgstr "Kiryu"

#. y4:line_status=translated
msgctxt "56_Alps Staff"
msgid "Welcome, sir. How many in your party?"
msgstr "Bienvenido, señor. ¿Cuántos son en su grupo?"

#. y4:line_status=translated
msgctxt "68_Kiryu"
msgid "I was actually wondering if you guys do takeout. I need curry, stat."
msgstr "¿Tiene comida para llevar? Necesito curry, y lo necesito urgentemente."

#. y4:line_status=translated
msgctxt "80_Alps Staff"
msgid "I'm sorry, sir. We only offer our dining experience\\r\nin-house."
msgstr "Lo siento, señor. Solo ofrecemos nuestra experiencia culinaria\\r\ndentro del establecimiento."

#. y4:line_status=translated
msgctxt "92_Kiryu"
msgid "But I can't just leave him...! Guess I'll have to look\\r\nsomewhere else."
msgstr "¡Pero no puedo dejarlo...! Supongo que tendré que buscar\\r\nen otro lugar."

#. y4:line_status=translated
msgctxt "104_Alps Staff"
msgid "My deepest apologies, sir."
msgstr "Mis más profundas disculpas, señor."

#. y4:line_status=translated
msgctxt "116_Kiryu"
msgid "(Where else can I get curry?)"
msgstr "(¿Dónde más puedo conseguir curry?)"

