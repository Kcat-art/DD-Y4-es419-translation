msgctxt "2428"
msgid "The Florist"
msgstr "El florista"

msgctxt "2432"
msgid "Talk_Info_F"
msgstr "Talk_Info_F"

msgctxt "2436"
msgid "Talk_Kamae"
msgstr "Talk_Kamae"

msgctxt "2440"
msgid "Saejima"
msgstr "Saejima"

msgctxt "2444"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "68_The Florist"
msgid "Hold up."
msgstr "Espera un momento."

msgctxt "80_Saejima"
msgid "Why?"
msgstr "¿Tú?"

msgctxt "92_The Florist"
msgid "I had a feeling you weren't just another psychopath."
msgstr "Tenía la sensación de que no eras un psicópata más."

msgctxt "104_Saejima"
msgid "The hell does that mean?"
msgstr "¿Qué quieres decir?"

msgctxt "116_The Florist"
msgid "If you had killed Ivan, I would have denied your request."
msgstr "La pelea, si hubieras intentado matar a Ivan, habría rechazado tu petición."

msgctxt "128_Saejima"
msgid "'Scuse me?"
msgstr "¿Disculpa?"

msgctxt "140_The Florist"
msgid "People come here to see blood, but letting my prizefighters\\r\n"\n"murder each other would be bad business."
msgstr "La gente viene aquí buscando sangre.\\r\n"\n"...pero no tengo intención de dejar que se maten entre sí."

msgctxt "152_The Florist"
msgid "I'm relieved to see there's some humanity left in you."
msgstr "Me alegra saber que aún te queda humanidad."

msgctxt "164_Saejima"
msgid "Get to the point."
msgstr "Déjate de rodeos."

msgctxt "176_The Florist"
msgid "I'll tell you what you want to know: where Sasai is."
msgstr "Aceptaré tu petición. Te diré dónde está Sasai."

