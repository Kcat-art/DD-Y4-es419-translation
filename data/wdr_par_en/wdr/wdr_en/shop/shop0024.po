msgctxt "532"
msgid "Quit"
msgstr "Salir"

msgctxt "537"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "555"
msgid "Order"
msgstr "Pagar"

msgctxt "561"
msgid "Order the currently selected item.  "
msgstr "Pedir el objeto actualmente seleccionado.  "

msgctxt "598"
msgid "(I haven't picked anything.)  "
msgstr "(No he escogido nada)"

msgctxt "629"
msgid "(I'm short on cash.)  "
msgstr "(Me hace falta dinero)"

msgctxt "652"
msgid "Thanks. That's %s."
msgstr "Gracias. Eso es %s."

msgctxt "671"
msgid "(I can't carry any more stuff.)"
msgstr "(No puedo llevar más cosas)."

msgctxt "703"
msgid "(They're sold out.)"
msgstr "(Están agotados)."

msgctxt "723"
msgid "Basically a mini flamethrower handcrafted by \n"
"Kamiyama Works."
msgstr "Básicamente, un mini lanzallamas creado por \n"
"Kamiyama Works."

msgctxt "785"
msgid "The next generation in self-defense technology."
msgstr "La próxima generación en tecnología de autodefensa."

msgctxt "833"
msgid "These are normally used for kendo practice, but they\n"
"still pack a punch."
msgstr "Estos se utilizan normalmente para prácticas de kendo,\n"
"pero todavía tienen un gran impacto."

msgctxt "906"
msgid "A good nunchaku set for beginners to start out with."
msgstr "Un buen set de nunchaku para principiantes."

msgctxt "959"
msgid "The street brawler's weapons of choice. Put them on\n"
"your fists to increase the power of your punches."
msgstr "Las armas preferidas del luchador callejero. Ponlos en\n"
"tus puños para aumentar el poder de tus golpes."

msgctxt "1061"
msgid "Collapsible and easy to store in a purse or jacket\n"
"pocket. It's good for blocking low attacks, too."
msgstr "Plegable y fácil de almacenar en una bolsa o chaqueta\n"
"de bolsillo. También es bueno para bloquear ataques bajos."

msgctxt "1161"
msgid "It's a shotgun. What more do you want?"
msgstr "Es una escopeta. ¿Qué más quieres?"

msgctxt "1200"
msgid "A cheap replica of a standard military issue weapon."
msgstr "Una réplica barata de un arma militar estándar."

msgctxt "1253"
msgid "Better against bladed weapons than a bulletproof \n"
"vest."
msgstr "Es mejor contra armas blancas que un chaleco\n"
"antibalas."

msgctxt "1309"
msgid "Historically worn by gamblers and is stronger than\n"
"regular chain mail."
msgstr "Históricamente usado por apostadores y es más\n"
"resistente que la cota de malla regular."

msgctxt "1380"
msgid "Stronger than iron, as I'm sure you know."
msgstr "Más fuerte que el hierro, como seguro que sabes."

msgctxt "1422"
msgid "Actually just an iron grill pounded into this shape. It's \n"
"heavy as hell, but it'll stop bullets."
msgstr "En realidad, es solo una parrilla de hierro que se forjó en esta\n"
"forma. Es pesado como el infierno, pero detendrá las balas."

msgctxt "1520"
msgid "Standard issue for Special Weapons and Tactics units.\n"
"It holds up well against bullets."
msgstr "Edición estándar para unidades de armas y tácticas\n"
"especiales. Resiste bien contra las balas."

msgctxt "1608"
msgid "Kamiyama told me to stock this rubber hose 'cause\n"
"it's a \"guaranteed sale.\""
msgstr "Kamiyama me dijo que almacenara esta manguera\n"
"de goma porque es una \"venta garantizada\""

