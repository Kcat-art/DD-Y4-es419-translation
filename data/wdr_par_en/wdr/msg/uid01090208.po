msgctxt "2456"
msgid "Tanimura"
msgstr "Tanimura"

msgctxt "2460"
msgid "Nui"
msgstr "Nui"

msgctxt "2464"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "2468"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "84_Tanimura"
msgid "You can't hide there forever, you know."
msgstr "No puedes ocultarte allí para siempre, lo sabes."

msgctxt "96_Nui"
msgid "Yikes! You found me!"
msgstr "¡Vaya! ¡Me encontraste!"

msgctxt "168_Tanimura"
msgid "Look, I'm not mad at you or anything, but I need to know\\r\n"
"why you've been tagging. Will you tell me?"
msgstr "Mira, no estoy enojado contigo ni nada, pero necesito saber\\r\n"
"por qué has estado pintando esas cosas. ¿Me lo dirás?"

msgctxt "180_Nui"
msgid "I'm not telling anything!"
msgstr "¡No te voy a contar nada!"

msgctxt "192_Tanimura"
msgid "Come on, I promise I won't get you in trouble. I just want to hear your side of things."
msgstr "Vamos, te prometo que no te meteré en problemas. Solo quiero escuchar tu versión de las cosas."

msgctxt "204_Tanimura"
msgid "So could you wait for me in West Park for a little while?"
msgstr "Entonces, ¿podrías esperarme un rato en el Parque Oeste?"

msgctxt "216_Tanimura"
msgid "That okay with you?"
msgstr "¿Te parece bien?"

msgctxt "228_Nui"
msgid "......"
msgstr "......"

msgctxt "240_Nui"
msgid "...Whatever."
msgstr "... Lo que sea."

msgctxt "252_Nui"
msgid "Fine."
msgstr "Bien."

msgctxt "288_Tanimura"
msgid "Next is the building across from Homeland."
msgstr "Al lado está el edificio frente a Homeland."

