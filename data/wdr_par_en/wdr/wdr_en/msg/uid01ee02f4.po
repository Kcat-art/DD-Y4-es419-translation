msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "204_Player"
msgid "(Boxcelios 2? Looks like an arcade shooter...)"
msgstr "(¿Boxcelios 2? Parece ser un shooter arcade...)"

msgctxt "216_Boxcelios 2"
msgid "The sequel to Boxcelios. Control an invincible fighter and destroy as many enemies as possible before time runs out. This time, the game takes place over land."
msgstr "La secuela de Boxcelios. Controla un invencible caza y destruye tantos enemigos sea posible antes que acabe el tiempo. Esta vez, el juego tiene lugar sobre la tierra."

msgctxt "228_Boxcelios 2"
msgid "Move your ship with <Action:Button_LS_Up@Shooting><Action:Button_LS_Down@Shooting><Action:Button_LS_Left@Shooting><Action:Button_LS_Right@Shooting>, and fire at enemies with your laser cannons using <Action:Button_Cross@Shooting>. Shoot and destroy either the glowing core or the majority of enemy ships to take them down."
msgstr "Mueve tu nave con <Action:Button_LS_Up@Shooting><Action:Button_LS_Down@Shooting><Action:Button_LS_Left@Shooting><Action:Button_LS_Right@Shooting>, y dispara tus cañones láser con <Action:Button_Cross@Shooting>. Dispara y destruye los núcleos brillantes para derribar a las naves enemigas."

msgctxt "240_Boxcelios 2"
msgid "Time stands still for two seconds after an enemy appears. Use this time to aim for the enemy's core for maximum efficiency. You can also increase your time by up to 1 second with a quick defeat."
msgstr "El tiempo se detiene dos segundos mientras aparece un nuevo enemigo. Aprovecha para apuntar al núcleo de la nave enemiga para mayor eficacia. Puedes incrementar el tiempo 1 segundo venciendo rápido al enemigo."

msgctxt "252_Player"
msgid "(Boxcelios 2... It's 100 yen per game. Should I give it a try?)"
msgstr "(Boxcelios 2 ... Son 100 yenes por partida. ¿Debería probarlo?)"

msgctxt "276_Player"
msgid "(All right, let's do this.)"
msgstr "(Muy bien, empecemos.)"

msgctxt "300_Player"
msgid "(I don't have the money...)"
msgstr "(No tengo dinero.)"

