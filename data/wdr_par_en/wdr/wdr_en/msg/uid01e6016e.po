msgctxt "1552"
msgid "Tanimura"
msgstr "Tanimura"

msgctxt "1556"
msgid "Chihiro's Voice"
msgstr "Voz de Chihiro"

msgctxt "1560"
msgid "Talk_Surp"
msgstr "Talk_Surp"

msgctxt "1564"
msgid "Kinugawa's Voice"
msgstr "Voz de Kinuwaga"

msgctxt "56_Tanimura"
msgid "(The building Chihiro was talking about must be around here somewhere.)"
msgstr "(El edificio que Chihiro menciono tiene que estar por aquí cerca.)"

msgctxt "68_Chihiro's Voice"
msgid "Eeeeek!"
msgstr "¡Aaaaah!"

msgctxt "80_Tanimura"
msgid "(What was that!?)"
msgstr "(¡¿Qué fue eso?!)"

msgctxt "92_Chihiro's Voice"
msgid "W-What're you doing!? Stop it!"
msgstr "¡¿Qué está haciendo?! ¡Deténgase!"

msgctxt "104_Kinugawa's Voice"
msgid "Look, if you're serious about making your big acting debut, you have to do what I say. I'll make you a star!"
msgstr "Escúchame bien, si quieres tomarte tu gran debut como actriz en serio, tendrás que hacer lo que te diga. ¡Yo te convertiré en toda una celebridad!"

msgctxt "116_Chihiro's Voice"
msgid "No!"
msgstr "¡No!"

msgctxt "128_Tanimura"
msgid "(Damn. That doesn't sound good. I'm going in!)"
msgstr "(Mierda. Eso no suena nada bien, ¡voy a entrar!)"

