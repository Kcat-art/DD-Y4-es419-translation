msgctxt "276"
msgid "The homeless man in Theater Square is now your ally."
msgstr "El sintecho de la Plaza del Teatro es ahora tu aliado."

msgctxt "3868"
msgid "Homeless Man"
msgstr "Hombre sin hogar"

