msgctxt "1544"
msgid "Customer"
msgstr "Cliente"

msgctxt "1548"
msgid "Player"
msgstr "Jugador"

msgctxt "1552"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "1556"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "112_Customer"
msgid "You wanna play a game of mahjong, man? Gotta have 25,000 sticks on you. You can buy 'em over at the desk."
msgstr "¿Quieres jugar una partida de mahjong? Necesitas 25.000 palos. Puedes comprarlos en el mostrador."

msgctxt "124_Customer"
msgid "Yo, play some mahjong with us? Not to toot our own horns, but we'll put up a pretty tough fight."
msgstr "Eh, ¿juegas mahjong con nosotros? No es por presumir, pero no lo pondremos fácil."

msgctxt "136_Customer"
msgid "Yeah, I'll play."
msgstr "Sí, jugaré."

msgctxt "148_Customer"
msgid "Okay, let's get started, then!"
msgstr "¡Bien, empecemos entonces!"

msgctxt "172_Customer"
msgid "Not right now."
msgstr "Ahora no."

msgctxt "184_Customer"
msgid "Aw, man... Well, come talk to me if you're feeling up to it later."
msgstr "Ay, hombre... Bueno, ven a hablar conmigo si te sientes con ganas más tarde."

msgctxt "196_Customer"
msgid "Play"
msgstr "Jugar"

msgctxt "208_Customer"
msgid "Don't Play"
msgstr "No jugar"

