msgid "Thank you."
msgstr "Gracias."

msgctxt "15588"
msgid "Here you are!"
msgstr "¡Permítame!"

msgctxt "16056"
msgid "Come again!"
msgstr "¡Ven otra vez!"

msgctxt "16116"
msgid "I really had a nice time."
msgstr "Realmente he pasado un buen rato."

msgctxt "16176"
msgid "Thanks for today."
msgstr "Gracias por hoy."

msgctxt "16392"
msgid "No? Well, be sure and tell me if you do hear anything."
msgstr "¿No? Bueno, asegúrate y dime si escuchas algo."

