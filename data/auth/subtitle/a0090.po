msgid "Arai-san!"
msgstr ""

#. y4:line_status=todo
msgctxt "2704\t2858"
msgid "One bullet, straight to the head.\\nClean and simple."
msgstr ""

#. y4:line_status=todo
msgctxt "2853\t2953"
msgid "No quicker way to bump a guy off."
msgstr ""

#. y4:line_status=todo
msgctxt "2996\t3091"
msgid "Shouldn't you be running?"
msgstr ""

#. y4:line_status=todo
msgctxt "3126\t3221"
