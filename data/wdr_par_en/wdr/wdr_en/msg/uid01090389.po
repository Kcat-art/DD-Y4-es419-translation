msgctxt "92_Kiryu"
msgid "Takashi? It's Kiryu."
msgstr "¿Takashi? Soy Kiryu."

msgctxt "104_Takashi"
msgid "Oh, Kiryu-san. Did you hear anything?"
msgstr "Oh, Kiryu-san. ¿Averiguaste algo?"

msgctxt "116_Kiryu"
msgid "I did, actually. The Florist gave me the details on your father."
msgstr "De hecho sí. El Florista me ha hablado de tu padre."

msgctxt "128_Takashi"
msgid "He did!?"
msgstr "¡¿De verdad?!"

msgctxt "140_Kiryu"
msgid "Yeah. Are you free?"
msgstr "Sí. Será mejor que nos veamos en persona."

msgctxt "152_Takashi"
msgid "Of course! I'll wait for you out front of the Millennium Tower!"
msgstr "¡Por supuesto! ¡Le esperaré delante de la Torre Millenium!"

msgctxt "164_Kiryu"
msgid "Got it. See you soon."
msgstr "Entendido. Nos vemos pronto."

