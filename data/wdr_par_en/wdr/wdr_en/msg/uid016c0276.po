msgctxt "3252_Attendant"
msgid "Actually, I like black hair the best."
msgstr "En realidad, lo que más me gusta es el pelo negro."

msgctxt "3264_Attendant"
msgid "Black hair will come back in style someday."
msgstr "El cabello negro volverá a estar de moda algún día."

msgctxt "3276_Attendant"
msgid "Just be yourself and you'll be fine."
msgstr "Sólo sé tú misma y estarás bien."

msgctxt "3288_Attendant"
