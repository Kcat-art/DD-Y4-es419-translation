msgctxt "116_Man"
msgid "Long time, no see, pops! It's me, remember? C'mon, how could you forget? Say, how about you loan me a little dough?"
msgstr "¡Hace tiempo que no te veo, abuelo! Soy yo, ¿recuerdas? Vamos, ¿cómo pudiste olvidar? Oye, ¿qué tal si me prestas un poco de dinero?"

msgctxt "128_Man"
msgid "Well? Cough it up already, asshole!"
msgstr "¿Y bien? ¡Suelta ya, idiota!"

msgctxt "152_Man"
msgid "My apologies. I could have sworn you were someone else."
msgstr "Mis disculpas. Estaba seguro de que eras otra persona."

msgctxt "164_Man"
msgid "This should make up for my mistake."
msgstr "Esto debería compensar mi error."

msgctxt "176_Man"
msgid "You got a weather-worn %s."
msgstr "Obtuviste un %s."

msgctxt "212_Man"
msgid "What is it this time?"
msgstr "¿Qué ocurre esta vez?"

