msgctxt "16520_Player"
msgid "Let's play golf."
msgstr "¿Qué te parece jugar golf?"

msgctxt "16532_望月京子：源氏名"
msgid "Golf? Wow, Kiryu-san, you play golf?"
msgstr "Golf? Wow, Kiryu-san, you play golf?"

