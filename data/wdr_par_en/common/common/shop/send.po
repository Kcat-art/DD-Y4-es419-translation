msgid "Cancel"
msgstr "Cancelar"

msgctxt "12"
msgid "Don't send the item."
msgstr "No enviar el objeto."

msgctxt "16"
msgid "Send"
msgstr "Enviar"

msgctxt "20"
msgid "Send the item to your hideout."
