msgctxt "24"
msgid "(I can't carry any more stuff... Better send something.)"
msgstr "(No puedo llevar más cosas... Mejor envío algo)."

msgctxt "28"
msgid "Are you sure you want to send this?"
msgstr "¿Estás seguro de que quieres enviar esto?"

