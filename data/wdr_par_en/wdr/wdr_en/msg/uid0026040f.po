msgctxt "1044"
msgid "Alps Staff"
msgstr "Alps Staff"

msgctxt "1048"
msgid "Talk_Ojigi"
msgstr "Talk_Ojigi"

msgctxt "1052"
msgid "Kiryu"
msgstr "Kiryu"

msgctxt "56_Alps Staff"
msgid "Welcome, sir. How many in your party?"
msgstr "Bienvenido, señor. ¿Cuántos son en su grupo?"

msgctxt "68_Kiryu"
msgid "I was actually wondering if you guys do takeout. I need curry, stat."
msgstr "¿Tiene comida para llevar? Necesito curry, y lo necesito urgentemente."

msgctxt "80_Alps Staff"
msgid "I'm sorry, sir. We only offer our dining experience\\r\n"
"in-house."
msgstr "Lo siento, señor. Solo ofrecemos nuestra experiencia culinaria\\r\n"
"dentro del establecimiento."

msgctxt "92_Kiryu"
msgid "But I can't just leave him...! Guess I'll have to look\\r\n"
"somewhere else."
msgstr "¡Pero no puedo dejarlo...! Supongo que tendré que buscar\\r\n"
"en otro lugar."

msgctxt "104_Alps Staff"
msgid "My deepest apologies, sir."
msgstr "Mis más profundas disculpas, señor."

msgctxt "116_Kiryu"
msgid "(Where else can I get curry?)"
msgstr "(¿Dónde más puedo conseguir curry?)"

