msgctxt "2180"
msgid "Tadokoro's Subordinate"
msgstr "Subordinado de Tadokoro"

msgctxt "2184"
msgid "Saejima"
msgstr "Saejima"

msgctxt "2188"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "2192"
msgid "Client"
msgstr "Cliente"

msgctxt "2196"
msgid "Talk_Info_F"
msgstr "Talk_Info_F"

msgctxt "56_Tadokoro's Subordinate"
msgid "Are you ready?"
msgstr "¿Estás listo?"

msgctxt "68_Saejima"
msgid "Yep."
msgstr "Sí."

msgctxt "80_Client"
msgid "Are you sure I'm going to be safe with this guy?"
msgstr "¿Estás seguro de que voy a estar a salvo con este tipo?"

msgctxt "104_Tadokoro's Subordinate"
msgid "You can breathe easy. Of all our employees, I'd wager he's our very best."
msgstr "Tu tranquilo y yo nervioso. De todos nuestros empleados, apostaría a que este es el mejor."

msgctxt "116_Saejima"
msgid "(How can he lie with such a straight face like that?)"
msgstr "(¿Cómo puede tener la cara tan dura para mentir así?)"

msgctxt "128_Tadokoro's Subordinate"
msgid "Very well, then. Best of luck to you."
msgstr "Muy bien. Te deseo la mejor de las suertes."

msgctxt "140_Tadokoro's Subordinate"
msgid "But allow me to repeat myself, just in case. Your job is to hand over this gentleman safe and sound."
msgstr "Pero permítame repetirlo, por si acaso. Su trabajo es entregar a este caballero sano y salvo."

msgctxt "152_Tadokoro's Subordinate"
msgid "If anything should happen to him, you'll take a commensurate amount of blame. Are we clear, Suzuki-san?"
msgstr "Si algo le ocurriera, tú asumirás una parte importante de la culpa. ¿Está claro, Suzuki-san?"

msgctxt "164_Saejima"
msgid "Yeah, I heard ya the first time."
msgstr "Sí, ya te oí la primera vez."

msgctxt "176_Tadokoro's Subordinate"
msgid "Excellent. Then I bid you farewell."
msgstr "Excelente. En ese caso, me despido."

