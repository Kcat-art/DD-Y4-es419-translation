msgctxt "432	523"
msgid "How the...?"
msgstr "¿Cómo...?"

msgctxt "596	710"
msgid "You fools always get the wrong idea about me."
msgstr "Sabes, a menudo tontos como ustedes\\ntienen una idea equivocada sobre mí."

msgctxt "742	853"
msgid "I get it. I look like your\\nrun-of-the-mill punk."
msgstr "¿Acaso es por la ropa que traigo?"

msgctxt "858	947"
msgid "So everyone thinks I'm some kinda pussy."
msgstr "Siempre piensan que soy algún debilucho más."

msgctxt "958	1003"
msgid "But come on."
msgstr "Pero vamos."

msgctxt "1004	1125"
msgid "Some little shit working\\ndirectly under Arai-aniki?"
msgstr "¿Alguien así trabajaría\\ndirectamente para Arai-aniki?"

msgctxt "1154	1249"
msgid "Well, that'd just never happen."
msgstr "Eso no pasaría nunca."

msgctxt "1327	1421"
msgid "You thought I'd be easy pickings, huh?"
msgstr "Pensaste que sería un blanco fácil, ¿no?"

msgctxt "1453	1594"
msgid "Dumbasses.\\nYou and the whole damn Shibata Family."
msgstr "Que idiotas.\\nTú y toda la maldita Familia Shibata."

msgctxt "1615	1757"
msgid "You keep pulling this shit,\\nyou're never gonna catch Arai-aniki."
msgstr "Si siguen pensando de esa manera,\\nnunca van a atrapar a Arai-aniki."

msgctxt "1796	1856"
msgid "Hey."
msgstr "Oye."

