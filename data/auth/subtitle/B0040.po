msgctxt "726\t789"
msgid "Welcome to your new home."
msgstr "Este será tu nuevo hogar."

msgctxt "801\t842"
msgid "Get in."
msgstr "Pasa."

msgctxt "1016\t1076"
msgid "Hands out."
msgstr "Saca las manos."

msgctxt "1292\t1463"
msgid "Dinner's at 1700. All other rules\\nare in the papers we've provided for you."
msgstr "La cena es las 5: 00. Todo lo demás\\nestá explicado en los documentos que te dieron."

msgctxt "1478\t1586"
msgid "You should know, this isn't your average prison."
msgstr "Te advertiré de que esta prisión no es como las comunes."

msgctxt "1590\t1711"
msgid "If you want to relish the final\\nscraps of life before your execution..."
msgstr "Si quieres tener unos pacíficos días finales\\nde vida antes de tu ejecución..."

msgctxt "1713\t1812"
msgid "Keep your head down and follow orders."
msgstr "Mejor baja la cabeza y sé obediente."

