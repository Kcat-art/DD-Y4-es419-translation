msgctxt "87	147"
msgid "The hell do you want?"
msgstr "¿Qué demonios quieres?"

msgctxt "389	508"
msgid "Ahh, you're drinking the good stuff."
msgstr "Ahh, están bebiendo alcohol de lo más caro..."

msgctxt "509	623"
msgid "You know they mark this up like,\\nfour hundred percent at a place like this?"
msgstr "¿Saben que esta tienda lo vende\\npor cuatro veces su precio de mercado?"

msgctxt "624	685"
msgid "Who are you?"
msgstr "¿Quién carajos eres?"

msgctxt "728	825"
msgid "You don't look like a fuckin' waiter."
msgstr "No tienes pinta de camarero."

msgctxt "899	984"
msgid "Damn, that's good!"
msgstr "¡Ahh, buenísimo!"

msgctxt "985	1069"
msgid "But if you really cared about your booze..."
msgstr "Pero ustedes lo beben como si fuera agua de la llave."

msgctxt "1070	1171"
msgid "You wouldn't be tossing this back\\nlike it was water."
msgstr "Eso no es lo que hace un buen\\namante del alcohol."

msgctxt "1168	1250"
msgid "I'm talking to you, pretty boy."
msgstr "¿Por qué demonios me estás ignorando?"

msgctxt "1251	1312"
msgid "You looking to get your ass beat?"
msgstr "¡¿Acaso nos estás tratando de idiotas?!"

msgctxt "1384	1518"
msgid "He asked you a fucking question, dipshit!"
msgstr "¡Te acaba de hacer una pregunta, idiota!"

msgctxt "1592	1652"
msgid "Smug little..."
msgstr "Imbécil..."

msgctxt "1655	1737"
msgid "Who do you think you are!?"
msgstr "¡¿Quién mierda te crees?!"

msgctxt "1942	2020"
msgid "Good thing it's me you picked a fight with."
msgstr "Menos mal que elegiste pelear conmigo."

msgctxt "2022	2132"
msgid "If I were a big, tough yakuza,\\nthis'd mean war."
msgstr "Si hubiera sido en contra de un yakuzita,\\neso hubiera significado la guerra."

msgctxt "2169	2223"
msgid "The shit, man?"
msgstr "¿Qué demonios?"

msgctxt "2244	2305"
msgid "This wasn't part of the deal!"
msgstr "¡Eso no era parte del trato!"

msgctxt "2331	2380"
msgid "What deal?"
msgstr "¿Qué trato?"

msgctxt "2381	2441"
msgid "Akiyama-san!"
msgstr "¡Akiyama-san!"

msgctxt "2450	2506"
msgid "What the hell's going on!?"
msgstr "¡¿Qué estás haciendo?!"

msgctxt "2507	2567"
msgid "You alone?"
msgstr "¿Vienes solo?"

msgctxt "2572	2679"
msgid "Yeah. Aniki's still gonna be a while."
msgstr "Sí. Al parecer mi aniki va a tardar un poco."

msgctxt "2680	2717"
msgid "That so?"
msgstr "Ya veo."

msgctxt "2718	2816"
msgid "I'm still standing here, assholes!"
msgstr "¿De qué carajos están hablando?"

msgctxt "2817	2878"
msgid "Wait, I get it."
msgstr "¡Espera, ya entiendo!"

msgctxt "2879	2981"
msgid "You bastards are trying to start a war!"
msgstr "¡¿Están tratando de tendernos una trampa para iniciar una guerra?!"

msgctxt "2988	3056"
msgid "Not sure what you mean, friend."
msgstr "No tengo ni idea a qué te refieres, amigo."

msgctxt "3057	3155"
msgid "Shut it! And stop trying to play the fool!"
msgstr "¡Cállate! ¡Y deja de hacerte el tonto!"

msgctxt "3159	3251"
msgid "At this point I don't fucking care <Italic>who</Italic> you are!"
msgstr "¡A estas alturas me da igual quiénes sean!"

msgctxt "3225	3275"
msgid "You're dead men, both of you!"
msgstr "¡Ustedes dos son hombres muertos!"

msgctxt "3276	3374"
msgid "You're the one starting shit\\non our turf, asshole!"
msgstr "¡Tú eres el bastardo que empezó a hacer\\nalboroto en nuestro territorio!"

msgctxt "3375	3435"
msgid "You stay put!"
msgstr "¡No te acerques!"

msgctxt "3450	3518"
msgid "I started this fight."
msgstr "Esta es mi pelea."

msgctxt "3519	3658"
msgid "So let's keep this between me\\nand these fine gentlemen here."
msgstr "Lo que pasó en este local,\\nes solo un problema mío y de ellos."

msgctxt "3663	3737"
msgid "It has nothing to do with Ueno or Kanemura."
msgstr "No tiene nada que ver con Ueno o Kanemura."

msgctxt "3738	3789"
msgid "Akiyama-san..."
msgstr "Akiyama-san..."

msgctxt "3815	3865"
msgid "I knew it."
msgstr "Lo sabía."

msgctxt "3866	3964"
msgid "You <Italic>do</Italic> know who we are."
msgstr "Estabas completamente al tanto de quiénes somos."

msgctxt "4093	4242"
msgid "I run a legit business here in town.\\nPlace called Sky Finance."
msgstr "Yo solo soy un prestamista que dirije un\\nlugar llamado Sky Finance en esta ciudad."

msgctxt "4295	4415"
msgid "So believe me when I say\\nthis isn't about politics."
msgstr "Así que créeme cuando te digo\\nque esto lo hago por mi cuenta."

msgctxt "4416	4505"
msgid "Just one civilian kicking another's ass."
msgstr "Solo me metí con ustedes porque me parecieron molestos."

msgctxt "4507	4591"
msgid "No clans. No turf war."
msgstr "Tus familias y esas cosas, no me importan."

msgctxt "4592	4644"
msgid "Asshole..."
msgstr "Maldito..."

msgctxt "4645	4732"
msgid "That big mouth's gonna get you killed."
msgstr "Esa arrogancia tuya te va a costar la vida."

msgctxt "4748	4805"
msgid "Wow."
msgstr "Vaya."

msgctxt "4793	4873"
msgid "You're a feisty one, tiger."
msgstr "Parece que alguien se anda enojando."

msgctxt "4875	4982"
msgid "I might actually enjoy this fight for once."
msgstr "Por fin podré disfrutar de una pelea seria después de mucho tiempo."

msgctxt "5019	5100"
msgid "You're really pissing me off, man."
msgstr "Que idiota tan molestoso."

msgctxt "5101	5242"
msgid "Fine. You want a beating that bad, you've got one."
msgstr "Está bien. Si tanto quieres ser golpeado, lo haré."

msgctxt "5243	5324"
msgid "Ready when you are."
msgstr "Cuando quieras."

msgctxt "5327	5421"
msgid "You're dead fucking meat!"
msgstr "¡Estás muerto, imbécil!"

