msgctxt "492	573"
msgid "I'll be back. Tomorrow."
msgstr "Nos vemos, mañana."

msgctxt "607	674"
msgid "Looking forward to it."
msgstr "Te estaremos esperando."

msgctxt "975	1031"
msgid "Hey, uh..."
msgstr "Oye..."

msgctxt "1056	1104"
msgid "Your name."
msgstr "Tu nombre..."

msgctxt "1105	1178"
msgid "I never asked you your name."
msgstr "¿Puedo saber al menos tu nombre?"

msgctxt "1275	1335"
msgid "Lily."
msgstr "Lily..."

msgctxt "1341	1392"
msgid "It's Lily."
msgstr "Mi nombre es Lily."

msgctxt "1413	1473"
msgid "Lily-san?"
msgstr "¿Lily-san?"

msgctxt "1474	1581"
msgid "That your real name?\\nOr just the one you use at work?"
msgstr "¿Ese es tu nombre real?\\n¿O es el que usas en el trabajo?"

msgctxt "1659	1720"
msgid "Does it really matter either way?"
msgstr "¿Es necesario que lo diga?"

msgctxt "1775	1845"
msgid "No... Guess it doesn't."
msgstr "No, está bien."

msgctxt "1899	1976"
msgid "See you tomorrow."
msgstr "Te estaremos esperado mañana."

