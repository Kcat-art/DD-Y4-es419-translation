msgctxt "56_Akiyama"
msgid "Thanks for waiting."
msgstr "Gracias por esperar."

msgctxt "68_Erena"
msgid "Hi!"
msgstr "¡Hola!"

msgctxt "80_Erena"
msgid "Hey! Look, it's that couple again."
msgstr "¡Oye! Mira, es esa pareja otra vez."

msgctxt "104_Miyuki"
msgid "Toshi-kun!"
msgstr "¡Toshi-kun!"

msgctxt "116_Toshi"
msgid "What're you still doing here?"
msgstr "¿Qué siguen haciendo aquí?"

msgctxt "128_Miyuki"
msgid "Why didn't you call me? I've been waiting for ages..."
msgstr "¿Por qué no me llamaste? Te he estado esperando por horas..."

msgctxt "140_Toshi"
msgid "Can't take a hint, huh? Most girls woulda figured out they've been dumped after three hours of waiting."
msgstr "¿No entiendes las indirectas, eh? La mayoría de las chicas habrían entendido que las dejaron después de esperar tres horas."

msgctxt "152_Toshi"
msgid "I'm seeing somebody else. Been hooking up for a while, actually."
msgstr "Estoy saliendo con alguien más. De hecho, llevamos un tiempo juntos."

msgctxt "164_Miyuki"
msgid "What?"
msgstr "¿Qué?"

msgctxt "176_Toshi"
msgid "So just go home."
msgstr "Pues vete a casa."

msgctxt "188_Miyuki"
msgid "But..."
msgstr "Pero..."

msgctxt "200_Akiyama"
msgid "Ouch... Could've done without seeing that."
msgstr "Auch... Con lo bien que estaba sin ver eso."

msgctxt "212_Erena"
msgid "No way! What a douchebag!"
msgstr "¡No puede ser! ¡Qué patán!"

msgctxt "224_Miyuki"
msgid "Toshi-kun... This is a joke, right? You're kidding, right?"
msgstr "Toshi-kun... Esto es una broma, ¿verdad? Estás bromeando, ¿no?"

msgctxt "236_Toshi"
msgid "Shut up!"
msgstr "¡Cállate!"

msgctxt "248_Miyuki"
msgid "Eek!"
msgstr "¡Ayy!"

msgctxt "260_Erena"
msgid "Can't believe we're seeing this!"
msgstr "¡No puedo creer que estemos viendo esto!"

msgctxt "272_Akiyama"
msgid "......"
msgstr "......"

msgctxt "296_Other Punks"
msgid "What's the holdup, Toshi? Let's go."
msgstr "¿A qué estamos esperando, Toshi? ¡Vámonos!"

msgctxt "320_Toshi"
msgid "Sorry. Ran into my ex."
msgstr "Lo siento. Me encontré con mi ex."

msgctxt "332_Other Punk"
msgid "Huh? This girl? She's pretty cute! Mind if I give her a try?"
msgstr "¿Eh? ¿Esta chica? ¡Es muy linda! ¿Te importa si le echo un vistazo?"

msgctxt "344_Toshi"
msgid "Whatever. Hey, Miyuki. Good news. You've got a new boyfriend."
msgstr "Como sea. Oye, Miyuki. ¡Adivina qué! ¡Tienes novio nuevo!"

msgctxt "368_Erena"
msgid "Hey! You jerks have no right to treat her like that! She has feelings, ya know."
msgstr "¡Oigan, idiotas! No tienen ningún derecho a tratarla así. ¡Ella también tiene sentimientos!"

msgctxt "380_Toshi"
msgid "Huh!? Who the hell are you?"
msgstr "¿¡Eh!? ¿Quién demonios eres tú?"

msgctxt "392_Other Punk"
msgid "Now, that girl's hot. She's way more my type than your ex."
msgstr "Esa chica está tremenda. Me gusta mucho más que tu ex."

msgctxt "404_Toshi"
msgid "Really? She's all yours, then."
msgstr "¿En serio? Entonces, es toda tuya."

msgctxt "416_Erena"
msgid "Gimme a break! I try not to make snap judgments about folks, but you three are rotten to the core!"
msgstr "¡Ya estuvo bueno! ¡Intento no juzgar a la gente a la primera pero ustedes tres son basura humana!"

msgctxt "428_Toshi"
msgid "What the!? Who the hell are you? Think you can insult us and then walk away? You don't get off that easy!"
msgstr "¿Qué carajos...? ¿Quién demonios te crees que eres? ¿Crees que puedes insultarnos e irte como si nada? ¡No te vas a librar tan fácil!"

msgctxt "440_Erena"
msgid "Aagh!"
msgstr "¡Aagh!"

msgctxt "452_Akiyama"
msgid "I didn't want to do this, but..."
msgstr "No quería llegar a esto, pero..."

msgctxt "464_Erena"
msgid "Help!"
msgstr "¡Ayuda!"

msgctxt "476_Toshi"
msgid "Huh!?"
msgstr "¡¿Eh?!"

msgctxt "488_Akiyama"
msgid "If you don't want to get hurt, you'd better get out of here. Now."
msgstr "Si no quieres salir lastimado, más te vale irte de aquí. ¡Ya!"

msgctxt "500_Toshi"
msgid "What the fu－ You got a problem, bro?"
msgstr "¿Qué mierda...? ¿Cuál es tu problema, imbécil?"

msgctxt "512_Akiyama"
msgid "A problem? No. No problem. Your relationship is your business."
msgstr "¿Problema? ¡Ninguno! Tu relación me da igual."

msgctxt "524_Toshi"
msgid "Then what do you want!?"
msgstr "¿¡Entonces qué quieres!?"

msgctxt "536_Akiyama"
msgid "Something about you guys just grates on my nerves. Do I need another reason to kick your asses?"
msgstr "Hay algo en ustedes que me saca de quicio. ¿Necesito otra razón para que les dé una paliza?"

msgctxt "548_Toshi"
msgid "Hah, try it! We'll tear you apart!"
msgstr "¡Ja, atrévete!! ¡Te vamos a descuartizar!"

msgctxt "560_Toshi"
msgid "Come on! Let's get this guy!"
msgstr "¡Vamos! ¡A por este tipo!"

msgctxt "572_Other Punks"
msgid "Yeah!"
msgstr "¡Sí!"

msgctxt "584_Erena"
msgid "Akiyama-san..."
msgstr "Akiyama-san..."

msgctxt "596_Akiyama"
msgid "It's all right. Leave this to me."
msgstr "No te preocupes. Yo me ocupo de esto."

msgctxt "608_Erena"
msgid "Okay..."
msgstr "Bueno..."

msgctxt "620_Toshi"
msgid "Think girls are impressed when you act all tough, huh? You're gonna regret ever opening your mouth, bro!"
msgstr "¿Crees que impresionas a las chicas haciéndote el valiente, eh? ¡Vas a lamentar el día en que abriste la boca!"

