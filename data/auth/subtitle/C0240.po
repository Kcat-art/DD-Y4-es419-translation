msgctxt "598	658"
msgid "I see."
msgstr "Ya veo."

msgctxt "670	736"
msgid "Sugiuchi's breathed his last."
msgstr "Entonces, Sugiuchi está muerto."

msgctxt "771	831"
msgid "Yes, sir."
msgstr "Sí, señor."

msgctxt "855	928"
msgid "Just as you ordered."
msgstr "Tal como lo ordenó."

msgctxt "1053	1113"
msgid "Yes, sir."
msgstr "Sí, señor."

msgctxt "1118	1172"
msgid "Both of them."
msgstr "Los dos."

msgctxt "1240	1393"
msgid "Tanimura's associates are the only ones left."
msgstr "Ahora me encargaré de los únicos socios que le quedan a Tanimura."

msgctxt "1427	1487"
msgid "But not for long."
msgstr "Con mis propias manos."

msgctxt "2026	2175"
msgid "Bastard! What are you going to do to Ma-chan!?"
msgstr "¡Maldito! ¿Qué le vas a hacer a Ma-chan?"

