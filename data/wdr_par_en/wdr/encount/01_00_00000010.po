msgctxt "116_Man"
msgid "Are you the one who iced our aniki? You are, aren't you? I'd recognize that expression anywhere!"
msgstr "¿Eres tú el que eliminó a nuestro aniki? ¡Lo eres, verdad? ¡Reconocería esa expresión en cualquier lugar!"

msgctxt "128_Man"
msgid "I'm gonna put your sorry ass six feet under!"
msgstr "¡Voy a enterrar tu miserable trasero a seis pies bajo tierra!"

msgctxt "152_Man"
msgid "Shit, you're strong. Wha? I got the wrong guy?"
msgstr "¡Mierda, eres fuerte! ¿Qué? ¿Me equivoqué de persona?"

msgctxt "164_Man"
msgid "I'm so very sorry. Please accept this."
msgstr "Lo siento mucho. Por favor, acepta esto."

msgctxt "176_Man"
msgid "You got a \"sorry\" %s."
msgstr "Obtuviste un %s."

msgctxt "212_Man"
msgid "Guess I mistook you..."
msgstr "Supongo que le confundí..."

