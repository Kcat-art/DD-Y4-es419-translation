msgctxt "210	NAME"
msgid "Sewer Path"
msgstr "Ruta de Alcantarillado"

msgctxt "223	NAME"
msgid "Air Raid Shelter No. 1, West"
msgstr "Refugio Antiaéreo Num. 1, Oeste."

msgctxt "254	NAME"
msgid "Air Raid Shelter No. 1, South"
msgstr "Refugio Antiaéreo Núm. 1, Sur"

msgctxt "286	NAME"
msgid "Old Access Tunnel"
msgstr "Antiguo Túnel de Acceso"

msgctxt "306	NAME"
msgid "Air Raid Shelter No. 2"
msgstr "Refugio Antiaéreo Nº 2"

msgctxt "369	EXPLANATION"
msgid "You dug out the Sewer Path and reached Air Raid Shelter No. 1."
msgstr "Encontraste el Camino de Alcantarillado y llegaste al Refugio Antiaéreo Nº 1."

msgctxt "432	EXPLANATION"
msgid "You dug out the west side of Air Raid Shelter No. 1, but couldn't find\n"
"a path."
msgstr "Encontraste el lado oeste del Refugio Antiaéreo Nº 1, pero no pudiste encontrar\n"
"un camino."

msgctxt "511	EXPLANATION"
msgid "You dug out the south side of Air Raid Shelter No. 1 and reached the\n"
"Old Access Tunnel."
msgstr "Encontraste el lado sur del Refugio Antiaéreo Nº 1 y llegaste al\n"
"Antiguo Túnel de Acceso."

msgctxt "599	EXPLANATION"
msgid "You dug out the Old Access Tunnel and reached Air Raid Shelter No. 2."
msgstr "Encontraste el Antiguo Túnel de Acceso y llegaste al Refugio Antiaéreo Nº 2."

msgctxt "669	EXPLANATION"
msgid "You dug out Air Raid Shelter No. 2 and found the Master's important item."
msgstr "Encontraste el Refugio Antiaéreo No. 2 y encontraste el objeto importante del Maestro."

