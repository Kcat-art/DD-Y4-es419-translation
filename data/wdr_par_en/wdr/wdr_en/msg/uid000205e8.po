msgctxt "160"
msgid "Kamuro taxi driver is now your ally."
msgstr "El taxista Kamuro ahora es tu aliado."

msgctxt "4352"
msgid "Taxi Driver"
msgstr "Taxista"

msgctxt "4356"
msgid "Player"
msgstr "Player"

msgctxt "4360"
msgid "Tanimura"
msgstr "Tanimura"

msgctxt "112_Taxi Driver"
msgid "Hello, sir. Where to? Hey...! I know you! You've used this taxi stand a lot, haven't you?"
msgstr "Buenas, señor. ¿A dónde...? ¡Eh, te conozco! Sueles usar esta parada de taxi bastante, ¿verdad?"

msgctxt "124_Taxi Driver"
msgid "Thank you very much!"
msgstr "¡Muchísimas gracias!"

msgctxt "136_Taxi Driver"
msgid "If you ever get into any trouble near this taxi stand on the north end of the Hotel District, I'll be there to back you up!"
msgstr "¡Si alguna vez te metes en líos cerca de esta parada en el norte del Distrito Hotel, estaré allí para ayudarte!"

msgctxt "148_Taxi Driver"
msgid "I'll be looking forward to seeing you again!"
msgstr "¡Espero verte de nuevo!"

msgctxt "184_Player"
msgid "(I seriously don't have 710 yen for a taxi...?)"
msgstr "(¿En serio no tengo 710 yenes para el taxi...?)."

msgctxt "196_Taxi Driver"
msgid "The minimum fare is 710 yen. Where would you like to go?"
msgstr "La tarifa base es de 710 yenes. ¿Adónde lo llevo?"

msgctxt "232_Tanimura"
msgid "(There's no way I can avoid fighting. Should I get more prepared before I go?)"
msgstr "(No hay manera de que pueda evitar pelear. ¿Debo prepararme antes de ir?)"

msgctxt "244_Tanimura"
msgid "(I'll come back when I'm better prepared...)"
msgstr "(Volveré cuando esté mejor preparado...)"

msgctxt "256_Taxi Driver"
msgid "Very well, sir."
msgstr "Muy bien, señor."

msgctxt "316_Taxi Driver"
msgid "Very well, sir."
msgstr "Muy bien, señor."

msgctxt "376_Taxi Driver"
msgid "I'm afraid you don't have enough money, sir. Please come again when you do."
msgstr "Me temo que no tiene suficiente dinero, señor. Por favor, vuelva cuando lo tenga."

msgctxt "388_Taxi Driver"
msgid "Very well, sir."
msgstr "Muy bien, señor."

msgctxt "472_Taxi Driver"
msgid "Please come again soon."
msgstr "Por favor, vuelva pronto."

msgctxt "484_Taxi Driver"
msgid "Prepare a Little More"
msgstr "Prepárate un poco más"

msgctxt "496_Taxi Driver"
msgid "Go Now"
msgstr "Ve ahora"

