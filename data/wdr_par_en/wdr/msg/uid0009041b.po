msgctxt "1468"
msgid "Yuya"
msgstr "Yuya"

msgctxt "1472"
msgid "Kiryu"
msgstr "Kiryu"

msgctxt "1476"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "80_Yuya"
msgid "Oh, Kiryu-san!"
msgstr "¡Oh, Kiryu-san!"

msgctxt "92_Yuya"
msgid "Boy, am I glad to see you. I thought you jumped ship and left town already."
msgstr "Qué bueno que aún sigue en Kamurocho."

msgctxt "104_Kiryu"
msgid "Hey, Yuya. What's up?"
msgstr "¿Mm? ¿Eres tú, Yuya? ¿Qué pasa?"

msgctxt "116_Yuya"
msgid "You, uh, got a moment? There's something I need to show you."
msgstr "Bueno, uh, ¿Tienes un momento? Hay algo que debo mostrarte."

msgctxt "128_Kiryu"
msgid "Of course. I always have time to help friends in need."
msgstr "Por supuesto."

