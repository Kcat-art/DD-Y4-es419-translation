msgstr "(Debería haberme asegurado de tener algo de dinero...)"

msgctxt "356_望月京子：源氏名"
msgid "That felt amazing! I put extra effort into my performance, just for you! <Color:7>♥<Color:Default>"
msgstr "That felt amazing! I put extra effort into my performance, just for you! <Color:7>♥<Color:Default>"

msgctxt "368_Player"
msgid "Hey, you're pretty good."
msgstr "Hey, you're pretty good."

