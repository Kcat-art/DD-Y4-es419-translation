msgstr ""

msgctxt "72_Saejima"
msgid "(Can't let any coppers spot me on my way to the Millennium Tower.)"
msgstr ""

msgctxt "84_Saejima"
msgid "(Better stick to the underground and the rooftops. The route Kido-chan told me about's my best bet, long as I keep my eye out for the boys in blue.)"
msgstr ""

msgctxt "96_CAUTION!"
msgid "<Color:7>Go to the Millennium Tower<Color:Default> <Color:7>without being seen by the police.<Color:Default>\\r\n"
"It's <Color:7>game over<Color:Default> if you're spotted, meaning you'll lose all progress since your last save.\\r\n"
"\\r\n"
"Tread carefully!"
msgstr ""

msgctxt "120_Saejima"
msgid "(Been out here a while now. Best hustle on back to the hideout without the coppers spottin' me.)"
msgstr ""

msgctxt "132_CAUTION!"
msgid "<Color:7>Return to your hideout<Color:Default> <Color:7>without being seen by the police.<Color:Default>\\r\n"
"It's <Color:7>game over<Color:Default> if you're spotted, meaning you'll lose all progress since your last save.\\r\n"
"\\r\n"
"Tread carefully!"
msgstr ""

