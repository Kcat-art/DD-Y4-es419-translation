msgctxt "2128"
msgid "Player"
msgstr "Player"

msgctxt "264_Player"
msgid "(Should I give her a present?)"
msgstr "(¿Debería darle un regalo...?)"

msgctxt "288_Player"
msgid " (Maybe she'd like this.)"
msgstr " (Puede que le guste esto)."

msgctxt "300_Player"
msgid "(On second thought, maybe not.)"
msgstr "(Pensándolo bien... quizá no)."

msgctxt "312_Player"
msgid "(This might be a good time to leave, but I've got enough money. Should I stay a bit longer?)"
msgstr "(Este parece ser un buen momento para irme, pero todavía tengo dinero. ¿Debería quedarme otro rato?)"

msgctxt "324_Player"
msgid " (I think I'll stay just a bit longer.)"
msgstr " (Supongo que puedo quedarme un rato más)."

msgctxt "336_Player"
msgid "(I think it's time to go.)"
msgstr "(Creo que es hora de irse)."

msgctxt "348_Player"
msgid "(What should I talk about?)"
msgstr "(¿Sobre qué debo hablar?)."

msgctxt "396_Player"
msgid "Yes"
msgstr "Sí"

msgctxt "408_Player"
msgid "No"
msgstr "No"

msgctxt "420_Player"
msgid "Stay"
msgstr "Quedarse"

msgctxt "432_Player"
msgid "Leave"
msgstr "Irse"

