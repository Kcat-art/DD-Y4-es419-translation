msgctxt "260_Dealer"
msgid "It looks like you don't have enough chips to play poker, sir."
msgstr "Parece que no tienes suficientes fichas para jugar al póker, señor."

msgctxt "272_Dealer"
msgid "If you'd like to purchase chips, you can do so at the front desk."
msgstr "If you'd like to purchase chips, you can do so at the front desk."

msgctxt "284_Dealer"
msgid "Welcome. Here, you can play Texas hold 'em poker. Would you like to play?"
msgstr "Bienvenido. Aquí puedes jugar al póker Texas hold 'em. ¿Quieres jugar?"

msgctxt "308_Haruka"
msgid "Uncle Kaz! I wanna watch you play poker. I bet you could get 2,000 points!"
msgstr "¡Tío Kaz! Quiero verte jugar al póker. ¡Apuesto a que podrías conseguir 2000 puntos!"

msgctxt "320_Kiryu"
msgid "(2,000 points in poker... Should I give it a try?)"
msgstr "(2000 puntos en póker... ¿Debería intentarlo?)"

msgctxt "332_Kiryu"
msgid "All right, I'll play."
msgstr "All right, I'll play."

msgctxt "344_Dealer"
msgid "Very good, sir. Please take your seat."
msgstr "Very good, sir. Please take your seat."

msgctxt "356_Haruka"
msgid "Good luck, Uncle Kaz!"
msgstr "¡Buena suerte, Tío Kaz!"

msgctxt "380_Kiryu"
msgid "Not right now."
msgstr "Ahora no."

msgctxt "392_Dealer"
msgid "Very well. We hope you'll play with us next time."
msgstr "Muy bien. Esperamos que vuelvas a jugar con nosotros."

msgctxt "404_Haruka"
msgid "Aww, I wanted to watch you play... Maybe next time?"
msgstr "Aww, I wanted to watch you play... Maybe next time?"

msgctxt "416_Haruka"
msgid "Uncle Kaz! You're good at poker, right? I bet you could get 5,000 points!"
msgstr "¡Tío Kaz! Eres bueno en el póker, ¿no? ¡Apuesto a que podrías conseguir 5000 puntos!"

msgctxt "428_Kiryu"
msgid "(5,000 points in poker... Should I give it a try?)"
msgstr "(5000 puntos en póker... ¿Debería intentarlo?)"

msgctxt "440_Kiryu"
msgid "All right, I'll play."
msgstr "All right, I'll play."

msgctxt "452_Dealer"
msgid "Very good, sir. Please take your seat."
msgstr "Very good, sir. Please take your seat."

msgctxt "464_Haruka"
msgid "Good luck, Uncle Kaz!"
msgstr "¡Buena suerte, Tío Kaz!"

msgctxt "488_Kiryu"
msgid "Not right now."
msgstr "Ahora no."

msgctxt "500_Dealer"
msgid "Very well. We hope you'll play with us next time."
msgstr "Muy bien. Esperamos que vuelvas a jugar con nosotros."

msgctxt "512_Haruka"
msgid "Aww, I wanted to watch you play..."
msgstr "Aww, I wanted to watch you play..."

msgctxt "524_Dealer"
msgid "Welcome. Here, you can play Texas hold 'em poker. Would you like to play?"
msgstr "Bienvenido. Aquí puedes jugar al póker Texas hold 'em. ¿Quieres jugar?"

msgctxt "536_Player"
msgid "Sure, I'll play."
msgstr "Claro, jugaré."

msgctxt "548_Dealer"
msgid "An excellent choice. What stakes would you like to play for?"
msgstr "Una elección excelente. ¿Con qué apuestas le gustaría jugar?"

msgctxt "560_Player"
msgid "I'll go with the low stakes."
msgstr "Iré con las apuestas bajas."

msgctxt "584_Dealer"
msgid "The starting bets are as follows: 5 chips for rounds one and two, then 10 chips on rounds three and four."
msgstr "Las apuestas iniciales son las que sigue: 5 fichas para las rondas uno y dos, luego, 10 fichas en las rondas tres y cuatro."

msgctxt "596_Dealer"
msgid "Please take a seat, sir."
msgstr "Por favor, tome asiento señor."

msgctxt "620_Dealer"
msgid "You'll need a minimum of 100 chips to play low-stakes poker, sir."
msgstr "Necesitarás un mínimo de 100 fichas para jugar al póker de bajo riesgo, señor."

msgctxt "632_Player"
msgid "I'll go with the high stakes."
msgstr "Voy a ir con las apuestas altas."

msgctxt "656_Dealer"
msgid "The starting bets are as follows: 50 chips for rounds one and two, then 100 chips on rounds three and four."
msgstr "Las apuestas iniciales son las que sigue: 50 fichas para las rondas uno y dos, luego, 100 fichas en las rondas tres y cuatro."

msgctxt "668_Dealer"
msgid "Please take a seat, sir."
msgstr "Por favor, tome asiento señor."

msgctxt "692_Dealer"
msgid "You'll need a minimum of 1,000 chips to play high-stakes poker, sir."
msgstr "Necesitarás un mínimo de 1000 fichas para jugar al póker de alto riesgo, señor."

msgctxt "704_Player"
msgid "Not right now."
msgstr "Ahora no."

msgctxt "716_Dealer"
msgid "Very well. We hope you'll play with us next time."
msgstr "Muy bien. Esperamos que vuelvas a jugar con nosotros."

