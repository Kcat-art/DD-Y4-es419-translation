msgctxt "116_Man"
msgid "Yeah, you! What do you think you're lookin' at!?"
msgstr "¡Sí, tú! ¡¿Qué crees que estás mirando?!"

msgctxt "128_Man"
msgid "You're a pain in the ass, you know that? I'm gonna murdalize ya!"
msgstr "Eres un grano en el culo, ¿lo sabías? ¡Te voy a asesinar!"

msgctxt "152_Man"
msgid "Sorry! I was wrong!"
msgstr "¡Lo siento! ¡Me equivoqué!"

msgctxt "164_Man"
msgid "That was a pretty dumb excuse for pickin' a fight, I admit. Here, take this. I'm real sorry."
msgstr "Fue una excusa muy tonta para empezar una pelea, lo admito. Toma esto. De verdad lo siento."

msgctxt "176_Man"
msgid "You got an unexciting %s. It's better than nothing."
msgstr "Obtuviste un %s."

msgctxt "212_Man"
msgid "P-Please don't look at me..."
msgstr "P-Por favor, no me mires..."

