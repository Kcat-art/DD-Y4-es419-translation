msgctxt "165\t234"
msgid "Pretty good, bro."
msgstr "Como era de esperar, kyoudai."

msgctxt "239\t338"
msgid "Looks like ya raised your boys right."
msgstr "Al parecer criaste muy bien a tus chicos."

msgctxt "362\t417"
msgid "Naw."
msgstr "Espera..."

msgctxt "418\t553"
msgid "I'm not... fuckin' done yet!"
msgstr "Espera... ¡Aún puedo seguir!"

msgctxt "1007\t1067"
msgid "Boss!"
msgstr "¡Jefe!"

msgctxt "1375\t1470"
msgid "Sorry 'bout the wait. Brother."
msgstr "Disculpa la demora, kyoudai."

msgctxt "1476\t1536"
msgid "Majima!"
msgstr "¡Majima!"

msgctxt "1558\t1661"
msgid "Guess we got some catchin' up to do."
msgstr "Supongo que tenemos que ponernos al día."

msgctxt "1670\t1742"
msgid "But not here."
msgstr "Pero no aquí."

msgctxt "1758\t1830"
msgid "How 'bout a little stroll?"
msgstr "Hay que dar un paseo."

