msgid "Listen."
msgstr "Mira."

msgctxt "546	646"
msgid "Your life's in the crapper, sure."
msgstr "Tu vida puede no tener arreglo."

msgctxt "649	730"
msgid "But don't blame your dead boss for that."
msgstr "Pero eso es solo culpa tuya, y de nadie más."

msgctxt "765	854"
msgid "A real yakuza owns up to his shit."
msgstr "Un verdadero yakuza no se escondería detrás de excusas."

msgctxt "872	993"
msgid "So if you wanna blame someone,\\ntry lookin' in a mirror."
msgstr "Si sigues molesto\\na la siguiente maldícete a ti mismo."

msgctxt "1094	1160"
msgid "What's going on in there!?"
msgstr "¡¿Qué crees que estás haciendo?!"

