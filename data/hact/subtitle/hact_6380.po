msgctxt "16	85"
msgid "We'll have time to chat later."
msgstr "Tendremos tiempo para charlar más tarde."

msgctxt "89	180"
msgid "You don't look like the bad guys..."
msgstr "Ustedes no se ven como los malos..."

msgctxt "181	296"
msgid "But I guess there's only\\none way to settle this."
msgstr "Pero supongo que solo hay\\nuna manera de resolver esto."

msgctxt "332	392"
msgid "Good luck with that."
msgstr "Buena suerte con eso."

msgctxt "399	516"
msgid "Well? Ready when you are."
msgstr "Vamos, puedes venir cuando quieras."

msgctxt "524	584"
msgid "If you say so."
msgstr "¿Están listos?"

msgctxt "610	670"
msgid "Let's do this!"
msgstr "¡Adelante!"

