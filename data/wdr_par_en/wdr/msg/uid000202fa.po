msgctxt "732"
msgid "Saejima"
msgstr "Saejima"

msgctxt "736"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "740"
msgid "Homeless Man"
msgstr "Hombre sin hogar"

msgctxt "56_Saejima"
msgid "'Scuse me. Know where I can find an info broker?"
msgstr "Discúlpeme. ¿Sabe dónde puedo encontrar un agente de información?"

msgctxt "68_Homeless Man"
msgid "Who, me? Nah, I don't know a thing."
msgstr "¿Quién, yo? Qué va, no sé nada."

msgctxt "80_Saejima"
msgid "Alright. Mind lettin' me by so I can ask someone who does?"
msgstr "De acuerdo. ¿Te importa dejarme pasar para poder preguntarle a alguien que lo sepa?"

msgctxt "92_Homeless Man"
msgid "No one's up ahead. You'd just be wasting your time.\\r\n"\n"I'd look elsewhere if I was you."
msgstr "Nadie está por delante. Estarías perdiendo el tiempo.\\r\n"\n"Si fuera tú, buscaría en otra parte."

