msgctxt "2496_Chihiro"
msgid "Hello? This is Chihiro from Jewel."
msgstr "¿Hola? Le habla Chihiro del Jewel."

msgctxt "2508_Player"
msgid "Oh, hi. What's up?"
msgstr "Ah, hola. ¿Qué tal?"

msgctxt "2520_Chihiro"
msgid "I don't have any classes tomorrow, so I'm free right now. Do you wanna go out with me?"
msgstr "No tengo ninguna clase mañana, así que ahora estoy libre. ¿Quiere salir conmigo?"

msgctxt "2532_Player"
msgid "You mean on a date?"
msgstr "¿Te refieres a una cita?"

msgctxt "2544_Chihiro"
msgid "Yes! You'll go out with me, right?"
msgstr "¡Sí! Saldrá conmigo, ¿cierto?"

msgctxt "2556_Player"
