msgctxt "2384"
msgid "Tanimura"
msgstr "Tanimura"

msgctxt "2388"
msgid "Man"
msgstr "Hombre"

msgctxt "2392"
msgid "Kiryu"
msgstr "Kiryu"

msgctxt "2396"
msgid "Akiyama"
msgstr "Akiyama"

msgctxt "2400"
msgid "Saejima"
msgstr "Saejima"

msgctxt "156_Tanimura"
msgid "Excuse me, I'd like to pass through here."
msgstr "Disculpe, quiero pasar por aquí."

msgctxt "168_Man"
msgid "這里是進入禁止。"
msgstr "這里是進入禁止。"

msgctxt "180_Tanimura"
msgid "(Doesn't look like he understands Japanese.)"
msgstr "(Creo que no entiende japonés)."

msgctxt "192_Tanimura"
msgid "\"Excuse me, are you Chinese? I'm a policeman. Could you let me through?\""
msgstr "\"Disculpe, ¿es chino? Soy policía, ¿me podría dejar pasar?\""

msgctxt "204_Man"
msgid "\"Go right ahead.\""
msgstr "\"Adelante\"."

msgctxt "264_Kiryu"
msgid "Hey, could you move?"
msgstr "Oiga, ¿podría moverse?"

msgctxt "276_Akiyama"
msgid "Hey there. Think you could move out of my way?"
msgstr "Disculpe. ¿Podría dejarme pasar?"

msgctxt "288_Saejima"
msgid "Hey, you're in my way."
msgstr "Oye, estás en mi camino."

msgctxt "300_Tanimura"
msgid "This place definitely wouldn't have been chosen."
msgstr "Este lugar definitivamente no habría sido elegido."

msgctxt "312_Man"
msgid "這里是進入禁止。"
msgstr "這里是進入禁止。"

msgctxt "336_Kiryu"
msgid "(A foreigner... Doesn't look like he understands Japanese, or wants to let me through.)"
msgstr "(Un extranjero... No parece que entienda japonés o que me vaya a dejar pasar)."

msgctxt "348_Akiyama"
msgid "(Doesn't look like he speaks Japanese, or wants to let me through.)"
msgstr "(No parece que entienda japonés o que me vaya a dejar pasar)."

msgctxt "360_Saejima"
msgid "(Doesn't look like he's gonna let me through. Best to avoid causin' trouble.)"
msgstr "(No parece que me vaya a dejar pasar. Mejor me evito problemas)."

msgctxt "372_Tanimura"
msgid "This place definitely wouldn't have been chosen."
msgstr "Este lugar definitivamente no habría sido elegido."

