msgctxt "68_Assassin"
msgid "...You have any idea what we're about to do to you?"
msgstr "...¿Tienes idea de lo que estamos a punto de hacerte?"

msgctxt "80_Tanimura"
msgid "That's my line."
msgstr "Eso mismo iba a decir yo."

msgctxt "92_Assassin"
msgid "What the!?"
msgstr "¡¿Qué pasa...?!"

msgctxt "104_Saki-chan"
msgid "Say your prayers, bitches!"
msgstr "¡Prepárense para lo peor, perras!"

msgctxt "116_Tanimura"
msgid "There's no escape now."
msgstr "No tienen escapatoria."

msgctxt "128_Tanimura"
msgid "Leave this to me, Saki-chan. As for you idiots...\\r\n"\n"Hurry up and bring it! I don't have all day here."
msgstr "Yo me encargo, Saki-chan. Y ustedes, idiotas...\\r\n"\n"¡Apúrense y vengan a por mí! Que no tengo todo el día."

