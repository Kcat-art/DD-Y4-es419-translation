msgctxt "17520_松岡里緒奈：源氏名"
msgid "Huh!? Seriously!? What, are you poor?"
msgstr "¿¡Eh!? ¿¡En serio!? ¿Qué, eres pobre?"

msgctxt "17532_松岡里緒奈：源氏名"
msgid "Huh? You're so stingy, %s-san..."
msgstr "¿Eh? Eres tan tacaño, %s-San..."

msgctxt "17544_松岡里緒奈：源氏名"
msgid "I'm hungry! Can I order something to eat?"
msgstr "Estoy hambrienta. ¿Puedo pedir algo para comer?"

msgctxt "17568_Kiryu"
msgid "Yay! I'll order, then."
msgstr "¡Qué bien! Pediré una, entonces."

msgctxt "17580_F_cab_sitsofa_sync_order"
