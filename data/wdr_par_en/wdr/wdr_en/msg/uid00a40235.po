msgctxt "5000"
msgid "Man in Black"
msgstr "Hombre de Negro"

msgctxt "5004"
msgid "Saejima"
msgstr "Saejima"

msgctxt "5008"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "5012"
msgid "Talk_Ojigi"
msgstr "Talk_Ojigi"

msgctxt "5016"
msgid "Takeda"
msgstr "Takeda"

msgctxt "5020"
msgid "Talk_Quest"
msgstr "Talk_Quest"

msgctxt "176_Man in Black"
msgid "Have you reconsidered, Saejima-san?"
msgstr "¿Has cambiado de parecer, Saejima-san?"

msgctxt "188_Saejima"
msgid "Sorry. Not interested. Find someone else."
msgstr "Lo lamento. No me interesa. Búscate a alguien más."

msgctxt "200_Man in Black"
msgid "I really do think you'd find this job worth your while.\\r\n"\n"I'll be here if you change your mind."
msgstr "De verdad creo que este trabajo te viene como anillo al dedo.\\r\n"\n"Estaré por aquí si cambias de opinión."

msgctxt "212_Saejima"
msgid "I don't come cheap, y'know."
msgstr "No salgo barato, ¿sabes?"

msgctxt "224_Man in Black"
msgid "I understand. But I'm happy to hear you're interested."
msgstr "Comprendo. Pero me alegra oír que estés interesado."

msgctxt "236_Takeda"
msgid "I'm Takeda, a manager at Oyamada Talent Productions.\\r\n"\n"Let's head to our office to discuss the particulars."
msgstr "Me llamo Takeda, soy un manager en Oyamada Talent Productions.\\r\n"\n"Acompañame a mi oficina para discutir los detalles."

msgctxt "284_Man in Black"
msgid "Excuse me, are you Saejima-san?"
msgstr "Perdona, ¿eres Saejima-san?"

msgctxt "296_Saejima"
msgid "Who's askin'?"
msgstr "¿Quién pregunta?"

msgctxt "308_Man in Black"
msgid "A friend. I'm a respectable businessman, I assure you.\\r\n"\n"I've been looking for you."
msgstr "Un amigo. Me considero un hombre de negocios respetable, eso te lo garantizo.\\r\n"\n"Llevo tiempo buscándote."

msgctxt "320_Saejima"
msgid "How'd ya hear 'bout me, anyhow?"
msgstr "¿Cómo supiste sobre mí?"

msgctxt "332_Man in Black"
msgid "You can relax. I just happen to have some homeless men\\r\n"\n"in my circle of acquaintances."
msgstr "Puedes estar relajado. Resulta que tengo a unos cuantos sin techo\\r\n"\n"en mi lista de contactos."

msgctxt "344_Man in Black"
msgid "I asked one if he knew anybody who could help me out,\\r\n"\n"and your name came up."
msgstr "Le pregunté a uno si conocía a alguien que me pudiera ayudar con algo,\\r\n"\n"y surgió tu nombre."

msgctxt "356_Saejima"
msgid "Alright, then. So whaddya want?"
msgstr "Bueno, entonces. ¿Qué es lo que quieres?"

msgctxt "368_Man in Black"
msgid "Actually, there's a little, uh, job I'd like you to do."
msgstr "De hecho, te tengo un pequeño, eh, trabajito con el que me gustaría que me ayudaras."

msgctxt "380_Saejima"
msgid "A paying job?"
msgstr "¿Y ese trabajito es remunerado?"

msgctxt "392_Man in Black"
msgid "Yes. Can you spare a moment to hear more about it?"
msgstr "Claro que sí. ¿Me das un momento para explicártelo más a fondo?"

msgctxt "404_Saejima"
msgid "I don't come cheap, y'know."
msgstr "No salgo barato, ¿sabes?"

msgctxt "416_Man in Black"
msgid "I understand. But I'm happy to hear you're interested."
msgstr "Comprendo. Pero me alegra oír que estés interesado."

msgctxt "428_Takeda"
msgid "I'm Takeda, a manager at Oyamada Talent Productions.\\r\n"\n"Let's head to our office to discuss the particulars."
msgstr "Me llamo Takeda, soy un manager en Oyamada Talent Productions.\\r\n"\n"Acompañame a mi oficina para discutir los detalles."

msgctxt "452_Saejima"
msgid "Nope."
msgstr "No."

msgctxt "464_Man in Black"
msgid "I'd really like to discuss this opportunity with you.\\r\n"\n"Meet me here if you happen to change your mind."
msgstr "De verdad me encantaría discutir esta oportunidad contigo.\\r\n"\n"Estaré justo aquí por si cambias de parecer."

msgctxt "476_Man in Black"
msgid "Hear Him Out"
msgstr "Escucharlo"

msgctxt "488_Man in Black"
msgid "Turn Him Down"
msgstr "Rechazarlo"

