msgctxt "62	122"
msgid "Then you don't have to worry."
msgstr "No te preocupes."

msgctxt "357	437"
msgid "Kiryu's not gonna be going to Tokyo."
msgstr "Kiryu no va a ir a Tokio."

msgctxt "444	552"
msgid "And one more thing.\\nI'm shipping out now, too."
msgstr "Y una cosa más.\\nMe voy de aquí ahora mismo."

msgctxt "580	624"
msgid "Hamazaki."
msgstr "Hamazaki..."

msgctxt "665	725"
msgid "My mind's made up."
msgstr "Ya lo he decidido."

msgctxt "742	840"
msgid "Saejima'll know the truth\\none way or another."
msgstr "Mientras pueda decirle la verdad a Saejima,\\nde alguna manera está bien."

msgctxt "871	948"
msgid "Even if someone else\\nhas gotta help me."
msgstr "Incluso si tengo que pedirle\\nayuda a alguien más."

msgctxt "1007	1071"
msgid "So, Kiryu-san."
msgstr "Entonces, Kiryu-san."

msgctxt "1081	1154"
msgid "You can forget all about that file."
msgstr "Puedes olvidarte del archivo."

msgctxt "1246	1382"
msgid "Your life's here.\\nIt's not worth throwing that away."
msgstr "Tienes una nueva vida en este lugar, ¿verdad?"

msgctxt "1396	1469"
msgid "And what about your life?"
msgstr "Pero entonces, tú..."

msgctxt "1485	1533"
msgid "Don't worry about that."
msgstr "No te preocupes por ello."

msgctxt "1540	1614"
msgid "I'm a tough bastard."
msgstr "Soy un tipo duro."

msgctxt "1637	1755"
msgid "I'll just kick back and wait\\nfor Saejima to get locked up again."
msgstr "Voy a esperar pacientemente\\nel regreso de Saejima en prisión."

msgctxt "1816	1876"
msgid "Hamazaki..."
msgstr "Hamazaki."

