msgctxt "174	256"
msgid "Looks like the cops are out in full force."
msgstr "Parece que la policía anda cerca."

msgctxt "265	354"
msgid "Best stick around for the night."
msgstr "Lo mejor sería quedarse esta noche."

msgctxt "498	611"
msgid "This place is basically my hideout."
msgstr "Este lugar es básicamente mi escondite."

msgctxt "612	684"
msgid "The cops won't find you here."
msgstr "No tiene conexión con la policía."

msgctxt "730	790"
msgid "You're safe."
msgstr "Tranquila."

msgctxt "831	891"
msgid "Why...?"
msgstr "¿Por qué...?"

msgctxt "951	1094"
msgid "Why do all this?\\nWhy risk yourself to protect me?"
msgstr "¿Por qué me ayudas a esconderme...?"

msgctxt "1465	1556"
msgid "This is the restaurant's special blend."
msgstr "Esta es la mezcla especial de té chino del restaurante."

msgctxt "1563	1653"
msgid "Puts the dishwater most places call tea to shame."
msgstr "El sabor es diferente al del té regular."

msgctxt "1793	1872"
msgid "One sip and you'll feel right at home."
msgstr "Por ahora, solo bébelo y trata de calmarte."

