msgctxt "268"
msgid "Quit"
msgstr "Salir"

msgctxt "273"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "291"
msgid "Order"
msgstr "Pagar"

msgctxt "297"
msgid "Order the currently selected item."
msgstr "Pagar el objeto seleccionado actualmente."

msgctxt "332"
msgid "(I haven't picked anything.)"
msgstr "(No he escogido nada)"

msgctxt "361"
msgid "(I'm short on cash.)"
msgstr "(Me hace falta dinero)"

msgctxt "382"
msgid "Have you decided what you want?"
msgstr "¿Ya decidió que va a querer?"

msgctxt "414"
msgid "(I can't eat anymore...)"
msgstr "(No puedo comer más...)"

msgctxt "439"
msgid "A single malt whisky aged in sherry barrels for a\n"
"balanced flavor."
msgstr "Un whisky de malta envejecido en barriles de jerez para conseguir un sabor equilibrado."

msgctxt "506"
msgid "A Yamazaki whisky made with carefully selected,\n"
"mature malts for a flavorful, smooth finish."
msgstr "Un whisky Yamazaki elaborado con maltas\n"
"cuidadosamente seleccionadas y maduras, que\n"
"ofrecen un sabor rico y un final suave."

msgctxt "599"
msgid "A whisky made in the Southern Alps of Japan. Has a\n"
"fruity flavor with smoky accents."
msgstr "Un whisky elaborado en los Alpes del Sur de Japón. tiene un\n"
"Sabor afrutado con toques ahumados."

msgctxt "684"
msgid "The champion of single malt whiskies."
msgstr "El campeón de los whiskies de malta."

