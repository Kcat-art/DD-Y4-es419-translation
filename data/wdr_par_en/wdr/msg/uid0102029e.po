msgctxt "92_Ihara"
msgid "How the shit do you still have a job, waiter!?"
msgstr "¡¿Cómo mierda sigue teniendo trabajo,\r\n"
"camarero?!"

msgctxt "104_Ihara"
msgid "Where's the hundred bottles of champagne we ordered!?\r\n"
"It's been ten minutes already!"
msgstr "¡¿Dónde están las cien botellas de champán que ordenamos?!\r\n"
"¡Ya pasaron diez minutos!"

msgctxt "116_Mishima"
msgid "You idiots growin' the grapes in the back room or some shit!?"
msgstr "¡¿Acaso están cultivando las putas uvas?!"

msgctxt "128_Akiyama"
msgid "So these are our boys, huh?"
msgstr "Con que esos son, eh..."

msgctxt "140_Attendant"
msgid "Yes, sir. It's been going on like this for hours now. They've scared off all our other customers..."
msgstr "Sí señor, llevan horas aquí. Ya espantaron a todos nuestros clientes."

msgctxt "164_Attendant"
msgid "Akiyama-san, wait! You can't just...!"
msgstr "¡Akiyama-san, espere! ¡No puede...!"

