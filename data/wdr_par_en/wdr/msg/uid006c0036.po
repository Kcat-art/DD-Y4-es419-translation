msgid "Thanks for listening, Kiryu-san. <Color:7>♥<Color:Default>"
msgstr "Gracias por escuchar, Kiryu-san. <Color:7>♥<Color:Default>"

msgctxt "17772_松岡里緒奈：源氏名"
