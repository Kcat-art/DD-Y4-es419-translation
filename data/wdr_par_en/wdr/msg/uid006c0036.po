msgid "You might be right. I'll be more careful from now on. <Color:7>♥<Color:Default>"
msgstr "Puede que tengas razón. Tendré más cuidado a partir de ahora. <Color:7>♥<Color:Default>"

msgctxt "17724_松岡里緒奈：源氏名"
msgid "So I'm homesick, huh?"
msgstr ""

msgctxt "17736_Kiryu"
msgid "Probably. Most people are happier being with their families than living alone."
msgstr "Probablemente. La mayoría de la gente es más feliz estando con su familia que viviendo sola."

msgctxt "17748_松岡里緒奈：源氏名"
msgid "I guess you're right. Maybe I'll email someone in my family."
msgstr "Supongo que tienes razón. Tal vez le envíe un correo a alguien de mi familia."

