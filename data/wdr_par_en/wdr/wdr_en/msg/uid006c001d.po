msgstr "Quizá necesites un novio masoquista."

msgctxt "21984_Akiyama"
msgid "I take big bites."
msgstr "Yo le doy mordidas grandes."

msgctxt "21996_Akiyama"
msgid "I take my time and lick it slowly."
msgstr "Me tomo mi tiempo y lo lamo lentamente."

msgctxt "22008_Akiyama"
