msgctxt "392"
msgid "Quit"
msgstr "Salir"

msgctxt "397"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "415"
msgid "Order"
msgstr "Pagar"

msgctxt "421"
msgid "Order the currently selected item.  "
msgstr "Pedir el objeto actualmente seleccionado.  "

msgctxt "458"
msgid "(I haven't picked anything.)  "
msgstr "(No he escogido nada)"

msgctxt "489"
msgid "(I'm short on cash.)  "
msgstr "(Me hace falta dinero)"

msgctxt "512"
msgid "Thank you. That'll be %s."
msgstr "Gracias. Eso sería %s."

msgctxt "538"
msgid "(I can't carry any more stuff.)"
msgstr "(No puedo llevar más cosas)."

msgctxt "570"
msgid "(They're sold out.)"
msgstr "(Están agotados)."

msgctxt "590"
msgid "The limited-edition Kamuro Burger: an enticing\n"
"combination of avocado, tomato, and cheese. To go."
msgstr "La hamburguesa Kamuro de edición limitada: una tentadora\n"
"combinación de aguacate, tomate, y queso. Para llevar."

msgctxt "688"
msgid "Our classic burger set, with a Smile Burger, fries, and\n"
"a drink. To go."
msgstr "Nuestro clásico combo, con una Hamburguesa Smile,\n"
"papas fritas y una bebida. Para llevar."

msgctxt "760"
msgid "This set includes a Smile Cheeseburger, fries, and a\n"
"drink. To go."
msgstr "Este combo incluye una hamburguesa de queso Smile,\n"
"papas fritas y una bebida. Para llevar."

msgctxt "827"
msgid "This set includes a Teriyaki Smile Burger with special\n"
"sauce, fries, and a drink. To go."
msgstr "Este combo incluye una hamburguesa Teriyaki Smile\n"
"con salsa especial, papas fritas y una bebida. Para llevar."

msgctxt "916"
msgid "As advertised, this set comes with a King Smile \n"
"Burger, fries, and a drink. To go."
msgstr "Como se anuncia, este combo viene con una Hamburguesa Rey Smile, papas fritas y una bebida. Para llevar."

msgctxt "1000"
msgid "A tasty Tuna Burger with a unique texture. Fries and \n"
"a drink come with this set. To go."
msgstr "Una sabrosa hamburguesa de atún con una textura única. \n"
"Patatas fritas y una bebida. Para llevar."

msgctxt "1089"
msgid "A tender, stewed pork burger with fries and a drink.\n"
"To go."
msgstr "Una tierna hamburguesa de cerdo estofado con papas\n"
"fritas y una bebida. Para llevar."

msgctxt "1149"
msgid "A Smile Shake made with fresh milk. Sure to put a \n"
"smile on anyone's face. To go."
msgstr "Un batido Smile hecho con leche fresca. Seguro que \n"
"hará sonreír a cualquiera. Para llevar."

msgctxt "1231"
msgid "The golden-fried standard of french fries. Served \n"
"with a smile. To go."
msgstr "Las clásicas y doradas papas fritas. Servidas con una sonrisa. Para llevar."

