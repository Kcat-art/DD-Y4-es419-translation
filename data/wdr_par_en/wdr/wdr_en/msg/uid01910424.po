msgctxt "1296"
msgid "Quickturns"
msgstr "Giros rápidos"

msgctxt "56_Quickturns"
msgid "Quickturns can be used during chase events as a technique to round corners without losing speed. This technique comes in handy in areas with many corners, such as rooftops."
msgstr "Los giros rápidos se pueden usar durante las persecuciones como una técnica para girar sin perder velocidad. Esta técnica es útil en áreas con muchas esquinas, como los tejados."

msgctxt "68_Quickturns"
msgid "Quickturns are executed by <Color:7>using <Color:Default><Action:Button_LS_Up@Chase><Action:Button_LS_Down@Chase><Action:Button_LS_Left@Chase><Action:Button_LS_Right@Chase><Color:7> while pressing<Color:Default> <Action:Button_R1@Chase>."
msgstr "Los giros rápidos se ejecutan <Color:7>usando\n"
"<Color:Default><Action:Button_LS_Up@Chase><Action:Button_LS_Down@Chase><Action:Button_LS_Left@Chase><Action:Button_LS_Right@Chase><Color:7> mientras mantienes presionado<Color:Default> <Action:Button_R1@Chase>."

msgctxt "80_Quickturns"
msgid "This information has been added as a <Color:14>memo<Color:Default>.\r\n"
"Read <Color:14>memos<Color:Default> by selecting <Color:14>Memos<Color:Default> in the Pause Menu.\r\n"
"You can access the Pause Menu with the <Action:Button_Options@Adventure> button."
msgstr "Esta información ha sido añadida como una <Color:14>nota<Color:Default>.\r\n"
"Lee las <Color:14>notas<Color:Default> seleccionando <Color:14>Notas<Color:Default> en el menú de pausa.\r\n"
"Puedes acceder al menú de pausa con el botón <Action:Button_Options@Adventure>."

