msgctxt "620"
msgid "Quit"
msgstr "Salir"

msgctxt "625"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "643"
msgid "Order"
msgstr "Pagar"

msgctxt "649"
msgid "Order the currently selected item."
msgstr "Pagar el objeto seleccionado actualmente."

msgctxt "684"
msgid "(I haven't picked anything.)"
msgstr "(No he escogido nada)"

msgctxt "713"
msgid "(I'm short on cash.)"
msgstr "(Me hace falta dinero)"

msgctxt "734"
msgid "Thank you. Your total comes to %s."
msgstr "Gracias. El precio total es de %s."

msgctxt "769"
msgid "(I can't eat anymore...)"
msgstr "(No puedo comer más...)"

msgctxt "817"
msgid "A blend of Mandheling and Brazilian beans with a\n"
"Colombian base."
msgstr "Una mezcla de granos mandheling y brasileños con una base colombiana."

msgctxt "882"
msgid "This is the ultimate cup of coffee, made with top-grade\n"
"coffee beans."
msgstr "Esta es la taza de café definitiva, elaborada con granos de café de primera calidad."

msgctxt "952"
msgid "A lot of coffee drinkers love our mocha for its rich,\n"
"bitter flavor."
msgstr "A muchos amantes del café les encanta el moca por su sabor amargo y rico."

msgctxt "1021"
msgid "Bergamot-scented and brewed with Sri Lankan tea\n"
"leaves from a farm under exclusive contract."
msgstr "Perfumada con bergamota y elaborada con hojas de té de Sri Lanka procedentes de una plantación exclusiva."

msgctxt "1114"
msgid "Assam tea leaves from a tea farm under our exclusive\n"
"contract have been carefully brewed with creamy,\n"
"pasteurized milk from Hokkaido."
msgstr "Hojas de té Assam de una plantación exclusiva contratada, cuidadosamente mezcladas con leche cremosa pasteurizada de Hokkaido."

msgctxt "1248"
msgid "Made with healthy, organic tomatoes."
msgstr "Hecho con tomates saludables y orgánicos."

msgctxt "1285"
msgid "Richly scented tea from the hills of Nuwara Eliya in\n"
"Sri Lanka combined with organic lemon."
msgstr "Té con un aroma intenso, proveniente de las colinas de Nuwara Eliya en Sri Lanka. Combinado con limón orgánico."

msgctxt "1377"
msgid "A creamy parfait loaded with fresh strawberries."
msgstr "Un parfait cremoso cargado de fresas frescas."

msgctxt "1426"
msgid "A sizable parfait loaded with rich chocolate."
msgstr "Un parfait grande cargado de chocolate rico y delicioso."

msgctxt "1472"
msgid "A popular float made with Uji green tea and creamy\n"
"vanilla ice cream."
msgstr "Un popular flotante hecho con té verde Uji y cremoso\n"
"helado de vainilla."

msgctxt "1542"
msgid "Our special shortcake and a drink."
msgstr "Nuestro especial de tarta y una bebida."

msgctxt "1577"
msgid "A fried egg, bacon, toast, and your choice of either\n"
"coffee or tea."
msgstr "Huevo frito, tocino, tostada y un café o té de tu elección."

msgctxt "1645"
msgid "This set features a bacon, egg, and lettuce sandwich on\n"
"white bread."
msgstr "Este set incluye un sandwich de huevo, tocino y lechuga en pan blanco."

msgctxt "1714"
msgid "Tuna and cream pasta with a drink."
msgstr "Pasta de atún y crema con una bebida."

msgctxt "1749"
msgid "This beef curry is our special house recipe."
msgstr "Este curry de carne de res es nuestra receta especial de la casa."

