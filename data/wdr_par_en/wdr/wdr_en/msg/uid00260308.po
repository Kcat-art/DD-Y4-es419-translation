msgctxt "1280_Player"
msgid "Should we go play darts at Bantam?"
msgstr "¿Qué tal si jugamos a los dardos en Bantam?"

msgctxt "1292_Shizuka"
msgid "Ooh, darts! That's so classy."
msgstr "¡Oh, dardos! Eso es tan elegante."

msgctxt "1304_Talk_Smile"
msgid "I only started playing recently, but this should be a good matchup. Hehehe! <Color:7>♥<Color:Default>"
msgstr "I only started playing recently, but this should be a good matchup. Hehehe! <Color:7>♥<Color:Default>"

