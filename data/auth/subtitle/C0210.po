msgctxt "1734\t1882"
msgid "I'm... still alive?"
msgstr "¿Todavía sigo vivo...?"

msgctxt "2051\t2150"
msgid "The hell's this?"
msgstr "¿Qué rayos es esto...?"

msgctxt "2192\t2252"
msgid "A rubber bullet."
msgstr "Una bala de goma."

msgctxt "2319\t2478"
msgid "They're not lethal,\\nbut they sure pack a serious punch."
msgstr "No son letales,\\npero tienden a golpear muy fuerte, ¿verdad?"

msgctxt "2497\t2627"
msgid "Katsuragi?\\nWhat are you talking about?"
msgstr "¿Katsuragi?\\nQué estás..."

msgctxt "2691\t2749"
msgid "Katsuragi!"
msgstr "¡Katsuragi!"

msgctxt "2836\t2921"
msgid "The fuck do you think you're doing!?"
msgstr "Imbécil, qué crees..."

msgctxt "4234\t4326"
msgid "Brother. You finished?"
msgstr "Kyoudai. ¿Ya terminaste?"

msgctxt "4426\t4552"
msgid "Yeah. Just need to\\nend up in the hospital now."
msgstr "Sí. Ahora solo necesito\\nterminar en el hospital."

msgctxt "4883\t4957"
msgid "Try not to hit anything too vital."
msgstr "Trate de no golpear nada vital."

msgctxt "4967\t5020"
msgid "I won't."
msgstr "Entendido."

msgctxt "5054\t5188"
msgid "You'll be out in no time.\\nAnd captain, too."
msgstr "Luego de que salgas del hospital... ¿serás el nuevo capitán?"

msgctxt "5282\t5364"
msgid "As long as the old man's still kicking."
msgstr "Mientras el viejo siga vivo."

msgctxt "5434\t5567"
msgid "No worry there, though.\\nHe'll come to soon enough."
msgstr "No hay de que preocuparse.\\nSe despertará en un rato."

msgctxt "5689\t5751"
msgid "The rest is on your shoulders."
msgstr "El resto está en tus manos."

