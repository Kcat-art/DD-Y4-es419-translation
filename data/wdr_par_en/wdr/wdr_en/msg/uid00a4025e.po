msgctxt "220_Young Man"
msgid "Hold up! I ain't gonna let you off the hook that easy.\\r\n"\n"C'mere a second."
msgstr "¡Quieto ahí! Ni creas que te irás así como así.\\r\n"\n"¡Vuelve aquí! ¡Ahora!"

msgctxt "232_Akiyama"
