msgctxt "116_Man"
msgid "Please, won't you help me? I've been partying too hard and I've run out of money!"
msgstr "Por favor, ¿me ayudarías? ¡He estado de fiesta y me he quedado sin dinero!"

msgctxt "128_Man"
msgid "Take out your wallet now and save me! C'mon pal, hand it over already!"
msgstr "¡Saca tu billetera ya y ayúdame! Vamos, compa, ¡dámela ya!"

msgctxt "152_Man"
msgid "That's enough! Really!"
msgstr "¡Ya basta! ¡En enserio!"

msgctxt "164_Man"
msgid "Your feelings came through loud and clear... and painfully. Please take this instead."
msgstr "Tus sentimientos se notaron fuerte y claro... y muy dolorosos. Mejor toma esto en su lugar."

msgctxt "176_Man"
msgid "You got a creaky %s."
msgstr "Obtuviste un %s."

msgctxt "212_Man"
msgid "Ouch..."
msgstr "Ouch..."

