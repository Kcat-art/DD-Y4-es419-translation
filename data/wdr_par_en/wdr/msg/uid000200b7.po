msgctxt "2484"
msgid "Tanimura"
msgstr "Tanimura"

msgctxt "2488"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "2492"
msgid "Player"
msgstr "Player"

msgctxt "2496"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "140_Tanimura"
msgid "Going out with Haruka-chan? Have fun."
msgstr "¿Vas a salir con Haruka-chan? Que se diviertan."

msgctxt "152_Tanimura"
msgid "%s-san... I wouldn't mind patrolling a bit if you're tired."
msgstr "%s-san... No me importaría vigilar un poco si estás cansado."

msgctxt "176_Player"
msgid "I'll be okay on my own for now."
msgstr "Estaré bien por ahora."

msgctxt "188_Player"
msgid "Sorry, gonna have to pass."
msgstr "Lo siento, voy a tener que pasar."

msgctxt "200_Player"
msgid "I'm good."
msgstr "Estoy bien."

msgctxt "212_Player"
msgid "Nah, I'm fine."
msgstr "No, estoy bien."

msgctxt "224_Tanimura"
msgid "Oh. Well, as long as you know your limits."
msgstr "Bueno, mientras conozcas tus límites."

msgctxt "248_Player"
msgid "That's a good idea. Go ahead."
msgstr "Buena idea. Adelante."

msgctxt "260_Player"
msgid "Sure, why not. I'm always down to chill for a bit."
msgstr "Claro, por qué no. Siempre estoy dispuesto a relajarme un poco."

msgctxt "272_Player"
msgid "Guess I don't mind catchin' my breath."
msgstr "Supongo que no me importa recuperar el aliento."

msgctxt "284_Player"
msgid "All right, I'll let you take things from here."
msgstr "Muy bien, dejaré que tomes las riendas a partir de aquí."

msgctxt "296_Tanimura"
msgid "Leave everything to me."
msgstr "Déjamelo todo a mí."

msgctxt "320_Tanimura"
msgid "Cancel"
msgstr "Cancelar"

msgctxt "332_Tanimura"
msgid "Switch to Tanimura"
msgstr "Cambiar a Tanimura"

