msgctxt "560"
msgid "Quit"
msgstr "Salir"

msgctxt "565"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "583"
msgid "Order"
msgstr "Pagar"

msgctxt "589"
msgid "Order the currently selected item.  "
msgstr "Pedir el objeto actualmente seleccionado.  "

msgctxt "626"
msgid "(I haven't picked anything.)  "
msgstr "(No he escogido nada)"

msgctxt "657"
msgid "(I'm short on cash.)  "
msgstr "(Me hace falta dinero)"

msgctxt "680"
msgid "Thank you. That'll be %s."
msgstr "Gracias. Eso sería %s."

msgctxt "706"
msgid "(I can't carry any more stuff.)"
msgstr "(No puedo llevar más cosas)."

msgctxt "738"
msgid "(They're sold out.)"
msgstr "(Están agotados)."

msgctxt "758"
msgid "Should help you get back on your feet when you're\n"
"low on health and Heat."
msgstr "Esto debería ayudarte a recuperarte cuando tengas\n"
"poca salud y Heat."

msgctxt "832"
msgid "More effective at revitalizing your health and Heat\n"
"than a regular Staminan X."
msgstr "Más efectivo para revitalizar tu salud y Heat que\n"
"el Staminan normal."

msgctxt "911"
msgid "One of the most potent energy drinks on the market.\n"
"It'll dramatically restore your health and Heat."
msgstr "Uno de los energizantes más potentes en el mercado.\n"
"Restaurará dramáticamente tu salud y Heat."

msgctxt "1012"
msgid "This flak vest is super resistant to bullets. It's extra \n"
"durable due to its special creation process."
msgstr "Este chaleco antibalas funciona bien contra las balas.\n"
"Es muy resistente gracias a su proceso de creación\n"
"especial."

msgctxt "1115"
msgid "A powerful chemical compound that can freeze\n"
"almost anything instantly."
msgstr "Un potente compuesto químico que puede congelar\n"
"casi cualquier cosa al instante."

msgctxt "1187"
msgid "It's highly explosive, so be careful with it."
msgstr "Es altamente explosivo, así que ten cuidado con él."

msgctxt "1233"
msgid "This chunk of metal has some serious magnetic pull. \n"
"Maybe you can use it for something."
msgstr "Este trozo de metal tiene una seria atracción magnética.\n"
"Tal vez puedas usarlo para algo."

msgctxt "1322"
msgid "Not really sure what you could do with this mystery\n"
"white liquid..."
msgstr "No estoy muy seguro de lo que podrías hacer con este misterioso líquido blanco..."

msgctxt "1390"
msgid "Used in cosmetics and stuff."
msgstr "Se utiliza en cosméticos y otras cosas."

msgctxt "1419"
msgid "Perfect for making stuff bouncy!"
msgstr "¡Perfecto para hacer que las cosas reboten!"

msgctxt "1452"
msgid "Can be put to good use making swords."
msgstr "Se le puede dar un buen uso haciendo espadas."

msgctxt "1490"
msgid "A weird-looking, blue fluorescent bulb. Probably not\n"
"something you'd use for most lights."
msgstr "Una bombilla fluorescente azul de aspecto extraño.\n"
"Probablemente no es algo que usarías para la mayoría\n"
"de las luces."

msgctxt "1580"
msgid "Kind of an odd looking blow-up doll. I'm sure you \n"
"know what it's for..."
msgstr "Una muñeca inflable de aspecto extraño. \n"
"Estoy seguro de que sabes para qué sirve..."

msgctxt "1653"
msgid "Adjusts its tension in response to temperature."
msgstr "Ajusta su tensión en respuesta a la temperatura."

msgctxt "1701"
msgid "The kind of dropper used in science experiments."
msgstr "El tipo de gotero que se usa en los experimentos científicos."

