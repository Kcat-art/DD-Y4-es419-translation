msgctxt "45	99"
msgid "All right, I got it!"
msgstr "Muy bien, ¡lo tengo!"

msgctxt "137	182"
msgid "This is tough..."
msgstr "Esto es difícil..."

msgctxt "190	230"
msgid "You little!"
msgstr "Hijo de!"

msgctxt "255	305"
msgid "You're mine this time!"
msgstr "¡Esta vez eres mío!"

msgctxt "330	395"
msgid "You're doing it! You're doing it!"
msgstr "¡Lo estás haciendo! ¡Lo estás haciendo!"

msgctxt "449	547"
msgid "What the? It's broken or something!"
msgstr "¿Qué? ¡Está roto o algo así!"

msgctxt "549	630"
msgid "The hell's it doing!?"
msgstr "¿¡Qué demonios está haciendo!?"

msgctxt "761	794"
msgid "You did it!"
msgstr "¡Lo hiciste!"

msgctxt "848	890"
msgid "Guess I did! Look at that!"
msgstr "¡Supongo que lo hice! ¡Mira eso!"

