msgctxt "2192"
msgid "Saejima"
msgstr "Saejima"

msgctxt "2196"
msgid "Player"
msgstr "Player"

msgctxt "2200"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "2204"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "100_Saejima"
msgid "Oh, %s. Why don't ya take a load off for a bit?\\r\n"\n"Be glad to run some errands if ya need a hand."
msgstr "Oh, %s. ¿Por qué no descansas un rato? Estaré encantado ayudándote con algún encargo si lo necesitas."

msgctxt "124_Player"
msgid "No, it's okay."
msgstr "No, está bien."

msgctxt "136_Player"
msgid "Sorry, gonna have to take a rain check."
msgstr "Lo siento, pero lo dejaré para después."

msgctxt "148_Player"
msgid "Think I'm good."
msgstr "Creo que estoy bien."

msgctxt "160_Player"
msgid "Appreciate the offer, but I'm gonna have to pass."
msgstr "Aprecio la oferta, pero voy a tener que pasar."

msgctxt "172_Saejima"
msgid "If ya say so."
msgstr "Si tú lo dices."

msgctxt "196_Player"
msgid "That's a good idea. Thanks, Saejima."
msgstr "Es una buena idea. Gracias, Saejima."

msgctxt "208_Player"
msgid "Sure, guess I wouldn't mind taking a little breather."
msgstr "Claro, supongo que no me importaría tomarme un pequeño respiro."

msgctxt "220_Player"
msgid "Yeah, gotta catch my breath."
msgstr "Sí, tengo que recuperar el aliento."

msgctxt "232_Player"
msgid "Thanks, I'll do that."
msgstr "Gracias, lo haré."

msgctxt "244_Saejima"
msgid "Rest good, yeah? I'll handle everythin' from here."
msgstr "Descansa bien, ¿sí? Me encargaré de todo desde aquí."

msgctxt "268_Saejima"
msgid "No, it's okay."
msgstr "No, está bien."

msgctxt "280_Saejima"
msgid "Sure."
msgstr "Claro."

