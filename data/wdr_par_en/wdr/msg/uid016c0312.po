msgctxt "816_Player"
msgid "\"I'm tired, too. Maybe I can pet you, instead?\""
msgstr "\"I'm tired, too. Maybe I can pet you, instead?\""

msgctxt "828_Player"
msgid "\"I'd like to pet Chachamaru sometime, myself.\""
msgstr "\"I'd like to pet Chachamaru sometime, myself.\""

msgctxt "840_Player"
msgid "\"Pets are nice.\""
msgstr "\"Pets are nice.\""

msgctxt "852_Player"
msgid "\"Let's have a sing-off.\""
msgstr "\"Tengamos un duelo de canto.\""

msgctxt "864_Player"
msgid "\"Sticking with something is important.\""
msgstr "\"Perseverar en algo es importante.\""

msgctxt "876_Player"
msgid "\"You should try singing for me at the club.\""
msgstr "\"Deberías intentar cantar para mí en el club.\""

msgctxt "888_Player"
msgid "\"I'm kind of picky about Chinese tea.\""
msgstr "\"Soy un poco exigente con el té chino.\""

msgctxt "900_Player"
msgid "\"I'd like to try your tea sometime.\""
msgstr "\"Me gustaría probar tu té algún día.\""

msgctxt "912_Player"
msgid "\"How you make the tea doesn't matter, does it?\""
msgstr "\"Como prepares el té no es tan importante, ¿no?\""

msgctxt "924_Player"
msgid "\"Nobody can do it well right off the bat.\""
msgstr "\"Nadie puede hacerlo bien a la primera.\""

msgctxt "936_Player"
msgid "\"You just have to keep practicing.\""
msgstr "\"Solo debes continuar practicando.\""

msgctxt "948_Player"
msgid "\"You could try looking at other performances.\""
msgstr "\"Podrías intentar ver otras actuaciones.\""

msgctxt "960_Player"
msgid "\"Keep working hard.\""
msgstr "\"Sigue trabajando duro.\""

msgctxt "972_Player"
msgid "\"I'll come see you again soon.\""
msgstr "\"Volveré a verte pronto.\""

msgctxt "984_Player"
msgid "\"I like you just the way you are.\""
msgstr "\"Me gustas tal y como eres.\""

