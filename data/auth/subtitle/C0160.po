msgctxt "809	869"
msgid "Who's there!?"
msgstr "¿Quién está ahí?"

msgctxt "970	1025"
msgid "Tanimura, Kamuro P.D."
msgstr "Soy Tanimura del D.P de Kamuro."

msgctxt "1046	1162"
msgid "A little bird told me you were\\nlooking for police protection."
msgstr "Vine aquí porque escuché\\nque querías protección."

msgctxt "1213	1298"
msgid "Yeah. So you're the cop."
msgstr "Sí. Así que eres policía."

msgctxt "1606	1707"
msgid "Which would make you\\nMishima from the Ueno Seiwa."
msgstr "Eres Mishima de Ueno Seiwa, ¿verdad?"

