msgctxt "56_Tanimura"
msgid "Now, I want answers. Where is Mei Hua?"
msgstr "Ahora, quiero respuestas. ¿Dónde está Mei Hua?"

msgctxt "68_Degenerate Punk"
msgid "Unh... Some tough-ass dude took her away."
msgstr "Ugh... Un tipo duro se la llevó."

msgctxt "80_Tanimura"
msgid "Be more specific."
msgstr "Sé más específico."

msgctxt "92_Degenerate Punk"
msgid "A middle-aged guy, in a suit. He put the girl in a car and they drove off towards the Hotel District."
msgstr "Un tipo de mediana edad, con traje. Metió a la chica en un coche y se marcharon hacia el Distrito Hotelero."

msgctxt "104_Tanimura"
msgid "Geez... How are we supposed to keep up with a car?"
msgstr "Cielos... ¿Cómo se supone que debemos seguirle la pista a un coche?"

msgctxt "140_Tanimura"
msgid "Zhao-san! Are you all right?"
msgstr "¡Zhao-san! ¿Estás bien?"

msgctxt "152_Zhao"
msgid "*wheeze* The Hotel District, right? *wheeze* <Italic>Right</Italic>!?"
msgstr "* jadeo * El Distrito Hotelero, ¿verdad? * jadeo * ¡¿<Italic>Verdad</Italic>?!"

msgctxt "164_Degenerate Punk"
msgid "Yeah."
msgstr "Sí."

msgctxt "176_Zhao"
msgid "Son of a－ I'm coming, Mei Hua!"
msgstr "Hijo de- ¡Ya voy, Mei Hua!"

msgctxt "188_Tanimura"
msgid "Zhao-san, we need to stay together! Something's not right here!"
msgstr "¡Zhao-san, tenemos que permanecer juntos! ¡Hay algo que no cuadra aquí!"

msgctxt "200_Tanimura"
msgid "(He's like a man possessed... I need to solve this, and quick!)"
msgstr "(Está prácticamente poseído... Necesito resolver esto, ¡y rápido!)"

