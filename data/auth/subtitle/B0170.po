msgctxt "44\t149"
msgid "Sorry for waking you up.\\nYou should rest."
msgstr "Perdón por despertarte.\\nTrata de descansar."

msgctxt "159\t241"
msgid "I'll go let Uncle Kaz know you're awake."
msgstr "Iré a decirle al Tío Kaz que ya despertaste."

msgctxt "247\t307"
msgid "Hold up!"
msgstr "¡Espera!"

msgctxt "564\t655"
msgid "Mister...?"
msgstr "¿Señor...?"

msgctxt "1740\t1787"
msgid "Everything okay, Haruka?"
msgstr "¿Todo bien, Haruka?"

msgctxt "1802\t1861"
msgid "Uncle Kaz! You're back."
msgstr "¡Tío Kaz! Has vuelto."

msgctxt "1862\t1954"
msgid "Yeah. Is he doing any better?"
msgstr "Sí. ¿Ya se siente mejor?"

msgctxt "1962\t2049"
msgid "Mhm. Much better."
msgstr "Sí. Parece que está bien."

msgctxt "2147\t2269"
msgid "Oh, right!\\nI should get over to the supermarket!"
msgstr "¡Oh, cierto!\\n¡Debería ir al supermercado!"

msgctxt "2253\t2319"
msgid "I still need a few things for dinner!"
msgstr "¡Todavía necesito algunas cosas para la cena!"

msgctxt "2306\t2370"
msgid "Hm? Uh, sure."
msgstr "¿Hm? Uh, claro."

msgctxt "2374\t2445"
msgid "Well, be back soon!"
msgstr "Bueno, ¡vuelvo luego!"

