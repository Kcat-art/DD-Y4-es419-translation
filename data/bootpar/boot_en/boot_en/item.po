msgctxt "110396	EXPLANATION"
msgid "Rare gunpowder with great combustion speed and power. Handle with caution."
msgstr "Pólvora rara con gran velocidad de combustión y potencia. Manejar con cuidado."

msgctxt "110471	EXPLANATION"
