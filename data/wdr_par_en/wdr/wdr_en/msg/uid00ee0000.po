msgctxt "136_Employee"
msgid "Hello, sir. May I take your order?"
msgstr "Hola, señor. ¿Qué le gustaría pedir?"

msgctxt "160_Haruka"
msgid "Uncle Kaz! Can I pleeease get a <Color:8>Strawberry Parfait<Color:Default>?"
msgstr "¡Tío Kaz! ¿Puedo pedir un <Color:8>Parfait de Fresa<Color:Default> por favooooor?"

