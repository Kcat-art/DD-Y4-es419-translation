msgctxt "1816"
msgid "Saejima"
msgstr "Saejima"

msgctxt "1820"
msgid "CAUTION!"
msgstr "¡PRECAUCIÓN!"

msgctxt "72_Saejima"
msgid "(Can't let any coppers spot me on my way to the Millennium Tower.)"
msgstr "(No puedo dejar que ningún policía me vea mientras voy a la Torre Millennium)."

msgctxt "84_Saejima"
msgid "(Better stick to the underground and the rooftops. The route Kido-chan told me about's my best bet, long as I keep my eye out for the boys in blue.)"
msgstr "(Mejor me quedo por el subterráneo y los tejados. La ruta de la que me habló Kido-chan es mi mejor opción, siempre que esté atento a los policías)."

msgctxt "96_CAUTION!"
msgid "<Color:7>Go to the Millennium Tower<Color:Default> <Color:7>without being seen by the police.<Color:Default>\\r\n"\n"It's <Color:7>game over<Color:Default> if you're spotted, meaning you'll lose all progress since your last save.\\r\n"\n"\\r\n"\n"Tread carefully!"
msgstr "<Color:7>Ve a la Torre Millennium<Color:Default> <Color:7>sin ser visto por ningún policía.<Color:Default>\\r\n"\n"<Color:7>Perderás<Color:Default> si te ven, lo que significa que perderás cualquier progreso desde tu último guardado.\\r\n"\n"\\r\n"\n"¡Ten cuidado!"

msgctxt "120_Saejima"
msgid "(Been out here a while now. Best hustle on back to the hideout without the coppers spottin' me.)"
msgstr "( Ya llevo aquí un rato. Mejor me apresuro a volver al escondite sin que los polis me descubran)."

msgctxt "132_CAUTION!"
msgid "<Color:7>Return to your hideout<Color:Default> <Color:7>without being seen by the police.<Color:Default>\\r\n"\n"It's <Color:7>game over<Color:Default> if you're spotted, meaning you'll lose all progress since your last save.\\r\n"\n"\\r\n"\n"Tread carefully!"
msgstr "<Color:7>Vuelve al escondite<Color:Default> <Color:7>sin ser visto por ningún policía.<Color:Default>\\r\n"\n"<Color:7>Perderás<Color:Default> si te ven, lo que significa que perderás cualquier progreso desde tu último guardado.\\r\n"\n"\\r\n"\n"¡Ten cuidado!"

