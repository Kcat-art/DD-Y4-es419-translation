msgctxt "708"
msgid "Akiyama"
msgstr "Akiyama"

msgctxt "100_Akiyama"
msgid "(This must be the fake Sky Finance. Wonder if I should head on in...)"
msgstr "(Tengo entendido que aquí está el falso Sky Finance. Bueno, ¿qué tal\n"
"si entramos de una vez?)"

msgctxt "112_Akiyama"
msgid "(Here goes nothing!)"
msgstr "(¡Vamos allá!)"

msgctxt "136_Akiyama"
msgid "(No need to rush things. I'll come back later.)"
msgstr "(No hay necesidad de apresurarse. Volveré más tarde.)"

msgctxt "148_Akiyama"
msgid "Go In"
msgstr "Entrar"

msgctxt "160_Akiyama"
msgid "Not Now"
msgstr "Ahora no"

