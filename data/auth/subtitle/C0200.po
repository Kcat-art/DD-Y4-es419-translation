msgctxt "275	335"
msgid "Now tell me!"
msgstr "¡Ahora dime!"

msgctxt "336	428"
msgid "Tell me who murdered my father!"
msgstr "¿Quién fue el asesino de mi padre?"

msgctxt "477	666"
msgid "Who dumped his body in\\nthe Arakawa 25 years ago!? Huh!?"
msgstr "¡¿Quién arrojó su cuerpo en\\nel río Arakawa hace 25 años?! ¡Dime!"

msgctxt "733	784"
msgid "Say it!"
msgstr "¡Habla!"

msgctxt "789	864"
msgid "Already have."
msgstr "Ya te lo he dicho."

msgctxt "882	942"
msgid "It was me."
msgstr "Fui yo."

msgctxt "1024	1148"
msgid "What's wrong?\\nCan't pull the trigger?"
msgstr "¿Qué pasa?\\n¿No puedes dispararme?"

msgctxt "1247	1307"
msgid "Why...?"
msgstr "¿Por qué...?"

msgctxt "1378	1451"
msgid "Why's it have to be you?"
msgstr "¿Por qué tenías que ser tú?"

msgctxt "1498	1549"
msgid "Tell me!"
msgstr "Por qué..."

msgctxt "1550	1671"
msgid "What would make an honest cop\\nbetray his own partner!?"
msgstr "¡¿Por qué un policía honesto\\ntraicionaría a su propio compañero?!"

msgctxt "1737	1850"
msgid "Sorry, but you got it all wrong."
msgstr "Lo siento, pero te equivocaste."

msgctxt "1866	1926"
msgid "I'm not honest."
msgstr "No soy honesto."

msgctxt "1946	2003"
msgid "Or even a cop."
msgstr "Ni siquiera un policía."

msgctxt "2008	2077"
msgid "Never have been."
msgstr "Nunca lo he sido."

msgctxt "2132	2192"
msgid "From day one..."
msgstr "En realidad yo..."

msgctxt "2209	2269"
msgid "I've been yakuza."
msgstr "Soy un yakuza."

msgctxt "2327	2387"
msgid "That's not possible."
msgstr "¿Qué estás diciendo?"

msgctxt "2409	2470"
msgid "Me and Katsuragi..."
msgstr "Katsuragi y yo..."

msgctxt "2503	2585"
msgid "We're what people in our world call brothers."
msgstr "Somos lo que la gente en ese mundo llama \"kyoudais\"."

msgctxt "2606	2720"
msgid "Bound by oath."
msgstr "Somos hermanos jurados."

msgctxt "2744	2804"
msgid "The hell...?"
msgstr "¿Qué...?"

msgctxt "2823	2973"
msgid "My allegiance... has always been with the Ueno Seiwa."
msgstr "He estado del lado de Ueno Seiwa desde el inicio."

msgctxt "3001	3230"
msgid "I joined the academy to be a spy.\\nGot a badge to keep tabs on the cops."
msgstr "Soy un yakuza que ingresó a la academia\\ny que se volvió en detective para espiar a la policía."

msgctxt "3252	3312"
msgid "That's how it is."
msgstr "Así son las cosas."

msgctxt "3359	3419"
msgid "You're..."
msgstr "Tú eres..."

msgctxt "3454	3513"
msgid "A yakuza?"
msgstr "¿Un yakuza?"

msgctxt "3518	3559"
msgid "That's right."
msgstr "Así es."

msgctxt "3609	3813"
msgid "So then, 25 years ago...\\nafter the attempted Yoshiharu Ueno hit."
msgstr "Entonces, el verdadero culpable\\ndel ataque a Yoshiharu Ueno hace 25 años..."

msgctxt "3841	3954"
msgid "My father found out Katsuragi was behind it all."
msgstr "Katsuragi, fue descubierto por mi padre."

msgctxt "3975	4056"
msgid "And you murdered him in cold blood."
msgstr "¿Y tú lo asesinaste por eso?"

msgctxt "4096	4187"
msgid "Wish it were that simple."
msgstr "Ojalá fuera así de simple."

msgctxt "4298	4381"
msgid "The truth's a whole lot bigger."
msgstr "La verdad es mucho más grande."

