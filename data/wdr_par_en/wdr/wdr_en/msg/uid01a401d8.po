msgid "You got <Color:8>80,000 yen<Color:Default>."
msgstr "Obtuviste <Color:8>80 000 yenes<Color:Default>."

msgctxt "400"
msgid "You got <Color:8>40,000 yen<Color:Default>."
msgstr "Obtuviste <Color:8>40 000 yenes<Color:Default>."

msgctxt "1144"
msgid "You knew going in that it was a scam, and you still strung\\r\n"\n"me along like that? Lousy son of a bitch!"
msgstr "¿Sabías que era una estafa y aun así me hiciste perder el\\r\n"\n"tiempo? ¡Maldito infeliz!"

msgctxt "1156"
msgid "C'mon, everybody. Let's teach this guy a lesson!"
msgstr "¡A por él, chicos! ¡Acabemos con este desgraciado!"

msgctxt "1276"
msgid "You can't just leave like that. Not after hearing me out this far!"
msgstr "No dejaré que te vayas. ¡No después de todo lo que te he contado!"

