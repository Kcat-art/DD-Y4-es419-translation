msgctxt "300"
msgid "Quit"
msgstr "Salir"

msgctxt "305"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "323"
msgid "Order"
msgstr "Pagar"

msgctxt "329"
msgid "Order the currently selected item."
msgstr "Pagar el objeto seleccionado actualmente."

msgctxt "364"
msgid "(I haven't picked anything.)"
msgstr "(No he escogido nada)"

msgctxt "393"
msgid "(I'm short on cash.)"
msgstr "(Me hace falta dinero)"

msgctxt "414"
msgid "Thank you. Your total comes to %s."
msgstr "Gracias. El precio total es de %s."

msgctxt "449"
msgid "(I can't eat anymore...)"
msgstr "(No puedo comer más...)"

msgctxt "493"
msgid "A standard menu item offering the authentic taste of\n"
"Kyushu tonkotsu ramen."
msgstr "Un plato estándar que ofrece el auténtico sabor del \n"
"ramen tonkatsu de Kyushu."

msgctxt "569"
msgid "Our famous tonkotsu ramen topped with tender, \n"
"juicy pork belly that'll melt in your mouth."
msgstr "Nuestro famoso ramen tonkotsu cubierto con suave y \n"
"jugosa panceta de cerdo que se deshace en la boca."

msgctxt "661"
msgid "Tasty tonkotsu ramen topped with succulent, thin \n"
"slices of roast pork."
msgstr "Sabroso ramen tonkotsu cubierto con suculentas y finas\n"
"lonchas de cerdo asado."

msgctxt "733"
msgid "This tonkotsu ramen is topped with spicy roe \n"
"imported straight from Kyushu."
msgstr "Este ramen tonkotsu lleva huevas picantes \n"
"importadas directamente de Kyushu."

msgctxt "810"
msgid "Delicious tonkotsu ramen topped with a soft-boiled\n"
"egg."
msgstr "Delicioso ramen tonkotsu coronado con un huevo \n"
"hervido."

