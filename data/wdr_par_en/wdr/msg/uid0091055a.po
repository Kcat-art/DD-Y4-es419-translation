msgctxt "2220"
msgid "Tanimura"
msgstr "Akiyama"

#. y4:line_status=translated
msgctxt "2224"
msgid "Nair"
msgstr "Nair"

#. y4:line_status=translated
msgctxt "2228"
msgid "Gangster"
msgstr "Gángster"

#. y4:line_status=translated
msgctxt "84_Tanimura"
msgid "[Are you all right?]"
msgstr "[¿Estás bien?]"

#. y4:line_status=translated
msgctxt "96_Nair"
msgid "[I'm fine. We have to hurry!]"
msgstr "[Estoy bien. ¡Hay de darse prisa!]"

#. y4:line_status=translated
msgctxt "108_Tanimura"
msgid "[Right.]"
msgstr "[Sí.]"

#. y4:line_status=translated
msgctxt "156_Tanimura"
msgid "[That elevator should take us to the roof.]"
msgstr "[Aquel ascensor debería llevarnos a la azotea.]"

#. y4:line_status=translated
msgctxt "168_Nair"
msgid "[Right, let's go!]"
msgstr "[Bien, ¡vamos!]"

#. y4:line_status=translated
msgctxt "180_Gangster"
msgid "[This is where it ends, folks.]"
msgstr "[Este es el final del camino, amigos.]"

#. y4:line_status=translated
msgctxt "204_Nair"
msgid "[Agh! Who are these guys!?]"
msgstr "[¡Agh! ¡¿Quiénes son estos tipos?!]"

#. y4:line_status=translated
msgctxt "216_Tanimura"
msgid "[Looks like they were expecting us.]"
msgstr "[Parece que nos estaban esperando.]"

#. y4:line_status=translated
msgctxt "228_Nair"
msgid "[I guess things are gonna get ugly.]"
msgstr "[Supongo que las cosas se van a poner feas.]"

#. y4:line_status=translated
msgctxt "240_Gangster"
msgid "[You got that right. When I'm done, not even your mother will recognize you!]"
msgstr "[Tú lo dijiste. ¡Cuando terminemos con ustedes ni siquiera sus\nmadres los reconocerán!]"

