msgctxt "56_Kiryu"
msgid "Date, you mind if I borrow your stove?"
msgstr "Date, ¿te importa si uso tu cocina?"

msgctxt "68_Date"
msgid "Help yourself. I never had you pegged for the cooking type, Kiryu."
msgstr "Sírvete tú mismo. Nunca pensé que fueras de los que cocinan, Kiryu."

msgctxt "80_Kiryu"
msgid "I don't have much choice. I have to heat up this curry."
msgstr "No tengo muchas opciones. Tengo que calentar este curry."

msgctxt "104_Date"
msgid "Well, have at it."
msgstr "Bueno, adelante."

msgctxt "116_Kiryu"
msgid "Thanks. It'll only take a second."
msgstr "Gracias. Solo tardará un segundo."

msgctxt "140_Kiryu"
msgid "You heated up the \"<Color:255,255,200,255>Large Curry Take-home Packs<Color:Default>.\""
msgstr "Calentaste el \"<Color:255,255,200,255>Pack de Curry Original para Llevar<Color:Default>.\""

msgctxt "188_Kiryu"
msgid "Man, heating up that much curry took longer than I expected. Thanks, Date."
msgstr "Hombre, calentar tanto curry me llevó más tiempo del que esperaba. Gracias, Date."

msgctxt "200_Date"
msgid "Sure, no problem. Take care of yourself."
msgstr "Claro, no hay problema. Cuídate."

msgctxt "212_Kiryu"
msgid "(I better hurry back to the construction site.)"
msgstr "(Será mejor que me apresure a regresar al sitio de construcción.)"

