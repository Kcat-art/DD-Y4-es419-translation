msgctxt "224"
msgid "Quit"
msgstr "Salir"

msgctxt "229"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "247"
msgid "Order"
msgstr "Pagar"

msgctxt "253"
msgid "Order the currently selected item.  "
msgstr "Pedir el objeto actualmente seleccionado.  "

msgctxt "290"
msgid "(I haven't picked anything.)  "
msgstr "(No he escogido nada)"

msgctxt "321"
msgid "(I'm short on cash.)  "
msgstr "(Me hace falta dinero)"

msgctxt "344"
msgid "Thank you for business. %s, please."
msgstr "Gracias por hacer negocios. %s, por favor."

msgctxt "380"
msgid "(I can't carry any more stuff.)"
msgstr "(No puedo llevar más cosas)."

msgctxt "412"
msgid "(They're sold out.)"
msgstr "(Están agotados)."

msgctxt "432"
msgid "Should help you get back on your feet when you're\n"
"low on health and Heat."
msgstr "Esto debería ayudarte a recuperarte cuando tengas\n"
"poca salud y Heat."

msgctxt "506"
msgid "More effective at revitalizing your health and Heat\n"
"than a regular Staminan X."
msgstr "Más efectivo para revitalizar tu salud y Heat que\n"
"el Staminan normal."

msgctxt "585"
msgid "One of the most potent energy drinks on the market.\n"
"It'll dramatically restore your health and Heat."
msgstr "Uno de los energizantes más potentes en el mercado.\n"
"Restaurará dramáticamente tu salud y Heat."

