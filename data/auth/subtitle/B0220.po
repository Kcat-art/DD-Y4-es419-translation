msgctxt "632	720"
msgid "Oh, sorry! I must've dozed off."
msgstr "¡Oh, lo siento! Me quedé dormida."

msgctxt "747	852"
msgid "I was laid out here the whole time?"
msgstr "¿Estuve durmiendo aquí todo este tiempo?"

msgctxt "868	995"
msgid "Yeah. Are you feeling any better, Suzuki-san?"
msgstr "Sí. ¿Te sientes mejor, Suzuki-san?"

msgctxt "1026	1086"
msgid "Suzuki?"
msgstr "¿Suzuki?"

msgctxt "1093	1153"
msgid "Oh, yeah."
msgstr "Ah, sí."

msgctxt "1184	1236"
msgid "Where's Kiryu-han?"
msgstr "¿Dónde está Kiryu-han?"

msgctxt "1237	1376"
msgid "You mean Uncle Kaz?\\nHe's out shopping."
msgstr "¿Te refieres al tío Kaz?\\nEstá de compras."

msgctxt "1369	1496"
msgid "He said we should fix you\\nsomething to help you recover."
msgstr "Pensó que sería buena idea alimentarte bien\\npara ayude con tu recuperación."

msgctxt "1558	1618"
msgid "That so?"
msgstr "Ya veo."

msgctxt "1628	1688"
msgid "Oh yeah."
msgstr "Oh, por cierto."

msgctxt "2059	2120"
msgid "Here we... go!"
msgstr "Ya... casi."

msgctxt "2132	2192"
msgid "Phew, that was heavy."
msgstr "Uf, que pesado."

msgctxt "2206	2266"
msgid "Here's your bag."
msgstr "Aquí está tu bolso."

msgctxt "2297	2363"
msgid "It's yours, right, Suzuki-san?"
msgstr "Esto es tuyo, ¿verdad, Suzuki-san?"

msgctxt "2368	2463"
msgid "Uncle Kaz said to give it to you\\nwhen you woke up."
msgstr "El Tío Kaz dijo que te lo diera\\ncuando despertaras."

msgctxt "2842	2952"
msgid "He told me he found it on the beach."
msgstr "Me dijo que lo encontró en la playa."

msgctxt "2950	3040"
msgid "You're the only one it could belong to."
msgstr "Eres el único al que le podría pertenecer eso."

msgctxt "3736	3819"
msgid "What's wrong, Suzuki-san?\\nAre you okay?"
msgstr "¿Qué pasa, Suzuki-san?\\n¿Estás bien?"

msgctxt "3824	3939"
msgid "Huh? Yeah... I'm good."
msgstr "¿Huh? Sí... Estoy bien."

msgctxt "4074	4134"
msgid "Suzuki-san?"
msgstr "¿Suzuki-san?"

msgctxt "4170	4207"
msgid "Little miss."
msgstr "Señorita."

msgctxt "4209	4306"
msgid "Er, Haruka-chan."
msgstr "No, Haruka-chan."

msgctxt "4323	4417"
msgid "I 'preciate all ya done."
msgstr "Yo realmente aprecio todo lo que han hecho."

msgctxt "4466	4558"
msgid "This here's goodbye for now."
msgstr "Por ahora, esto es un adiós."

msgctxt "4560	4643"
msgid "Ya might not see me for a while."
msgstr "Puede que no me veas por un tiempo."

msgctxt "4685	4768"
msgid "But it's just past three in the morning."
msgstr "¿Justo ahora? Son las tres de la mañana."

msgctxt "4780	4852"
msgid "I don't got the time to wait."
msgstr "No hay tiempo que perder."

msgctxt "5260	5468"
msgid "But you're still hurt really bad, Suzuki-san.\\nAt least stay and rest a bit more."
msgstr "Pero todavía estás herido, Suzuki-san.\\nDeberías tomarlo con más calma..."

msgctxt "5508	5583"
msgid "Can't do that, Haruka-chan."
msgstr "Nos vemos, Haruka-chan."

msgctxt "5604	5659"
msgid "Suzuki-san."
msgstr "Suzuki-san."

msgctxt "5741	5809"
msgid "It ain't Suzuki."
msgstr "No es Suzuki."

msgctxt "5812	5936"
msgid "Name's Saejima.\\nTaiga Saejima."
msgstr "Mi nombre es Saejima.\\nTaiga Saejima."

msgctxt "5982	6075"
msgid "Saejima... san?"
msgstr "¿Saejima... san?"

msgctxt "6078	6252"
msgid "Ya got it. Tell Kiryu-san, too.\\nThat Saejima was here."
msgstr "Cierto. Díselo a Kiryu-san también.\\nQue Saejima estuvo aquí."

msgctxt "6307	6367"
msgid "Okay."
msgstr "Está bien."

msgctxt "6371	6521"
msgid "I won't forget what ya did for me.\\nWe'll meet again someday."
msgstr "Nunca olvidaré la amabilidad que me dieron.\\nNos volveremos a encontrar algún día."

msgctxt "6530	6612"
msgid "Pass that along, too."
msgstr "Dile eso también."

msgctxt "6647	6700"
msgid "I will."
msgstr "Lo haré."

msgctxt "6712	6751"
msgid "Later, then."
msgstr "Hasta luego."

msgctxt "7279	7322"
msgid "Uncle Kaz!"
msgstr "¡Tío Kaz!"

msgctxt "7323	7363"
msgid "Sorry I took so long."
msgstr "He regresado."

msgctxt "7364	7413"
msgid "Uncle Kaz, Suzuki-san..."
msgstr "Tío Kaz, Suzuki-san..."

msgctxt "7414	7497"
msgid "I mean, Saejima-san just left!"
msgstr "Quiero decir, ¡Saejima-san acaba de irse!"

msgctxt "7513	7573"
msgid "Did he, now?"
msgstr "Ya veo."

msgctxt "7581	7654"
msgid "You're not gonna stop him?"
msgstr "¿\"Ya veo\"?"

msgctxt "7665	7755"
msgid "There's no way he's fully recovered."
msgstr "Al parecer sus heridas aún no han sanado por completo."

msgctxt "7756	7840"
msgid "I'm sure he'll be just fine."
msgstr "Estoy seguro de que estará bien."

msgctxt "7863	7975"
msgid "How are you so confident?"
msgstr "¿Estará bien?\\nBueno..."

msgctxt "8006	8096"
msgid "And what about the groceries, Uncle Kaz?"
msgstr "¿Y qué hay de las compras, Tío Kaz?"

msgctxt "8097	8157"
msgid "Oh, yeah."
msgstr "Ah..."

msgctxt "8146	8261"
msgid "Turns out you were right.\\nThe stores were all closed."
msgstr "Resulta que tenías razón.\\nTodas las tiendas estaban cerradas."

msgctxt "8333	8507"
msgid "I can't figure out how\\nyou grownups work sometimes."
msgstr "Bah, a veces no logro entender como ustedes,\\nlos adultos, hacen las cosas."

