msgctxt "1516"
msgid "Greedy Shima"
msgstr "El Avaricioso Shima"

msgctxt "232_Greedy Shima"
msgid "Let's pick the banker."
msgstr "Elijamos al banquero."

msgctxt "244_Greedy Shima"
msgid "I'm the banker."
msgstr "Yo soy el banquero."

msgctxt "256_Greedy Shima"
msgid "How much you gonna wager?"
msgstr "How much you gonna wager?"

msgctxt "268_Greedy Shima"
msgid "All right, here goes."
msgstr "All right, here goes."

msgctxt "280_Greedy Shima"
msgid "My turn."
msgstr "My turn."

msgctxt "292_Greedy Shima"
msgid "(This line signifies failure.)"
msgstr "(This line signifies failure.)"

msgctxt "304_Greedy Shima"
msgid "Time to settle up."
msgstr "Time to settle up."

msgctxt "316_Greedy Shima"
msgid "You're the banker."
msgstr "Tú eres el banquero."

msgctxt "328_Greedy Shima"
msgid "Let's switch bankers."
msgstr "Let's switch bankers."

msgctxt "340_Greedy Shima"
msgid "You wanna play again?"
msgstr "You wanna play again?"

msgctxt "352_Greedy Shima"
msgid "That's it for me. Meh, I'm outta here..."
msgstr "That's it for me. Meh, I'm outta here..."

msgctxt "364_Greedy Shima"
msgid "Ya couldn't bet more if ya wanted to. Come back when you got some more money."
msgstr "Ya couldn't bet more if ya wanted to. Come back when you got some more money."

