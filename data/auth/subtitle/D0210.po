msgctxt "101	157"
msgid "Heyo. Hm?"
msgstr "Buenas."

msgctxt "527	623"
msgid "Nobody home?"
msgstr "¿No hay nadie en casa?"

msgctxt "2043	2115"
msgid "The legal codes, huh?"
msgstr "Los códigos legales, ¿uh?"

msgctxt "2352	2459"
msgid "Akiyama-san's always been the smart one."
msgstr "Después de todo, Akiyama-san es muy inteligente."

msgctxt "2610	2655"
msgid "The heck is this?"
msgstr "¿Qué es esta cosa?"

msgctxt "2789	2870"
msgid "Whoa, what the!?"
msgstr "¡¿Wow, qué?!"

msgctxt "2903	2931"
msgid "Shit!"
msgstr "¡Mierda!"

msgctxt "2934	2982"
msgid "What'd I do!?"
msgstr "¡¿Qué está pasando?!"

msgctxt "4830	4890"
msgid "Holy..."
msgstr "Dinero..."

msgctxt "5431	5461"
msgid "Fuck!"
msgstr "¡Mierda!"

msgctxt "5638	5680"
msgid "C'mon, c'mon!"
msgstr "¡Ah, vamos!"

msgctxt "5834	5885"
msgid "I'm back!"
msgstr "¡He vuelto!"

msgctxt "5900	5947"
msgid "Huh?"
msgstr "Uh, ¿y eso?"

msgctxt "5952	6085"
msgid "How many times do I have to\\ntell him to lock up when he leaves?"
msgstr "Otra vez el presidente\\ndejando la puerta abierta."

msgctxt "6112	6235"
msgid "Kido-san, sorry to keep you waiting!\\nI was just grabbing a few things."
msgstr "Oh, Kido-san.\\nLo siento, salí de compras."

msgctxt "6258	6415"
msgid "Oh, no problem at all.\\nThe door was unlocked, so..."
msgstr "Ah, discúlpame a mí,\\nno quería molestar."

