msgctxt "17	77"
msgid "Not another step!"
msgstr "¡Se acabó!"

msgctxt "455	515"
msgid "What the!?"
msgstr "¡¿Qué pasa...?!"

msgctxt "566	627"
msgid "It's over, Sugiuchi."
msgstr "Se acabó, Sugiuchi."

msgctxt "634	761"
msgid "We know you've been collaborating with\\nKatsuragi from the Ueno Seiwa Clan."
msgstr "Sabemos que has estado colaborando con\\nKatsuragi del Clan Ueno Seiwa."

msgctxt "778	884"
msgid "Don't make this any more\\ndifficult than it already is."
msgstr "No hagas esto más\\ndifícil de lo que ya es."

msgctxt "887	947"
msgid "Dammit...!"
msgstr "¡Mierda...!"

msgctxt "964	1024"
msgid "Sugiuchi-san."
msgstr "Sugiuchi-san."

msgctxt "1055	1157"
msgid "It's time to give it up."
msgstr "Es hora de que te rindas."

msgctxt "1445	1545"
msgid "You morons don't understand a damn thing!"
msgstr "¡Después de todo, ustedes son idiotas\\nque no entienden nada!"

msgctxt "1620	1680"
msgid "Sugiuchi-san."
msgstr "Sugiuchi-san."

msgctxt "1737	1893"
msgid "So you know who I work with.\\nWho cares?"
msgstr "A nadie le importa si conoces con quién trabajo..."

msgctxt "1917	2002"
msgid "I'm untouchable!"
msgstr "Al final no puedes hacer nada."

msgctxt "2086	2146"
msgid "Later."
msgstr "Nos vemos."

msgctxt "2147	2207"
msgid "Don't move!"
msgstr "¡No te muevas!"

msgctxt "2370	2452"
msgid "Or what, your boys'll shoot me?"
msgstr "¡¿Vas a hacer que me disparen, Sudo-san?!"

msgctxt "2553	2628"
msgid "Anyone pulls the trigger and you're through."
msgstr "Si alguno dispara estarás acabado."

msgctxt "2627	2753"
msgid "Japanese police can't shoot.\\nAnd you damn well know it."
msgstr "Sabes muy bien que la policía\\njaponesa no puede disparar."

msgctxt "2757	2817"
msgid "Prove me wrong."
msgstr "¿No es así?"

msgctxt "2904	3011"
msgid "Chief! Why are you hesitating?\\nGive the order!"
msgstr "¡Jefe! ¡¿Qué está haciendo?!\\n¡De la orden!"

msgctxt "3242	3335"
msgid "See what the \"justice\" everyone\\nloves so much chalks up to?"
msgstr "Esta es la \"justicia\" que la policía\\ntrata desesperadamente de proteger..."

msgctxt "3336	3382"
msgid "Absolutely nothing."
msgstr "Absolutamente nada."

msgctxt "3400	3460"
msgid "There's a lesson for you, kid."
msgstr "Ahora lo entiendes, ¿verdad?"

msgctxt "3469	3519"
msgid "Be seeing you."
msgstr "Adiós."

msgctxt "3707	3767"
msgid "I'm not afraid to shoot."
msgstr "No tengo miedo de disparar."

msgctxt "3781	3841"
msgid "Tanimura!"
msgstr "¡Tanimura!"

msgctxt "3849	3940"
msgid "I've never been one for playing by the rules."
msgstr "No me importa lo que diga la ley."

msgctxt "3965	4025"
msgid "Sorry..."
msgstr "La cuestión es que..."

msgctxt "4045	4162"
msgid "But I've got my own brand of justice!"
msgstr "¡Esta es mi manera de impartir \"justicia\"!"

msgctxt "4268	4328"
msgid "Tanimura."
msgstr "Tanimura."

msgctxt "4331	4429"
msgid "I always knew you'd grow into your uniform."
msgstr "¡Siempre supe que serías una promesa!"

msgctxt "4437	4598"
msgid "You're the first one in my 30 years\\nwho's really deserved it. So congrats."
msgstr "¡He sido detective durante 30 años\\ny te puedo asegurar ello!"

msgctxt "4607	4701"
msgid "Wow. I'm honored."
msgstr "Gracias por eso."

msgctxt "4704	4764"
msgid "All right, kid."
msgstr "Muy bien."

msgctxt "4775	4893"
msgid "Let's see how far your justice takes you."
msgstr "Entonces veamos hasta dónde te lleva tu justicia."

msgctxt "4911	4979"
msgid "Hope you're up to the challenge!"
msgstr "¡Es momento de ponerla a prueba!"

msgctxt "5003	5063"
msgid "Stop!"
msgstr "¡Espera!"

