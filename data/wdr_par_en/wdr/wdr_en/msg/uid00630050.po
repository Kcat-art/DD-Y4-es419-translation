msgctxt "4928"
msgid "Maya"
msgstr "Maya"

msgctxt "4932"
msgid "Kiryu"
msgstr "Kiryu"

msgctxt "256_Maya"
msgid "Karaoke, huh? Hehe, can't wait. <Color:7>♥<Color:Default>"
msgstr "¿Karaoke, eh? Je, je, no puedo esperar. <Color:7>♥<Color:Default>"

msgctxt "268_Maya"
msgid "What should I sing? I think I'll go with \"Get to the Top\"! <Color:7>♥<Color:Default>"
msgstr "¿Qué debería cantar? ¡Creo que optaré por \"Get to the Top\"! <Color:7>♥<Color:Default>"

msgctxt "280_Maya"
msgid "Hehe, that was fun! <Color:7>♥<Color:Default> I never knew you could get so lively!"
msgstr "¡Je, je, eso fue divertido! <Color:7>♥<Color:Default> ¡Nunca supe que podías ponerte tan animado!"

msgctxt "292_Maya"
msgid "Now let me hear you sing!"
msgstr "¡Ahora déjame oírte cantar!"

msgctxt "304_Maya"
msgid "Ooh, I have the best idea! Why don't we sing a duet? <Color:7>♥<Color:Default>"
msgstr "¡Oh, tengo una mejor idea! ¿Por qué no hacemos un dueto? <Color:7>♥<Color:Default>"

msgctxt "316_Kiryu"
msgid "Sure, why not."
msgstr "Sure, why not."

msgctxt "328_Maya"
msgid "Great! I can't wait to hear you sing. <Color:7>♥<Color:Default>"
msgstr "¡Estupendo! Estoy deseando oírte cantar. <Color:7>♥<Color:Default>"

msgctxt "340_Kiryu"
msgid "Nah, not right now."
msgstr "No, ahora no."

msgctxt "352_Maya"
msgid "Huh? Seriously? You're no fun..."
msgstr "¿Eh? ¿En serio? No eres divertido..."

msgctxt "364_Maya"
msgid "That was... different."
msgstr "Eso fue... distinto."

msgctxt "376_Kiryu"
msgid "Sorry."
msgstr "Lo siento."

msgctxt "388_Maya"
msgid "That felt great. <Color:7>♥<Color:Default>\\r\n"\n"Has anyone ever told you that you have a great sense of rhythm?"
msgstr "Eso se sintió genial. <Color:7>♥<Color:Default>\\r\n"\n"¿Alguna vez te han dicho que tienes un gran sentido del ritmo?"

msgctxt "400_Maya"
msgid "Now let me hear you sing!"
msgstr "¡Ahora déjame oírte cantar!"

msgctxt "412_Maya"
msgid "Ooh, I have the best idea! Why don't we sing a duet? <Color:7>♥<Color:Default>"
msgstr "¡Oh, tengo una mejor idea! ¿Por qué no hacemos un dueto? <Color:7>♥<Color:Default>"

msgctxt "424_Kiryu"
msgid "Sure, why not."
msgstr "Sure, why not."

msgctxt "436_Maya"
msgid "Great! I can't wait to hear you sing. <Color:7>♥<Color:Default>"
msgstr "¡Estupendo! Estoy deseando oírte cantar. <Color:7>♥<Color:Default>"

msgctxt "448_Kiryu"
msgid "Nah, not right now."
msgstr "No, ahora no."

msgctxt "460_Maya"
msgid "Huh? Seriously? You're no fun..."
msgstr "¿Eh? ¿En serio? No eres divertido..."

msgctxt "472_Maya"
msgid "Did I manage to stay in key?"
msgstr "¿Logré mantenerme en tono?"

msgctxt "484_Kiryu"
msgid "Yeah, you were great."
msgstr "Sí, estuviste genial."

msgctxt "496_Maya"
msgid "Umm... Maybe you should try again later."
msgstr "Bueno... Quizás deberías intentarlo de nuevo más tarde."

msgctxt "508_Kiryu"
msgid "Sorry."
msgstr "Lo siento."

msgctxt "520_Maya"
msgid "We've got great harmony. <Color:7>♥<Color:Default> I think we might be perfect for each other... <Color:7>♥<Color:Default>"
msgstr "Tenemos una gran armonía. <Color:7>♥<Color:Default> Creo que podríamos ser perfectos el uno para el otro... <Color:7>♥<Color:Default>"

msgctxt "532_Kiryu"
msgid "Heh, oh yeah?"
msgstr "Heh, oh yeah?"

msgctxt "544_Maya"
msgid "Sure."
msgstr "Claro."

msgctxt "556_Maya"
msgid "I'd rather not."
msgstr "Preferiría no hacerlo."

msgctxt "568_Maya"
msgid "Sure."
msgstr "Claro."

msgctxt "580_Maya"
