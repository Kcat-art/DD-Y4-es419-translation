msgctxt "82	166"
msgid "Huh. Look at you."
msgstr "Oh... Increíble."

msgctxt "185	303"
msgid "You should have shown this kinda\\nambition back when we first met."
msgstr "Si tan solo hubieras tenido\\nese espíritu cuando nos conocimos..."

msgctxt "304	389"
msgid "We could have avoided this whole mess."
msgstr "Todo esto no hubiera pasado."

msgctxt "408	507"
msgid "What's done is done."
msgstr "No se puede retroceder el tiempo."

msgctxt "520	589"
msgid "No sense in regretting it."
msgstr "No tiene sentido arrepentirse."

msgctxt "673	742"
msgid "Right. No regrets."
msgstr "Cierto. Adelante."

msgctxt "769	889"
msgid "Let's end this, Akiyama!"
msgstr "¡Vamos! ¡Akiyama!"

