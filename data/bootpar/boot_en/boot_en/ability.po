msgctxt "23602	EXPLANATION"
msgid "Use <Action:Button_LS_Up@Adventure><Action:Button_LS_Down@Adventure><Action:Button_LS_Left@Adventure><Action:Button_LS_Right@Adventure> to walk and run."
msgstr "Usa <Action:Button_LS_Up@Adventure><Action:Button_LS_Down@Adventure><Action:Button_LS_Left@Adventure><Action:Button_LS_Right@Adventure> para caminar y correr."

msgctxt "23755	EXPLANATION"
msgid "Lock on to enemies in front of you.\n"
"Effective for concentrated attacks."
msgstr "Bloquea a los enemigos frente a ti.\n"
"Efectivo contra ataques concentrados."

msgctxt "23827	EXPLANATION"
msgid "Grab enemy in front of you to prevent movement.\n"
"Some enemies can immediately escape your grasp."
msgstr "Agarra un enemigo en frente tuyo para evitar su movimiento.\n"
"Algunos enemigos pueden escapar inmediatamente de tu agarre."

msgctxt "23923	EXPLANATION"
msgid "Grab the legs of a downed enemy.\n"
"From here you can spin, throw, or kick them."
msgstr "Agarra las piernas de un enemigo derribado.\n"
"Desde aquí puedes darles vueltas, lanzarlos o patearlos."

msgctxt "24001	EXPLANATION"
msgid "Force a downed enemy onto his feet. Enemies pulled\n"
"up while in agony will stand in a stunned state."
msgstr "Fuerza a un enemigo a ponerse de pie. Enemigos levantados\n"
"que estén agonizando estarán aturdidos cuando se levanten."

msgctxt "24101	EXPLANATION"
msgid "Pick up a weapon with a <Action:Battle_Drop_Weapon@Combat> icon.\n"
"Items can be thrown by pressing <Action:Battle_Drop_Weapon@Combat> again."
msgstr "Coge un arma con el icono de <Action:Battle_Drop_Weapon@Combat>.\n"
"Los objetos se pueden lanzar pulsando <Action:Battle_Drop_Weapon@Combat> de nuevo."

msgctxt "24240	EXPLANATION"
msgid "Guard against attacks from the front. Blunt\n"
"objects can be stopped. Knives and guns cannot."
msgstr "Bloquea los ataques frontales. Los objetos\n"
"pueden ser detenidos. Armas de fuego y cuchillos no."

msgctxt "24332	EXPLANATION"
msgid "Guard against knife attacks from the front.\n"
"Certain weapons can even block bullets."
msgstr "Bloquea ataques de cuchillos frontales.\n"
"Ciertas armas pueden incluso bloquear balas."

msgctxt "24416	EXPLANATION"
msgid "Evade attacks with agile footwork.\n"
"Some grabs cannot be evaded."
msgstr "Evade ataques con pies ágiles.\n"
"Algunos agarres no pueden ser evitados."

msgctxt "24480	EXPLANATION"
msgid "After certain attacks, increase Heat Gauge with\n"
"Recovery Stance. Fight calmly to avoid defeat."
msgstr "Después de ciertos ataques, incrementa el Medidor de Heat con\n"
"la Postura de Recuperación. Lucha tranquilo para evitar la derrota."

msgctxt "24575	EXPLANATION"
msgid "Taunt to avoid lowering Heat Gauge. Enhance\n"
"performance by strengthening certain abilities."
msgstr "Búrlate para evitar que tu Medidor de Heat baje.\n"
"Mejora tu rendimiento fortalecimiento ciertas habilidades."

msgctxt "24667	EXPLANATION"
msgid "Move camera up, down, right, or left. Change the\n"
"controls in Options from the Pause Menu."
msgstr "Mueve la cámara hacia arriba, abajo, derecha o izquierda. Cambia\n"
"los controles en Opciones del Menú Pausa."

msgctxt "24757	EXPLANATION"
msgid "Set the camera behind the character."
msgstr "Coloca la cámara detrás del personaje."

msgctxt "24794	EXPLANATION"
msgid "Take a moment for a leisurely smoke right in\n"
"front of your opponent."
msgstr "Tómate un momento para fumar tranquilamente\n"
"en frente de tu oponente."

msgctxt "24863	EXPLANATION"
msgid "A combo attack."
msgstr "Un combo."

msgctxt "24879	EXPLANATION"
msgid "A powerful finish for a Rush Combo.\n"
"A must-have for dominating unarmed matches."
msgstr "Un poderoso finalizador para tu Combo Rápido.\n"
"Imprescindible para dominar peleas desarmadas."

msgctxt "24959	EXPLANATION"
msgid "Attack enemies to the sides and rear\n"
"without taking a Fighting Stance."
msgstr "Ataca enemigos desde los lados o por detrás\n"
"sin perder la Postura de Combate."

msgctxt "25030	EXPLANATION"
msgid "A high kick. In Fighting Stance, performs a middle\n"
"kick instead. Can also kick away weapons."
msgstr "Una patada alta. En Postura de Combate, haces un\n"
"patada media. También puedes patear armas."

msgctxt "25123	EXPLANATION"
msgid "A kick thrown from a lower stance.\n"
"Knocks down enemies and sends weapons flying."
msgstr "Un patada lanzada desde una posición baja.\n"
"Derriba a los enemigos y manda las armas a volar."

msgctxt "25204	EXPLANATION"
msgid "A backward kick for when an enemy is behind you.\n"
"Kick away pests to deal with stronger enemies."
msgstr "Una patada hacia atrás cuando un enemigo se encuentra detrás tuyo.\n"
"Patea a esa basura para poder lidiar con enemigos más fuertes."

msgctxt "25300	EXPLANATION"
msgid "Grab and attack an enemy. Keep hitting the enemy\n"
"or hurl them into a group of other enemies."
msgstr "Agarra y ataca a un enemigo. Mantente golpeando\n"
"al enemigo o lánzalo contra un grupo de enemigos."

msgctxt "25393	EXPLANATION"
msgid "Attack when you are grabbing or are grabbed.\n"
"Attack direction differs based on your stance."
msgstr "Ataca cuando estás agarrando te están agarrando.\n"
"La dirección del ataque difiere según tu postura."

msgctxt "25485	EXPLANATION"
msgid "Grab and throw an enemy. Hurl them into others\n"
"and thwart incoming attacks."
msgstr "Agarra y lanza a un enemigo. Lánzalos a otros y\n"
"frustra los ataques inminentes."

msgctxt "25561	EXPLANATION"
msgid "Take out a weapon while fighting. Stuns some\n"
"enemies. Change weapons from the Pause Menu."
msgstr "Saca un arma mientras luchas. Aturde algunos\n"
"enemigos. Cambia de armas desde el Menú de Pausa."

msgctxt "25651	EXPLANATION"
msgid "Pick up and throw weapons at enemies.\n"
"The impact differs based on the weapon."
msgstr "Recoge y lanza armas a los enemigos.\n"
"El impacto difiere según el arma."

msgctxt "25729	EXPLANATION"
msgid "Small weapons such as beer bottles.\n"
"Some weapons can knock enemies out."
msgstr "Armas pequeñas como botellas de cerveza.\n"
"Algunas armas pueden noquear enemigos."

msgctxt "25801	EXPLANATION"
msgid "Spray various substances in enemies' faces.\n"
"Not very effective when used to hit enemies."
msgstr "Rocía varias sustancias en la cara de los enemigos.\n"
"No es muy efectivo cuando se usa para golpear."

msgctxt "25890	EXPLANATION"
msgid "All small-bladed weapons.\n"
"Use for swift slashing attacks."
msgstr "Todas las armas de hoja pequeña.\n"
"Úsalas para ataques cortantes rápidos."

msgctxt "25948	EXPLANATION"
msgid "All large-bladed weapons. Kicking with <Action:Battle_Drop_Weapon@Combat>\n"
"will break an enemy's guard."
msgstr "Todas las armas con hoja grande. Patear con <Action:Battle_Drop_Weapon@Combat>\n"
"romperá el bloqueo del enemigo."

msgctxt "26051	EXPLANATION"
msgid "Ancient staff technique learned from Granny White.\n"
"Good for attacking the feet and defending."
msgstr "Técnica de bastón antigua aprendida de La Abuelita.\n"
"Bueno por atacar los pies y defender."

msgctxt "26145	EXPLANATION"
msgid "Iron pipes, bats, and golf clubs. The <Action:Battle_Heavy_Attack@Combat>\n"
"attack changes depending on the weapon's shape."
msgstr "Tubos de hierro, bates y palos de golf. El ataque de <Action:Battle_Heavy_Attack@Combat>\n"
"cambia dependiendo de la forma del arma."

msgctxt "26267	EXPLANATION"
msgid "Light weapons like beer cases that can be used\n"
"to attack. Combo attacks briefly stun enemies."
msgstr "Armas ligeras como cajas de cerveza que pueden\n"
"usarse para atacar. Los combos puede aturdir enemigos."

msgctxt "26361	EXPLANATION"
msgid "Heaviest objects among weapons that can be held\n"
"such as neon signs. Spin and throw at enemies."
msgstr "Objetos más pesados entre las armas que se pueden utilizar\n"
", como los letreros de neón. Gira y lánzalo a los enemigos."

msgctxt "26456	EXPLANATION"
msgid "Weapons too heavy to pick up.\n"
"They can, however, be kicked at enemies."
msgstr "Armas demasiado pesada para recoger.\n"
"Sin embargo, pueden ser pateados a los enemigos."

msgctxt "26527	EXPLANATION"
msgid "Hammer from a construction site. Swing to attack.\n"
"Rumors say portable hammers are out there."
msgstr "Martillo de una obra de construcción. Balancea para atacar.\n"
"Los rumores dicen que hay martillos portátiles por ahí."

msgctxt "26620	EXPLANATION"
msgid "Explosives or smoke-emitting devices. Make sure\n"
"to take from enemies that carry them."
msgstr "Explosivo o dispositivos emisores de humo.\n"
"Asegúrate de quitárselo a los enemigos que lo lleven."

msgctxt "26706	EXPLANATION"
msgid "Weapons such as handguns and shotguns. Bullets\n"
"can be purchased at stores."
msgstr "Armas como pistolas y escopetas. Las balas\n"
"pueden comprarse en tiendas."

msgctxt "26781	EXPLANATION"
msgid "Weapon from Okinawa with the fastest combo\n"
"attacks. Useful against difficult enemies."
msgstr "Arma de Okinawa con el combo más rápido de\n"
"ataques. Útil contra enemigos difíciles."

msgctxt "26867	EXPLANATION"
msgid "A weapon from Okinawan martial arts. Useful for\n"
"taking out enemies with pressing attacks."
msgstr "Un arma de artes marciales de Okinawa. Útil para\n"
"eliminar enemigos con ataques molestos."

msgctxt "26957	EXPLANATION"
msgid "Handheld weapons such as brass knuckles. Use <Action:Battle_Drop_Weapon@Combat>\n"
"to unleash an extremely powerful combo."
msgstr "Armas de mano como los nudillos de latón. Usa <Action:Battle_Drop_Weapon@Combat>\n"
"para desatar un combo extremadamente poderoso."

msgctxt "27077	EXPLANATION"
msgid "A weapon from the Philippines. Allows you to\n"
"block attacks from all directions."
msgstr "Un arma de Filipinas. Te permite bloquear\n"
"ataques desde todas las direcciones."

msgctxt "27157	EXPLANATION"
msgid "Taunt enemies with the spirit of the white tiger\n"
"to boost morale and increase your Heat Gauge."
msgstr "Provoca a tus enemigos con el espíritu del Tigre Blanco\n"
"para fortalecer tu moral e incrementar tu Barra de Heat."

msgctxt "27252	EXPLANATION"
msgid "The phoenix's spirit automatically fills up the\n"
"Heat Gauge if your health gauge is flashing red."
msgstr "El espíritu del Fénix llena automáticamente la\n"
"Barra de Heat si tu salud está parpadeando en rojo."

msgctxt "27349	EXPLANATION"
msgid "Block enemy attacks with the spirit of the black\n"
"tortoise to increase your Heat Gauge."
msgstr "Bloquea los ataques enemigos con el espíritu de\n"
"la Tortuga Negra para aumentar tu Barra de Heat."

msgctxt "27436	EXPLANATION"
msgid "Stay alive while in Heat Mode with the tireless\n"
"strength of the azure dragon."
msgstr "Mantente vivo mientras estás en Modo Heat gracias \n"
"a la incansable fuerza del Dragón Azul."

msgctxt "27514	EXPLANATION"
msgid "First level in the art of balance. Makes it\n"
"difficult to be knocked down when in Heat Mode."
msgstr "Primer nivel en el arte del equilibrio. Te hace\n"
"difícil de derribar cuando estás en Modo Heat."

msgctxt "27606	EXPLANATION"
msgid "Mastery of the art of balance. Become even more\n"
"difficult to knock down when in Heat Mode."
msgstr "Dominio del arte del balance. Es incluso aún más\n"
"difícil derribarte cuando estas en el Modo Heat."

msgctxt "27697	EXPLANATION"
msgid "Guard against knife attacks with bare hands when\n"
"in Heat Mode."
msgstr "Protégete contra ataques de cuchillos simplemente\n"
"con las manos cuando estás en Modo Heat."

msgctxt "27760	EXPLANATION"
msgid "Fully charge your energy with the spirit of the\n"
"golden dragon to fill your Heat Gauge."
msgstr "Carga completamente tu energía con el espíritu\n"
"del Dragón Dorado para llenar tu Barra de Calor."

msgctxt "27847	EXPLANATION"
msgid "Increase agility of Quickstep with the alacrity of\n"
"the Wind God. Cannot use while holding weapons."
msgstr "Incrementa la agilidad del Paso Rápido con la presteza\n"
"del Dios del Viento. No se puede usar llevando armas."

msgctxt "27946	EXPLANATION"
msgid "Thwart enemy attacks while running in Heat Mode\n"
"with the tireless spirit of the Thunder God."
msgstr "Frustrar ataques enemigos mientras corres en Modo Heat\n"
"con el incansable espíritu del Dios del Trueno."

msgctxt "28039	EXPLANATION"
msgid "Depletes Heat Gauge but replenishes some health."
msgstr "Consume tu Medidor de Heat, pero restaura algo de tu salud."

msgctxt "28088	EXPLANATION"
msgid "A leaping kick performed from a run.\n"
"A risky maneuver that requires caution."
msgstr "Una patada alta que se realiza mientras corres.\n"
"Una maniobra arriesgada que requiere precaución."

msgctxt "28165	EXPLANATION"
msgid "Boosts the speed of combo attacks."
msgstr "Aumenta la velocidad de los combos."

msgctxt "28200	EXPLANATION"
msgid "A Lotus Style fist attack that employs both body\n"
"and soul. Strips enemy of spiritual strength."
msgstr "Un ataque de puño del Estilo Loto que usa tu cuerpo\n"
"y alma. Despoja al enemigo de su fuerza espiritual."

msgctxt "28295	EXPLANATION"
msgid "A devastating strike executed after a Finishing Blow."
msgstr "Un ataque devastador ejecutado después de un Golpe Finalizador."

msgctxt "28349	EXPLANATION"
msgid "A counterattack executed after being knocked\n"
"away. Use to get out of tight situations."
msgstr "Un contraataque ejecutado después de haber sido derribado.\n"
"Úsalo para salir de situaciones difíciles."

msgctxt "28436	EXPLANATION"
msgid "A dynamic throw executed after a Finishing Blow.\n"
"Using this move drains your Heat Gauge."
msgstr "Un lanzamiento dinámico ejecutado después de Golpe Finalizador.\n"
"Utilizar este movimiento drena tu Barra de Heat."

msgctxt "28525	EXPLANATION"
msgid "An attack executed while Quickstepping.\n"
"Technique and effects differ based on direction."
msgstr "Un ataque ejecutado mientras se usan los Pasos Rápidos.\n"
"La técnica y los efectos difieren en función de la dirección."

msgctxt "28614	EXPLANATION"
msgid "An ancient throw executed when grabbed by\n"
"enemies. Cannot execute in certain situations."
msgstr "Un antiguo lanzamiento ejecutado cuando los enemigos\n"
"te agarran. No se puede ejecutar en ciertas situaciones."

msgctxt "28703	EXPLANATION"
msgid "One of the Three Ultimate Komaki techniques.\n"
"Send an enemy's attack right back at them."
msgstr "Una de las Tres Técnicas Secretas de Komaki.\n"
"Repele los ataques enemigos."

msgctxt "28791	EXPLANATION"
msgid "One of the Three Ultimate Komaki techniques.\n"
"A counterattack with a tiger's power."
msgstr "Una de las Tres Técnicas Secretas de Komaki.\n"
"Un contraataque poderoso."

msgctxt "28874	EXPLANATION"
msgid "The third and final of Komaki's Ultimate Three, but\n"
"strangely enough, the Tiger Drop is more powerful."
msgstr "La última de las Tres Técnicas Secretas de Komaki. Por\n"
"alguna razón, su poder es inferior a la Lágrima de Tigre."

msgctxt "28977	EXPLANATION"
msgid "Increases the ability to evade attacks by\n"
"Quickstepping."
msgstr "Aumenta la habilidad de evadir ataques\n"
"mientras se utilizan los Pasos Rápidos."

msgctxt "29034	EXPLANATION"
msgid "Swiftly return to your feet after being thrown.\n"
"A Komaki technique for avoiding knockdown."
msgstr "Levántate rápidamente después de ser lanzado.\n"
"Una técnica de Komaki para evitar ser derribado."

msgctxt "29125	EXPLANATION"
msgid "Roll after a Quickstep to evade attacks. Use\n"
"carefully as you lose a chance to counterattack."
msgstr "Gira después de un Paso Rápido para evadir ataques. Úsalo\n"
"con cuidado cuando pierdas la oportunidad de contraatacar."

msgctxt "29219	EXPLANATION"
msgid "Increases the power of all techniques executed\n"
"while grabbing your enemy."
msgstr "Aumenta el poder de todas las técnicas ejecutadas\n"
"mientras se agarra a un enemigo."

msgctxt "29293	EXPLANATION"
msgid "Increases power so that enemies that you throw\n"
"stay down."
msgstr "Aumenta el poder para que los enemigos que lances\n"
"se manténgan en el suelo."

msgctxt "29351	EXPLANATION"
msgid "Stand up faster after being knocked down."
msgstr "Te levantas más rápido después de ser derribado."

msgctxt "29393	EXPLANATION"
msgid "Swiftly regain your guard in tight situations\n"
"after your guard has been broken."
msgstr "Recupera rápidamente tu defensa en situaciones difíciles\n"
"después de que tu defensa se haya roto."

msgctxt "29473	EXPLANATION"
msgid "Escape from an enemy hold faster by enhancing\n"
"your physical strength."
msgstr "Escapa de una presa enemiga más rápido,\n"
"aumentando tu fuerza física."

msgctxt "29543	EXPLANATION"
msgid "Reduces the amount of times you have to tap\n"
"<Action:Battle_Drop_Weapon@Combat> to throw an enemy."
msgstr "Reduce la cantidad de veces que tienes que presionar\n"
"<Action:Battle_Drop_Weapon@Combat> para lanzar a un enemigo."

msgctxt "29641	EXPLANATION"
msgid "A Quickstep executed during a Rush Combo.\n"
"Cannot be performed when in Heat Mode."
msgstr "Un Paso Rápido ejecutado durante un Combo Rápido.\n"
"No se puede realizar cuando estás en Modo Heat."

msgctxt "29722	EXPLANATION"
msgid "A ruthless attack executed on a downed enemy.\n"
"<Color:255,100,100,255>Mastery may unlock a follow-up technique.<Color:Default>"
msgstr "Un ataque despiadado ejecutado contra un enemigo abatido.\n"
"<Color:255,100,100,255>La Maestría puede desbloquear una técnica mejor.<Color:Default>"

msgctxt "29848	EXPLANATION"
msgid "A three-hit combo finish that can be unlocked.\n"
"<Color:255,100,100,255>No further techniques can be unlocked.<Color:Default>"
msgstr "Un combo final de tres golpes que se puede desbloquear.\n"
"<Color:255,100,100,255>No se pueden desbloquear más técnicas.<Color:Default>"

msgctxt "29972	EXPLANATION"
msgid "A big move unleashed with incredible strength!"
msgstr "¡Un gran movimiento desatado con una fuerza increíble!"

msgctxt "30019	EXPLANATION"
msgid "A brutal attack where you slam an enemy down\n"
"upon a downed enemy."
msgstr "Un ataque brutal donde arrojas a un enemigo\n"
"sobre otro enemigo derribado."

msgctxt "30085	EXPLANATION"
msgid "Grab an enemy's legs and swing. Can also be used\n"
"to swing an enemy into other nearby enemies."
msgstr "Agarra de las piernas y gira a un enemigo. También\n"
"se puede usar para atacar a otros enemigos cercanos."

msgctxt "30179	EXPLANATION"
msgid "An intense punching combo that can be executed\n"
"when you are injured."
msgstr "Un intenso combo de golpes que puede ejecutarse\n"
"cuando estás herido."

msgctxt "30248	EXPLANATION"
msgid "Anger enemies by having a smoke. A secret\n"
"technique that takes advantage of their anger."
msgstr "Enoja a tus enemigos fumando. Una técnica\n"
"secreta que toma ventaja de su enojo."

msgctxt "30337	EXPLANATION"
msgid "Take out two enemies by smashing their heads\n"
"together. Effect depends on enemies' sizes."
msgstr "Destroza a dos enemigos aplastando sus cabeza una\n"
"con otra. El efecto dependerá del tamaño de los enemigos."

msgctxt "30426	EXPLANATION"
msgid "A flowing technique used against attacking\n"
"enemies. Only works for weaker enemies."
msgstr "Una técnica fluida utilizada contra enemigos atacando.\n"
"Solo funciona contra enemigos débiles."

msgctxt "30509	EXPLANATION"
msgid "An ancient technique from the samurai era.\n"
"Komaki later changed this to a non-deadly move."
msgstr "Una técnica antigua de la época samurai.\n"
"Komaki la modificó para hacerla un movimiento no mortal."

msgctxt "30600	EXPLANATION"
msgid "A technique used on enemies with guns. Repurposed\n"
"by Komaki for modern times."
msgstr "Una técnica utilizada contra enemigos con armas.\n"
"Reutilizado por Komaki para los tiempos modernos."

msgctxt "30678	EXPLANATION"
msgid "The last of Komaki's secret techniques.\n"
"A finishing blow named for its immense power."
msgstr "La última de las técnicas secretas de Komaki. Un golpe final\n"
"llamado así por la criatura superior a los cuatro dioses."

msgctxt "30764	EXPLANATION"
msgid "An attack with immense power that belies\n"
"its simplicity."
msgstr "Un ataque con inmenso poder que desmiente\n"
"su sencillez."

msgctxt "30821	EXPLANATION"
msgid "Jump over guard rails and other objects."
msgstr "Salta sobre barandillas y otros objetos."

msgctxt "30862	EXPLANATION"
msgid "Show an enemy grabbing you to keep their hands\n"
"to themselves by piledriving them."
msgstr "Muestra a un enemigo agarrándote a que no te toque\n"
"apilando sus manos."

msgctxt "30944	EXPLANATION"
msgid "Wrap around an enemy and bring them to the\n"
"ground in a truly impressive feat of acrobatics."
msgstr "Envuelve a un enemigo y tíralo al suelo en una hazaña\n"
"de acrobacias verdaderamente impresionante."

msgctxt "31036	EXPLANATION"
msgid "A flowing attack from a forward roll."
msgstr "Un ataque que fluye de un lanzamiento hacia adelante."

msgctxt "31074	EXPLANATION"
msgid "Disarm a foe wielding a large weapon, then use\n"
"it to beat them into submission."
msgstr "Desarma a un enemigo usando un arma grande, luego\n"
"úsala para someterlo."

msgctxt "31154	EXPLANATION"
msgid "Surprise an opponent while you're knocked down\n"
"by breaking their shins."
msgstr "Sorprende a un oponente mientras estás derribado\n"
"rompiéndole las piernas."

msgctxt "31226	EXPLANATION"
msgid "A showy technique where you relentlessly wreck\n"
"the face of a rising enemy."
msgstr "Una técnica llamativa en la que destrozas implacablemente \n"
"la cara de un enemigo que se está levantando."

msgctxt "31301	EXPLANATION"
msgid "Use an enemy to wipe out nearby enemies."
msgstr "Usa un enemigo para acabar con los enemigos cercanos."

msgctxt "31342	EXPLANATION"
msgid "Strike down your opponents with frightening\n"
"speed."
msgstr "Derriba a tus oponentes con una velocidad\n"
"aterradora."

msgctxt "31393	EXPLANATION"
msgid "Drunkenly attack an opponent with a deft \n"
"shoulder thrust."
msgstr "Cuando estás ebrio ataca a un oponente \n"
"con un hábil empujón de hombro."

msgctxt "31452	EXPLANATION"
msgid "Boosts the overall power of attacks when not\n"
"holding a weapon."
msgstr "Aumenta el poder general de los ataques cuando no\n"
"se tiene un arma."

msgctxt "31515	EXPLANATION"
msgid "Boosts the overall power of attacks when using a\n"
"weapon."
msgstr "Aumenta el poder general de los ataques cuando\n"
"se utiliza un arma."

msgctxt "31572	EXPLANATION"
msgid "Boosts the overall power of Heat actions."
msgstr "Aumenta el poder general de las Acciones Heat."

msgctxt "31614	EXPLANATION"
msgid "Thwart enemies who try to rush you\n"
"after being taunted."
msgstr "Frustra a los enemigos que intentan abalanzarse\n"
"sobre ti después de que te provocaran."

msgctxt "31670	EXPLANATION"
msgid "A ruthless combo throw performed after forcing a\n"
"downed enemy to their feet."
msgstr "Un combo despiadado realizado después de forzar a\n"
"un enemigo derribado a estar de pie."

msgctxt "31747	EXPLANATION"
msgid "One of Miyamoto Musashi's secret techniques.\n"
"Reminiscent of a cat's nimble two-step leap."
msgstr "Una técnica especial inventada por Miyamoto Musahi.\n"
"Llamada así por el salto ágil de dos patas de un gato."

msgctxt "31837	EXPLANATION"
msgid "One of Miyamoto Musashi's secret techniques. Epitomizes\n"
"the ferocity of his unique double-bladed style."
msgstr "Una técnica especial inventada por Miyamoto Musahi.\n"
"Aterroriza a tus enemigos con la técnica del Niten Ichi."

msgctxt "31941	EXPLANATION"
msgid "One of Miyamoto Musashi's secret techniques. Swat\n"
"down your foes as though they were but flies."
msgstr "Una técnica especial inventada por Miyamoto Musahi.\n"
"Llamado así por la forma en que aplasta las moscas."

msgctxt "32037	EXPLANATION"
msgid "One of Miyamoto Musashi's secret techniques.\n"
"Reminiscent of a wolf's swift and accurate strike."
msgstr "Una técnica especial inventada por Miyamoto Musahi.\n"
"Llamada así en honor a un lobo que mostraba movimientos muy rápidos."

msgctxt "32133	EXPLANATION"
msgid "One of Miyamoto Musashi's secret techniques.\n"
"Reminiscent of a bird capturing its prey."
msgstr "Una técnica especial inventada por Miyamoto Musahi.\n"
"Llamada así por la manera en el que un pájaro atrapa a su presa."

msgctxt "32220	EXPLANATION"
msgid "One of Miyamoto Musashi's secret techniques.\n"
"Reminiscent of a charging bull."
msgstr "Una técnica especial inventada por Miyamoto Musahi.\n"
"Llamada así por recordar a un toro embistiendo."

msgctxt "32297	EXPLANATION"
msgid "An Essence of Terrain. Smash enemies against a wall.\n"
"<Color:255,100,100,255>Mastery may unlock a follow-up technique.<Color:Default>"
msgstr "Una Esencia de Terreno. Aplasta a tus enemigos contra una pared.\n"
"<Color:255,100,100,255>La Maestría puede desbloquear una técnica mejor.<Color:Default>"

msgctxt "32430	EXPLANATION"
msgid "A stronger version of the Wall Crush that can be\n"
"unlocked. <Color:255,100,100,255>No further techniques can be unlocked.<Color:Default>"
msgstr "Una versión más fuerte del Aplastamiente con Pared puede ser\n"
"desbloqueada. <Color:255,100,100,255>No se pueden desbloquear más técnicas.<Color:Default>"

msgctxt "32566	EXPLANATION"
msgid "A ruthless attack executed on a downed enemy.\n"
"<Color:255,100,100,255>Mastery may unlock a follow-up technique.<Color:Default>"
msgstr "Un ataque despiadado ejecutado contra un enemigo abatido.\n"
"<Color:255,100,100,255>La Maestría puede desbloquear una técnica mejor.<Color:Default>"

msgctxt "32692	EXPLANATION"
msgid "A three-hit combo finish that can be unlocked.\n"
"<Color:255,100,100,255>No further techniques can be unlocked.<Color:Default>"
msgstr "Un combo final de tres golpes que se puede desbloquear.\n"
"<Color:255,100,100,255>No se pueden desbloquear más técnicas.<Color:Default>"

msgctxt "32816	EXPLANATION"
msgid "A showy move that utilizes the surrounding\n"
"terrain."
msgstr "Un movimiento llamativo que utiliza el terreno\n"
