msgctxt "460	EXPLANATION"
msgid "You became a regular customer at the Poppo on Tenkaichi St. and are\n"
"now allies with the manager."
msgstr "Te convertiste en un cliente habitual del Poppo de la calle Tenkaichi y\n"
"ahora te has aliado con el gerente."

msgctxt "557	EXPLANATION"
msgid "You became a regular customer at M Store and are now allies with\n"
"the manager."
msgstr "Te convertiste en un cliente habitual de la M Store y ahora te has\n"
"aliado con el gerente."

msgctxt "635	EXPLANATION"
msgid "You gave alcohol to the homeless man in front of West Park and are\n"
"now allies with him."
msgstr "Le diste alcohol al vagabundo que estaba frente al parque oeste y\n"
"ahora te has aliado con él."

msgctxt "723	EXPLANATION"
msgid "You became a regular customer at Cuez Bar and are now allies with\n"
"the bartender."
msgstr "Te convertiste en un cliente habitual del Bar Cuez y ahora te has\n"
"aliado con el barman."

msgctxt "804	EXPLANATION"
msgid "You used the taxi frequently and are now allies with a driver\n"
"at the north end of the Hotel District."
msgstr "Usaste el taxi con frecuencia y ahora eres aliado de un\n"
"conductor que está en el norte del distrito hotelero."

msgctxt "906	EXPLANATION"
msgid "You became a regular customer at Asia and are now allies with the\n"
"employee there."
msgstr "Te convertiste en un cliente habitual del Club Asia y ahora eres\n"
"aliado de los empleados del lugar."

msgctxt "988	EXPLANATION"
msgid "You became a regular customer at Earth Angel and are now allies\n"
"with the mama."
msgstr "Te convertiste en un cliente habitual del Ángel Terrenal y ahora\n"
"eres aliado de la mama."

msgctxt "1067	EXPLANATION"
msgid "You played Boxcelios 2 frequently and are now allies with a\n"
"Club SEGA employee."
msgstr "Jugaste Boxcelios 2 con frecuencia y ahora eres aliado\n"
"de un empleado del Club SEGA."

msgctxt "1147	EXPLANATION"
msgid "You became a regular customer at Kotobuki Drugs and are now allies\n"
"with the employee there."
msgstr "Te convertiste en un cliente habitual de Farmacias Kotobuki y\n"
"ahora te has aliado con los empleados del lugar."

msgctxt "1239	EXPLANATION"
msgid "You became a regular customer at Café Alps and are now allies\n"
"with an employee there."
msgstr "Te convertiste en cliente habitual del Café Alps y ahora te has\n"
"aliado con el empleado del lugar."

msgctxt "1326	EXPLANATION"
msgid "You gave a drink to the homeless man in Theater Square and are now\n"
"allies with him."
msgstr "Le diste una bebida al vagabundo que estaba en la Plaza del Teatro\n"
"y ahora te has aliado con él."

msgctxt "1410	EXPLANATION"
msgid "You became a regular customer at Kyushu No. 1 Star and are now\n"
"allies with the owner."
msgstr "Te convertiste en un cliente habitual de Kyushu Estrella N° 1 y\n"
"ahora te has aliado con el dueño."

