msgctxt "992_Mack"
msgid "Hear Explanation of Revelations"
msgstr "Escuchar la explicación de las revelaciones"

msgctxt "1004_Mack"
msgid "Quit Revelation Practice"
msgstr "Salir de la práctica de revelaciones"

msgctxt "1016_Mack"
msgid "Nothing"
msgstr "Nada"

