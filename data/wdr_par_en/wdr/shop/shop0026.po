msgctxt "252"
msgid "Quit"
msgstr "Salir"

msgctxt "257"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "275"
msgid "Order"
msgstr "Pagar"

msgctxt "281"
msgid "Order the currently selected item.  "
msgstr "Pedir el objeto actualmente seleccionado.  "

msgctxt "318"
msgid "(I haven't picked anything.)  "
msgstr "(No he escogido nada)"

msgctxt "349"
msgid "(I'm short on cash.)  "
msgstr "(Me hace falta dinero)"

msgctxt "372"
msgid "Thanks... %s, please."
msgstr "Son %s por favor."

msgctxt "394"
msgid "(I can't carry any more stuff.)"
msgstr "(No puedo llevar más cosas)."

msgctxt "426"
msgid "(They're sold out.)"
msgstr "(Están agotados)."

msgctxt "446"
msgid "Standard issue for Special Weapons and Tactics units.\n"
"It holds up well against bullets."
msgstr "Edición estándar para unidades de armas y tácticas\n"
"especiales. Resiste bien contra las balas."

msgctxt "534"
msgid "This light-weight breastplate protects against bullets \n"
"and can be worn under a suit."
msgstr "Esta coraza ligera protege contra las balas \n"
"y puede usarse debajo de un traje."

msgctxt "620"
msgid "Will really help psych you up before a fight."
msgstr "Realmente te ayudará a mentalizarte antes\n"
"de una pelea."

msgctxt "666"
msgid "Only for those who truly understand the dangers of \n"
"the business."
msgstr "Solo para aquellos que realmente entienden los \n"
"peligros del negocio."

