msgctxt "252"
msgid "Quit"
msgstr "Salir"

msgctxt "257"
msgid "Cancel the order."
msgstr "Cancelar el pedido."

msgctxt "275"
msgid "Order"
msgstr "Pagar"

msgctxt "281"
msgid "Order the currently selected item.  "
msgstr "Pedir el objeto actualmente seleccionado.  "

msgctxt "318"
msgid "(I haven't picked anything.)  "
msgstr "(No he escogido nada)"

msgctxt "349"
msgid "(I'm short on cash.)  "
msgstr "(Me hace falta dinero)"

msgctxt "372"
msgid "Thank you. That'll be %s."
msgstr "Gracias. Eso sería %s."

msgctxt "398"
msgid "(I can't carry any more stuff.)"
msgstr "(No puedo llevar más cosas)."

msgctxt "430"
msgid "(They're sold out.)"
msgstr "(Están agotados)."

msgctxt "450"
msgid "Our standard massage option. Simple, but relaxing."
msgstr "Nuestra opción de masaje estándar. Simple, pero relajante."

msgctxt "501"
msgid "A more lavish massage option. You'll feel all your\n"
"worries bursting out of you."
msgstr "Una opción de masaje más lujosa. Sentirás que todas tus preocupaciones salen de tu cuerpo."

msgctxt "581"
msgid "Reserved for regular customers, this VIP massage\n"
"option is sure to impress."
msgstr "Reservado para clientes habituales, esta opción de masaje VIP seguro que le impresionará."

msgctxt "657"
msgid "The ultimate massage experience, only available to\n"
"the most select few."
msgstr "La experiencia de masaje definitiva, sólo al alcance\n"
"los más selectos."

