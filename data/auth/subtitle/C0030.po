msgctxt "102	162"
msgid "啊 阿正\\n[Oh, Ma-chan!]"
msgstr "啊 阿正\\n[Oh, ¡Ma-chan!]"

msgctxt "167	229"
msgid "嗨 趙在裡頭嗎？\\n[Hey. Zhao hiding back there?]"
msgstr "嗨 趙在裡頭嗎？\\n[Hey. ¿Zhao está atrás?]"

msgctxt "241	301"
msgid "是啊\\n[Yup.]"
msgstr "是啊\\n[Sí.]"

msgctxt "343	458"
msgid "朴被強制遣返！？孩子怎麼辦？\\n[Park got deported? What about his kid?]"
msgstr "朴被強制遣返！？孩子怎麼辦？\\n[¡¿Park fue deportado?! ¿Qué pasará con su hijo?]"

msgctxt "596	656"
msgid "是嗎？\\n[Got it.]"
msgstr "是嗎？\\n[¿Seguro?]"

msgctxt "720	808"
msgid "嗯 明白了 我來照顧孩子 \\n[Yeah, that's fine. I'll take her here.]"
msgstr "嗯 明白了 我來照顧孩子 \\n[Sí, está bien. Yo me ocuparé del niño.]"

msgctxt "888	948"
msgid "嗯 別擔心\\n[Sure, don't worry.]"
msgstr "嗯 別擔心\\n[Claro, no te preocupes.]"

msgctxt "1077	1142"
msgid "Another joining the ranks?"
msgstr "¿Vendrá una persona más?"

msgctxt "1154	1270"
msgid "Yeah. Her dad just got sent back to Korea."
msgstr "Sí. Su padre acaba de ser enviado de regreso a Corea."

msgctxt "1281	1323"
msgid "What happened?"
msgstr "¿Por qué?"

msgctxt "1332	1459"
msgid "Traffic accident.\\nHappened a few days ago."
msgstr "Hace unos días tuvo\\nun accidente de tráfico."

msgctxt "1486	1624"
msgid "The cops picked him up and\\nnoticed he'd overstayed his visa."
msgstr "Los policías lo detuvieron y\\nnotaron que su visa estaba vencida."

msgctxt "1625	1706"
msgid "Tough break."
msgstr "Que mala suerte."

msgctxt "1721	1867"
msgid "The kid's only five, too.\\nNo place for her to go but here."
msgstr "El niño solo tiene cinco años.\\nSupongo que tendré que encargarme de él por ahora."

msgctxt "1949	2041"
msgid "This should cover some of the expenses."
msgstr "Esto debería cubrir algunos de los gastos."

msgctxt "2095	2246"
msgid "Prize winnings?\\nOr let me guess, another shakedown?"
msgstr "¿Ganancia de juegos?\\nO déjame adivinar, ¿otra extorsión?"

msgctxt "2305	2375"
msgid "Honest? A bit of both."
msgstr "¿Sinceramente? Un poco de ambos."

msgctxt "2448	2548"
msgid "I really can't believe you sometimes."
msgstr "Realmente no puedo creerte a veces..."

msgctxt "2557	2648"
msgid "Still, I should be thanking you, too."
msgstr "Aún así, estoy agradecido por ello."

msgctxt "2657	2713"
msgid "Just don't do anything stupid."
msgstr "Solo no te excedas."

