msgctxt "68_Tanimura"
msgid "(Hm, it's from Homeland.)"
msgstr "(Hm, me llaman de casa)."

msgctxt "104_Tanimura"
msgid "Hello?"
msgstr "Oi."

msgctxt "116_Mei Hua"
msgid "Ma-chan!"
msgstr "¡Ma-chan!"

msgctxt "128_Tanimura"
msgid "Mei Hua? What's up?"
msgstr "¿Mei Hua? ¿Qué pasa?"

msgctxt "140_Mei Hua"
msgid "We need you back at Homeland! Hurry!"
msgstr "¡Te necesitamos de vuelta en casa! ¡Apúrate!"

msgctxt "152_Tanimura"
msgid "Whoa. Calm down and tell me what happened."
msgstr "Ey. Tranquilízate y cuéntame qué pasó."

msgctxt "164_Mei Hua"
msgid "Just hurry back here now! Something awful has happened!"
msgstr "¡Solo date prisa en volver aquí ahora! ¡Algo horrible ha sucedido!"

msgctxt "176_Tanimura"
msgid "Okay, okay! I'll be right there!"
msgstr "¡Está bien! ¡Allí estaré!"

msgctxt "236_Tanimura"
msgid "(She seemed really rattled... I should head over to Homeland.)"
msgstr "(Parecía realmente nerviosa... Debería volver con ella)."

