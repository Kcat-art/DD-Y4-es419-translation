msgctxt "224"
msgid "You gained 3,000 EXP."
msgstr "Obtuviste 3,000 de experiencia."

msgctxt "2676"
msgid "Tadokoro's Subordinate"
msgstr "Subordinado de Tadokoro"

msgctxt "2680"
msgid "Talk_Ojigi"
msgstr "Talk_Ojigi"

msgctxt "2684"
msgid "Saejima"
msgstr "Saejima"

msgctxt "2688"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "2692"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "56_Tadokoro's Subordinate"
msgid "How did it go, Suzuki-san?"
msgstr "¿Cómo te fue, Suzuki-san?"

msgctxt "68_Saejima"
msgid "Motoyama skipped town. He ain't comin' back."
msgstr "Motoyama se fue de la ciudad. No va a volver."

msgctxt "80_Tadokoro's Subordinate"
msgid "Yes, one of our agents confirmed it. I knew we could count on you."
msgstr "Sí, uno de nuestros agentes lo ha confirmado. Sabía que podíamos contar contigo."

msgctxt "92_Saejima"
msgid "Don't forget my pay."
msgstr "No olviden mi paga."

msgctxt "104_Tadokoro's Subordinate"
msgid "I wouldn't dream of it. Shall I apply it to the repayment of Tadashi-kun's debts?"
msgstr "Jamás lo haría. ¿Debería aplicarlo al pago de las deudas de Tadashi-kun?"

msgctxt "116_Saejima"
msgid "Yep."
msgstr "Sí."

msgctxt "140_Tadokoro's Subordinate"
msgid "Oh, and just out of curiosity, Suzuki-san..."
msgstr "Oh, y solo por curiosidad, Suzuki-san..."

msgctxt "152_Tadokoro's Subordinate"
msgid "Did you happen to have some history with this Motoyama?"
msgstr "¿Tenías algún pasado con ese tal Motoyama?"

msgctxt "164_Saejima"
msgid "......"
msgstr "......"

msgctxt "176_Tadokoro's Subordinate"
msgid "Ooh, if looks could kill... All right, if you don't want to answer, so be it. Goodbye, now."
msgstr "Ooh, si las miradas pudieran matar... Está bien, si no quieres responder, que así sea. Adiós."

