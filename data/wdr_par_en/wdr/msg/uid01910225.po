msgid "Chase Battles (Fleeing)"
msgstr ""

msgctxt "56_Chase Battles (Fleeing)"
msgid "When you find yourself fleeing during a chase battle, try to accomplish your goal before your Chase Gauge is fully depleted.\\r\n"
"\\r\n"
"Your current objective is <Color:7>to reach Sky Finance<Color:Default>."
msgstr ""

msgctxt "68_Chase Battles (Fleeing)"
msgid "Use <Action:Button_LS_Up@Chase><Action:Button_LS_Down@Chase><Action:Button_LS_Left@Chase><Action:Button_LS_Right@Chase> to run during chase events.\\r\n"
"\\r\n"
"Make it all the way to Sky Finance without getting caught by the police."
msgstr ""

msgctxt "80_Chase Battles (Fleeing)"
msgid "This information has been added as a <Color:14>memo<Color:Default>.\\r\n"
"Read <Color:14>memos<Color:Default> by selecting <Color:14>Memos<Color:Default> in the Pause Menu.\\r\n"
"You can access the Pause Menu with the <Action:Button_Options@Adventure> button."
msgstr ""

