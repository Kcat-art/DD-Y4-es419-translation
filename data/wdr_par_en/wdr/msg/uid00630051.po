msgctxt "4976"
msgid "望月京子：源氏名"
msgstr "望月京子：源氏名"

msgctxt "4980"
msgid "Kiryu"
msgstr "Kiryu"

msgctxt "256_望月京子：源氏名"
msgid "Hahaha! I love karaoke! It's great to sing songs by other people once in a while!"
msgstr "¡Ja, ja, ja! ¡Me encanta el karaoke! ¡Es genial cantar con otras personas de vez en cuando!"

msgctxt "268_望月京子：源氏名"
msgid "What should I sing for you today? How about \"Saturday Night☆Lover\" or \"Where Has Your Touch Gone?\""
msgstr "¿Qué debería cantar para ti hoy? ¿Qué tal \"Saturday Night☆Lover\" o \"Where Has Your Touch Gone?\""

msgctxt "280_望月京子：源氏名"
msgid "Haha! <Color:7>♥<Color:Default> That was intense! I bet it's because you were cheering me on. <Color:7>♥<Color:Default>"
msgstr "¡Ja, ja! <Color:7>♥<Color:Default> ¡Eso fue intenso! Apuesto a que fue porque me estabas animando. <Color:7>♥<Color:Default>"

msgctxt "292_望月京子：源氏名"
msgid "Oh, I almost forgot. Why don't you sing something, too? <Color:7>♥<Color:Default>"
msgstr "Oh, casi lo olvido. ¿Por qué no cantas algo tú también? <Color:7>♥<Color:Default>"

msgctxt "304_Kiryu"
msgid "Sure, why not."
msgstr "Sure, why not."

msgctxt "316_望月京子：源氏名"
msgid "You have a sexy voice, so I bet your singing voice is just as hot! I can't wait to hear it!"
msgstr "Tienes una voz sexy, ¡así que apuesto a que tu voz al cantar es igual de atractiva! ¡No puedo esperar a escucharla!"

msgctxt "328_Kiryu"
msgid "No, I'm good."
msgstr "No, estoy bien."

msgctxt "340_望月京子：源氏名"
msgid "Huh. That's too bad."
msgstr "Eh, Qué lástima."

msgctxt "352_望月京子：源氏名"
msgid "Huh. That's weird... I'm not sounding like myself. Sorry, I'm not usually like this."
msgstr "Vaya, esto es raro... No estoy sonando como de costumbre. Lo siento, no suelo ser así."

msgctxt "364_Kiryu"
msgid "Sorry."
msgstr "Lo siento."

msgctxt "376_望月京子：源氏名"
msgid "Whew... That felt crazy good. <Color:7>♥<Color:Default> I bet it's because you were cheering me on."
msgstr "Uff... Eso se sintió increíble. <Color:7>♥<Color:Default> Apostaría a que es porque me estabas animando."

msgctxt "388_望月京子：源氏名"
msgid "Oh, I almost forgot. Why don't you sing something, too? <Color:7>♥<Color:Default>"
msgstr "Oh, casi lo olvido. ¿Por qué no cantas algo tú también? <Color:7>♥<Color:Default>"

msgctxt "400_Kiryu"
msgid "Sure, why not."
msgstr "Sure, why not."

msgctxt "412_望月京子：源氏名"
msgid "You have a sexy voice, so I bet your singing voice is just as hot! I can't wait to hear it!"
msgstr "Tienes una voz sexy, ¡así que apuesto a que tu voz al cantar es igual de atractiva! ¡No puedo esperar a escucharla!"

msgctxt "424_Kiryu"
msgid "No, I'm good."
msgstr "No, estoy bien."

msgctxt "436_望月京子：源氏名"
msgid "Huh. That's too bad."
msgstr "Eh, Qué lástima."

msgctxt "448_望月京子：源氏名"
msgid "You're really good at karaoke! I think you might have some star potential. <Color:7>♥<Color:Default>"
msgstr "¡Eres muy bueno en el karaoke! Creo que podrías tener potencial de estrella. <Color:7>♥<Color:Default>"

msgctxt "460_Kiryu"
msgid "Heh, oh yeah?"
msgstr "Heh, oh yeah?"

msgctxt "472_望月京子：源氏名"
msgid "Oh, are you done? It sounded like you were having some trouble..."
msgstr "Oh, ¿ya terminaste? Sonaba como si tuvieras un poco de dificultad..."

msgctxt "484_Kiryu"
msgid "Uh, it's because my throat's been acting up..."
msgstr "Uh, es porque mi garganta ha estado molestando..."

msgctxt "496_望月京子：源氏名"
msgid "You never told me you were such a good singer!\\r\n"\n"Wanna try to make it to the big time together!?"
msgstr "¡Nunca me dijiste que eras tan buen cantante!\\r\n"\n"¿¡Quieres que intentemos llegar a lo más alto juntos!?"

msgctxt "508_Kiryu"
msgid "Heh... That's really flattering."
msgstr "Je... Eso es realmente halagador."

msgctxt "520_望月京子：源氏名"
msgid "Sure."
msgstr "Claro."

msgctxt "532_望月京子：源氏名"
msgid "Not me."
msgstr "Yo no."

msgctxt "544_望月京子：源氏名"
msgid "Sure."
msgstr "Claro."

msgctxt "556_望月京子：源氏名"
msgid "Not me."
msgstr "Yo no."

