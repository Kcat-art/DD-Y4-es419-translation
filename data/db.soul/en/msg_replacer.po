msgctxt "185	520201	1	CHK"
msgid "You're lookin' fine as ever, babe!"
msgstr "¡Te ves tan bien como siempre, nena!"

msgctxt "185	520236	2	CHK"
msgid "Really? It's all for you, darling."
msgstr "¿En serio? Es todo para ti, cariño."

msgctxt "185	520271	3	CHK"
msgid "Oh, you!"
msgstr "¡Ah, tú!"

msgctxt "185	520280	4	CHK"
msgid "Hold it!"
msgstr "¡Un momento!"

msgctxt "185	520289	5	CHK"
msgid "I turn my back for one second,\n"
"and this happens!?"
msgstr "¡¿Me doy la vuelta un segundo,\n"
"y pasa esto?!"

msgctxt "185	520339	6	CHK"
msgid "You no-good son-of-a-bitch!"
msgstr "¡Tú, maldito hijo de puta!"

msgctxt "185	520367	7	CHK"
msgid "Well, \"darling\"...\n"
"Get ready to die!"
msgstr "Bueno, \"cariño\"\n"
"¡Prepárate para morir!"

msgctxt "186	520969	1	CHK"
msgid "Stop!\n"
"Give those back!"
msgstr "¡Espera!\n"
"¡Devuélvemelas!"

msgctxt "186	520992	2	CHK"
msgid "Thief!"
msgstr "¡Ladrón!"

msgctxt "187	521593	1	CHK"
msgid "Yes. I understand."
msgstr "Sí, entendido."

msgctxt "187	521612	2	CHK"
msgid "Now then..."
msgstr "Y ahora..."

msgctxt "187	521624	3	CHK"
msgid "On second thought...\n"
"I gotta postpone."
msgstr "Pensándolo bien...\n"
"Tengo que posponer el encargo."

msgctxt "187	521663	4	CHK"
msgid "Wire it to my usual account."
msgstr "Cárguelo a mi cuenta habitual."

msgctxt "187	521692	5	CHK"
msgid "I'll be done in a flash."
msgstr "Habré acabado en un pestañeo."

msgctxt "188	522489	1	CHK"
msgid "End of the line!"
msgstr "¡No tienes escapatoria!"

msgctxt "188	522506	2	CHK"
msgid "Bullshit it is!\n"
"You want the kid to get it!?"
msgstr "¡Y una mierda!\n"
"¡¿Acaso quieres que acabe con él?!"

msgctxt "188	522551	3	CHK"
msgid "Answer me."
msgstr "Respóndeme."

msgctxt "188	522562	4	CHK"
msgid "Which wire should I cut?\n"
"The blue one or the red one!?"
msgstr "La bomba, ¿qué cable debo cortar? ¡¿El azul o el rojo?!"

msgctxt "188	522617	5	CHK"
msgid "Just drop the piece, lady!"
msgstr "¡Suelte la pistola, señorita!"

msgctxt "188	522644	6	CHK"
msgid "You want a dead kid on your hands?"
msgstr "¿Acaso quieres un niño muerto sobre tu conciencia?"

msgctxt "188	522679	7	CHK"
msgid "Take this!"
msgstr "Toma esto!"

msgctxt "188	522690	8	CHK"
msgid "You... pervert!"
msgstr "¡Serás pervertido!"

msgctxt "189	523865	1	CHK"
msgid "Nooo!"
msgstr "¡Nooo!"

msgctxt "189	523871	2	CHK"
msgid "I don't wanna die!"
msgstr "¡No quiero morir!"

msgctxt "189	523890	3	CHK"
msgid "It's your own damn fault."
msgstr "Todo esto es culpa tuya."

msgctxt "189	523916	4	CHK"
msgid "You did this to yourself, pal."
msgstr "Tú te hiciste eso, amigo."

msgctxt "189	523947	5	CHK"
msgid "Help!"
msgstr "¡Ayuda!"

msgctxt "189	523953	6	CHK"
msgid "Please, somebody help!"
msgstr "¡Por favor, que alguien me ayude!"

msgctxt "189	523976	7	CHK"
msgid "One, two...!"
msgstr "¡Uno, dos...!"

msgctxt "189	523989	8	CHK"
msgid "Shit, this thing weighs a fuckin' ton!"
msgstr "Mierda, ¡esto pesa una jodida tonelada!"

msgctxt "189	524028	9	CHK"
msgid "Keep lifting!"
msgstr "¡Sigue levantándolo!"

msgctxt "189	524042	10	CHK"
msgid "No, please!"
msgstr "¡No, por favor!"

msgctxt "189	524054	11	CHK"
msgid "C'mon, lift your side!"
msgstr "¡Vamos, ponle ganas!"

msgctxt "189	524077	12	CHK"
msgid "You hear me?\n"
"You're not even lifting!"
msgstr "¿Me estás oyendo?\n"
"¡Parece que ni lo estás intentando!"

msgctxt "189	524115	13	CHK"
msgid "I'm trying!\n"
"I'm trying, man!"
msgstr "¡Que sí!\n"
"¡Que lo estoy intentando, tío!"

msgctxt "189	524144	14	CHK"
msgid "Wait, hold it!\n"
"Quit moving!"
msgstr "Espera, ¡aguanta!\n"
"¡Deja de moverte!"

msgctxt "189	524172	15	CHK"
msgid "Stay still, you idiot!\n"
"Stay still!"
msgstr "¡Quieto, idiota!\n"
"¡Quédate quieto!"

msgctxt "189	524207	16	CHK"
msgid "I'm alive!"
msgstr "¡Estoy vivo!"

msgctxt "189	524218	17	CHK"
msgid "I'm gonna die!"
msgstr "¡Voy a morir!"

msgctxt "189	524233	18	CHK"
msgid "Noooooo!"
msgstr "¡Nooooo!"

msgctxt "190	525337	1	CHK"
msgid "Ugh, no luck..."
msgstr "Uf, no hubo suerte..."

msgctxt "190	525353	2	CHK"
msgid "Oh, I got one!"
msgstr "¡Oh, tengo uno!"

msgctxt "190	525368	3	CHK"
msgid "Wait, come back!"
msgstr "¡Espera, vuelve!"

msgctxt "190	525385	4	CHK"
msgid "You're mine!"
msgstr "¡Prepárate!"

msgctxt "190	525398	5	CHK"
msgid "Five hundred!?"
msgstr "¿¡Quinientos!?"

msgctxt "190	525413	6	CHK"
msgid "Thank you very much, sir!"
msgstr "¡Muchas gracias, señor!"

msgctxt "190	525439	7	CHK"
msgid "Please take this."
msgstr "Por favor, tome esto."

msgctxt "190	525457	8	CHK"
msgid "You can..."
msgstr "Puedes..."

msgctxt "190	525468	9	CHK"
msgid "Keep it."
msgstr "Guárdalo."

msgctxt "191	526473	1	CHK"
msgid "C'mon! It's all good, babe."
msgstr "¡Venga! Todo irá bien, nena."

msgctxt "191	526501	2	CHK"
msgid "Just leave me alone!"
msgstr "¡Déjame en paz!"

msgctxt "191	526522	3	CHK"
msgid "Let me go!"
msgstr "¡Déjame ir!"

msgctxt "191	526533	4	CHK"
msgid "Unhand her, foul beast!"
msgstr "¡Aléjate de ella, monstruo repugnante!"

msgctxt "191	526557	5	CHK"
msgid "Huh?"
msgstr "Uh, ¿y eso?"

msgctxt "191	526562	6	CHK"
msgid "Can't you tell...\n"
"she's not interested in you?"
msgstr "¿Es que no ves... \n"
"que no le interesas?"

msgctxt "191	526609	7	CHK"
msgid "Just get the hell outta here!"
msgstr "¡Vete al carajo de una maldita vez!"

msgctxt "191	526639	8	CHK"
msgid "What was that?"
msgstr "¡¿Qué dijiste?!"

msgctxt "191	526654	9	CHK"
msgid "You need your ears cleaned or somethin'?"
msgstr "¿Qué pasa, tienes cera en los oídos o qué?"

msgctxt "191	526695	10	CHK"
msgid "In that case... I'll gladly do it for ya!"
msgstr "En ese caso... ¡Lo haré con gusto!"

msgctxt "191	526737	11	CHK"
msgid "Bring it!"
msgstr "¡Vamos!"

msgctxt "191	526747	12	CHK"
msgid "It won't take long, pinky swear."
msgstr "No tardaremos mucho, te lo prometo."

msgctxt "192	527785	1	CHK"
msgid "All right, I got it!"
msgstr "Muy bien, ¡lo tengo!"

msgctxt "192	527806	2	CHK"
msgid "This is tough..."
msgstr "Esto es difícil..."

msgctxt "192	527823	3	CHK"
msgid "You're mine this time!"
msgstr "¡Esta vez eres mío!"

msgctxt "192	527846	4	CHK"
msgid "You're doing it! You're doing it!"
msgstr "¡Lo estás haciendo! ¡Lo estás haciendo!"

msgctxt "192	527880	5	CHK"
msgid "What the? It's broken or something!"
msgstr "¿Qué? ¡Está roto o algo así!"

msgctxt "192	527916	6	CHK"
msgid "The hell's it doing!?"
msgstr "¿¡Qué demonios está haciendo!?"

msgctxt "192	527938	7	CHK"
msgid "You did it!"
msgstr "¡Lo hiciste!"

msgctxt "192	527950	8	CHK"
msgid "Guess I did! Look at that!"
msgstr "¡Supongo que lo hice! ¡Mira eso!"

msgctxt "192	527977	9	CHK"
msgid "You little!"
msgstr "Hijo de!"

msgctxt "193	528729	1	CHK"
msgid "The hell?"
msgstr "¿Dónde?"

msgctxt "193	528739	2	CHK"
msgid "Ah, excuse me!"
msgstr "¡Ay, discúlpame!"

msgctxt "193	528754	3	CHK"
msgid "Watch where you're going, brat!\n"
"You know who I am!?"
msgstr "¡Mira a dónde vas, mocoso!\n"
"¡¿No sabes quién soy!?"

msgctxt "193	528806	4	CHK"
msgid "Heh."
msgstr "Je."

msgctxt "193	528811	5	CHK"
msgid "Ow!"
msgstr "¡Ouch!"

msgctxt "193	528815	6	CHK"
msgid "You son of a...!"
msgstr "¡Hijo de...!"

