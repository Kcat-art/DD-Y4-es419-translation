msgctxt "3144_Rio"
msgid "Cheers!"
msgstr "¡Salud!"

msgctxt "3156_Shizuka"
msgid "Cheers!"
msgstr "¡Salud!"

msgctxt "3168_Attendant"
msgid "I could tell because you're so pretty."
msgstr "Se notaba por tu belleza."

msgctxt "3180_Attendant"
msgid "I kind of wish I was half Japanese myself."
msgstr "A veces desearía ser medio japonés."

msgctxt "3192_Attendant"
msgid "Can you speak Portuguese?"
msgstr "¿Puedes hablar portugués?"

msgctxt "3204_Attendant"
msgid "You just made a wild guess, didn't you?"
msgstr "Fue pura suerte, ¿verdad?"

msgctxt "3216_Attendant"
msgid "So what do you usually do?"
msgstr "¿Qué sueles hacer?"

msgctxt "3228_Attendant"
msgid "Do I look suspicious or something?"
msgstr "¿Parezco sospechoso o algo?"

