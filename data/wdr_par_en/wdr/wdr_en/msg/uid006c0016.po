msgstr "A mí... no me agrada eso..."

msgctxt "18276_Shizuka"
msgid "I'll put in the order, then."
msgstr "Bien, ahora haré el pedido."

msgctxt "18288_Shizuka"
msgid "Excuse me."
msgstr "Disculpe."

msgctxt "18312_Attendant"
