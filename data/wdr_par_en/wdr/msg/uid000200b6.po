msgctxt "2532"
msgid "Saejima"
msgstr "Saejima"

msgctxt "2536"
msgid "Player"
msgstr "Player"

msgctxt "2540"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "2544"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "112_Saejima"
msgid "Goin' somewhere with Haruka-chan? Have a good time."
msgstr "¿Vas a algún lado con Haruka-chan? Que se diviertan."

msgctxt "124_Saejima"
msgid "Oh, %s. Why don't ya take it easy for a change? I'll handle whatever ya gotta do out there."
msgstr "Oh, %s. ¿Por qué no te lo tomas con calma? Yo me encargaré de lo que tengas que hacer."

msgctxt "148_Player"
msgid "I'll be okay on my own for now."
msgstr "Estaré bien por ahora."

msgctxt "160_Player"
msgid "Sorry, gonna have to pass."
msgstr "Lo siento, voy a tener que pasar."

msgctxt "172_Player"
msgid "I'm good."
msgstr "Estoy bien."

msgctxt "184_Player"
msgid "Nah, I'm fine."
msgstr "No, estoy bien."

msgctxt "196_Saejima"
msgid "If ya say so. Just don't come complainin' if ya get too tired out there."
msgstr "Si tú lo dices. Solo no vengas a quejarte si te cansas."

msgctxt "220_Player"
msgid "That's a good idea. Go ahead."
msgstr "Buena idea. Adelante."

msgctxt "232_Player"
msgid "Sure, why not. I'm always down to chill for a bit."
msgstr "Claro, por qué no. Siempre estoy dispuesto a relajarme un poco."

msgctxt "244_Player"
msgid "Guess I don't mind catchin' my breath."
msgstr "Supongo que no me importa recuperar el aliento."

msgctxt "256_Player"
msgid "All right, I'll let you take things from here."
msgstr "Muy bien, dejaré que tomes las riendas a partir de aquí."

msgctxt "268_Saejima"
msgid "Just kick back n' relax. I'll handle everythin' for ya."
msgstr "Solo ponte cómodo y relájate. Yo me encargaré de todo por ti."

msgctxt "292_Saejima"
msgid "Cancel"
msgstr "Cancelar"

msgctxt "304_Saejima"
msgid "Switch to Saejima"
msgstr "Cambiar a Saejima"

