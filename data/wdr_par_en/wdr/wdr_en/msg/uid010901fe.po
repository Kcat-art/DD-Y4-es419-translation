msgctxt "2628"
msgid "Tanimura"
msgstr "Tanimura"

msgctxt "2632"
msgid "Tao"
msgstr "Tao"

msgctxt "2636"
msgid "Talk_No"
msgstr "Talk_No"

msgctxt "2640"
msgid "Talk_Yes"
msgstr "Talk_Yes"

msgctxt "84_Tanimura"
msgid "Found you, Tao."
msgstr "Te encontré, Tao."

msgctxt "96_Tao"
msgid "Ahhh! You scared me!"
msgstr "¡Ahhh! ¡Me asustaste!"

msgctxt "108_Tanimura"
msgid "Hey, calm down."
msgstr "Oye, cálmate."

msgctxt "180_Tao"
msgid "I didn't do anything! I swear!"
msgstr "¡No hice nada! ¡Te lo juro!"

msgctxt "192_Tanimura"
msgid "You were about to tag this place up, weren't you?"
msgstr "Estabas a punto de pintar este lugar, ¿verdad?"

msgctxt "204_Tao"
msgid "......"
msgstr "......"

msgctxt "216_Tanimura"
msgid "I'm guessing you've been at this for a while now."
msgstr "Supongo que has estado en esto por un tiempo."

msgctxt "228_Tao"
msgid "...How'd you know?"
msgstr "... ¿Cómo lo supiste?"

msgctxt "240_Tanimura"
msgid "We'll talk about it later. For now, just go to West Park and wait there for me, okay?"
msgstr "Hablaremos de ello después. Por ahora, solo ve al Parque Oeste y espérame allí, ¿de acuerdo?"

msgctxt "252_Tao"
msgid "......"
msgstr "......"

msgctxt "264_Tao"
msgid "...Okay."
msgstr "...Bien."

msgctxt "312_Tanimura"
msgid "Last is the entrance to Little Asia from East Taihei Boulevard."
msgstr "La última es la entrada a Pequeña Asia desde Bulevar Taihei Este."

