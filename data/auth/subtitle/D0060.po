msgctxt "46\t196"
msgid "You're wasting your time here, ma'am.\\nDo yourself a favor and go home."
msgstr "No importa como lo veas, es lo mismo.\\nPor favor, váyase a casa."

msgctxt "208\t268"
msgid "Wait, please!"
msgstr "¡Esperen, por favor!"

msgctxt "393\t459"
msgid "I couldn't help but overhear."
msgstr "Será que tú..."

msgctxt "470\t550"
msgid "Do you know Taiga Saejima?"
msgstr "¿Eres una conocida de Saejima Taiga?"

msgctxt "581\t630"
msgid "Huh? Yes."
msgstr "¿Eh? Sí."

msgctxt "655\t728"
msgid "Taiga is my brother."
msgstr "Taiga es mi hermano."

msgctxt "853\t959"
msgid "Better not to talk in front of the station."
msgstr "Mejor no hablemos frente\\na la estación de policía."

msgctxt "974\t1099"
msgid "I know this'll sound strange,\\nbut could we talk to you in private?"
msgstr "Si no te importa,\\n¿podrías contarme un poco más al respecto?"

msgctxt "1111\t1263"
msgid "Why? Do you know something\\nabout my brother?"
msgstr "¿Por qué?\\n¿Sabes algo sobre mi hermano?"

msgctxt "1282\t1413"
msgid "Yup. Might even help you out\\nif you play your cards right."
msgstr "Sí. Y dependiendo del caso,\\npodríamos ayudarte."

msgctxt "1434\t1539"
msgid "For now, let's find somewhere better to talk."
msgstr "Por ahora, busquemos un lugar más privado."

msgctxt "1550\t1614"
msgid "Are you coming?"
msgstr "¿Vendrás con nosotros?"

msgctxt "1651\t1711"
msgid "Yes."
msgstr "Sí."

