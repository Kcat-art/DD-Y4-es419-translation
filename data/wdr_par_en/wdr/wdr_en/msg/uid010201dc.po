msgctxt "8568"
msgid "Hostess Club Scouting"
msgstr "Reclutamiento de Hostess Club"

msgctxt "544_Player"
msgid "(Now's not the time for that...)"
msgstr "(Ahora no es el momento para eso...)."

msgctxt "556_Akiyama"
msgid "(I'm with Lily-chan right now. I'll come back later.)"
msgstr "(Ahora estoy con Lily-chan. Volveré aquí en otra ocasión...)."

msgctxt "580_Player"
msgid "What took you so long, Uncle Kaz? I got tired of waiting..."
msgstr "¿Por qué demoraste tanto, tío Kaz? Me cansé de esperar..."

msgctxt "604_Player"
msgid "Oh, you're back, Akiyama-san. Shall we go, then?"
msgstr "Ah, ahí estás, Akiyama-san. ¿Vamos?"

msgctxt "616_Player"
msgid "Oh, Kiryu-san, I've been waiting for you. Shall we go, then?"
msgstr "Ah, Kiryu-san, te estaba esperando. ¿Nos vamos?"

msgctxt "652_Player"
msgid "Are you... going in there, Uncle Kaz?"
msgstr "¿Vas a entrar... ahí, tío Kaz?"

msgctxt "664_Player"
msgid "(Haruka's with me. What should I do?)"
msgstr "(Haruka está conmigo. ¿Qué podría hacer?)"

msgctxt "676_Player"
msgid "Yeah, sorry. Think you can be a big girl and wait here while I'm gone?"
msgstr "Sí, lo siento. ¿Podrías ser una niña grande y esperarme aquí mientras?"

msgctxt "688_Haruka"
msgid "...Okay. Have fun, Uncle Kaz."
msgstr "... Bueno, diviértete, tío Kaz."

msgctxt "700_Player"
msgid "No, I'm okay."
msgstr "No, estoy bien."

msgctxt "712_Haruka"
msgid "Really? I don't mind."
msgstr "¿En serio? No me importa."

msgctxt "736_Player"
msgid "Um, are you going in here?"
msgstr "Mm, ¿vas a entrar ahí?"

msgctxt "748_Player"
msgid "(I forgot Lily-chan's with me. What to do...)"
msgstr "(Me olvidé que Lily-chan estaba conmigo. Qué hago ahora...)."

msgctxt "760_Player"
msgid "Yeah. Sorry, but could you wait a bit out here?"
msgstr "Sí, ¿podría esperar aquí fuera?"

msgctxt "772_Lily"
msgid "Oh, sure. I understand."
msgstr "Claro. Entiendo."

msgctxt "784_Player"
msgid "Actually, never mind."
msgstr "Pensándolo bien, no importa."

msgctxt "796_Lily"
msgid "I see... You don't have to worry about me though."
msgstr "Entiendo... No tienes que preocuparte por mí."

msgctxt "808_Player"
msgid "Um, are you going in here?"
msgstr "Mm, ¿vas a entrar ahí?"

msgctxt "820_Player"
msgid "(I forgot Yasuko-san's with me. What to do...)"
msgstr "(Me olvidé que Yasuko-san estaba conmigo. Qué hago ahora...)."

msgctxt "832_Player"
msgid "Sorry, but could you wait here for a bit?"
msgstr "Disculpe, ¿podría esperar aquí un momento?"

msgctxt "844_Yasuko"
msgid "Oh, sure. I understand."
msgstr "Claro. Entiendo."

msgctxt "856_Player"
msgid "Never mind."
msgstr "No importa."

msgctxt "868_Yasuko"
msgid "I see... You don't have to worry about me though."
msgstr "Entiendo... No tienes que preocuparte por mí."

msgctxt "952_Player"
msgid "(Hostess club, Elise... Ain't interested.)"
msgstr "(Club de Hostess, Elise... No me interesa)."

msgctxt "1000_Akiyama"
msgid "(I don't have any business here right now. I've done everything I can.)"
msgstr "(No tengo nada que hacer aquí... Creo que ya hice lo que tenía que hacer)."

msgctxt "1012_Akiyama"
msgid "(Come to think of it, I was recruiting hostesses earlier. Maybe I should try again.)"
msgstr "(Ahora que lo pienso, dejé el reclutamiento a medias. ¿Debería volver a buscar chicas para el club?)."

msgctxt "1024_Akiyama"
msgid "(Okay, I'll give it another try.)"
msgstr "(Bien, retomemos el reclutamiento)."

msgctxt "1036_Hostess Club Scouting"
msgid "The game's story will not advance while you are recruiting girls for the club. Walk around the streets of Kamurocho until you find a girl you like."
msgstr "La historia del juego no avanzará mientras reclutes chicas para el club. Camina por las calles de Kamurocho hasta que encuentres a una chica que te guste."

msgctxt "1084_Akiyama"
msgid "(No, I have other things to do. I'll get back to recruiting later.)"
msgstr "(No, todavía tengo cosas que hacer. Retomaré el reclutamiento más tarde)."

msgctxt "1096_Akiyama"
msgid "(Gotta scout some girls for the club...)"
msgstr "(Tengo que ir a buscar candidatas para el club...)."

msgctxt "1108_Akiyama"
msgid "(Or should I stop recruiting for the moment?)"
msgstr "(¿O debería detener el reclutamiento por ahora?)."

msgctxt "1120_Akiyama"
msgid "(I'll stop for now.)"
msgstr "(Por ahora, voy a parar el reclutamiento)."

msgctxt "1168_Akiyama"
msgid "(No, I should keep looking.)"
msgstr "(No, voy a seguir buscando)."

msgctxt "1180_Akiyama"
msgid "(Now's not the time for this.)"
msgstr "(Ahora no es momento para distracciones...)."

msgctxt "1192_Akiyama"
msgid "(Now's not the time for this.)"
msgstr "(Ahora no es momento para distracciones...)."

msgctxt "1216_Akiyama"
msgid "(I think I was supposed to meet a girl now.)"
msgstr "(Creo que tenía que verme con una chica ahora)."

