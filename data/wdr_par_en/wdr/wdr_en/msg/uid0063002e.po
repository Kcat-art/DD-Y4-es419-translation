msgctxt "4812"
msgid "Shizuka"
msgstr "Shizuka"

msgctxt "4816"
msgid "Kiryu"
msgstr "Kiryu"

msgctxt "256_Shizuka"
msgid "Hehe. I can't wait to go karaoke with you. <Color:7>♥<Color:Default>"
msgstr "Je, je. No puedo esperar para ir al karaoke con usted. <Color:7>♥<Color:Default>"

msgctxt "268_Shizuka"
msgid "Now, what should I sing? How about \"Raindrops\"? <Color:7>♥<Color:Default>"
msgstr "Ahora, ¿qué debería cantar? ¿Qué tal \"Raindrops\"? <Color:7>♥<Color:Default>"

msgctxt "280_Shizuka"
msgid "Hehe. I think I was able to sing that fairly well!"
msgstr "Je, je. ¡Creo que pude cantar eso bastante bien!"

msgctxt "292_Shizuka"
msgid "Um... Would you do me the honor of singing a song?"
msgstr "¿Me haría el honor de cantar una canción?"

msgctxt "304_Shizuka"
msgid "I know! Will you sing a duet with me?"
msgstr "¡Lo sé! ¿Va a cantar un dueto conmigo?"

msgctxt "316_Kiryu"
msgid "Sure, why not."
msgstr "Sure, why not."

msgctxt "328_Shizuka"
msgid "Thank you! <Color:7>♥<Color:Default> I can't wait to hear you sing. <Color:7>♥<Color:Default>"
msgstr "¡Gracias! <Color:7>♥<Color:Default> No puedo esperar a escucharlo cantar. <Color:7>♥<Color:Default>"

msgctxt "340_Kiryu"
msgid "I'd rather not."
msgstr "Preferiría no hacerlo."

msgctxt "352_Shizuka"
msgid "I see... I apologize for being so selfish."
msgstr "Ya veo... Me disculpo por ser tan egoísta."

msgctxt "364_Shizuka"
msgid "That was very awkward..."
msgstr "Eso fue muy incómodo..."

msgctxt "376_Kiryu"
msgid "Sorry."
msgstr "Lo siento."

msgctxt "388_Shizuka"
msgid "That was wonderful. <Color:7>♥<Color:Default> You certainly know how to make a girl feel like a diva. <Color:7>♥<Color:Default>"
msgstr "Eso fue maravilloso. <Color:7>♥<Color:Default> Ciertamente sabe cómo hacer que una chica se sienta como una diva. <Color:7>♥<Color:Default>"

msgctxt "400_Shizuka"
msgid "Um... Would you do me the honor of singing a song?"
msgstr "¿Me haría el honor de cantar una canción?"

msgctxt "412_Shizuka"
msgid "I know! Will you sing a duet with me?"
msgstr "¡Lo sé! ¿Va a cantar un dueto conmigo?"

msgctxt "424_Kiryu"
msgid "Sure, why not."
msgstr "Sure, why not."

msgctxt "436_Shizuka"
msgid "Thank you! <Color:7>♥<Color:Default>  I can't wait to hear you sing. <Color:7>♥<Color:Default>"
msgstr "¡Gracias! <Color:7>♥<Color:Default> No puedo esperar a escucharlo cantar. <Color:7>♥<Color:Default>"

msgctxt "448_Kiryu"
msgid "I'd rather not."
msgstr "Preferiría no hacerlo."

msgctxt "460_Shizuka"
msgid "I see... I apologize for being so selfish."
msgstr "Ya veo... Me disculpo por ser tan egoísta."

msgctxt "472_Shizuka"
msgid "Was that okay?"
msgstr "¿Estuvo bien?"

msgctxt "484_Kiryu"
msgid "You were great."
msgstr "Estuviste genial."

msgctxt "496_Shizuka"
msgid "I wish you would try a little harder..."
msgstr "Me gustaría que pusiera un poco más de esfuerzo..."

msgctxt "508_Kiryu"
msgid "Sorry."
msgstr "Lo siento."

msgctxt "520_Shizuka"
msgid "You're very good. <Color:7>♥<Color:Default> I was so enchanted by your voice, I almost forgot to sing!"
msgstr "Usted es muy bueno. <Color:7>♥<Color:Default> ¡Estaba tan encantada con su voz que casi me olvido de cantar!"

msgctxt "532_Kiryu"
msgid "Heh..."
msgstr "Je..."

