msgctxt "1012"
msgid "Tutorial"
msgstr "Tutorial"

msgctxt "104_Tutorial"
msgid "Adjust the spin by pressing the <Action:Button_DPad_Left@Bowling><Action:Button_DPad_Right@Bowling> buttons or using <Action:Button_LS_Left@Bowling><Action:Button_LS_Right@Bowling> before releasing the ball."
msgstr "Puedes ajustar el efecto del lanzamiento con <Action:Button_DPad_Left@Bowling><Action:Button_DPad_Right@Bowling> o usando <Action:Button_LS_Left@Bowling><Action:Button_LS_Right@Bowling> antes de lanzar la bola."

msgctxt "116_Tutorial"
msgid "Press the <Action:Button_Cross@Bowling> button to adjust throwing power."
msgstr "Pulsa <Action:Button_Cross@Bowling> para ajustar la potencia del lanzamiento."

msgctxt "128_Tutorial"
msgid "Press the <Action:Button_Cross@Bowling> button to determine the direction."
msgstr "Pulsa <Action:Button_Cross@Bowling> para determinar la dirección del lanzamiento."

msgctxt "140_Tutorial"
msgid "Press the <Action:Button_DPad_Left@Bowling><Action:Button_DPad_Right@Bowling> buttons to choose where to stand, then confirm with the <Action:Button_Cross@Bowling> button."
msgstr "Pulsa <Action:Button_DPad_Left@Bowling><Action:Button_DPad_Right@Bowling> para elegir desde dónde lanzar, luego pulsa <Action:Button_Cross@Bowling> para confirmar."

